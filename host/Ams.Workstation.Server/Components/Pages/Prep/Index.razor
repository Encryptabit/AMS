                <div class="prep-control-section">
                    <BitText Typography="BitTypography.Subtitle2">MFA quality</BitText>
                    <div class="prep-grid prep-grid--compact">
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Beam profile</BitText>
