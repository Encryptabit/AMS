@page "/prep"
@page "/prep/pipeline"
@using System.Globalization
@using System.IO
@using System.Linq
@using Ams.Core.Application.Pipeline
@using Ams.Core.Application.Runs
@using Ams.Workstation.Server.Services
@using Ams.Workstation.Server.Services.Prep
@implements IDisposable
@inject BlazorWorkspace Workspace
@inject PrepRunSession Session

<PageTitle>Prep - AMS Workstation</PageTitle>

<SectionContent SectionName="header-extra">
    @if (HasWorkingDirectory)
    {
        <BitStack Horizontal="true"
                  Gap="0.5rem"
                  VerticalAlign="BitAlignment.Center"
                  Wrap="true"
                  Class="prep-header-extra">
            <BitTag Color="@GetPhaseColor(Session.CurrentPhase)">@FormatPhase(Session.CurrentPhase)</BitTag>

            @if (!string.IsNullOrWhiteSpace(Session.CurrentStage))
            {
                <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">
                    Stage: @Session.CurrentStage
                </BitText>
            }

            <BitButton Variant="BitVariant.Outline"
                       Size="BitSize.Small"
                       Color="BitColor.Warning"
                       OnClick="HandleCancel"
                       IsEnabled="@(Session.IsRunning && !Session.IsCancellationRequested)">
                Cancel
            </BitButton>
        </BitStack>
    }
</SectionContent>

<SectionContent SectionName="module-inspector">
    @if (HasWorkingDirectory && Workspace.HasBookIndex)
    {
        <BitStack Horizontal="false" Gap="0.75rem" Class="prep-header-extra">
            <BitText Typography="BitTypography.Subtitle2">Pipeline Inspector</BitText>
            @if (SelectedQueueItem is not null)
            {
                <BitCard>
                    <BitStack Horizontal="false" Gap="0.5rem">
                        <BitText Typography="BitTypography.Body1">@SelectedQueueItem.Chapter</BitText>
                        <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">
                            State: @SelectedQueueItem.State • Stage: @DisplayOrPlaceholder(SelectedQueueItem.Stage, "n/a")
                        </BitText>
                        <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">
                            Last message: @DisplayOrPlaceholder(SelectedQueueItem.Message, "n/a")
                        </BitText>
                        <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">
                            Artifacts: @SelectedQueueItem.ArtifactCount
                        </BitText>
                    </BitStack>
                </BitCard>
            }
            else
            {
                <BitMessage Color="BitColor.Info">
                    Select a queue row to inspect run diagnostics.
                </BitMessage>
            }

            <BitCard>
                <BitStack Horizontal="false" Gap="0.4rem">
                    <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Batch throughput</BitText>
                    <BitText Typography="BitTypography.Body2">Queued: @BatchQueuedCount</BitText>
                    <BitText Typography="BitTypography.Body2">Running: @BatchRunningCount</BitText>
                    <BitText Typography="BitTypography.Body2">Completed: @BatchCompletedCount</BitText>
                    <BitText Typography="BitTypography.Body2">Failed: @BatchFailedCount</BitText>
                </BitStack>
            </BitCard>
        </BitStack>
    }
</SectionContent>

<div class="prep-page">
    <BitStack Horizontal="false" Gap="1rem">
        <BitStack Horizontal="false" Gap="0.25rem">
            <BitText Typography="BitTypography.H4">Prep Area</BitText>
            <BitText Typography="BitTypography.Body1" Color="BitColor.SecondaryForeground">
                Pipeline Dashboard: build queues, execute batch prep, and inspect chapter-level pipeline outcomes without leaving Workstation.
            </BitText>
        </BitStack>

        @if (HasWorkingDirectory && Workspace.HasBookIndex)
        {
            <BitCard>
                <BitStack Horizontal="false" Gap="0.75rem">
                    <BitStack Horizontal="true" HorizontalAlign="BitAlignment.SpaceBetween" VerticalAlign="BitAlignment.Start" Gap="1rem" Wrap="true">
                        <BitStack Horizontal="false" Gap="0.25rem">
                            <BitText Typography="BitTypography.Subtitle1">Pipeline Dashboard</BitText>
                            <BitText Typography="BitTypography.Body2" Color="BitColor.SecondaryForeground">
                                Queue Builder + Pipeline Throughput surfaces are mapped to BitUI controls and execute module-scoped batch processing.
                            </BitText>
                        </BitStack>
                        <BitTag Color="BitColor.Primary">Batch queue enabled</BitTag>
                    </BitStack>

                    <div class="prep-grid prep-grid--compact">
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Queue start</BitText>
                            <BitDropdown TItem="BitDropdownItem<string>"
                                         TValue="string"
                                         Items="@ChapterItems"
                                         Value="@_queueStartChapter"
                                         OnChange="HandleQueueStartChange"
                                         Placeholder="Start chapter"
                                         IsEnabled="@(!Session.IsRunning && !_isBatchRunning)" />
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Queue end</BitText>
                            <BitDropdown TItem="BitDropdownItem<string>"
                                         TValue="string"
                                         Items="@ChapterItems"
                                         Value="@_queueEndChapter"
                                         OnChange="HandleQueueEndChange"
                                         Placeholder="End chapter"
                                         IsEnabled="@(!Session.IsRunning && !_isBatchRunning)" />
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Selected chapter</BitText>
                            <BitText Typography="BitTypography.Body2">@DisplayOrPlaceholder(_selectedChapter, "Select a chapter")</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Batch state</BitText>
                            <BitTag Color="@(_isBatchRunning ? BitColor.Primary : BitColor.Secondary)">@(_isBatchRunning ? "Running" : "Idle")</BitTag>
                        </div>
                    </div>

                    <BitStack Horizontal="true" Gap="0.5rem" Wrap="true">
                        <BitButton Variant="BitVariant.Outline"
                                   Color="BitColor.Primary"
                                   OnClick="HandleAddSelectedChapterToQueue"
                                   IsEnabled="@CanAddSelectedChapterToQueue">
                            Add selected chapter
                        </BitButton>
                        <BitButton Variant="BitVariant.Outline"
                                   Color="BitColor.Primary"
                                   OnClick="HandleAddRangeToQueue"
                                   IsEnabled="@CanAddRangeToQueue">
                            Add range to queue
                        </BitButton>
                        <BitButton Variant="BitVariant.Outline"
                                   Color="BitColor.Secondary"
                                   OnClick="HandleClearQueue"
                                   IsEnabled="@CanClearQueue">
                            Clear queue
                        </BitButton>
                        <BitButton Variant="BitVariant.Fill"
                                   Color="BitColor.Primary"
                                   OnClick="HandleRunBatchPrepAsync"
                                   IsEnabled="@CanRunBatchQueue">
                            Run batch prep
                        </BitButton>
                        <BitButton Variant="BitVariant.Outline"
                                   Color="BitColor.Warning"
                                   OnClick="HandleCancelBatch"
                                   IsEnabled="@(_isBatchRunning || (Session.IsRunning && !Session.IsCancellationRequested))">
                            Cancel batch
                        </BitButton>
                    </BitStack>

                    <div class="prep-grid prep-grid--compact">
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Queued</BitText>
                            <BitText Typography="BitTypography.Body1">@BatchQueuedCount</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Running</BitText>
                            <BitText Typography="BitTypography.Body1">@BatchRunningCount</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Succeeded</BitText>
                            <BitText Typography="BitTypography.Body1">@BatchCompletedCount</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Failed</BitText>
                            <BitText Typography="BitTypography.Body1">@BatchFailedCount</BitText>
                        </div>
                    </div>

                    <table class="prep-table">
                        <thead>
                            <tr>
                                <th>Chapter</th>
                                <th>State</th>
                                <th>Stage</th>
                                <th>Message</th>
                                <th>Artifacts</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (_batchQueue.Count == 0)
                            {
                                <tr>
                                    <td colspan="6">Queue is empty. Add chapters to start batch processing.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var item in _batchQueue)
                                {
                                    <tr>
                                        <td>@item.Chapter</td>
                                        <td><BitTag Color="@GetRunStateColor(item.State)">@item.State</BitTag></td>
                                        <td>@DisplayOrPlaceholder(item.Stage, "n/a")</td>
                                        <td>@DisplayOrPlaceholder(item.Message, "—")</td>
                                        <td>@item.ArtifactCount</td>
                                        <td>
                                            <BitStack Horizontal="true" Gap="0.4rem">
                                                <BitButton Variant="BitVariant.Text"
                                                           Size="BitSize.Small"
                                                           Color="BitColor.Primary"
                                                           OnClick="@(() => SelectQueueItem(item.Chapter))">
                                                    Inspect
                                                </BitButton>
                                                <BitButton Variant="BitVariant.Text"
                                                           Size="BitSize.Small"
                                                           Color="BitColor.Secondary"
                                                           OnClick="@(() => RemoveQueueItem(item.Chapter))"
                                                           IsEnabled="@(!_isBatchRunning)">
                                                    Remove
                                                </BitButton>
                                            </BitStack>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </BitStack>
            </BitCard>
        }

        <BitCard>
            <BitStack Horizontal="false" Gap="0.75rem">
                <BitText Typography="BitTypography.Subtitle1">Workspace status</BitText>

                <div class="prep-grid">
                    <div class="prep-kv">
                        <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Working directory</BitText>
                        <BitText Typography="BitTypography.Body2" Class="prep-mono">@GetWorkingDirectoryDisplay()</BitText>
                    </div>
                    <div class="prep-kv">
                        <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Book index</BitText>
                        <BitText Typography="BitTypography.Body2">@(Workspace.HasBookIndex ? "Present" : "Missing")</BitText>
                    </div>
                    <div class="prep-kv">
                        <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Workspace initialized</BitText>
                        <BitText Typography="BitTypography.Body2">@(Workspace.IsInitialized ? "Yes" : "No")</BitText>
                    </div>
                    <div class="prep-kv">
                        <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Current chapter</BitText>
                        <BitText Typography="BitTypography.Body2">@DisplayOrPlaceholder(Workspace.CurrentChapterName, "No chapter selected")</BitText>
                    </div>
                    <div class="prep-kv">
                        <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Workspace reloads</BitText>
                        <BitText Typography="BitTypography.Body2">@Workspace.WorkspaceRefreshCount (@DisplayOrPlaceholder(Workspace.LastWorkspaceRefreshReason, "none yet"))</BitText>
                    </div>
                    <div class="prep-kv">
                        <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Chapter reloads</BitText>
                        <BitText Typography="BitTypography.Body2">@Workspace.ChapterHandleRefreshCount (@DisplayOrPlaceholder(Workspace.LastChapterHandleRefreshReason, "none yet"))</BitText>
                    </div>
                </div>
            </BitStack>
        </BitCard>

        @if (Session.IsRunning)
        {
            <BitCard>
                <BitStack Horizontal="false" Gap="0.75rem">
                    <BitText Typography="BitTypography.Subtitle1">Active run</BitText>

                    @if (Session.CurrentProgress?.Progress is double progress)
                    {
                        <BitProgress Percent="@(progress * 100d)"
                                     Label="@(Session.CurrentProgress.Message)"
                                     ShowPercentNumber="true" />
                    }
                    else
                    {
                        <div class="prep-running-status">
                            <BitProgress Circular="true" />
                            <BitText Typography="BitTypography.Body2">
                                @(Session.CurrentProgress?.Message ?? Session.LastMessage ?? "Working...")
                            </BitText>
                        </div>
                    }

                    <div class="prep-grid prep-grid--compact">
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Phase</BitText>
                            <BitText Typography="BitTypography.Body2">@FormatPhase(Session.CurrentPhase)</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Current stage</BitText>
                            <BitText Typography="BitTypography.Body2">@DisplayOrPlaceholder(Session.CurrentStage, "Pending")</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Item id</BitText>
                            <BitText Typography="BitTypography.Body2">@DisplayOrPlaceholder(Session.CurrentProgress?.ItemId, Session.LastChapterId ?? "n/a")</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Cancellation</BitText>
                            <BitText Typography="BitTypography.Body2">@(Session.IsCancellationRequested ? "Requested" : "Active")</BitText>
                        </div>
                    </div>
                </BitStack>
            </BitCard>
        }

        @if (ShouldShowOutcomeBanner())
        {
            <BitMessage Color="@GetOutcomeColor()">
                <BitStack Horizontal="false" Gap="0.25rem">
                    <BitText Typography="BitTypography.Body1">@GetOutcomeHeadline()</BitText>
                    <BitText Typography="BitTypography.Body2">@DisplayOrPlaceholder(Session.LastMessage, "No session message recorded.")</BitText>
                    @if (Session.LastFailure is not null)
                    {
                        <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">
                            Failure kind: @Session.LastFailure.Kind | Stage: @DisplayOrPlaceholder(Session.LastFailure.Stage, "n/a")
                        </BitText>
                    }
                </BitStack>
            </BitMessage>
        }

        @if (!HasWorkingDirectory)
        {
            <BitMessage Color="BitColor.Info">
                <BitStack Horizontal="false" Gap="0.5rem">
                    <BitText Typography="BitTypography.Body1">
                        Set a working directory from the header before running Prep.
                    </BitText>
                    <BitText Typography="BitTypography.Body2" Color="BitColor.SecondaryForeground">
                        Once a workspace is loaded, this page will either ask for a manuscript path to build book-index.json or let you run chapter prep against the shared pipeline service.
                    </BitText>
                </BitStack>
            </BitMessage>
        }
        else if (!Workspace.HasBookIndex)
        {
            <BitCard>
                <BitStack Horizontal="false" Gap="1rem">
                    <BitStack Horizontal="true"
                              HorizontalAlign="BitAlignment.SpaceBetween"
                              VerticalAlign="BitAlignment.Start"
                              Gap="1rem"
                              Wrap="true">
                        <BitStack Horizontal="false" Gap="0.25rem">
                            <BitText Typography="BitTypography.Subtitle1">Build book index</BitText>
                            <BitText Typography="BitTypography.Body2" Color="BitColor.SecondaryForeground">
                                book-index.json is missing, so Prep needs an explicit manuscript path before chapter prep can run.
                            </BitText>
                        </BitStack>
                        <BitTag Color="BitColor.Warning">Index required</BitTag>
                    </BitStack>

                    <BitTextField @bind-Value="_manuscriptPath"
                                  Immediate="true"
                                  Placeholder="Absolute path to the manuscript markdown file..."
                                  IsEnabled="@(!Session.IsRunning)" />

                    <div class="prep-grid">
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Output file</BitText>
                            <BitText Typography="BitTypography.Body2" Class="prep-mono">@GetBookIndexOutputPath()</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Average WPM</BitText>
                            <BitText Typography="BitTypography.Body2">@PrepRunSession.ExplicitAverageWordsPerMinute</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Cache mode</BitText>
                            <BitText Typography="BitTypography.Body2">PreferCache</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Workspace reload</BitText>
                            <BitText Typography="BitTypography.Body2">Automatic after a successful build</BitText>
                        </div>
                    </div>

                    <BitStack Horizontal="true" Gap="0.75rem" Wrap="true">
                        <BitButton Variant="BitVariant.Fill"
                                   Color="BitColor.Primary"
                                   OnClick="HandleBuildBookIndexAsync"
                                   IsEnabled="@CanBuildBookIndex">
                            Build book index
                        </BitButton>
                        <BitButton Variant="BitVariant.Outline"
                                   Color="BitColor.Warning"
                                   OnClick="HandleCancel"
                                   IsEnabled="@(Session.IsRunning && !Session.IsCancellationRequested)">
                            Cancel
                        </BitButton>
                    </BitStack>
                </BitStack>
            </BitCard>
        }
        else
        {
            <BitCard>
                <BitStack Horizontal="false" Gap="1rem">
                    <BitStack Horizontal="true"
                              HorizontalAlign="BitAlignment.SpaceBetween"
                              VerticalAlign="BitAlignment.Start"
                              Gap="1rem"
                              Wrap="true">
                        <BitStack Horizontal="false" Gap="0.25rem">
                            <BitText Typography="BitTypography.Subtitle1">Run chapter prep</BitText>
                            <BitText Typography="BitTypography.Body2" Color="BitColor.SecondaryForeground">
                                Run the selected chapter through the shared pipeline service and keep Workstation state synchronized after the run.
                            </BitText>
                        </BitStack>
                        <BitTag Color="BitColor.Success">Index ready</BitTag>
                    </BitStack>

                    <BitDropdown TItem="BitDropdownItem<string>"
                                 TValue="string"
                                 Items="@ChapterItems"
                                 @bind-Value="_selectedChapter"
                                 Placeholder="Select chapter"
                                 OnChange="HandleChapterChange"
                                 Class="prep-field-min prep-field-min--wide"
                                 IsEnabled="@(!Session.IsRunning)" />

                    <div class="prep-grid">
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Book source</BitText>
                            <BitText Typography="BitTypography.Body2" Class="prep-mono">@DisplayOrPlaceholder(GetIndexedBookSourcePath(), "Book source not available")</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Selected chapter</BitText>
                            <BitText Typography="BitTypography.Body2">@DisplayOrPlaceholder(_selectedChapter, "Select a chapter")</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Chapter id</BitText>
                            <BitText Typography="BitTypography.Body2">@DisplayOrPlaceholder(GetSelectedChapterStem(), "Select a chapter")</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Average WPM</BitText>
                            <BitText Typography="BitTypography.Body2">@PrepRunSession.ExplicitAverageWordsPerMinute</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Chapter handle refresh</BitText>
                            <BitText Typography="BitTypography.Body2">Automatic after success, failure, or cancellation</BitText>
                        </div>
                    </div>

                    <div class="prep-control-sections">
                        <div class="prep-control-section">
                            <BitText Typography="BitTypography.Subtitle2">Pipeline execution</BitText>
                            <div class="prep-grid prep-grid--compact">
                                <div class="prep-kv">
                                    <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">End stage</BitText>
                                    <BitDropdown TItem="BitDropdownItem<string>"
                                                 TValue="string"
                                                 Items="@EndStageItems"
                                                 Value="@_operatorControls.EndStageKey"
                                                 OnChange="HandleEndStageChange"
                                                 Class="prep-field-min"
                                                 IsEnabled="@(!Session.IsRunning)" />
                                </div>
                                <div class="prep-kv">
                                    <BitCheckbox Label="Force rerun"
                                                 Value="@_operatorControls.Force"
                                                 OnChange="HandleForceChange"
                                                 IsEnabled="@(!Session.IsRunning)" />
                                </div>
                                <div class="prep-kv">
                                    <BitCheckbox Label="Force index rebuild"
                                                 Value="@_operatorControls.ForceIndex"
                                                 OnChange="HandleForceIndexChange"
                                                 IsEnabled="@(!Session.IsRunning)" />
                                </div>
                            </div>
                        </div>

                        <div class="prep-control-section">
                            <BitText Typography="BitTypography.Subtitle2">ASR identity & refinement</BitText>
                            <div class="prep-grid prep-grid--compact">
                                <div class="prep-kv">
                                    <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Engine</BitText>
                                    <BitDropdown TItem="BitDropdownItem<string>"
                                                 TValue="string"
                                                 Items="@AsrEngineItems"
                                                 Value="@_operatorControls.AsrEngineKey"
                                                 OnChange="HandleAsrEngineChange"
                                                 Class="prep-field-min"
                                                 IsEnabled="@(!Session.IsRunning)" />
                                </div>
                                <div class="prep-kv">
                                    <BitTextField Label="Model"
                                                  Value="@_operatorControls.AsrModel"
                                                  OnChange="HandleAsrModelChange"
                                                  Placeholder="Optional model alias/path"
                                                  IsEnabled="@(!Session.IsRunning)" />
                                </div>
                                <div class="prep-kv">
                                    <BitTextField Label="Language"
                                                  Value="@_operatorControls.AsrLanguage"
                                                  OnChange="HandleAsrLanguageChange"
                                                  Placeholder="en"
                                                  IsEnabled="@(!Session.IsRunning)" />
                                </div>
                                <div class="prep-kv">
                                    <BitCheckbox Label="Word timestamps"
                                                 Value="@_operatorControls.EnableWordTimestamps"
                                                 OnChange="HandleEnableWordTimestampsChange"
                                                 IsEnabled="@(!Session.IsRunning)" />
                                </div>
                                <div class="prep-kv">
                                    <BitCheckbox Label="FlashAttention"
                                                 Value="@_operatorControls.EnableFlashAttention"
                                                 OnChange="HandleEnableFlashAttentionChange"
                                                 IsEnabled="@(!Session.IsRunning)" />
                                </div>
                                <div class="prep-kv">
                                    <BitCheckbox Label="DTW timestamps"
                                                 Value="@_operatorControls.EnableDtwTimestamps"
                                                 OnChange="HandleEnableDtwTimestampsChange"
                                                 IsEnabled="@(!Session.IsRunning)" />
                                </div>
                                <div class="prep-kv">
                                    <BitCheckbox Label="Disable prompt"
                                                 Value="@_operatorControls.DisablePrompt"
                                                 OnChange="HandleDisablePromptChange"
                                                 IsEnabled="@(!Session.IsRunning)" />
                                </div>
                            </div>
                        </div>

                        <div class="prep-control-section">
                            <BitText Typography="BitTypography.Subtitle2">MFA quality</BitText>
                            <div class="prep-grid prep-grid--compact">
                                <div class="prep-kv">
                                    <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Beam profile</BitText>
                                    <BitDropdown TItem="BitDropdownItem<string>"
                                                 TValue="string"
                                                 Items="@MfaBeamProfileItems"
                                                 Value="@_operatorControls.MfaBeamProfileKey"
                                                 OnChange="HandleMfaBeamProfileChange"
                                                 Class="prep-field-min"
                                                 IsEnabled="@(!Session.IsRunning)" />
                                </div>
                                <div class="prep-kv">
                                    <BitTextField Label="Beam override"
                                                  Value="@_operatorControls.MfaBeamText"
                                                  OnChange="HandleMfaBeamChange"
                                                  Placeholder="Optional integer"
                                                  IsEnabled="@(!Session.IsRunning)" />
                                </div>
                                <div class="prep-kv">
                                    <BitTextField Label="Retry beam override"
                                                  Value="@_operatorControls.MfaRetryBeamText"
                                                  OnChange="HandleMfaRetryBeamChange"
                                                  Placeholder="Optional integer"
                                                  IsEnabled="@(!Session.IsRunning)" />
                                </div>
                            </div>
                        </div>

                        <div class="prep-control-section">
                            <BitText Typography="BitTypography.Subtitle2">Chunking policy</BitText>
                            <div class="prep-grid prep-grid--compact">
                                <div class="prep-kv">
                                    <BitCheckbox Label="Disable chunk plan"
                                                 Value="@_operatorControls.DisableChunkPlan"
                                                 OnChange="HandleDisableChunkPlanChange"
                                                 IsEnabled="@(!Session.IsRunning)" />
                                </div>
                                <div class="prep-kv">
                                    <BitCheckbox Label="Disable chunked MFA"
                                                 Value="@_operatorControls.DisableChunkedMfa"
                                                 OnChange="HandleDisableChunkedMfaChange"
                                                 IsEnabled="@(!Session.IsRunning)" />
                                </div>
                                <div class="prep-kv">
                                    <BitCheckbox Label="Require ASR chunk audio"
                                                 Value="@_operatorControls.RequireAsrChunkAudio"
                                                 OnChange="HandleRequireAsrChunkAudioChange"
                                                 IsEnabled="@(!Session.IsRunning)" />
                                </div>
                                <div class="prep-kv">
                                    <BitTextField Label="Silence threshold (dB)"
                                                  Value="@_operatorControls.ChunkSilenceThresholdDbText"
                                                  OnChange="HandleChunkSilenceThresholdChange"
                                                  Placeholder="Optional number"
                                                  IsEnabled="@(!Session.IsRunning)" />
                                </div>
                                <div class="prep-kv">
                                    <BitTextField Label="Min silence (ms)"
                                                  Value="@_operatorControls.ChunkMinSilenceDurationMsText"
                                                  OnChange="HandleChunkMinSilenceDurationChange"
                                                  Placeholder="Optional number"
                                                  IsEnabled="@(!Session.IsRunning)" />
                                </div>
                                <div class="prep-kv">
                                    <BitTextField Label="Min chunk (sec)"
                                                  Value="@_operatorControls.ChunkMinDurationSecText"
                                                  OnChange="HandleChunkMinDurationChange"
                                                  Placeholder="Optional number"
                                                  IsEnabled="@(!Session.IsRunning)" />
                                </div>
                                <div class="prep-kv">
                                    <BitTextField Label="Max chunk (sec)"
                                                  Value="@_operatorControls.ChunkMaxDurationSecText"
                                                  OnChange="HandleChunkMaxDurationChange"
                                                  Placeholder="Optional number"
                                                  IsEnabled="@(!Session.IsRunning)" />
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(RunValidationMessage))
                    {
                        <BitMessage Color="BitColor.Warning">
                            @RunValidationMessage
                        </BitMessage>
                    }

                    @if (OperatorWarnings.Count > 0)
                    {
                        <BitMessage Color="BitColor.Warning">
                            <BitStack Horizontal="false" Gap="0.25rem">
                                <BitText Typography="BitTypography.Body2">Review these option warnings before running:</BitText>
                                <ul class="prep-warning-list">
                                    @foreach (var warning in OperatorWarnings)
                                    {
                                        <li>@warning</li>
                                    }
                                </ul>
                            </BitStack>
                        </BitMessage>
                    }

                    <BitStack Horizontal="true" Gap="0.75rem" Wrap="true">
                        <BitButton Variant="BitVariant.Fill"
                                   Color="BitColor.Primary"
                                   OnClick="HandleRunChapterPrepAsync"
                                   IsEnabled="@CanRunSelectedChapter">
                            Run chapter prep
                        </BitButton>
                        <BitButton Variant="BitVariant.Outline"
                                   Color="BitColor.Warning"
                                   OnClick="HandleCancel"
                                   IsEnabled="@(Session.IsRunning && !Session.IsCancellationRequested)">
                            Cancel
                        </BitButton>
                    </BitStack>

                    @if (Workspace.AvailableChapters.Count == 0)
                    {
                        <BitMessage Color="BitColor.Warning">
                            No chapters were discovered after loading book-index.json.
                        </BitMessage>
                    }
                </BitStack>
            </BitCard>
        }

        @if (Session.LastBuildRequest is not null || Session.LastBuildBookIndexResult is not null)
        {
            <BitCard>
                <BitStack Horizontal="false" Gap="0.75rem">
                    <BitText Typography="BitTypography.Subtitle1">Last book-index request</BitText>

                    <div class="prep-grid">
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Manuscript</BitText>
                            <BitText Typography="BitTypography.Body2" Class="prep-mono">@DisplayOrPlaceholder(Session.LastBuildRequest?.BookFile.FullName, "No build request recorded")</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Output</BitText>
                            <BitText Typography="BitTypography.Body2" Class="prep-mono">@DisplayOrPlaceholder(Session.LastBuildRequest?.OutputFile.FullName, "No output file recorded")</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Average WPM</BitText>
                            <BitText Typography="BitTypography.Body2">@GetLastBuildAverageWpmDisplay()</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Cache disposition</BitText>
                            <BitText Typography="BitTypography.Body2">@DisplayOrPlaceholder(Session.LastBuildBookIndexResult?.CacheDisposition.ToString(), "No result yet")</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Phonemes backfilled</BitText>
                            <BitText Typography="BitTypography.Body2">@(Session.LastBuildBookIndexResult?.PhonemesBackfilled is true ? "Yes" : Session.LastBuildBookIndexResult is null ? "n/a" : "No")</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Workspace reloaded</BitText>
                            <BitText Typography="BitTypography.Body2">@(Session.LastWorkspaceReloaded ? "Yes" : "No")</BitText>
                        </div>
                    </div>
                </BitStack>
            </BitCard>
        }

        @if (Session.LastRuntimeReadiness is not null)
        {
            var readiness = Session.LastRuntimeReadiness;

            <BitCard>
                <BitStack Horizontal="false" Gap="0.75rem">
                    <BitStack Horizontal="true"
                              HorizontalAlign="BitAlignment.SpaceBetween"
                              VerticalAlign="BitAlignment.Start"
                              Gap="1rem"
                              Wrap="true">
                        <BitStack Horizontal="false" Gap="0.25rem">
                            <BitText Typography="BitTypography.Subtitle1">Runtime readiness snapshot</BitText>
                            <BitText Typography="BitTypography.Body2" Color="BitColor.SecondaryForeground">
                                Captured before pipeline dispatch so Prep failures can be triaged with deterministic runtime provenance.
                            </BitText>
                        </BitStack>
                        <BitTag Color="@(readiness.IsReady ? BitColor.Success : BitColor.Warning)">
                            @(readiness.IsReady ? "Ready" : "Needs attention")
                        </BitTag>
                    </BitStack>

                    <div class="prep-grid prep-grid--compact">
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Captured</BitText>
                            <BitText Typography="BitTypography.Body2">@FormatCapturedAt(readiness.CapturedAtUtc)</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Chapter</BitText>
                            <BitText Typography="BitTypography.Body2">@DisplayOrPlaceholder(readiness.ChapterDisplayTitle, "n/a") (@DisplayOrPlaceholder(readiness.ChapterId, "n/a"))</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Deterministic</BitText>
                            <BitText Typography="BitTypography.Body2">@FormatYesNo(readiness.IsDeterministic)</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Probe source</BitText>
                            <BitText Typography="BitTypography.Body2">@(readiness.ReusedCachedProbe ? "Cached snapshot reuse" : "Fresh probe")</BitText>
                        </div>
                    </div>

                    <div class="prep-grid prep-grid--compact">
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">ASR model provenance</BitText>
                            <BitTag Color="@GetRuntimeReadinessColor(readiness.ModelProvenance.State)">@readiness.ModelProvenance.State</BitTag>
                            <BitText Typography="BitTypography.Body2">@readiness.ModelProvenance.Summary</BitText>
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">@readiness.ModelProvenance.Guidance</BitText>
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">
                                Source: @readiness.ModelProvenance.SourceKind | Requested: @DisplayOrPlaceholder(readiness.ModelProvenance.RequestedModel, "default/implicit")
                            </BitText>
                            @if (!string.IsNullOrWhiteSpace(readiness.ModelProvenance.NormalizedModelPath))
                            {
                                <BitText Typography="BitTypography.Caption1" Class="prep-mono prep-wrap">@readiness.ModelProvenance.NormalizedModelPath</BitText>
                            }
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">FFmpeg readiness</BitText>
                            <BitTag Color="@GetRuntimeReadinessColor(readiness.Ffmpeg.State)">@readiness.Ffmpeg.State</BitTag>
                            <BitText Typography="BitTypography.Body2">@readiness.Ffmpeg.Summary</BitText>
                            @if (!string.IsNullOrWhiteSpace(readiness.Ffmpeg.Detail))
                            {
                                <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">@readiness.Ffmpeg.Detail</BitText>
                            }
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">
                                Exit: @FormatNullableInt(readiness.Ffmpeg.ExitCode) | Duration: @FormatDuration(readiness.Ffmpeg.DurationMs)
                            </BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">MFA readiness</BitText>
                            <BitTag Color="@GetRuntimeReadinessColor(readiness.Mfa.State)">@readiness.Mfa.State</BitTag>
                            <BitText Typography="BitTypography.Body2">@readiness.Mfa.Summary</BitText>
                            @if (!string.IsNullOrWhiteSpace(readiness.Mfa.Detail))
                            {
                                <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">@readiness.Mfa.Detail</BitText>
                            }
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">
                                Duration: @FormatDuration(readiness.Mfa.DurationMs)
                            </BitText>
                        </div>
                    </div>

                    @if (readiness.Notes.Count > 0)
                    {
                        <BitMessage Color="BitColor.Info">
                            <BitStack Horizontal="false" Gap="0.25rem">
                                <BitText Typography="BitTypography.Body2">Readiness notes</BitText>
                                <ul class="prep-warning-list">
                                    @foreach (var note in readiness.Notes)
                                    {
                                        <li>@note</li>
                                    }
                                </ul>
                            </BitStack>
                        </BitMessage>
                    }
                </BitStack>
            </BitCard>
        }

        @if (Session.LastPipelineOptions is not null || Session.LastPipelineResult is not null)
        {
            <BitCard>
                <BitStack Horizontal="false" Gap="0.75rem">
                    <BitText Typography="BitTypography.Subtitle1">Last chapter prep result</BitText>

                    <div class="prep-grid">
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Chapter id</BitText>
                            <BitText Typography="BitTypography.Body2">@DisplayOrPlaceholder(Session.LastPipelineResult?.ChapterId ?? Session.LastPipelineOptions?.ChapterId, "No chapter run recorded")</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">State</BitText>
                            <BitText Typography="BitTypography.Body2">@DisplayOrPlaceholder(Session.LastPipelineResult?.State.ToString(), Session.CurrentPhase.ToString())</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Last completed stage</BitText>
                            <BitText Typography="BitTypography.Body2">@DisplayOrPlaceholder(Session.LastCompletedStage, "None yet")</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Failure stage</BitText>
                            <BitText Typography="BitTypography.Body2">@DisplayOrPlaceholder(Session.LastFailureStage, "n/a")</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Chapter handle reloaded</BitText>
                            <BitText Typography="BitTypography.Body2">@(Session.LastChapterHandleReloaded ? "Yes" : "No")</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Reopened current selection</BitText>
                            <BitText Typography="BitTypography.Body2">@(Workspace.LastChapterHandleRefreshReopenedCurrentSelection ? "Yes" : "No")</BitText>
                        </div>
                    </div>

                    @if (Session.LastPipelineRequest is not null)
                    {
                        <BitText Typography="BitTypography.Subtitle2">Last typed request snapshot</BitText>

                        <div class="prep-grid prep-grid--compact">
                            <div class="prep-kv">
                                <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">End stage</BitText>
                                <BitText Typography="BitTypography.Body2">@Session.LastPipelineRequest.EndStage</BitText>
                            </div>
                            <div class="prep-kv">
                                <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Force / Force index</BitText>
                                <BitText Typography="BitTypography.Body2">@(Session.LastPipelineRequest.Force ? "Force" : "Normal") / @(Session.LastPipelineRequest.ForceIndex ? "Force index" : "Default index")</BitText>
                            </div>
                            <div class="prep-kv">
                                <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">ASR engine</BitText>
                                <BitText Typography="BitTypography.Body2">@DisplayOrPlaceholder(Session.LastPipelineRequest.Asr.Engine?.ToString(), "Auto")</BitText>
                            </div>
                            <div class="prep-kv">
                                <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">ASR model/language</BitText>
                                <BitText Typography="BitTypography.Body2">@DisplayOrPlaceholder(Session.LastPipelineRequest.Asr.Model, "Default model") / @DisplayOrPlaceholder(Session.LastPipelineRequest.Asr.Language, "Default language")</BitText>
                            </div>
                            <div class="prep-kv">
                                <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">ASR feature flags</BitText>
                                <BitText Typography="BitTypography.Body2">Word timestamps: @FormatEnabled(Session.LastPipelineRequest.Asr.EnableWordTimestamps) | FlashAttention: @FormatEnabled(Session.LastPipelineRequest.Asr.EnableFlashAttention) | DTW: @FormatEnabled(Session.LastPipelineRequest.Asr.EnableDtwTimestamps) | Prompt: @FormatEnabled(!Session.LastPipelineRequest.Asr.DisablePrompt, enabledLabel: "Enabled", disabledLabel: "Disabled")</BitText>
                            </div>
                            <div class="prep-kv">
                                <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">MFA profile/beam</BitText>
                                <BitText Typography="BitTypography.Body2">@DisplayOrPlaceholder(Session.LastPipelineRequest.Mfa.BeamProfile?.ToString(), "Default") / @FormatOptionalInt(Session.LastPipelineRequest.Mfa.Beam, "auto") / @FormatOptionalInt(Session.LastPipelineRequest.Mfa.RetryBeam, "auto")</BitText>
                            </div>
                            <div class="prep-kv">
                                <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Chunk controls</BitText>
                                <BitText Typography="BitTypography.Body2">Disable plan: @FormatYesNo(Session.LastPipelineRequest.Chunking.DisableChunkPlan) | Disable MFA chunking: @FormatYesNo(Session.LastPipelineRequest.Chunking.DisableChunkedMfa) | Require ASR chunk audio: @FormatYesNo(Session.LastPipelineRequest.Chunking.RequireAsrChunkAudio)</BitText>
                            </div>
                            <div class="prep-kv">
                                <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Chunk policy overrides</BitText>
                                <BitText Typography="BitTypography.Body2">Silence threshold: @FormatOptionalDouble(Session.LastPipelineRequest.Chunking.Policy.SilenceThresholdDb, "default") dB | Min silence: @FormatOptionalDouble(Session.LastPipelineRequest.Chunking.Policy.MinSilenceDurationMs, "default") ms | Min chunk: @FormatOptionalDouble(Session.LastPipelineRequest.Chunking.Policy.MinChunkDurationSec, "default") sec | Max chunk: @FormatOptionalDouble(Session.LastPipelineRequest.Chunking.Policy.MaxChunkDurationSec, "default") sec</BitText>
                            </div>
                        </div>
                    }

                    @if (Session.LastPipelineRequest is not null)
                    {
                        if (Session.LastPipelineOptionWarnings.Count > 0)
                        {
                            <BitMessage Color="BitColor.Warning">
                                <BitStack Horizontal="false" Gap="0.25rem">
                                    <BitText Typography="BitTypography.Body2">Option normalization warnings</BitText>
                                    <ul class="prep-warning-list">
                                        @foreach (var warning in Session.LastPipelineOptionWarnings)
                                        {
                                            <li>@warning</li>
                                        }
                                    </ul>
                                </BitStack>
                            </BitMessage>
                        }
                        else
                        {
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">
                                Option normalization warnings: none
                            </BitText>
                        }
                    }

                    @if (Session.LastPipelineResult is not null)
                    {
                        <table class="prep-table">
                            <thead>
                                <tr>
                                    <th>Stage</th>
                                    <th>State</th>
                                    <th>Mode</th>
                                    <th>Message</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var stage in Session.LastPipelineResult.StageResults)
                                {
                                    <tr>
                                        <td>@stage.StageName</td>
                                        <td>
                                            <BitTag Color="@GetRunStateColor(stage.State)">@stage.State</BitTag>
                                        </td>
                                        <td>@(stage.Executed ? "Executed" : "Cached")</td>
                                        <td>
                                            <div>@stage.Message</div>
                                            @if (stage.Failure is not null)
                                            {
                                                <div class="prep-inline-note">@stage.Failure.Kind: @stage.Failure.Message</div>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </BitStack>
            </BitCard>
        }

        @if (Session.ProgressUpdates.Count > 0)
        {
            <BitCard>
                <BitStack Horizontal="false" Gap="0.75rem">
                    <BitText Typography="BitTypography.Subtitle1">Progress timeline</BitText>

                    <table class="prep-table">
                        <thead>
                            <tr>
                                <th>Module</th>
                                <th>Stage</th>
                                <th>State</th>
                                <th>Message</th>
                                <th>Progress</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var update in Session.ProgressUpdates.Reverse())
                            {
                                <tr>
                                    <td>@update.ModuleId.Value</td>
                                    <td>@DisplayOrPlaceholder(update.Stage, "n/a")</td>
                                    <td>
                                        <BitTag Color="@GetRunStateColor(update.State)">@update.State</BitTag>
                                    </td>
                                    <td>
                                        <div>@update.Message</div>
                                        @if (update.Failure is not null)
                                        {
                                            <div class="prep-inline-note">@update.Failure.Kind: @update.Failure.Message</div>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(update.ItemId))
                                        {
                                            <div class="prep-inline-note">Item: @update.ItemId</div>
                                        }
                                    </td>
                                    <td>@FormatProgress(update.Progress)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </BitStack>
            </BitCard>
        }

        @if (Session.LastArtifacts.Count > 0)
        {
            <BitCard>
                <BitStack Horizontal="false" Gap="0.75rem">
                    <BitText Typography="BitTypography.Subtitle1">Last artifact set</BitText>

                    <table class="prep-table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Kind</th>
                                <th>Exists</th>
                                <th>Path</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var artifact in Session.LastArtifacts)
                            {
                                <tr>
                                    <td>@artifact.Name</td>
                                    <td>@artifact.Kind</td>
                                    <td>@(artifact.Exists ? "Yes" : "No")</td>
                                    <td class="prep-mono prep-wrap">@artifact.Path</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </BitStack>
            </BitCard>
        }
    </BitStack>
</div>

@code {
    private string _manuscriptPath = string.Empty;
    private string? _selectedChapter;
    private string? _queueStartChapter;
    private string? _queueEndChapter;
    private string? _selectedQueueChapter;
    private bool _isBatchRunning;
    private bool _batchCancelRequested;
    private readonly List<PipelineBatchQueueItem> _batchQueue = [];
    private readonly PrepPipelineOperatorControls _operatorControls = new();

    private static List<BitDropdownItem<string>> EndStageItems { get; } = PrepPipelineOperatorControls.EndStageOptions
        .Select(option => new BitDropdownItem<string> { Text = option.Label, Value = option.Value })
        .ToList();

    private static List<BitDropdownItem<string>> AsrEngineItems { get; } = PrepPipelineOperatorControls.AsrEngineOptions
        .Select(option => new BitDropdownItem<string> { Text = option.Label, Value = option.Value })
        .ToList();

    private static List<BitDropdownItem<string>> MfaBeamProfileItems { get; } = PrepPipelineOperatorControls.MfaBeamProfileOptions
        .Select(option => new BitDropdownItem<string> { Text = option.Label, Value = option.Value })
        .ToList();

    private bool HasWorkingDirectory => !string.IsNullOrWhiteSpace(Workspace.WorkingDirectory);

    private string? RunValidationMessage => _operatorControls.GetValidationMessage(_selectedChapter, Workspace.AvailableChapters);

    private IReadOnlyList<string> OperatorWarnings => _operatorControls.GetCompatibilityWarnings();

    private bool CanBuildBookIndex => HasWorkingDirectory
        && !Workspace.HasBookIndex
        && !Session.IsRunning
        && !string.IsNullOrWhiteSpace(_manuscriptPath);

    private bool CanRunSelectedChapter => Workspace.HasBookIndex
        && Workspace.IsInitialized
        && !Session.IsRunning
        && !_isBatchRunning
        && string.IsNullOrWhiteSpace(RunValidationMessage);

    private bool CanAddSelectedChapterToQueue => Workspace.HasBookIndex
        && !Session.IsRunning
        && !_isBatchRunning
        && !string.IsNullOrWhiteSpace(_selectedChapter);

    private bool CanAddRangeToQueue => Workspace.HasBookIndex
        && !Session.IsRunning
        && !_isBatchRunning
        && !string.IsNullOrWhiteSpace(_queueStartChapter)
        && !string.IsNullOrWhiteSpace(_queueEndChapter);

    private bool CanClearQueue => _batchQueue.Count > 0 && !_isBatchRunning;

    private bool CanRunBatchQueue => Workspace.HasBookIndex
        && Workspace.IsInitialized
        && !Session.IsRunning
        && !_isBatchRunning
        && _batchQueue.Any(item => item.State is RunState.Pending or RunState.Failed);

    private int BatchQueuedCount => _batchQueue.Count(item => item.State == RunState.Pending);

    private int BatchRunningCount => _batchQueue.Count(item => item.State == RunState.Running);

    private int BatchCompletedCount => _batchQueue.Count(item => item.State == RunState.Completed);

    private int BatchFailedCount => _batchQueue.Count(item => item.State == RunState.Failed);

    private PipelineBatchQueueItem? SelectedQueueItem
        => _batchQueue.FirstOrDefault(item => string.Equals(item.Chapter, _selectedQueueChapter, StringComparison.OrdinalIgnoreCase));

    private List<BitDropdownItem<string>> ChapterItems => Workspace.AvailableChapters
        .Select(chapter => new BitDropdownItem<string> { Text = chapter, Value = chapter })
        .ToList();

    protected override void OnInitialized()
    {
        Session.StateChanged += HandleSessionStateChanged;

        if (Session.LastPipelineRequest is not null)
        {
            _operatorControls.ApplyRequest(Session.LastPipelineRequest);
        }

        SyncSelectedChapter(preferFirstAvailable: true);
        SyncQueueRangeDefaults();
    }

    private async Task HandleBuildBookIndexAsync()
    {
        if (!CanBuildBookIndex)
        {
            return;
        }

        var success = await Session.BuildBookIndexAsync(_manuscriptPath);
        if (success)
        {
            SyncSelectedChapter(preferFirstAvailable: true);
        }
    }

    private async Task HandleRunChapterPrepAsync()
    {
        var validationMessage = RunValidationMessage;
        if (!CanRunSelectedChapter
            || !string.IsNullOrWhiteSpace(validationMessage)
            || string.IsNullOrWhiteSpace(_selectedChapter))
        {
            return;
        }

        if (!_operatorControls.TryBuildRequest(out var request))
        {
            return;
        }

        if (Workspace.IsInitialized)
        {
            Workspace.SelectChapter(_selectedChapter);
        }

        await Session.RunChapterPrepAsync(_selectedChapter, request);

        if (Session.LastPipelineRequest is not null)
        {
            _operatorControls.ApplyRequest(Session.LastPipelineRequest);
        }

        SyncSelectedChapter(preferFirstAvailable: false);
    }

    private void HandleCancel()
    {
        Session.Cancel();
    }

    private void HandleChapterChange(string? chapter)
    {
        _selectedChapter = string.IsNullOrWhiteSpace(chapter) ? null : chapter;

        if (!string.IsNullOrWhiteSpace(_selectedChapter) && Workspace.IsInitialized)
        {
            Workspace.SelectChapter(_selectedChapter);
        }

        SyncQueueRangeDefaults();
    }

    private void HandleQueueStartChange(string? chapter)
    {
        _queueStartChapter = string.IsNullOrWhiteSpace(chapter) ? null : chapter;
    }

    private void HandleQueueEndChange(string? chapter)
    {
        _queueEndChapter = string.IsNullOrWhiteSpace(chapter) ? null : chapter;
    }

    private void HandleAddSelectedChapterToQueue()
    {
        if (!CanAddSelectedChapterToQueue || string.IsNullOrWhiteSpace(_selectedChapter))
        {
            return;
        }

        QueueChapter(_selectedChapter);
    }

    private void HandleAddRangeToQueue()
    {
        if (!CanAddRangeToQueue || string.IsNullOrWhiteSpace(_queueStartChapter) || string.IsNullOrWhiteSpace(_queueEndChapter))
        {
            return;
        }

        var chapters = Workspace.AvailableChapters;
        var startIndex = chapters.FindIndex(chapter => string.Equals(chapter, _queueStartChapter, StringComparison.OrdinalIgnoreCase));
        var endIndex = chapters.FindIndex(chapter => string.Equals(chapter, _queueEndChapter, StringComparison.OrdinalIgnoreCase));

        if (startIndex < 0 || endIndex < 0)
        {
            return;
        }

        var from = Math.Min(startIndex, endIndex);
        var to = Math.Max(startIndex, endIndex);

        for (var i = from; i <= to; i++)
        {
            QueueChapter(chapters[i]);
        }
    }

    private void HandleClearQueue()
    {
        if (!CanClearQueue)
        {
            return;
        }

        _batchQueue.Clear();
        _selectedQueueChapter = null;
    }

    private void SelectQueueItem(string chapter)
    {
        _selectedQueueChapter = chapter;
    }

    private void RemoveQueueItem(string chapter)
    {
        if (_isBatchRunning)
        {
            return;
        }

        var index = _batchQueue.FindIndex(item => string.Equals(item.Chapter, chapter, StringComparison.OrdinalIgnoreCase));
        if (index < 0)
        {
            return;
        }

        _batchQueue.RemoveAt(index);
        if (string.Equals(_selectedQueueChapter, chapter, StringComparison.OrdinalIgnoreCase))
        {
            _selectedQueueChapter = _batchQueue.FirstOrDefault()?.Chapter;
        }
    }

    private async Task HandleRunBatchPrepAsync()
    {
        if (!CanRunBatchQueue)
        {
            return;
        }

        if (!_operatorControls.TryBuildRequest(out var request))
        {
            return;
        }

        _isBatchRunning = true;
        _batchCancelRequested = false;

        try
        {
            foreach (var queueItem in _batchQueue.Where(item => item.State is RunState.Pending or RunState.Failed).ToArray())
            {
                if (_batchCancelRequested)
                {
                    break;
                }

                queueItem.State = RunState.Running;
                queueItem.Stage = Session.CurrentStage;
                queueItem.Message = "Running";
                _selectedQueueChapter = queueItem.Chapter;
                await InvokeAsync(StateHasChanged);

                if (Workspace.IsInitialized)
                {
                    Workspace.SelectChapter(queueItem.Chapter);
                }

                var success = await Session.RunChapterPrepAsync(queueItem.Chapter, request);

                queueItem.State = success ? RunState.Completed : RunState.Failed;
                queueItem.Stage = Session.LastFailureStage ?? Session.LastCompletedStage ?? Session.CurrentStage;
                queueItem.Message = success
                    ? DisplayOrPlaceholder(Session.LastMessage, "Completed")
                    : DisplayOrPlaceholder(Session.LastFailure?.Message ?? Session.LastMessage, "Failed");
                queueItem.ArtifactCount = Session.LastArtifacts.Count;
                queueItem.LastUpdatedUtc = DateTimeOffset.UtcNow;

                if (Session.WasCancelled)
                {
                    _batchCancelRequested = true;
                    break;
                }

                await InvokeAsync(StateHasChanged);
            }
        }
        finally
        {
            _isBatchRunning = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void HandleCancelBatch()
    {
        _batchCancelRequested = true;
        Session.Cancel();
    }

    private void QueueChapter(string chapter)
    {
        if (_batchQueue.Any(item => string.Equals(item.Chapter, chapter, StringComparison.OrdinalIgnoreCase)))
        {
            return;
        }

        _batchQueue.Add(new PipelineBatchQueueItem(chapter));
        _selectedQueueChapter ??= chapter;
    }

