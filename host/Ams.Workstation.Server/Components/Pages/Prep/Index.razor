                    </div>
                </div>

                <div class="prep-control-section">
                    <h3 class="ams-subtitle">MFA quality</h3>
                    <div class="prep-grid prep-grid--compact">
                        <div class="prep-kv">
                            <span class="ams-caption ams-caption--muted">Beam profile</span>
                            <select class="ams-select prep-field-min"
                                    value="@_operatorControls.MfaBeamProfileKey"
                                    @onchange="@(e => HandleMfaBeamProfileChange(e.Value?.ToString()))"
                                    disabled="@Session.IsRunning">
                                @foreach (var opt in PrepPipelineOperatorControls.MfaBeamProfileOptions)
                                {
                                    <option value="@opt.Value" selected="@(opt.Value == _operatorControls.MfaBeamProfileKey)">@opt.Label</option>
                                }
                            </select>
                        </div>
                        <div class="prep-kv">
                            <label class="ams-field">
                                <span class="ams-caption ams-caption--muted">Beam override</span>
                                <input type="text"
                                       class="ams-input"
                                       value="@_operatorControls.MfaBeamText"
                                       @oninput="@(e => HandleMfaBeamChange(e.Value?.ToString()))"
                                       placeholder="Optional integer"
                                       disabled="@Session.IsRunning" />
                            </label>
                        </div>
                        <div class="prep-kv">
                            <label class="ams-field">
                                <span class="ams-caption ams-caption--muted">Retry beam override</span>
                                <input type="text"
                                       class="ams-input"
                                       value="@_operatorControls.MfaRetryBeamText"
                                       @oninput="@(e => HandleMfaRetryBeamChange(e.Value?.ToString()))"
                                       placeholder="Optional integer"
                                       disabled="@Session.IsRunning" />
                            </label>
                        </div>
                    </div>
                </div>

                <div class="prep-control-section">
                    <h3 class="ams-subtitle">Chunking policy</h3>
                    <div class="prep-grid prep-grid--compact">
                        <div class="prep-kv">
                            <label class="ams-checkbox">
                                <input type="checkbox"
                                       checked="@_operatorControls.DisableChunkPlan"
                                       @onchange="@(e => HandleDisableChunkPlanChange((bool)e.Value!))"
                                       disabled="@Session.IsRunning" />
                                <span>Disable chunk plan</span>
                            </label>
                        </div>
                        <div class="prep-kv">
                            <label class="ams-checkbox">
                                <input type="checkbox"
                                       checked="@_operatorControls.DisableChunkedMfa"
                                       @onchange="@(e => HandleDisableChunkedMfaChange((bool)e.Value!))"
                                       disabled="@Session.IsRunning" />
                                <span>Disable chunked MFA</span>
                            </label>
                        </div>
                        <div class="prep-kv">
                            <label class="ams-checkbox">
                                <input type="checkbox"
                                       checked="@_operatorControls.RequireAsrChunkAudio"
                                       @onchange="@(e => HandleRequireAsrChunkAudioChange((bool)e.Value!))"
                                       disabled="@Session.IsRunning" />
                                <span>Require ASR chunk audio</span>
                            </label>
                        </div>
                        <div class="prep-kv">
                            <label class="ams-field">
                                <span class="ams-caption ams-caption--muted">Silence threshold (dB)</span>
                                <input type="text"
                                       class="ams-input"
                                       value="@_operatorControls.ChunkSilenceThresholdDbText"
                                       @oninput="@(e => HandleChunkSilenceThresholdChange(e.Value?.ToString()))"
                                       placeholder="Optional number"
                                       disabled="@Session.IsRunning" />
                            </label>
                        </div>
                        <div class="prep-kv">
                            <label class="ams-field">
                                <span class="ams-caption ams-caption--muted">Min silence (ms)</span>
                                <input type="text"
                                       class="ams-input"
                                       value="@_operatorControls.ChunkMinSilenceDurationMsText"
                                       @oninput="@(e => HandleChunkMinSilenceDurationChange(e.Value?.ToString()))"
                                       placeholder="Optional number"
                                       disabled="@Session.IsRunning" />
                            </label>
                        </div>
                        <div class="prep-kv">
                            <label class="ams-field">
                                <span class="ams-caption ams-caption--muted">Min chunk (sec)</span>
                                <input type="text"
                                       class="ams-input"
                                       value="@_operatorControls.ChunkMinDurationSecText"
                                       @oninput="@(e => HandleChunkMinDurationChange(e.Value?.ToString()))"
                                       placeholder="Optional number"
                                       disabled="@Session.IsRunning" />
                            </label>
                        </div>
                        <div class="prep-kv">
                            <label class="ams-field">
                                <span class="ams-caption ams-caption--muted">Max chunk (sec)</span>
                                <input type="text"
                                       class="ams-input"
                                       value="@_operatorControls.ChunkMaxDurationSecText"
                                       @oninput="@(e => HandleChunkMaxDurationChange(e.Value?.ToString()))"
                                       placeholder="Optional number"
                                       disabled="@Session.IsRunning" />
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            @if (OperatorWarnings.Count > 0)
            {
                <div class="ams-message ams-message--warning" role="status">
                    <div class="prep-warning-stack">
                        <p class="ams-body">Option warnings</p>
                        <ul class="prep-warning-list">
                            @foreach (var warning in OperatorWarnings)
                            {
                                <li>@warning</li>
                            }
                        </ul>
                    </div>
                </div>
            }
        </div>
    </AmsDialog>
}

@code {
    private string _manuscriptPath = string.Empty;
    private double _queueRangeStart;
    private double _queueRangeEnd;
    private string? _selectedQueueChapter;
    private bool _isBatchRunning;
    private bool _batchCancelRequested;
    private bool _isPipelineSettingsOpen;
    private int _historyPageIndex;
    private readonly List<PipelineBatchQueueItem> _batchQueue = [];
    private readonly PrepPipelineOperatorControls _operatorControls = new();

    private bool HasWorkingDirectory => !string.IsNullOrWhiteSpace(Workspace.WorkingDirectory);

    private IReadOnlyList<string> OperatorWarnings => _operatorControls.GetCompatibilityWarnings();

    private bool CanBuildBookIndex => HasWorkingDirectory
        && !Workspace.HasBookIndex
        && !Session.IsRunning
        && !string.IsNullOrWhiteSpace(_manuscriptPath);

    private bool CanAddRangeToQueue => Workspace.HasBookIndex
        && !Session.IsRunning
        && !_isBatchRunning
        && Workspace.AvailableChapters.Count > 0;

    private bool CanClearQueue => _batchQueue.Count > 0 && !_isBatchRunning;

    private bool CanRunBatchQueue => Workspace.HasBookIndex
        && Workspace.IsInitialized
        && !Session.IsRunning
        && !_isBatchRunning
        && _batchQueue.Any(item => item.State is RunState.Pending or RunState.Failed);

    private int BatchQueuedCount => _batchQueue.Count(item => item.State == RunState.Pending);

    private int BatchRunningCount => _batchQueue.Count(item => item.State == RunState.Running);

    private int BatchCompletedCount => _batchQueue.Count(item => item.State == RunState.Completed);

    private int BatchFailedCount => _batchQueue.Count(item => item.State == RunState.Failed);

    private int PendingReadyCount => Workspace.AvailableChapters.Count - _batchQueue.Count;

    private IReadOnlyList<string> HistoryChapterKeys => Session.ProgressUpdates
        .Select(u => u.ItemId ?? "__global__")
        .Distinct()
        .ToArray();

    private string? HistoryCurrentChapter => HistoryChapterKeys.Count > 0
        ? HistoryChapterKeys[Math.Clamp(_historyPageIndex, 0, HistoryChapterKeys.Count - 1)]
        : null;

    private IReadOnlyList<RunProgressUpdate> HistoryPageUpdates => HistoryCurrentChapter is null
        ? []
        : Session.ProgressUpdates
            .Where(u => string.Equals(u.ItemId ?? "__global__", HistoryCurrentChapter, StringComparison.Ordinal))
            .Reverse()
            .ToArray();

    private PipelineBatchQueueItem? SelectedQueueItem
        => _batchQueue.FirstOrDefault(item => string.Equals(item.Chapter, _selectedQueueChapter, StringComparison.OrdinalIgnoreCase));

    protected override void OnInitialized()
    {
        Session.StateChanged += HandleSessionStateChanged;

        if (Session.LastPipelineRequest is not null)
        {
            _operatorControls.ApplyRequest(Session.LastPipelineRequest);
        }

        SyncQueueRangeDefaults();
    }

    private async Task HandleBuildBookIndexAsync()
    {
        if (!CanBuildBookIndex)
        {
            return;
        }

        await Session.BuildBookIndexAsync(_manuscriptPath);
    }

    private void HandleCancel()
    {
        Session.Cancel();
    }

    private void HandleAddRangeToQueue()
    {
        if (!CanAddRangeToQueue)
        {
            return;
        }

        var chapters = Workspace.AvailableChapters;
        var from = Math.Min((int)_queueRangeStart, (int)_queueRangeEnd) - 1;
        var to = Math.Max((int)_queueRangeStart, (int)_queueRangeEnd) - 1;
        from = Math.Max(0, Math.Min(from, chapters.Count - 1));
        to = Math.Max(0, Math.Min(to, chapters.Count - 1));

        for (var i = from; i <= to; i++)
        {
            QueueChapter(chapters[i]);
        }
    }

    private void HandleClearQueue()
    {
        if (!CanClearQueue)
        {
            return;
        }

        _batchQueue.Clear();
        _selectedQueueChapter = null;
        _historyPageIndex = 0;
        Session.ClearHistory();
    }

    private void SelectQueueItem(string chapter)
    {
        _selectedQueueChapter = chapter;
    }

    private void RemoveQueueItem(string chapter)
    {
        if (_isBatchRunning)
        {
            return;
        }

        var index = _batchQueue.FindIndex(item => string.Equals(item.Chapter, chapter, StringComparison.OrdinalIgnoreCase));
        if (index < 0)
        {
            return;
        }

        _batchQueue.RemoveAt(index);
        if (string.Equals(_selectedQueueChapter, chapter, StringComparison.OrdinalIgnoreCase))
        {
            _selectedQueueChapter = _batchQueue.FirstOrDefault()?.Chapter;
        }
    }

    private async Task HandleRunBatchPrepAsync()
    {
        if (!CanRunBatchQueue)
        {
            return;
        }

        if (!_operatorControls.TryBuildRequest(out var request))
        {
            return;
        }

        _isBatchRunning = true;
        _batchCancelRequested = false;
        var chapterBeforeBatch = Workspace.CurrentChapterName;

        try
        {
            foreach (var queueItem in _batchQueue.Where(item => item.State is RunState.Pending or RunState.Failed).ToArray())
            {
                if (_batchCancelRequested)
                {
                    break;
                }

                queueItem.State = RunState.Running;
                queueItem.Stage = Session.CurrentStage;
                queueItem.Message = "Running";
                _selectedQueueChapter = queueItem.Chapter;
                await InvokeAsync(StateHasChanged);

                if (Workspace.IsInitialized)
                {
                    Workspace.SelectChapter(queueItem.Chapter);
                }

                var success = await Session.RunChapterPrepAsync(queueItem.Chapter, request);

                queueItem.State = success ? RunState.Completed : RunState.Failed;
                queueItem.Stage = Session.LastFailureStage ?? Session.LastCompletedStage ?? Session.CurrentStage;
                queueItem.Message = success
                    ? DisplayOrPlaceholder(Session.LastMessage, "Completed")
                    : DisplayOrPlaceholder(Session.LastFailure?.Message ?? Session.LastMessage, "Failed");
                queueItem.ArtifactCount = Session.LastArtifacts.Count;
                queueItem.LastUpdatedUtc = DateTimeOffset.UtcNow;

                if (Session.WasCancelled)
                {
                    _batchCancelRequested = true;
                    break;
                }

                await InvokeAsync(StateHasChanged);
            }
        }
        finally
        {
            _isBatchRunning = false;

            var restoreChapter = chapterBeforeBatch
                ?? Workspace.AvailableChapters.FirstOrDefault();
            if (restoreChapter is not null && Workspace.IsInitialized)
            {
                Workspace.SelectChapter(restoreChapter);
            }

            await InvokeAsync(StateHasChanged);
        }
    }

    private void HandleCancelBatch()
    {
        _batchCancelRequested = true;
        Session.Cancel();
    }

    private void QueueChapter(string chapter)
    {
        if (_batchQueue.Any(item => string.Equals(item.Chapter, chapter, StringComparison.OrdinalIgnoreCase)))
        {
            return;
        }

        _batchQueue.Add(new PipelineBatchQueueItem(chapter));
        _selectedQueueChapter ??= chapter;
    }

    private void HandleEndStageChange(string? value)
    {
        _operatorControls.EndStageKey = string.IsNullOrWhiteSpace(value) ? "mfa" : value;
    }

    private void HandleForceChange(bool value)
    {
        _operatorControls.Force = value;
    }

    private void HandleForceIndexChange(bool value)
    {
        _operatorControls.ForceIndex = value;
    }

    private void HandleAsrEngineChange(string? value)
    {
        _operatorControls.AsrEngineKey = string.IsNullOrWhiteSpace(value)
            ? PrepPipelineOperatorControls.EngineAutoKey
            : value;
    }

    private void HandleAsrModelChange(string? value)
    {
        _operatorControls.AsrModel = value ?? string.Empty;
    }

    private void HandleAsrLanguageChange(string? value)
    {
        _operatorControls.AsrLanguage = value ?? string.Empty;
    }

    private void HandleEnableWordTimestampsChange(bool value)
    {
        _operatorControls.EnableWordTimestamps = value;
    }

    private void HandleEnableFlashAttentionChange(bool value)
    {
        _operatorControls.EnableFlashAttention = value;
    }

    private void HandleEnableDtwTimestampsChange(bool value)
    {
        _operatorControls.EnableDtwTimestamps = value;
    }

    private void HandleDisablePromptChange(bool value)
    {
        _operatorControls.DisablePrompt = value;
    }

    private void HandleMfaBeamProfileChange(string? value)
    {
        _operatorControls.MfaBeamProfileKey = string.IsNullOrWhiteSpace(value)
            ? PrepPipelineOperatorControls.BeamProfileDefaultKey
            : value;
    }

    private void HandleMfaBeamChange(string? value)
    {
        _operatorControls.MfaBeamText = value ?? string.Empty;
    }

    private void HandleMfaRetryBeamChange(string? value)
    {
        _operatorControls.MfaRetryBeamText = value ?? string.Empty;
    }

    private void HandleDisableChunkPlanChange(bool value)
    {
        _operatorControls.DisableChunkPlan = value;
    }

    private void HandleDisableChunkedMfaChange(bool value)
    {
        _operatorControls.DisableChunkedMfa = value;
    }

    private void HandleRequireAsrChunkAudioChange(bool value)
    {
        _operatorControls.RequireAsrChunkAudio = value;
    }

    private void HandleChunkSilenceThresholdChange(string? value)
    {
        _operatorControls.ChunkSilenceThresholdDbText = value ?? string.Empty;
    }

    private void HandleChunkMinSilenceDurationChange(string? value)
    {
        _operatorControls.ChunkMinSilenceDurationMsText = value ?? string.Empty;
    }

    private void HandleChunkMinDurationChange(string? value)
    {
        _operatorControls.ChunkMinDurationSecText = value ?? string.Empty;
    }

    private void HandleChunkMaxDurationChange(string? value)
    {
        _operatorControls.ChunkMaxDurationSecText = value ?? string.Empty;
    }

    private void HandleSessionStateChanged()
    {
        _ = InvokeAsync(() =>
        {
            if (Session.LastPipelineRequest is not null)
            {
                _operatorControls.ApplyRequest(Session.LastPipelineRequest);
            }

            SyncQueueRangeDefaults();
            StateHasChanged();
        });
    }

    private void SyncQueueRangeDefaults()
    {
        if (Workspace.AvailableChapters.Count == 0)
        {
            _queueRangeStart = 1;
            _queueRangeEnd = 1;
            return;
        }

        var maxValue = (double)Workspace.AvailableChapters.Count;

        // On first load both are 0 (or 1 after reset); set full range
        if (_queueRangeEnd <= 1 && _queueRangeStart <= 1 && maxValue > 1)
        {
            _queueRangeStart = 1;
            _queueRangeEnd = maxValue;
            return;
        }

        if (_queueRangeEnd > maxValue)
        {
            _queueRangeEnd = maxValue;
        }

        if (_queueRangeStart < 1 || _queueRangeStart > maxValue)
        {
            _queueRangeStart = 1;
        }
    }

    private string GetChapterAtIndex(int oneBasedIndex)
    {
        var chapters = Workspace.AvailableChapters;
        if (chapters.Count == 0)
        {
            return "—";
        }

        var arrayIndex = Math.Max(0, Math.Min(oneBasedIndex - 1, chapters.Count - 1));
        return chapters[arrayIndex];
    }

    private string GetBookIndexOutputPath()
        => HasWorkingDirectory ? Path.Combine(Workspace.RootPath, "book-index.json") : "Set a workspace first.";

    private string GetLastBuildAverageWpmDisplay()
        => Session.LastBuildRequest?.IndexOptions is null
            ? "n/a"
            : Session.LastBuildRequest.IndexOptions.AverageWpm.ToString();

    private static string GetPhaseTone(PrepRunPhase phase)
        => phase switch
        {
            PrepRunPhase.Completed => "success",
            PrepRunPhase.Cancelled => "warning",
            PrepRunPhase.Failed => "danger",
            PrepRunPhase.BuildingBookIndex or PrepRunPhase.RefreshingWorkspace or PrepRunPhase.RunningPipeline or PrepRunPhase.RefreshingChapterHandle => "primary",
            _ => "neutral"
        };

    private static string GetRunStateTone(RunState state)
        => state switch
        {
            RunState.Completed => "success",
            RunState.Failed => "danger",
            RunState.Running => "primary",
            _ => "info"
        };

    private static string GetRuntimeReadinessTone(PrepRuntimeReadinessState state)
        => state switch
        {
            PrepRuntimeReadinessState.Ready => "success",
            PrepRuntimeReadinessState.Warning => "warning",
            PrepRuntimeReadinessState.Failed => "danger",
            _ => "info"
        };

    private static string FormatPhase(PrepRunPhase phase)
        => phase switch
        {
            PrepRunPhase.BuildingBookIndex => "Building book index",
            PrepRunPhase.RefreshingWorkspace => "Refreshing workspace",
            PrepRunPhase.RunningPipeline => "Running pipeline",
            PrepRunPhase.RefreshingChapterHandle => "Refreshing chapter handle",
            _ => phase.ToString()
        };

    private static string FormatProgress(double? progress)
        => progress is double value ? $"{value:P0}" : "n/a";

    private static string DisplayOrPlaceholder(string? value, string placeholder)
        => string.IsNullOrWhiteSpace(value) ? placeholder : value;

    private sealed class PipelineBatchQueueItem
    {
        public PipelineBatchQueueItem(string chapter)
        {
            Chapter = chapter;
        }

        public string Chapter { get; }

        public RunState State { get; set; } = RunState.Pending;

        public string? Stage { get; set; }

        public string? Message { get; set; }

        public int ArtifactCount { get; set; }

        public DateTimeOffset? LastUpdatedUtc { get; set; }
    }

    public void Dispose()
    {
        Session.StateChanged -= HandleSessionStateChanged;
        Session.Dispose();
    }
}
