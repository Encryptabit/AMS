@page "/prep"
@page "/prep/pipeline"
@using System.IO
@using System.Linq
@using Ams.Core.Application.Pipeline
@using Ams.Core.Application.Runs
@using Ams.Workstation.Server.Services
@using Ams.Workstation.Server.Services.Prep
@implements IDisposable
@inject BlazorWorkspace Workspace
@inject PrepRunSession Session

<PageTitle>Prep - AMS Workstation</PageTitle>

<SectionContent SectionName="header-extra">
    @if (HasWorkingDirectory)
    {
        <BitStack Horizontal="true"
                  Gap="0.5rem"
                  VerticalAlign="BitAlignment.Center"
                  Wrap="true"
                  Class="prep-header-extra">
            <BitTag Color="@GetPhaseColor(Session.CurrentPhase)">@FormatPhase(Session.CurrentPhase)</BitTag>

            @if (!string.IsNullOrWhiteSpace(Session.CurrentStage))
            {
                <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">
                    Stage: @Session.CurrentStage
                </BitText>
            }

            <BitButton Variant="BitVariant.Outline"
                       Size="BitSize.Small"
                       Color="BitColor.Warning"
                       OnClick="HandleCancel"
                       IsEnabled="@(Session.IsRunning && !Session.IsCancellationRequested)">
                Cancel
            </BitButton>
        </BitStack>
    }
</SectionContent>

<SectionContent SectionName="module-inspector">
    @if (HasWorkingDirectory && Workspace.HasBookIndex)
    {
        <BitStack Horizontal="false" Gap="0rem" Class="prep-header-extra">
            <div class="inspector-header">
                <BitText Typography="BitTypography.Subtitle2">
                    @if (SelectedQueueItem is not null)
                    {
                        <text>INSPECTOR: @SelectedQueueItem.Chapter</text>
                    }
                    else
                    {
                        <text>Pipeline Inspector</text>
                    }
                </BitText>
            </div>

            @if (Session.IsRunning)
            {
                <div class="inspector-section">
                    <BitText Typography="BitTypography.Overline">Active Run</BitText>
                    <div class="prep-kv">
                        <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Phase</BitText>
                        <BitTag Color="@GetPhaseColor(Session.CurrentPhase)">@FormatPhase(Session.CurrentPhase)</BitTag>
                    </div>
                    <div class="prep-kv">
                        <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Stage</BitText>
                        <BitText Typography="BitTypography.Body2">@DisplayOrPlaceholder(Session.CurrentStage, "Pending")</BitText>
                    </div>
                    @if (Session.CurrentProgress?.Progress is double progress)
                    {
                        <BitProgress Percent="@(progress * 100d)" ShowPercentNumber="true" />
                    }
                    else
                    {
                        <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">
                            @(Session.CurrentProgress?.Message ?? Session.LastMessage ?? "Working...")
                        </BitText>
                    }
                </div>
            }

            @if (SelectedQueueItem is not null)
            {
                <div class="inspector-section">
                    <BitText Typography="BitTypography.Overline">Status</BitText>
                    <div class="prep-kv">
                        <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">State</BitText>
                        <BitTag Color="@GetRunStateColor(SelectedQueueItem.State)">@SelectedQueueItem.State</BitTag>
                    </div>
                    <div class="prep-kv">
                        <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Stage</BitText>
                        <BitText Typography="BitTypography.Body2">@DisplayOrPlaceholder(SelectedQueueItem.Stage, "n/a")</BitText>
                    </div>
                    <div class="prep-kv">
                        <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Artifacts</BitText>
                        <BitText Typography="BitTypography.Body2">@SelectedQueueItem.ArtifactCount</BitText>
                    </div>
                </div>
                @if (SelectedQueueItem.State == RunState.Failed && !string.IsNullOrWhiteSpace(SelectedQueueItem.Message))
                {
                    <div class="inspector-section">
                        <BitText Typography="BitTypography.Overline">Error</BitText>
                        <div class="inspector-error-log">@SelectedQueueItem.Message</div>
                    </div>
                }
                @if (SelectedQueueItem.ArtifactCount > 0 && Session.LastArtifacts.Count > 0
                     && string.Equals(Session.LastChapterId, SelectedQueueItem.Chapter, StringComparison.OrdinalIgnoreCase))
                {
                    <div class="inspector-section">
                        <BitText Typography="BitTypography.Overline">Last artifact set</BitText>
                        @foreach (var artifact in Session.LastArtifacts)
                        {
                            <div class="inspector-asset-row">
                                <BitIcon IconName="@(artifact.Name.Contains("audio", StringComparison.OrdinalIgnoreCase) ? BitIconName.MusicInCollection : BitIconName.TextDocument)" />
                                <BitText Typography="BitTypography.Caption1">@artifact.Name</BitText>
                                @if (!artifact.Exists)
                                {
                                    <BitTag Color="BitColor.Warning" Size="BitSize.Small">missing</BitTag>
                                }
                            </div>
                        }
                    </div>
                }
                <div class="inspector-section">
                    <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">
                        @DisplayOrPlaceholder(SelectedQueueItem.Message, "n/a")
                    </BitText>
                </div>
            }
            else
            {
                <div class="inspector-section">
                    <BitMessage Color="BitColor.Info">
                        Select a queue row to inspect run diagnostics.
                    </BitMessage>
                </div>
            }

            @if (Session.LastPipelineResult is not null)
            {
                <div class="inspector-section">
                    <BitText Typography="BitTypography.Overline">Stage Results</BitText>
                    @foreach (var stage in Session.LastPipelineResult.StageResults)
                    {
                        <div class="inspector-stage-row">
                            <BitTag Color="@GetRunStateColor(stage.State)" Size="BitSize.Small">@stage.State</BitTag>
                            <BitText Typography="BitTypography.Caption1">@stage.StageName</BitText>
                            <BitText Typography="BitTypography.Caption2" Color="BitColor.SecondaryForeground">@(stage.Executed ? "ran" : "cached")</BitText>
                        </div>
                    }
                    @if (Session.LastFailure is not null)
                    {
                        <div class="inspector-error-log">@Session.LastFailure.Kind: @DisplayOrPlaceholder(Session.LastFailure.Message, "Unknown error")</div>
                    }
                </div>
            }

            @if (Session.LastRuntimeReadiness is not null)
            {
                var readiness = Session.LastRuntimeReadiness;
                <div class="inspector-section">
                    <BitText Typography="BitTypography.Overline">Runtime readiness snapshot</BitText>
                    <div class="inspector-runtime-row">
                        <BitText Typography="BitTypography.Caption2" Color="BitColor.SecondaryForeground">ASR</BitText>
                        <BitTag Color="@GetRuntimeReadinessColor(readiness.ModelProvenance.State)" Size="BitSize.Small">@readiness.ModelProvenance.State</BitTag>
                    </div>
                    <div class="inspector-runtime-row">
                        <BitText Typography="BitTypography.Caption2" Color="BitColor.SecondaryForeground">FFmpeg</BitText>
                        <BitTag Color="@GetRuntimeReadinessColor(readiness.Ffmpeg.State)" Size="BitSize.Small">@readiness.Ffmpeg.State</BitTag>
                    </div>
                    <div class="inspector-runtime-row">
                        <BitText Typography="BitTypography.Caption2" Color="BitColor.SecondaryForeground">MFA</BitText>
                        <BitTag Color="@GetRuntimeReadinessColor(readiness.Mfa.State)" Size="BitSize.Small">@readiness.Mfa.State</BitTag>
                    </div>
                    @if (readiness.Notes.Count > 0)
                    {
                        @foreach (var note in readiness.Notes)
                        {
                            <BitText Typography="BitTypography.Caption2" Color="BitColor.Warning">@note</BitText>
                        }
                    }
                </div>
            }

            <div class="inspector-section">
                <BitText Typography="BitTypography.Overline">Batch Throughput</BitText>
                <div class="prep-grid prep-grid--compact">
                    <div class="prep-kv">
                        <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Queued</BitText>
                        <BitText Typography="BitTypography.Body2">@BatchQueuedCount</BitText>
                    </div>
                    <div class="prep-kv">
                        <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Running</BitText>
                        <BitText Typography="BitTypography.Body2">@BatchRunningCount</BitText>
                    </div>
                    <div class="prep-kv">
                        <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Completed</BitText>
                        <BitText Typography="BitTypography.Body2">@BatchCompletedCount</BitText>
                    </div>
                    <div class="prep-kv">
                        <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Failed</BitText>
                        <BitText Typography="BitTypography.Body2">@BatchFailedCount</BitText>
                    </div>
                </div>
            </div>
        </BitStack>
    }
</SectionContent>

<div class="prep-page">
    <BitStack Horizontal="false" Gap="1rem">
        @if (HasWorkingDirectory && Workspace.HasBookIndex)
        {
            <BitStack Horizontal="true"
                      HorizontalAlign="BitAlignment.SpaceBetween"
                      VerticalAlign="BitAlignment.Center"
                      Gap="0.75rem"
                      Wrap="true"
                      Class="pipeline-action-bar"
                      data-ams-prep-mobile-contract="pipeline-action-bar">
                <BitStack Horizontal="true"
                          VerticalAlign="BitAlignment.Center"
                          Gap="0.5rem"
                          Wrap="true"
                          Class="pipeline-action-bar__stats">
                    <BitText Typography="BitTypography.Body2">
                        <strong>@Workspace.AvailableChapters.Count</strong> CHAPTERS
                    </BitText>
                    <BitTag Color="@(_isBatchRunning ? BitColor.Primary : BitColor.Secondary)"
                            Class="prep-running-status">
                        @(_isBatchRunning ? "Batch running" : "Batch idle")
                    </BitTag>
                </BitStack>
                <BitStack Horizontal="true"
                          VerticalAlign="BitAlignment.Center"
                          Gap="0.5rem"
                          Wrap="true"
                          Class="pipeline-action-bar__controls">
                    <BitButton Variant="BitVariant.Outline"
                               Size="BitSize.Small"
                               Color="BitColor.Secondary"
                               IconName="@BitIconName.Equalizer"
                               Title="Pipeline settings"
                               AriaLabel="Pipeline settings"
                               Class="pipeline-action-button"
                               OnClick="@(() => _isPipelineSettingsOpen = true)" />
                    <BitButton Variant="BitVariant.Fill"
                               Color="BitColor.Primary"
                               Size="BitSize.Small"
                               Class="pipeline-action-button"
                               OnClick="HandleRunBatchPrepAsync"
                               IsEnabled="@CanRunBatchQueue">
                        Run batch prep
                    </BitButton>
                    <BitButton Variant="BitVariant.Outline"
                               Color="BitColor.Warning"
                               Size="BitSize.Small"
                               Class="pipeline-action-button"
                               OnClick="HandleCancelBatch"
                               IsEnabled="@(_isBatchRunning || (Session.IsRunning && !Session.IsCancellationRequested))">
                        Cancel batch
                    </BitButton>
                </BitStack>
            </BitStack>

            <BitText Typography="BitTypography.Caption1"
                     Color="BitColor.SecondaryForeground"
                     Class="pipeline-top-summary">
                Queue Builder + Pipeline Throughput
            </BitText>

            <BitGrid Columns="12" Gap="1rem" Class="pipeline-layout-grid">

                <BitGridItem ColumnSpan="4" Class="pipeline-grid-item--top">
                    <BitCard FullWidth="true" Class="pipeline-card pipeline-card--top">
                        <BitStack Horizontal="false" Gap="0.75rem" Class="queue-builder-stack">
                            <BitText Typography="BitTypography.Overline">Queue Builder</BitText>
                            <div class="queue-builder-range">
                                <BitStack Horizontal="true" HorizontalAlign="BitAlignment.SpaceBetween" VerticalAlign="BitAlignment.Center">
                                    <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">
                                        @GetChapterAtIndex((int)_queueRangeStart)
                                    </BitText>
                                    <BitText Typography="BitTypography.Caption2" Color="BitColor.Primary">
                                        @(Math.Abs((int)_queueRangeEnd - (int)_queueRangeStart) + 1) chapters selected
                                    </BitText>
                                    <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">
                                        @GetChapterAtIndex((int)_queueRangeEnd)
                                    </BitText>
                                </BitStack>
                                <BitSlider IsRanged="true"
                                           Min="1"
                                           Max="@((double)(Math.Max(Workspace.AvailableChapters.Count, 1)))"
                                           @bind-LowerValue="_queueRangeStart"
                                           @bind-UpperValue="_queueRangeEnd"
                                           Step="1"
                                           IsEnabled="@(!Session.IsRunning && !_isBatchRunning)" />
                            </div>
                            <BitStack Horizontal="true" Gap="0.5rem" Wrap="true" Class="queue-builder-actions">
                                <BitButton Variant="BitVariant.Fill"
                                           Color="BitColor.Primary"
                                           Size="BitSize.Small"
                                           OnClick="HandleAddRangeToQueue"
                                           IsEnabled="@CanAddRangeToQueue"
                                           IconName="@BitIconName.Add">
                                    Add range
                                </BitButton>
                                <BitButton Variant="BitVariant.Outline"
                                           Color="BitColor.Secondary"
                                           Size="BitSize.Small"
                                           OnClick="HandleClearQueue"
                                           IsEnabled="@CanClearQueue">
                                    Clear queue
                                </BitButton>
                            </BitStack>
                        </BitStack>
                    </BitCard>
                </BitGridItem>

                <BitGridItem ColumnSpan="8" Class="pipeline-grid-item--top">
                    <BitCard FullWidth="true" Class="pipeline-card pipeline-card--top">
                        <BitStack Horizontal="false" Gap="0.75rem" Class="throughput-stack">
                            <BitStack Horizontal="true" HorizontalAlign="BitAlignment.SpaceBetween" VerticalAlign="BitAlignment.Center">
                                <BitText Typography="BitTypography.Overline">Pipeline Throughput</BitText>
                                <BitTag Color="@(_isBatchRunning ? BitColor.Primary : BitColor.Secondary)">@(_isBatchRunning ? "Running" : "Idle")</BitTag>
                            </BitStack>
                            <div class="pipeline-throughput-row">
                                <div class="pipeline-throughput-box">
                                    <BitText Typography="BitTypography.H5">@PendingReadyCount</BitText>
                                    <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Ready</BitText>
                                    <div class="pipeline-throughput-indicator pipeline-throughput-indicator--secondary"></div>
                                </div>
                                <div class="pipeline-throughput-box">
                                    <BitText Typography="BitTypography.H5">@BatchQueuedCount</BitText>
                                    <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Queued</BitText>
                                    <div class="pipeline-throughput-indicator pipeline-throughput-indicator--info"></div>
                                </div>
                                <div class="pipeline-throughput-box">
                                    <BitText Typography="BitTypography.H5" Color="BitColor.Primary">@BatchRunningCount</BitText>
                                    <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Running</BitText>
                                    <div class="pipeline-throughput-indicator pipeline-throughput-indicator--primary"></div>
                                </div>
                                <div class="pipeline-throughput-box">
                                    <BitText Typography="BitTypography.H5" Color="BitColor.Error">@BatchFailedCount</BitText>
                                    <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Failed</BitText>
                                    <div class="pipeline-throughput-indicator pipeline-throughput-indicator--error"></div>
                                </div>
                                <div class="pipeline-throughput-box pipeline-throughput-box--wide">
                                    <BitText Typography="BitTypography.H5">@BatchCompletedCount</BitText>
                                    <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Succeeded</BitText>
                                    <div class="pipeline-throughput-indicator pipeline-throughput-indicator--success"></div>
                                </div>
                            </div>
                        </BitStack>
                    </BitCard>
                </BitGridItem>

                <BitGridItem ColumnSpan="12">
                    <BitCard FullWidth="true" Class="pipeline-card">
                        <BitStack Horizontal="false" Gap="0.5rem">
                            <BitText Typography="BitTypography.Overline">Pipeline Dashboard</BitText>
                            <BitPivot>
                                <BitPivotItem HeaderText="Active Tasks" IconName="@BitIconName.TaskGroup">
                                    <table class="prep-table">
                                        <thead>
                                            <tr>
                                                <th>#</th>
                                                <th>Chapter</th>
                                                <th>Status</th>
                                                <th>Stage</th>
                                                <th>Progress</th>
                                                <th>Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (_batchQueue.Count == 0)
                                            {
                                                <tr>
                                                    <td colspan="6">Queue is empty. Add chapters to start batch processing.</td>
                                                </tr>
                                            }
                                            else
                                            {
                                                var rowIndex = 0;
                                                @foreach (var item in _batchQueue)
                                                {
                                                    rowIndex++;
                                                    var isSelected = string.Equals(item.Chapter, _selectedQueueChapter, StringComparison.OrdinalIgnoreCase);
                                                    <tr class="@(isSelected ? "pipeline-row--selected" : "")">
                                                        <td>@rowIndex.ToString("D3")</td>
                                                        <td><strong>@item.Chapter</strong></td>
                                                        <td><BitTag Color="@GetRunStateColor(item.State)">@item.State</BitTag></td>
                                                        <td>@DisplayOrPlaceholder(item.Stage, "n/a")</td>
                                                        <td>
                                                            @if (item.State == RunState.Running)
                                                            {
                                                                <BitProgress Percent="50" />
                                                            }
                                                            else if (item.State == RunState.Completed)
                                                            {
                                                                <BitProgress Percent="100" Color="BitColor.Success" />
                                                            }
                                                            else if (item.State == RunState.Failed)
                                                            {
                                                                <BitProgress Percent="75" Color="BitColor.Error" />
                                                            }
                                                        </td>
                                                        <td>
                                                            <BitStack Horizontal="true" Gap="0.25rem" Class="pipeline-row-actions">
                                                                <BitButton Variant="BitVariant.Text"
                                                                           Size="BitSize.Small"
                                                                           Color="BitColor.Primary"
                                                                           IconName="@BitIconName.EntryView"
                                                                           OnClick="@(() => SelectQueueItem(item.Chapter))">
                                                                    Inspect
                                                                </BitButton>
                                                                <BitButton Variant="BitVariant.Text"
                                                                           Size="BitSize.Small"
                                                                           Color="BitColor.Secondary"
                                                                           IconName="@BitIconName.Delete"
                                                                           OnClick="@(() => RemoveQueueItem(item.Chapter))"
                                                                           IsEnabled="@(!_isBatchRunning)">
                                                                    Remove
                                                                </BitButton>
                                                            </BitStack>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </BitPivotItem>
                                <BitPivotItem HeaderText="History" IconName="@BitIconName.History">
                                    <BitText Typography="BitTypography.Caption1"
                                             Color="BitColor.SecondaryForeground"
                                             Class="pipeline-history-label">
                                        Progress timeline
                                    </BitText>
                                    @if (Session.ProgressUpdates.Count > 0)
                                    {
                                        var chapters = HistoryChapterKeys;
                                        var currentChapter = HistoryCurrentChapter;
                                        var pageUpdates = HistoryPageUpdates;

                                        <BitStack Horizontal="true"
                                                  VerticalAlign="BitAlignment.Center"
                                                  HorizontalAlign="BitAlignment.SpaceBetween"
                                                  Gap="0.5rem"
                                                  Class="history-pager">
                                            <BitButton Variant="BitVariant.Text"
                                                       Size="BitSize.Small"
                                                       IconName="@BitIconName.ChevronLeft"
                                                       OnClick="@(() => _historyPageIndex = Math.Max(0, _historyPageIndex - 1))"
                                                       IsEnabled="@(_historyPageIndex > 0)" />
                                            <BitText Typography="BitTypography.Body2">
                                                <strong>@(currentChapter == "__global__" ? "Global" : currentChapter)</strong>
                                                <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">
                                                    (@(_historyPageIndex + 1) of @chapters.Count)
                                                </BitText>
                                            </BitText>
                                            <BitButton Variant="BitVariant.Text"
                                                       Size="BitSize.Small"
                                                       IconName="@BitIconName.ChevronRight"
                                                       OnClick="@(() => _historyPageIndex = Math.Min(chapters.Count - 1, _historyPageIndex + 1))"
                                                       IsEnabled="@(_historyPageIndex < chapters.Count - 1)" />
                                        </BitStack>

                                        <table class="prep-table">
                                            <thead>
                                                <tr>
                                                    <th>Module</th>
                                                    <th>Stage</th>
                                                    <th>State</th>
                                                    <th>Message</th>
                                                    <th>Progress</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var update in pageUpdates)
                                                {
                                                    <tr>
                                                        <td>@update.ModuleId.Value</td>
                                                        <td>@DisplayOrPlaceholder(update.Stage, "n/a")</td>
                                                        <td>
                                                            <BitTag Color="@GetRunStateColor(update.State)">@update.State</BitTag>
                                                        </td>
                                                        <td>
                                                            <div>@update.Message</div>
                                                            @if (update.Failure is not null)
                                                            {
                                                                <div class="prep-inline-note">@update.Failure.Kind: @update.Failure.Message</div>
                                                            }
                                                        </td>
                                                        <td>@FormatProgress(update.Progress)</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    }
                                    else
                                    {
                                        <BitMessage Color="BitColor.Info">No progress history recorded yet.</BitMessage>
                                    }
                                </BitPivotItem>
                            </BitPivot>
                        </BitStack>
                    </BitCard>
                </BitGridItem>
            </BitGrid>
        }

        @if (!HasWorkingDirectory)
        {
            <BitMessage Color="BitColor.Info">
                <BitStack Horizontal="false" Gap="0.5rem">
                    <BitText Typography="BitTypography.Body1">
                        Set a working directory from the header before running Prep.
                    </BitText>
                    <BitText Typography="BitTypography.Body2" Color="BitColor.SecondaryForeground">
                        Once a workspace is loaded, this page will either ask for a manuscript path to build book-index.json or let you run chapter prep against the shared pipeline service.
                    </BitText>
                </BitStack>
            </BitMessage>
        }
        else if (!Workspace.HasBookIndex)
        {
            <BitCard>
                <BitStack Horizontal="false" Gap="1rem">
                    <BitStack Horizontal="true"
                              HorizontalAlign="BitAlignment.SpaceBetween"
                              VerticalAlign="BitAlignment.Start"
                              Gap="1rem"
                              Wrap="true">
                        <BitStack Horizontal="false" Gap="0.25rem">
                            <BitText Typography="BitTypography.Subtitle1">Build book index</BitText>
                            <BitText Typography="BitTypography.Body2" Color="BitColor.SecondaryForeground">
                                book-index.json is missing, so Prep needs an explicit manuscript path before queue processing can run.
                            </BitText>
                        </BitStack>
                        <BitTag Color="BitColor.Warning">Index required</BitTag>
                    </BitStack>

                    <BitTextField @bind-Value="_manuscriptPath"
                                  Immediate="true"
                                  Placeholder="Absolute path to the manuscript markdown file..."
                                  IsEnabled="@(!Session.IsRunning)" />

                    <div class="prep-grid">
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Output file</BitText>
                            <BitText Typography="BitTypography.Body2" Class="prep-mono">@GetBookIndexOutputPath()</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Average WPM</BitText>
                            <BitText Typography="BitTypography.Body2">@PrepRunSession.ExplicitAverageWordsPerMinute</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Cache mode</BitText>
                            <BitText Typography="BitTypography.Body2">PreferCache</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Workspace reload</BitText>
                            <BitText Typography="BitTypography.Body2">Automatic after a successful build</BitText>
                        </div>
                    </div>

                    <BitStack Horizontal="true" Gap="0.75rem" Wrap="true">
                        <BitButton Variant="BitVariant.Fill"
                                   Color="BitColor.Primary"
                                   OnClick="HandleBuildBookIndexAsync"
                                   IsEnabled="@CanBuildBookIndex">
                            Build book index
                        </BitButton>
                        <BitButton Variant="BitVariant.Outline"
                                   Color="BitColor.Warning"
                                   OnClick="HandleCancel"
                                   IsEnabled="@(Session.IsRunning && !Session.IsCancellationRequested)">
                            Cancel
                        </BitButton>
                    </BitStack>
                </BitStack>
            </BitCard>
        }
        else
        {
            @if (Workspace.AvailableChapters.Count == 0)
            {
                <BitMessage Color="BitColor.Warning">
                    No chapters were discovered after loading book-index.json.
                </BitMessage>
            }
        }

        @if (Session.LastBuildRequest is not null || Session.LastBuildBookIndexResult is not null)
        {
            <BitCard>
                <BitStack Horizontal="false" Gap="0.75rem">
                    <BitText Typography="BitTypography.Subtitle1">Last book-index request</BitText>

                    <div class="prep-grid">
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Manuscript</BitText>
                            <BitText Typography="BitTypography.Body2" Class="prep-mono">@DisplayOrPlaceholder(Session.LastBuildRequest?.BookFile.FullName, "No build request recorded")</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Output</BitText>
                            <BitText Typography="BitTypography.Body2" Class="prep-mono">@DisplayOrPlaceholder(Session.LastBuildRequest?.OutputFile.FullName, "No output file recorded")</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Average WPM</BitText>
                            <BitText Typography="BitTypography.Body2">@GetLastBuildAverageWpmDisplay()</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Cache disposition</BitText>
                            <BitText Typography="BitTypography.Body2">@DisplayOrPlaceholder(Session.LastBuildBookIndexResult?.CacheDisposition.ToString(), "No result yet")</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Phonemes backfilled</BitText>
                            <BitText Typography="BitTypography.Body2">@(Session.LastBuildBookIndexResult?.PhonemesBackfilled is true ? "Yes" : Session.LastBuildBookIndexResult is null ? "n/a" : "No")</BitText>
                        </div>
                        <div class="prep-kv">
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Workspace reloaded</BitText>
                            <BitText Typography="BitTypography.Body2">@(Session.LastWorkspaceReloaded ? "Yes" : "No")</BitText>
                        </div>
                    </div>
                </BitStack>
            </BitCard>
        }

    </BitStack>
</div>

@if (HasWorkingDirectory && Workspace.HasBookIndex)
{
    <BitDialog @bind-IsOpen="_isPipelineSettingsOpen"
