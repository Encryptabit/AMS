@page "/prep"
@page "/prep/pipeline"
@using System.IO
@using System.Linq
@using Ams.Core.Application.Pipeline
@using Ams.Core.Application.Runs
@using Ams.Workstation.Server.Components.UI
@using Ams.Workstation.Server.Services
@using Ams.Workstation.Server.Services.Prep
@implements IDisposable
@inject BlazorWorkspace Workspace
@inject PrepRunSession Session

<PageTitle>Prep - AMS Workstation</PageTitle>

@* Icon glyph mapping (Bit icon name → vanilla glyph):
     Equalizer → ⚙, Add → +, EntryView → ◉, Delete → ✕,
     ChevronLeft → ‹, ChevronRight → ›, TaskGroup → ☰,
     History → ⏱, MusicInCollection → ♪, TextDocument → ▤. *@

<SectionContent SectionName="header-extra">
    @if (HasWorkingDirectory)
    {
        <div class="prep-header-extra prep-header-extra--row">
            <AmsTag Tone="@GetPhaseTone(Session.CurrentPhase)" Size="sm">@FormatPhase(Session.CurrentPhase)</AmsTag>

            @if (!string.IsNullOrWhiteSpace(Session.CurrentStage))
            {
                <span class="ams-caption ams-caption--muted">Stage: @Session.CurrentStage</span>
            }

            <AmsButton Variant="danger"
                       Size="sm"
                       OnClick="HandleCancel"
                       Disabled="@(!(Session.IsRunning && !Session.IsCancellationRequested))">
                Cancel
            </AmsButton>
        </div>
    }
</SectionContent>

<SectionContent SectionName="module-inspector">
    @if (HasWorkingDirectory && Workspace.HasBookIndex)
    {
        <div class="prep-header-extra prep-header-extra--column">
            <div class="inspector-header">
                <h3 class="ams-subtitle">
                    @if (SelectedQueueItem is not null)
                    {
                        <text>INSPECTOR: @SelectedQueueItem.Chapter</text>
                    }
                    else
                    {
                        <text>Pipeline Inspector</text>
                    }
                </h3>
            </div>

            @if (Session.IsRunning)
            {
                <div class="inspector-section" data-ams-inspector-section="session">
                    <span class="ams-overline">Active Run</span>
                    <div class="prep-kv">
                        <span class="ams-caption ams-caption--muted">Phase</span>
                        <AmsTag Tone="@GetPhaseTone(Session.CurrentPhase)" Size="sm">@FormatPhase(Session.CurrentPhase)</AmsTag>
                    </div>
                    <div class="prep-kv">
                        <span class="ams-caption ams-caption--muted">Stage</span>
                        <span class="ams-body">@DisplayOrPlaceholder(Session.CurrentStage, "Pending")</span>
                    </div>
                    @if (Session.CurrentProgress?.Progress is double progress)
                    {
                        <AmsProgress Value="@(progress * 100d)" State="info" ShowLabel="true" />
                    }
                    else
                    {
                        <span class="ams-caption ams-caption--muted">
                            @(Session.CurrentProgress?.Message ?? Session.LastMessage ?? "Working...")
                        </span>
                    }
                </div>
            }

            @if (SelectedQueueItem is not null)
            {
                <div class="inspector-section" data-ams-inspector-section="queue">
                    <span class="ams-overline">Status</span>
                    <div class="prep-kv">
                        <span class="ams-caption ams-caption--muted">State</span>
                        <AmsTag Tone="@GetRunStateTone(SelectedQueueItem.State)" Size="sm">@SelectedQueueItem.State</AmsTag>
                    </div>
                    <div class="prep-kv">
                        <span class="ams-caption ams-caption--muted">Stage</span>
                        <span class="ams-body">@DisplayOrPlaceholder(SelectedQueueItem.Stage, "n/a")</span>
                    </div>
                    <div class="prep-kv">
                        <span class="ams-caption ams-caption--muted">Artifacts</span>
                        <span class="ams-body">@SelectedQueueItem.ArtifactCount</span>
                    </div>
                </div>
                @if (SelectedQueueItem.State == RunState.Failed && !string.IsNullOrWhiteSpace(SelectedQueueItem.Message))
                {
                    <div class="inspector-section" data-ams-inspector-section="queue">
                        <span class="ams-overline">Error</span>
                        <div class="inspector-error-log">@SelectedQueueItem.Message</div>
                    </div>
                }
                @if (SelectedQueueItem.ArtifactCount > 0 && Session.LastArtifacts.Count > 0
                     && string.Equals(Session.LastChapterId, SelectedQueueItem.Chapter, StringComparison.OrdinalIgnoreCase))
                {
                    <div class="inspector-section" data-ams-inspector-section="assets">
                        <span class="ams-overline">Artifacts</span>
                        @foreach (var artifact in Session.LastArtifacts)
                        {
                            <div class="inspector-asset-row">
                                <span aria-hidden="true">@(artifact.Name.Contains("audio", StringComparison.OrdinalIgnoreCase) ? "♪" : "▤")</span>
                                <span class="ams-caption">@artifact.Name</span>
                                @if (!artifact.Exists)
                                {
                                    <AmsTag Tone="warning" Size="sm">missing</AmsTag>
                                }
                            </div>
                        }
                    </div>
                }
                <div class="inspector-section" data-ams-inspector-section="queue">
                    <span class="ams-caption ams-caption--muted">
                        @DisplayOrPlaceholder(SelectedQueueItem.Message, "n/a")
                    </span>
                </div>
            }
            else
            {
                <div class="inspector-section" data-ams-inspector-section="queue">
                    <div class="ams-message ams-message--info" role="status">
                        Select a queue row to inspect run diagnostics.
                    </div>
                </div>
            }

            @if (Session.LastPipelineResult is not null)
            {
                <div class="inspector-section" data-ams-inspector-section="session">
                    <span class="ams-overline">Stage Results</span>
                    @foreach (var stage in Session.LastPipelineResult.StageResults)
                    {
                        <div class="inspector-stage-row">
                            <AmsTag Tone="@GetRunStateTone(stage.State)" Size="sm">@stage.State</AmsTag>
                            <span class="ams-caption">@stage.StageName</span>
                            <span class="ams-caption ams-caption--muted">@(stage.Executed ? "ran" : "cached")</span>
                        </div>
                    }
                    @if (Session.LastFailure is not null)
                    {
                        <div class="inspector-error-log">@Session.LastFailure.Kind: @DisplayOrPlaceholder(Session.LastFailure.Message, "Unknown error")</div>
                    }
                </div>
            }

            @if (Session.LastRuntimeReadiness is not null)
            {
                var readiness = Session.LastRuntimeReadiness;
                <div class="inspector-section" data-ams-inspector-section="runtime">
                    <span class="ams-overline">Runtime</span>
                    <div class="inspector-runtime-row">
                        <span class="ams-caption ams-caption--muted">ASR</span>
                        <AmsTag Tone="@GetRuntimeReadinessTone(readiness.ModelProvenance.State)" Size="sm">@readiness.ModelProvenance.State</AmsTag>
                    </div>
                    <div class="inspector-runtime-row">
                        <span class="ams-caption ams-caption--muted">FFmpeg</span>
                        <AmsTag Tone="@GetRuntimeReadinessTone(readiness.Ffmpeg.State)" Size="sm">@readiness.Ffmpeg.State</AmsTag>
                    </div>
                    <div class="inspector-runtime-row">
                        <span class="ams-caption ams-caption--muted">MFA</span>
                        <AmsTag Tone="@GetRuntimeReadinessTone(readiness.Mfa.State)" Size="sm">@readiness.Mfa.State</AmsTag>
                    </div>
                    @if (readiness.Notes.Count > 0)
                    {
                        @foreach (var note in readiness.Notes)
                        {
                            <span class="ams-caption ams-caption--warning">@note</span>
                        }
                    }
                </div>
            }

            <div class="inspector-section" data-ams-inspector-section="session">
                <span class="ams-overline">Batch Throughput</span>
                <div class="prep-grid prep-grid--compact">
                    <div class="prep-kv">
                        <span class="ams-caption ams-caption--muted">Queued</span>
                        <span class="ams-body">@BatchQueuedCount</span>
                    </div>
                    <div class="prep-kv">
                        <span class="ams-caption ams-caption--muted">Running</span>
                        <span class="ams-body">@BatchRunningCount</span>
                    </div>
                    <div class="prep-kv">
                        <span class="ams-caption ams-caption--muted">Completed</span>
                        <span class="ams-body">@BatchCompletedCount</span>
                    </div>
                    <div class="prep-kv">
                        <span class="ams-caption ams-caption--muted">Failed</span>
                        <span class="ams-body">@BatchFailedCount</span>
                    </div>
                </div>
            </div>
        </div>
    }
</SectionContent>

<div class="prep-page">
    <div class="prep-page__stack">
        @if (HasWorkingDirectory && Workspace.HasBookIndex)
        {
            <div class="pipeline-action-bar">
                <span class="ams-body"><strong>@Workspace.AvailableChapters.Count</strong> CHAPTERS</span>
                <AmsButton Variant="secondary"
                           Size="sm"
                           Icon="⚙"
                           data-ams-prep="pipeline-settings-button"
                           title="Pipeline settings"
                           aria-label="Pipeline settings"
                           OnClick="@(() => _isPipelineSettingsOpen = true)" />
                <AmsButton Variant="primary"
                           Size="sm"
                           OnClick="HandleRunBatchPrepAsync"
                           Disabled="@(!CanRunBatchQueue)">
                    Run batch prep
                </AmsButton>
                <AmsButton Variant="danger"
                           Size="sm"
                           OnClick="HandleCancelBatch"
                           Disabled="@(!(_isBatchRunning || (Session.IsRunning && !Session.IsCancellationRequested)))">
                    Cancel batch
                </AmsButton>
            </div>

            <div class="prep-grid-12 pipeline-layout-grid">

                <div class="prep-grid-item--span-4 pipeline-grid-item--top">
                    <section class="ams-card pipeline-card pipeline-card--top" data-ams-prep="queue-builder">
                        <div class="queue-builder-stack">
                            <span class="ams-overline">Queue Builder</span>
                            <div class="queue-builder-range">
                                <div class="queue-builder-range__row">
                                    <span class="ams-caption ams-caption--muted">
                                        @GetChapterAtIndex((int)_queueRangeStart)
                                    </span>
                                    <span class="ams-caption ams-caption--primary">
                                        @(Math.Abs((int)_queueRangeEnd - (int)_queueRangeStart) + 1) chapters selected
                                    </span>
                                    <span class="ams-caption ams-caption--muted">
                                        @GetChapterAtIndex((int)_queueRangeEnd)
                                    </span>
                                </div>
                                <AmsRangeSlider Min="1"
                                                Max="@((double)(Math.Max(Workspace.AvailableChapters.Count, 1)))"
                                                @bind-LowerValue="_queueRangeStart"
                                                @bind-UpperValue="_queueRangeEnd"
                                                Step="1"
                                                IsEnabled="@(!Session.IsRunning && !_isBatchRunning)" />
                            </div>
                            <div class="queue-builder-actions">
                                <AmsButton Variant="primary"
                                           Size="sm"
                                           Icon="+"
                                           OnClick="HandleAddRangeToQueue"
                                           Disabled="@(!CanAddRangeToQueue)">
                                    Add range
                                </AmsButton>
                                <AmsButton Variant="secondary"
                                           Size="sm"
                                           OnClick="HandleClearQueue"
                                           Disabled="@(!CanClearQueue)">
                                    Clear queue
                                </AmsButton>
                            </div>
                        </div>
                    </section>
                </div>

                <div class="prep-grid-item--span-8 pipeline-grid-item--top">
                    <section class="ams-card pipeline-card pipeline-card--top" data-ams-prep="throughput">
                        <div class="throughput-stack">
                            <div class="throughput-heading">
                                <span class="ams-overline">Pipeline Throughput</span>
                                <AmsTag Tone="@(_isBatchRunning ? "primary" : "neutral")" Size="sm">@(_isBatchRunning ? "Running" : "Idle")</AmsTag>
                            </div>
                            <div class="pipeline-throughput-row">
                                <div class="pipeline-throughput-box">
                                    <h2 class="ams-metric">@PendingReadyCount</h2>
                                    <span class="ams-caption ams-caption--muted">Ready</span>
                                    <div class="pipeline-throughput-indicator pipeline-throughput-indicator--secondary"></div>
                                </div>
                                <div class="pipeline-throughput-box">
                                    <h2 class="ams-metric">@BatchQueuedCount</h2>
                                    <span class="ams-caption ams-caption--muted">Queued</span>
                                    <div class="pipeline-throughput-indicator pipeline-throughput-indicator--info"></div>
                                </div>
                                <div class="pipeline-throughput-box">
                                    <h2 class="ams-metric ams-metric--primary">@BatchRunningCount</h2>
                                    <span class="ams-caption ams-caption--muted">Running</span>
                                    <div class="pipeline-throughput-indicator pipeline-throughput-indicator--primary"></div>
                                </div>
                                <div class="pipeline-throughput-box">
                                    <h2 class="ams-metric ams-metric--danger">@BatchFailedCount</h2>
                                    <span class="ams-caption ams-caption--muted">Failed</span>
                                    <div class="pipeline-throughput-indicator pipeline-throughput-indicator--error"></div>
                                </div>
                                <div class="pipeline-throughput-box pipeline-throughput-box--wide">
                                    <h2 class="ams-metric">@BatchCompletedCount</h2>
                                    <span class="ams-caption ams-caption--muted">Succeeded</span>
                                    <div class="pipeline-throughput-indicator pipeline-throughput-indicator--success"></div>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>

                <div class="prep-grid-item--span-12">
                    <section class="ams-card pipeline-card">
                        <div class="pipeline-dashboard-stack">
                            <span class="ams-overline">Pipeline Dashboard</span>
                            <div data-ams-prep="pipeline-tabs">
                                <AmsTabs>
                                    <AmsTabItem Icon="☰">
                                        <Header>Active Tasks</Header>
                                        <ChildContent>
                                            <table class="prep-table">
                                                <thead>
                                                    <tr>
                                                        <th>#</th>
                                                        <th>Chapter</th>
                                                        <th>Status</th>
                                                        <th>Stage</th>
                                                        <th>Progress</th>
                                                        <th>Action</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @if (_batchQueue.Count == 0)
                                                    {
                                                        <tr>
                                                            <td colspan="6">Queue is empty. Add chapters to start batch processing.</td>
                                                        </tr>
                                                    }
                                                    else
                                                    {
                                                        var rowIndex = 0;
                                                        @foreach (var item in _batchQueue)
                                                        {
                                                            rowIndex++;
                                                            var isSelected = string.Equals(item.Chapter, _selectedQueueChapter, StringComparison.OrdinalIgnoreCase);
                                                            <tr class="@(isSelected ? "pipeline-row--selected" : "")">
                                                                <td>@rowIndex.ToString("D3")</td>
                                                                <td><strong>@item.Chapter</strong></td>
                                                                <td><AmsTag Tone="@GetRunStateTone(item.State)" Size="sm">@item.State</AmsTag></td>
                                                                <td>@DisplayOrPlaceholder(item.Stage, "n/a")</td>
                                                                <td>
                                                                    @if (item.State == RunState.Running)
                                                                    {
                                                                        <AmsProgress Value="50" State="info" />
                                                                    }
                                                                    else if (item.State == RunState.Completed)
                                                                    {
                                                                        <AmsProgress Value="100" State="success" />
                                                                    }
                                                                    else if (item.State == RunState.Failed)
                                                                    {
                                                                        <AmsProgress Value="75" State="danger" />
                                                                    }
                                                                </td>
                                                                <td>
                                                                    <div class="pipeline-row-actions">
                                                                        <AmsButton Variant="ghost"
                                                                                   Size="sm"
                                                                                   Icon="◉"
                                                                                   OnClick="@(() => SelectQueueItem(item.Chapter))">
                                                                            Inspect
                                                                        </AmsButton>
                                                                        <AmsButton Variant="ghost"
                                                                                   Size="sm"
                                                                                   Icon="✕"
                                                                                   OnClick="@(() => RemoveQueueItem(item.Chapter))"
                                                                                   Disabled="@_isBatchRunning">
                                                                            Remove
                                                                        </AmsButton>
                                                                    </div>
                                                                </td>
                                                            </tr>
                                                        }
                                                    }
                                                </tbody>
                                            </table>
                                        </ChildContent>
                                    </AmsTabItem>
                                    <AmsTabItem Icon="⏱">
                                        <Header>History</Header>
                                        <ChildContent>
                                            @if (Session.ProgressUpdates.Count > 0)
                                            {
                                                var chapters = HistoryChapterKeys;
                                                var currentChapter = HistoryCurrentChapter;
                                                var pageUpdates = HistoryPageUpdates;

                                                <div class="history-pager">
                                                    <AmsButton Variant="ghost"
                                                               Size="sm"
                                                               Icon="‹"
                                                               OnClick="@(() => _historyPageIndex = Math.Max(0, _historyPageIndex - 1))"
                                                               Disabled="@(_historyPageIndex <= 0)" />
                                                    <span class="ams-body">
                                                        <strong>@(currentChapter == "__global__" ? "Global" : currentChapter)</strong>
                                                        <span class="ams-caption ams-caption--muted">
                                                            (@(_historyPageIndex + 1) of @chapters.Count)
                                                        </span>
                                                    </span>
                                                    <AmsButton Variant="ghost"
                                                               Size="sm"
                                                               Icon="›"
                                                               OnClick="@(() => _historyPageIndex = Math.Min(chapters.Count - 1, _historyPageIndex + 1))"
                                                               Disabled="@(_historyPageIndex >= chapters.Count - 1)" />
                                                </div>

                                                <table class="prep-table">
                                                    <thead>
                                                        <tr>
                                                            <th>Module</th>
                                                            <th>Stage</th>
                                                            <th>State</th>
                                                            <th>Message</th>
                                                            <th>Progress</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var update in pageUpdates)
                                                        {
                                                            <tr>
                                                                <td>@update.ModuleId.Value</td>
                                                                <td>@DisplayOrPlaceholder(update.Stage, "n/a")</td>
                                                                <td>
                                                                    <AmsTag Tone="@GetRunStateTone(update.State)" Size="sm">@update.State</AmsTag>
                                                                </td>
                                                                <td>
                                                                    <div>@update.Message</div>
                                                                    @if (update.Failure is not null)
                                                                    {
                                                                        <div class="prep-inline-note">@update.Failure.Kind: @update.Failure.Message</div>
                                                                    }
                                                                </td>
                                                                <td>@FormatProgress(update.Progress)</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            }
                                            else
                                            {
                                                <div class="ams-message ams-message--info" role="status">No progress history recorded yet.</div>
                                            }
                                        </ChildContent>
                                    </AmsTabItem>
                                </AmsTabs>
                            </div>
                        </div>
                    </section>
                </div>
            </div>
        }

        @if (!HasWorkingDirectory)
        {
            <div class="ams-message ams-message--info" role="status" data-ams-prep="no-workspace-message">
                <div class="prep-message-stack">
                    <p class="ams-body">
                        Set a working directory from the header before running Prep.
                    </p>
                    <span class="ams-caption ams-caption--muted">
                        Once a workspace is loaded, this page will either ask for a manuscript path to build book-index.json or let you run chapter prep against the shared pipeline service.
                    </span>
                </div>
            </div>
        }
        else if (!Workspace.HasBookIndex)
        {
            <section class="ams-card" data-ams-prep="build-index-form">
                <div class="prep-card-stack">
                    <div class="prep-card-heading">
                        <div class="prep-card-heading__text">
                            <h3 class="ams-subtitle">Build book index</h3>
                            <span class="ams-caption ams-caption--muted">
                                book-index.json is missing, so Prep needs an explicit manuscript path before queue processing can run.
                            </span>
                        </div>
                        <AmsTag Tone="warning" Size="sm">Index required</AmsTag>
                    </div>

                    <input type="text"
                           class="ams-input"
                           value="@_manuscriptPath"
                           @oninput="@(e => _manuscriptPath = e.Value?.ToString() ?? string.Empty)"
                           placeholder="Absolute path to the manuscript markdown file..."
                           disabled="@Session.IsRunning" />

                    <div class="prep-grid">
                        <div class="prep-kv">
                            <span class="ams-caption ams-caption--muted">Output file</span>
                            <span class="ams-body prep-mono">@GetBookIndexOutputPath()</span>
                        </div>
                        <div class="prep-kv">
                            <span class="ams-caption ams-caption--muted">Average WPM</span>
                            <span class="ams-body">@PrepRunSession.ExplicitAverageWordsPerMinute</span>
                        </div>
                        <div class="prep-kv">
                            <span class="ams-caption ams-caption--muted">Cache mode</span>
                            <span class="ams-body">PreferCache</span>
                        </div>
                        <div class="prep-kv">
                            <span class="ams-caption ams-caption--muted">Workspace reload</span>
                            <span class="ams-body">Automatic after a successful build</span>
                        </div>
                    </div>

                    <div class="prep-card-actions">
                        <AmsButton Variant="primary"
                                   OnClick="HandleBuildBookIndexAsync"
                                   Disabled="@(!CanBuildBookIndex)">
                            Build book index
                        </AmsButton>
                        <AmsButton Variant="danger"
                                   OnClick="HandleCancel"
                                   Disabled="@(!(Session.IsRunning && !Session.IsCancellationRequested))">
                            Cancel
                        </AmsButton>
                    </div>
                </div>
            </section>
        }
        else
        {
            @if (Workspace.AvailableChapters.Count == 0)
            {
                <div class="ams-message ams-message--warning" role="status">
                    No chapters were discovered after loading book-index.json.
                </div>
            }
        }

        @if (Session.LastBuildRequest is not null || Session.LastBuildBookIndexResult is not null)
        {
            <section class="ams-card">
                <div class="prep-card-stack">
                    <h3 class="ams-subtitle">Last book-index request</h3>

                    <div class="prep-grid">
                        <div class="prep-kv">
                            <span class="ams-caption ams-caption--muted">Manuscript</span>
                            <span class="ams-body prep-mono">@DisplayOrPlaceholder(Session.LastBuildRequest?.BookFile.FullName, "No build request recorded")</span>
                        </div>
                        <div class="prep-kv">
                            <span class="ams-caption ams-caption--muted">Output</span>
                            <span class="ams-body prep-mono">@DisplayOrPlaceholder(Session.LastBuildRequest?.OutputFile.FullName, "No output file recorded")</span>
                        </div>
                        <div class="prep-kv">
                            <span class="ams-caption ams-caption--muted">Average WPM</span>
                            <span class="ams-body">@GetLastBuildAverageWpmDisplay()</span>
                        </div>
                        <div class="prep-kv">
                            <span class="ams-caption ams-caption--muted">Cache disposition</span>
                            <span class="ams-body">@DisplayOrPlaceholder(Session.LastBuildBookIndexResult?.CacheDisposition.ToString(), "No result yet")</span>
                        </div>
                        <div class="prep-kv">
                            <span class="ams-caption ams-caption--muted">Phonemes backfilled</span>
                            <span class="ams-body">@(Session.LastBuildBookIndexResult?.PhonemesBackfilled is true ? "Yes" : Session.LastBuildBookIndexResult is null ? "n/a" : "No")</span>
                        </div>
                        <div class="prep-kv">
                            <span class="ams-caption ams-caption--muted">Workspace reloaded</span>
                            <span class="ams-body">@(Session.LastWorkspaceReloaded ? "Yes" : "No")</span>
                        </div>
                    </div>
                </div>
            </section>
        }

    </div>
</div>

@if (HasWorkingDirectory && Workspace.HasBookIndex)
{
    <AmsDialog @bind-IsOpen="_isPipelineSettingsOpen"
               Title="Pipeline settings"
               OnDismiss="@(() => _isPipelineSettingsOpen = false)">
        <div class="pipeline-settings-stack">
            <span class="ams-caption ams-caption--muted">
                Configure pipeline execution options. Changes apply immediately to the next run.
            </span>

            <div class="prep-control-sections">
                <div class="prep-control-section">
                    <h3 class="ams-subtitle">Pipeline execution</h3>
                    <div class="prep-grid prep-grid--compact">
                        <div class="prep-kv">
                            <span class="ams-caption ams-caption--muted">End stage</span>
                            <select class="ams-select prep-field-min"
                                    value="@_operatorControls.EndStageKey"
                                    @onchange="@(e => HandleEndStageChange(e.Value?.ToString()))"
                                    disabled="@Session.IsRunning">
                                @foreach (var opt in PrepPipelineOperatorControls.EndStageOptions)
                                {
                                    <option value="@opt.Value" selected="@(opt.Value == _operatorControls.EndStageKey)">@opt.Label</option>
                                }
                            </select>
                        </div>
                        <div class="prep-kv">
                            <label class="ams-checkbox">
                                <input type="checkbox"
                                       checked="@_operatorControls.Force"
                                       @onchange="@(e => HandleForceChange((bool)e.Value!))"
                                       disabled="@Session.IsRunning" />
                                <span>Force rerun</span>
                            </label>
                        </div>
                        <div class="prep-kv">
                            <label class="ams-checkbox">
                                <input type="checkbox"
                                       checked="@_operatorControls.ForceIndex"
                                       @onchange="@(e => HandleForceIndexChange((bool)e.Value!))"
                                       disabled="@Session.IsRunning" />
                                <span>Force index rebuild</span>
                            </label>
                        </div>
                    </div>
                </div>

                <div class="prep-control-section">
                    <h3 class="ams-subtitle">ASR identity &amp; refinement</h3>
                    <div class="prep-grid prep-grid--compact">
                        <div class="prep-kv">
                            <span class="ams-caption ams-caption--muted">Engine</span>
                            <select class="ams-select prep-field-min"
                                    value="@_operatorControls.AsrEngineKey"
                                    @onchange="@(e => HandleAsrEngineChange(e.Value?.ToString()))"
                                    disabled="@Session.IsRunning">
                                @foreach (var opt in PrepPipelineOperatorControls.AsrEngineOptions)
                                {
                                    <option value="@opt.Value" selected="@(opt.Value == _operatorControls.AsrEngineKey)">@opt.Label</option>
                                }
                            </select>
                        </div>
                        <div class="prep-kv">
                            <label class="ams-field">
                                <span class="ams-caption ams-caption--muted">Model</span>
                                <input type="text"
                                       class="ams-input"
                                       value="@_operatorControls.AsrModel"
                                       @oninput="@(e => HandleAsrModelChange(e.Value?.ToString()))"
                                       placeholder="Optional model alias/path"
                                       disabled="@Session.IsRunning" />
                            </label>
                        </div>
                        <div class="prep-kv">
                            <label class="ams-field">
                                <span class="ams-caption ams-caption--muted">Language</span>
                                <input type="text"
                                       class="ams-input"
                                       value="@_operatorControls.AsrLanguage"
                                       @oninput="@(e => HandleAsrLanguageChange(e.Value?.ToString()))"
                                       placeholder="en"
                                       disabled="@Session.IsRunning" />
                            </label>
                        </div>
                        <div class="prep-kv">
                            <label class="ams-checkbox">
                                <input type="checkbox"
                                       checked="@_operatorControls.EnableWordTimestamps"
                                       @onchange="@(e => HandleEnableWordTimestampsChange((bool)e.Value!))"
                                       disabled="@Session.IsRunning" />
                                <span>Word timestamps</span>
                            </label>
                        </div>
                        <div class="prep-kv">
                            <label class="ams-checkbox">
                                <input type="checkbox"
                                       checked="@_operatorControls.EnableFlashAttention"
                                       @onchange="@(e => HandleEnableFlashAttentionChange((bool)e.Value!))"
                                       disabled="@Session.IsRunning" />
                                <span>FlashAttention</span>
                            </label>
                        </div>
                        <div class="prep-kv">
                            <label class="ams-checkbox">
                                <input type="checkbox"
                                       checked="@_operatorControls.EnableDtwTimestamps"
                                       @onchange="@(e => HandleEnableDtwTimestampsChange((bool)e.Value!))"
                                       disabled="@Session.IsRunning" />
                                <span>DTW timestamps</span>
                            </label>
                        </div>
                        <div class="prep-kv">
                            <label class="ams-checkbox">
                                <input type="checkbox"
                                       checked="@_operatorControls.DisablePrompt"
                                       @onchange="@(e => HandleDisablePromptChange((bool)e.Value!))"
                                       disabled="@Session.IsRunning" />
                                <span>Disable prompt</span>
                            </label>
