@page "/proof/patterns"
@inject BlazorWorkspace Workspace
@inject ErrorPatternService ErrorPatternService
@inject IgnoredPatternsService IgnoredPatternsService
@using Ams.Workstation.Server.Models
@using Ams.Workstation.Server.Services
@using Ams.Workstation.Server.Components.UI

<PageTitle>Error Patterns - AMS Workstation</PageTitle>

<div class="proof-patterns proof-patterns-page">
    <div class="proof-patterns__header proof-patterns-header">
        <h1>Error Patterns</h1>
        <p class="ams-body ams-body--muted">Recurring differences across all chapters</p>
    </div>

    <input type="text"
           class="ams-input proof-patterns__filter"
           value="@_filterText"
           @oninput="@(e => HandleFilterChange(e.Value?.ToString()))"
           placeholder="Filter patterns…"
           data-ams-proof="patterns-filter" />

    @if (_loading)
    {
        <div class="proof-patterns-loading">
            <AmsSpinner Label="Loading error patterns" />
        </div>
    }
    else if (_patterns != null && _patterns.Patterns.Count > 0)
    {
        <p class="ams-caption ams-caption--muted">Showing @FilteredPatterns.Count() of @_patterns.Patterns.Count patterns</p>

        <div class="proof-patterns-grid" data-ams-proof="patterns-grid">
            @foreach (var pattern in FilteredPatterns)
            {
                <div>
                    <PatternCard Pattern="pattern"
                                 OnToggleIgnore="() => ToggleIgnore(pattern)" />
                </div>
            }
        </div>

        @if (!FilteredPatterns.Any())
        {
            <p class="ams-body ams-body--muted"><em>No patterns match filter.</em></p>
        }
    }
    else if (_patterns != null && _patterns.Patterns.Count == 0)
    {
        <div class="ams-message ams-message--info" role="status">
            No error patterns found. All sentences match perfectly.
        </div>
    }
    else
    {
        <div class="ams-message ams-message--info" role="status">
            No pattern data available. Set working directory first.
        </div>
    }
</div>


@code {
    private ErrorPatternsResult? _patterns;
    private string _filterText = "";
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadPatterns();
    }

    private async Task LoadPatterns()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            if (!Workspace.IsInitialized || !Workspace.HasBookIndex)
            {
                _patterns = null;
            }
            else
            {
                await Task.Yield();
                _patterns = ErrorPatternService.AggregatePatterns(IgnoredPatternsService.GetIgnoredKeys());
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to load error patterns: {ex.Message}");
            _patterns = null;
        }

        _loading = false;
        StateHasChanged();
    }

    private IEnumerable<ErrorPattern> FilteredPatterns =>
        _patterns?.Patterns.Where(p =>
            string.IsNullOrEmpty(_filterText) ||
            p.Book.Contains(_filterText, StringComparison.OrdinalIgnoreCase) ||
            p.Script.Contains(_filterText, StringComparison.OrdinalIgnoreCase)
        ) ?? Enumerable.Empty<ErrorPattern>();

    private void HandleFilterChange(string? value)
    {
        _filterText = value ?? "";
        StateHasChanged();
    }

    private Task ToggleIgnore(ErrorPattern pattern)
    {
        // Persist via IgnoredPatternsService (direct service call, NOT HTTP)
        IgnoredPatternsService.ToggleIgnored(pattern.Key);
        // Update local state
        pattern.Ignored = !pattern.Ignored;
        StateHasChanged();
        return Task.CompletedTask;
    }

}
