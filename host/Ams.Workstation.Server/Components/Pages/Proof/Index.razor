@page "/proof"
@page "/proof/editing"
@using Ams.Workstation.Server.Components.Navigation
@inject Ams.Workstation.Server.Services.BlazorWorkspace Workspace

<PageTitle>Proof - AMS Workstation</PageTitle>

<div class="proof-index">
    <div class="proof-index__stack">
        <div class="proof-header">
            <h1>Proof Area</h1>
            <p class="ams-body ams-body--muted">Review and validate chapter alignments.</p>
        </div>

        @if (Workspace.HasBookIndex)
        {
            <section class="ams-card overview-link">
                <a href="@GetProofOverviewPath()" class="ams-btn ams-btn--secondary ams-btn--md proof-index__quick-link">
                    <span aria-hidden="true">▦</span>
                    <span>Book Overview</span>
                    <span class="proof-index__quick-link-detail">View all chapters</span>
                </a>
            </section>

            <section class="ams-card overview-link">
                <a href="@GetProofPatternsPath()" class="ams-btn ams-btn--secondary ams-btn--md proof-index__quick-link">
                    <span aria-hidden="true">⚠</span>
                    <span>Error Patterns</span>
                    <span class="proof-index__quick-link-detail">Recurring differences</span>
                </a>
            </section>

            <section class="ams-card overview-link" data-proof-index-link="pickups">
                <a href="@GetProofPickupsPath()" class="ams-btn ams-btn--secondary ams-btn--md proof-index__quick-link">
                    <span aria-hidden="true">🎙</span>
                    <span>Pickups</span>
                    <span class="proof-index__quick-link-detail">Import stitched pickups and stage replacements</span>
                </a>
            </section>

            <section class="ams-card">
                <p class="proof-index__section-label">Select a Chapter to Review</p>

                @if (Workspace.AvailableChapters.Count == 0)
                {
                    <p class="ams-body ams-body--muted">No chapters available.</p>
                }
                else
                {
                    <ul class="chapters">
                        @foreach (var chapter in Workspace.AvailableChapters)
                        {
                            <li>
                                <a href="@GetProofChapterPath(chapter)" class="chapter-link">
                                    <span class="chapter-link__start">
                                        <span aria-hidden="true">▤</span>
                                        <span class="chapter-name">@chapter</span>
                                    </span>
                                    <span aria-hidden="true">›</span>
                                </a>
                            </li>
                        }
                    </ul>
                }
            </section>
        }
        else
        {
            <div class="ams-message ams-message--info" role="status" data-ams-proof="no-workspace-message">
                <div class="proof-index__message">
                    <p>No working directory set or book-index.json not found.</p>
                    <a href="/" class="ams-btn ams-btn--secondary ams-btn--md">Go to Home to set a working directory</a>
                </div>
            </div>
        }
    </div>
</div>


@code {
    private static string GetProofOverviewPath()
        => StageRouteCatalog.GetModuleCanonicalPath(
            StageRouteCatalog.StageIds.Proof,
            StageRouteCatalog.ModuleIds.ProofOverview);

    private static string GetProofPatternsPath()
        => StageRouteCatalog.GetModuleCanonicalPath(
            StageRouteCatalog.StageIds.Proof,
            StageRouteCatalog.ModuleIds.ProofPatterns);

    private static string GetProofPickupsPath()
        => StageRouteCatalog.GetModuleCanonicalPath(
            StageRouteCatalog.StageIds.Proof,
            StageRouteCatalog.ModuleIds.ProofPickups);

    private static string GetProofChapterPath(string chapterName)
        => StageRouteCatalog.BuildProofChapterCompatibilityPath(chapterName);
}
