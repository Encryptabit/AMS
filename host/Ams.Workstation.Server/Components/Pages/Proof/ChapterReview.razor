@page "/proof/{ChapterName}"
@page "/proof/editing/{ChapterName}"
@inject Ams.Workstation.Server.Services.BlazorWorkspace Workspace
@inject Ams.Workstation.Server.Services.ChapterDataService ChapterDataService
@inject Ams.Workstation.Server.Services.ProofReportService ProofReportService
@inject Ams.Workstation.Server.Services.ErrorPatternService ErrorPatternService
@inject Ams.Workstation.Server.Services.ReviewedStatusService ReviewedStatusService
@inject Ams.Workstation.Server.Services.AudioExportService AudioExportService
@inject Ams.Workstation.Server.Services.IgnoredPatternsService IgnoredPatternsService
@inject Ams.Workstation.Server.Services.ToastService ToastService
@inject Ams.Workstation.Server.Services.CrxService CrxService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using Ams.Workstation.Server.Components.Navigation
@using Ams.Workstation.Server.Models
@using Ams.Core.Runtime.Audio
@implements IAsyncDisposable

<PageTitle>@ChapterName - Proof - AMS Workstation</PageTitle>

<SectionContent SectionName="mobile-action-bar">
    <div class="proof-mobile-fallback-actions"
         data-ams-proof-gesture-fallback-controls="mobile-action-buttons"
         role="region"
         aria-label="Proof gesture fallback controls">
        <MobileActionBar CurrentView="@_currentView"
                         IsSelectionModeActive="@_isSelectionModeActive"
                         SelectedCount="@SelectionCount"
                         IsBatchActionsEnabled="@CanRunSelectionBatchActions"
                         IsReviewed="@_isReviewed"
                         OnSwitchToErrors="SwitchToErrorsFromMobileActionBar"
                         OnSwitchToPlayback="SwitchToPlaybackFromMobileActionBar"
                         OnExportSelection="ExportSelectionFromMobileActionBarAsync"
                         OnIgnoreSelection="IgnoreSelectionFromMobileActionBarAsync"
                         OnToggleReviewed="ToggleReviewedFromMobileActionBar"
                         OnToggleModules="ToggleModulesFromMobileActionBarAsync"
                         OnNavigateToPickups="NavigateToPickupsFromMobileActionBar" />
    </div>
</SectionContent>

<SectionContent SectionName="header-settings-extra">
    <div class="proof-alert-settings-section" data-ams-proof-alert-settings-state="@PlaybackAlertSettingsState">
        <BitStack Horizontal="false" Gap="0.5rem">
            <BitStack Horizontal="true" Gap="0.5rem" Wrap="true" VerticalAlign="BitAlignment.Center">
                <BitButton Variant="BitVariant.Outline"
                           Color="BitColor.Secondary"
                           Size="BitSize.Small"
                           OnClick="TogglePlaybackAlertSettings">
                    @(_isPlaybackAlertSettingsExpanded ? "Hide alert sound" : "Alert sound")
                </BitButton>
                <BitText Typography="BitTypography.Caption1"
                         Color="BitColor.SecondaryForeground">
                    @GetPlaybackErrorAlertSummaryText()
                </BitText>
            </BitStack>
            <BitText Typography="BitTypography.Caption1"
                     Color="BitColor.SecondaryForeground">
                @GetPlaybackErrorAlertStatusText()
            </BitText>
            @if (_isPlaybackAlertSettingsExpanded)
            {
                <BitStack Horizontal="false" Gap="0.45rem">
                    <BitTextField @bind-Value="_playbackErrorAlertSourcePath"
                                  Immediate="true"
                                  Placeholder="Alert sound file path (.wav, .mp3, .ogg, .flac, .m4a)"
                                  Style="width: 100%;" />
                    <BitStack Horizontal="true" Gap="0.45rem" Wrap="true">
                        <BitButton Variant="BitVariant.Fill"
                                   Color="BitColor.Primary"
                                   Size="BitSize.Small"
                                   OnClick="SavePlaybackErrorAlertSound">
                            Save
                        </BitButton>
                        <BitButton Variant="BitVariant.Outline"
                                   Color="BitColor.Secondary"
                                   Size="BitSize.Small"
                                   IsEnabled="@(_playbackErrorAlertSoundSetting is not null)"
                                   OnClick="ClearPlaybackErrorAlertSound">
                            Clear
                        </BitButton>
                    </BitStack>
                </BitStack>
            }
        </BitStack>
    </div>
</SectionContent>

<div class="proof-review" data-ams-proof-mobile-action-bar-contract="selection-workflows">
    <div class="proof-view-switcher">
        <BitStack Horizontal="true" Wrap="true" Class="proof-view-switcher-stack" Gap="0.5rem" AutoHeight="true" HorizontalAlign="BitAlignment.Center" Style="margin-bottom: 1rem;">
            <BitButton Variant="@(_currentView == "errors" ? BitVariant.Fill : BitVariant.Outline)"
                       OnClick="@(() => SwitchView("errors"))">
                Errors View
            </BitButton>
            <BitButton Variant="@(_currentView == "playback" ? BitVariant.Fill : BitVariant.Outline)"
                       OnClick="@(() => SwitchView("playback"))">
                Playback View
            </BitButton>
            <BitButton Variant="@(_isReviewed ? BitVariant.Fill : BitVariant.Outline)"
                       Color="@(_isReviewed ? BitColor.Success : BitColor.Primary)"
                       OnClick="ToggleReviewed">
                @(_isReviewed ? "Reviewed" : "Mark as Reviewed")
            </BitButton>
            <span data-proof-editing-handoff="pickups">
                <BitButton Variant="BitVariant.Outline"
                           OnClick="NavigateToPickups">
                    Pickups
                </BitButton>
            </span>
        </BitStack>
    </div>

    <div class="proof-selection-indicator"
         data-ams-proof-selection-mode-state="@SelectionModeState"
         data-ams-proof-selection-count="@SelectionCount"
         data-ams-proof-selection-last-event="@_lastSelectionGestureEvent">
        <BitText Typography="BitTypography.Caption1"
                 Color="BitColor.SecondaryForeground"
                 Class="proof-selection-indicator-text">
            @GetSelectionModeIndicatorText()
        </BitText>
        <BitButton Variant="BitVariant.Outline"
                   Color="BitColor.Secondary"
                   Size="BitSize.Small"
                   data-ams-proof-selection-fallback-toggle="true"
                   aria-label="@SelectionFallbackToggleAriaLabel"
                   title="@SelectionFallbackToggleTitle"
                   OnClick="ToggleSelectionModeFallbackAsync">
            @SelectionFallbackToggleText
        </BitButton>
    </div>

    @if (_currentView == "playback")
    {
        <div class="proof-playback-shell" data-ams-proof-mobile-contract="sentence-first">
            <BitGrid Columns="12">
                <BitGridItem ColumnSpan="12">
                    <div class="proof-playback-alert" data-ams-proof-alert-settings-state="@PlaybackAlertSettingsState">
                        <BitCard Class="playback-alert-settings" FullWidth="true">
                            <BitStack Horizontal="true"
                                      Gap="0.5rem"
                                      Wrap="true"
                                      VerticalAlign="BitAlignment.Center"
                                      Class="playback-alert-header">
                                <span data-ams-proof-alert-settings-toggle="true">
                                    <BitButton Variant="BitVariant.Outline"
                                               Color="BitColor.Secondary"
                                               OnClick="TogglePlaybackAlertSettings">
                                        @(_isPlaybackAlertSettingsExpanded ? "Hide alert settings" : "Alert settings")
                                    </BitButton>
                                </span>
                                <BitText Typography="BitTypography.Caption1"
                                         Color="BitColor.SecondaryForeground"
                                         Class="playback-alert-summary">
                                    @GetPlaybackErrorAlertSummaryText()
                                </BitText>
                            </BitStack>
                            <BitText Typography="BitTypography.Caption1"
                                     Color="BitColor.SecondaryForeground"
                                     Class="playback-alert-status">
                                @GetPlaybackErrorAlertStatusText()
                            </BitText>
                            @if (_isPlaybackAlertSettingsExpanded)
                            {
                                <div class="playback-alert-editor" data-ams-proof-alert-settings-panel="true">
                                    <BitStack Horizontal="true" Gap="0.6rem" VerticalAlign="BitAlignment.End" Wrap="true">
                                        <BitTextField @bind-Value="_playbackErrorAlertSourcePath"
                                                      Immediate="true"
                                                      Placeholder="Alert sound file path (.wav, .mp3, .ogg, .flac, .m4a)"
                                                      Style="min-width: 18rem; flex: 1;" />
                                        <BitButton Variant="BitVariant.Fill"
                                                   Color="BitColor.Primary"
                                                   OnClick="SavePlaybackErrorAlertSound">
                                            Save Alert Sound
                                        </BitButton>
                                        <BitButton Variant="BitVariant.Outline"
                                                   Color="BitColor.Secondary"
                                                   IsEnabled="@(_playbackErrorAlertSoundSetting is not null)"
                                                   OnClick="ClearPlaybackErrorAlertSound">
                                            Clear
                                        </BitButton>
                                    </BitStack>
                                </div>
                            }
                        </BitCard>
                    </div>
                </BitGridItem>
                <BitGridItem ColumnSpan="12" style="min-width: 0;">
                    <div class="proof-playback-waveform" data-ams-proof-mobile-waveform="compact">
                        <WaveformPlayer
                            @ref="_waveformPlayer"
                            AudioUrl="@GetAudioUrl()"
                            PeaksUrl="@GetPeaksUrl()"
                            Title="@GetDisplayTitle()"
                            Height="125"
                            TimeUpdated="HandleTimeUpdate"
                            OnReady="HandleWaveformReady"
                            OnSeek="HandleSeek"
                            OnFinished="HandlePlaybackFinished" />
                    </div>
                </BitGridItem>
                <BitGridItem ColumnSpan="12">
                    <div class="proof-playback-sentences" data-ams-proof-gesture-surface="playback">
                        <SentenceList
                            Sentences="@_sentences"
                            CurrentTime="@_currentTime"
                            ActiveSentenceId="@_selectedSentenceId"
                            SelectedSentenceIds="@_selectedSentenceIds"
                            OnSentenceSelected="HandleSentenceSelected"
                            OnSentenceLongPress="OnSentenceLongPress" />
                    </div>
                </BitGridItem>
            </BitGrid>
        </div>
    }
    else
    {
        <div class="proof-errors-shell" data-ams-proof-gesture-surface="errors">
            <ErrorsView Report="_report" ChapterPatterns="_chapterPatterns"
                        IgnoredKeys="IgnoredPatternsService.GetIgnoredKeys()"
                        ExportedSentenceIds="_exportedSentenceIds"
                        SelectedIndex="_selectedErrorIndex"
                        OnPlaySentence="HandlePlayFromErrors"
                        OnExportSentence="HandleExportFromErrors"
                        OnCrxSentence="HandleCrxFromErrors"
                        OnIgnoreSentence="HandleIgnoreSentenceActionAsync"
                        OnTogglePatternIgnore="HandleTogglePatternIgnore"
                        OnViewSentence="HandleViewFromErrors" />
        </div>
    }

    <CrxModal @ref="_crxModal" OnSubmitted="HandleCrxSubmitted" />
    <IgnoreErrorModal @ref="_ignoreModal" OnSubmitted="HandleIgnoreModalSubmitted" />
</div>


@code {
    private const int PeakPxPerSec = 1200;
    private const double CrxMinExportDurationSec = 0.001;
    private const double CrxFallbackExportDurationSec = 1.0;
    private const double CrxFallbackLeadInSec = 0.25;

    private sealed record CrxExportSeed(
        int SentenceId,
        double StartTime,
        double EndTime,
        string Text,
        SentenceReport? Report);

    private sealed record CrxExportComposition(
        double StartTime,
        double EndTime,
        int AnchorSentenceId,
        string Excerpt,
        SentenceReport? AnchorReport,
        IReadOnlyList<SentenceReport> AllReports,
        bool RequiresRangeConfirmation,
        string RangeMode,
        int Cardinality);

    private double _currentTime;
    private WaveformPlayer? _waveformPlayer;
    private List<SentenceViewModel> _sentences = new();
    private string _currentView = "playback";
    private ChapterReport? _report;
    private IReadOnlyList<ErrorPattern>? _chapterPatterns;
    private bool _isReviewed;
    private CrxModal? _crxModal;
    private IgnoreErrorModal? _ignoreModal;
    private HashSet<int> _exportedSentenceIds = new();
    private HashSet<int> _pendingExportSentenceIds = new();
    private HashSet<int> _visibleErrorSentenceIds = new();
    private IJSObjectReference? _snippetPlayer;
    private IJSObjectReference? _alertSoundPlayer;
    private string _playbackErrorAlertSourcePath = string.Empty;
    private AppPlaybackAlertSoundSettings? _playbackErrorAlertSoundSetting;
    private bool _isPlaybackAlertSettingsExpanded;
    private string PlaybackAlertSettingsState => _isPlaybackAlertSettingsExpanded ? "expanded" : "collapsed";
    private string? _lastRenderedChapter;
    private bool _scrollToTopPending;

    // Touch selection state
    private static readonly TimeSpan DuplicateLongPressWindow = TimeSpan.FromMilliseconds(250);
    private static readonly TimeSpan PostLongPressTapSuppressionWindow = TimeSpan.FromMilliseconds(700);
    private const string MobileModuleRailToggleElementId = "workstation-mobile-module-rail-toggle";
    private bool _isSelectionModeActive;
    private HashSet<int> _selectedSentenceIds = new();
    private bool _resumePlaybackOnSelectionExit;
    private string _lastSelectionGestureEvent = "idle";
    private DateTimeOffset _lastLongPressDispatchAtUtc = DateTimeOffset.MinValue;
    private int _lastLongPressDispatchSentenceId;
    private readonly Dictionary<int, DateTimeOffset> _suppressedSelectionTapSentenceIds = new();
    private string SelectionModeState => _isSelectionModeActive ? "active" : "inactive";
    private int SelectionCount => _selectedSentenceIds.Count;
    private bool CanRunSelectionBatchActions => _isSelectionModeActive && _selectedSentenceIds.Count > 0;
    private string CurrentMobileActionSurface => _currentView == "errors" ? "errors" : "playback";
    private string SelectionFallbackToggleText => _isSelectionModeActive ? "Exit Selection" : "Select Current";
    private string SelectionFallbackToggleAriaLabel => _isSelectionModeActive
        ? "Exit selection mode and resume playback"
        : "Enter selection mode using the current sentence";
    private string SelectionFallbackToggleTitle => _isSelectionModeActive ? "Exit selection mode" : "Enter selection mode";

    // Keyboard navigation state
    private int _selectedErrorIndex;
    private int? _selectedSentenceId;
    private int? _lastTimeBasedSentenceId;
    private int? _lastPlaybackAlertSentenceId;
    private int? _playbackNavigationIndex;
    private IJSObjectReference? _keyboardModule;
    private IJSObjectReference? _touchGesturesModule;
    private DotNetObjectReference<ChapterReview>? _dotNetRef;
    private List<SentenceReport> _errorSentencesList = new();
    private double? _pendingSeekTime;
    private double? _pendingKeyboardSeekTime;

    [Parameter] public string? ChapterName { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        // Ensure chapter is selected (opens handle if not already)
        if (!string.IsNullOrEmpty(ChapterName))
        {
            var decodedName = Uri.UnescapeDataString(ChapterName);
            if (!string.Equals(_lastRenderedChapter, decodedName, StringComparison.Ordinal))
            {
                _scrollToTopPending = true;
                _lastRenderedChapter = decodedName;
                _selectedErrorIndex = 0;
                _selectedSentenceId = null;
                _lastTimeBasedSentenceId = null;
                _lastPlaybackAlertSentenceId = null;
                _playbackNavigationIndex = null;
                _pendingSeekTime = null;
                _pendingKeyboardSeekTime = null;
                _isPlaybackAlertSettingsExpanded = false;
                _isSelectionModeActive = false;
                _selectedSentenceIds.Clear();
                _resumePlaybackOnSelectionExit = false;
                _lastSelectionGestureEvent = "chapter-reset";
                _lastLongPressDispatchAtUtc = DateTimeOffset.MinValue;
                _lastLongPressDispatchSentenceId = 0;
                _suppressedSelectionTapSentenceIds.Clear();
            }
            if (Workspace.CurrentChapterName != decodedName)
            {
                Workspace.SelectChapter(decodedName);
            }

            // Load sentences for this chapter
            await LoadSentencesAsync(decodedName);

            // Load proof report for errors view
            LoadReport(decodedName);

            // Load exported sentence IDs from CRX entries
            LoadExportedSentenceIds();

            // Load reviewed status (direct service call)
            _isReviewed = ReviewedStatusService.IsReviewed(decodedName);
            _playbackErrorAlertSoundSetting = Workspace.GetPlaybackErrorAlertSoundSetting();
        }

        _currentTime = 0;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);

            _keyboardModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/keyboard-shortcuts.js");
            await _keyboardModule.InvokeVoidAsync("init", _dotNetRef);

            _touchGesturesModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/touch-gestures.js");
            await _touchGesturesModule.InvokeVoidAsync("init", _dotNetRef);
        }

        if (_scrollToTopPending)
        {
            _scrollToTopPending = false;
            await JS.InvokeVoidAsync("eval", "document.querySelector('.workstation-content')?.scrollTo(0, 0)");
        }

    }

    private void LoadReport(string chapterName)
    {
        // Direct service call - NO HttpClient
        var hydrate = Workspace.CurrentChapterHandle?.Chapter.Documents.HydratedTranscript;
        if (hydrate != null)
        {
            _report = ProofReportService.BuildReport(chapterName, hydrate);
            _chapterPatterns = ErrorPatternService.AggregatePatternsForChapter(chapterName, hydrate, IgnoredPatternsService.GetIgnoredKeys()).Patterns;
            MaterializeErrorSentences();
        }
        else
        {
            _report = null;
            _chapterPatterns = null;
            MaterializeErrorSentences();
        }
    }

    private void LoadExportedSentenceIds()
    {
        try
        {
            var entries = CrxService.GetEntries();
            _exportedSentenceIds = entries
                .Where(e => e.SentenceId > 0)
                .Select(e => e.SentenceId)
                .ToHashSet();
        }
        catch
        {
            _exportedSentenceIds = new();
        }
    }

    private void MaterializeErrorSentences()
    {
        if (_report == null)
        {
            _errorSentencesList = new();
            _visibleErrorSentenceIds = new();
            return;
        }

        _errorSentencesList = _report.Sentences
            .Where(HasVisibleError)
            .OrderBy(s => s.Id)
            .ToList();
        _visibleErrorSentenceIds = _errorSentencesList
            .Select(sentence => sentence.Id)
            .ToHashSet();

        // Clamp index to prevent out-of-range after list shrinks (e.g., ignore pattern)
        if (_errorSentencesList.Count == 0)
            _selectedErrorIndex = 0;
        else if (_selectedErrorIndex >= _errorSentencesList.Count)
            _selectedErrorIndex = _errorSentencesList.Count - 1;
    }

    private void SwitchView(string view)
    {
        // Save position before switching
        if (_currentView == "playback")
        {
            SnapshotPlaybackPosition();
        }

        _currentView = view;
        StateHasChanged();
    }

    private void SwitchToErrorsFromMobileActionBar()
    {
        ApplyCrossNav("playback-to-errors", "mobile-action-errors");
    }

    private void SwitchToPlaybackFromMobileActionBar()
    {
        ApplyCrossNav("errors-to-playback", "mobile-action-playback");
    }

    private Task ToggleReviewedFromMobileActionBar()
    {
        ToggleReviewed();
        return Task.CompletedTask;
    }

    private Task ExportSelectionFromMobileActionBarAsync()
    {
        var anchorSentenceId = ResolveSelectionActionAnchorSentenceId();
        return HandleSelectionSwipeRightAsync(anchorSentenceId, $"mobile-action-bar-{CurrentMobileActionSurface}");
    }

    private Task IgnoreSelectionFromMobileActionBarAsync()
    {
        var anchorSentenceId = ResolveSelectionActionAnchorSentenceId();
        return HandleSelectionSwipeLeftAsync(anchorSentenceId, $"mobile-action-bar-{CurrentMobileActionSurface}");
    }

    private async Task ToggleSelectionModeFallbackAsync()
    {
        var anchorSentenceId = ResolveSelectionActionAnchorSentenceId();
        if (anchorSentenceId <= 0)
        {
            anchorSentenceId = ResolveFallbackSelectionSentenceId();
        }

        if (_isSelectionModeActive)
        {
            await ClearSelectionModeAndResumeAsync(anchorSentenceId, "fallback-selection-toggle");
            return;
        }

        await EnterSelectionModeAsync(anchorSentenceId, "fallback-selection-toggle");
    }

    private int ResolveFallbackSelectionSentenceId()
    {
        if (_currentView == "errors" && _errorSentencesList.Count > 0)
        {
            var clampedIndex = Math.Clamp(_selectedErrorIndex, 0, _errorSentencesList.Count - 1);
            return _errorSentencesList[clampedIndex].Id;
        }

        return ResolvePlaybackSelectionSentenceId() ?? 0;
    }

    private async Task ToggleModulesFromMobileActionBarAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("eval", $"document.getElementById('{MobileModuleRailToggleElementId}')?.click();");
            LogSelectionModeDiagnostic("mobile-action-modules-toggle", "mobile-action-modules", ResolveSelectionActionAnchorSentenceId(), $"view={_currentView}");
        }
        catch (JSDisconnectedException)
        {
            // Ignore disconnect races during navigation.
        }
        catch (Exception ex)
        {
            LogSelectionModeDiagnostic("mobile-action-modules-toggle-failed", "mobile-action-modules", ResolveSelectionActionAnchorSentenceId(), ex.Message);
        }
    }

    private int ResolveSelectionActionAnchorSentenceId()
    {
        if (_selectedSentenceId.HasValue && _selectedSentenceIds.Contains(_selectedSentenceId.Value))
        {
            return _selectedSentenceId.Value;
        }

        return _selectedSentenceIds
            .OrderBy(id => id)
            .FirstOrDefault();
    }

    private int? ResolvePlaybackSelectionSentenceId()
    {
        if (_selectedSentenceId.HasValue && _sentences.Any(sentence => sentence.Id == _selectedSentenceId.Value))
        {
            return _selectedSentenceId.Value;
        }

        if (_lastTimeBasedSentenceId.HasValue && _sentences.Any(sentence => sentence.Id == _lastTimeBasedSentenceId.Value))
        {
            return _lastTimeBasedSentenceId.Value;
        }

        var sentenceAtCurrentTime = _sentences.FirstOrDefault(sentence => _currentTime >= sentence.StartTime && _currentTime < sentence.EndTime);
        if (sentenceAtCurrentTime is not null)
        {
            return sentenceAtCurrentTime.Id;
        }

        return _sentences.Count > 0 ? _sentences[0].Id : null;
    }

    private bool TryResolveCrossNavPlaybackSentence(int? preferredSentenceId, out SentenceViewModel? sentence)
    {
        sentence = null;

        if (preferredSentenceId.HasValue)
        {
            sentence = _sentences.FirstOrDefault(candidate => candidate.Id == preferredSentenceId.Value);
        }

        if (sentence is null)
        {
            var fallbackSentenceId = ResolvePlaybackSelectionSentenceId();
            if (fallbackSentenceId.HasValue)
            {
                sentence = _sentences.FirstOrDefault(candidate => candidate.Id == fallbackSentenceId.Value);
            }
        }

        if (sentence is null && _sentences.Count > 0)
        {
            sentence = _sentences[0];
        }

        return sentence is not null;
    }

    private int ResolveCrossNavErrorIndex()
    {
        if (_errorSentencesList.Count == 0)
        {
            return 0;
        }

        var sentenceId = ResolvePlaybackSelectionSentenceId();
        if (sentenceId.HasValue)
        {
            var mappedIndex = _errorSentencesList.FindIndex(sentence => sentence.Id == sentenceId.Value);
            if (mappedIndex >= 0)
            {
                return mappedIndex;
            }
        }

        if (_selectedErrorIndex >= 0 && _selectedErrorIndex < _errorSentencesList.Count)
        {
            return _selectedErrorIndex;
        }

        return 0;
    }

    private void ApplyCrossNav(string direction, string trigger)
    {
        if (string.Equals(direction, "errors-to-playback", StringComparison.Ordinal))
        {
            int? preferredSentenceId = null;
            if (_errorSentencesList.Count > 0)
            {
                var clampedIndex = Math.Clamp(_selectedErrorIndex, 0, _errorSentencesList.Count - 1);
                preferredSentenceId = _errorSentencesList[clampedIndex].Id;
            }

            _currentView = "playback";

            if (TryResolveCrossNavPlaybackSentence(preferredSentenceId, out var playbackSentence) && playbackSentence is not null)
            {
                _selectedSentenceId = playbackSentence.Id;
                _playbackNavigationIndex = _sentences.FindIndex(sentence => sentence.Id == playbackSentence.Id);
                _pendingSeekTime = playbackSentence.StartTime;

                LogSelectionModeDiagnostic(
                    "cross-nav-errors-to-playback",
                    trigger,
                    playbackSentence.Id,
                    $"autoSelected=true;selectedCount={_selectedSentenceIds.Count}");
            }
            else
            {
                _selectedSentenceId = null;
                _playbackNavigationIndex = null;
                _pendingSeekTime = null;

                LogSelectionModeDiagnostic(
                    "cross-nav-errors-to-playback",
                    trigger,
                    0,
                    "autoSelected=false;reason=no-playback-sentences");
            }

            StateHasChanged();
            return;
        }

        if (string.Equals(direction, "playback-to-errors", StringComparison.Ordinal))
        {
            _currentView = "errors";
            _selectedErrorIndex = ResolveCrossNavErrorIndex();

            var selectedErrorSentenceId = _errorSentencesList.Count > 0
                ? _errorSentencesList[_selectedErrorIndex].Id
                : 0;

            LogSelectionModeDiagnostic(
                "cross-nav-playback-to-errors",
                trigger,
                selectedErrorSentenceId,
                $"autoSelected={_errorSentencesList.Count > 0};errorCount={_errorSentencesList.Count}");

            StateHasChanged();
            return;
        }

        LogSelectionModeDiagnostic("cross-nav-invalid-direction", trigger, 0, $"direction={direction}");
    }

    private void NavigateToPickups()
    {
        Navigation.NavigateTo(StageRouteCatalog.GetProofPickupsHandoffPath());
    }

    private void NavigateToPickupsFromMobileActionBar()
    {
        LogSelectionModeDiagnostic("mobile-action-pickups-navigate", "mobile-action-pickups", ResolveSelectionActionAnchorSentenceId(), $"view={_currentView}");
        NavigateToPickups();
    }

    private void SnapshotPlaybackPosition()
    {
        // If no explicit selection, find sentence containing current playback time
        if (!_selectedSentenceId.HasValue && _sentences.Count > 0)
        {
            var timeSentence = _sentences.FirstOrDefault(s => _currentTime >= s.StartTime && _currentTime < s.EndTime);
            if (timeSentence != null)
            {
                _selectedSentenceId = timeSentence.Id;
            }
        }
    }

    private async Task LoadSentencesAsync(string chapterName)
    {
        _sentences = await ChapterDataService.GetSentencesAsync(chapterName, IgnoredPatternsService.GetIgnoredKeys());
    }

    private string GetAudioUrl()
    {
        // Playback view must resolve through corrected-aware endpoint (corrected → treated → current).
        if (!string.IsNullOrWhiteSpace(ChapterName))
        {
            return $"/api/audio/chapter/{Uri.EscapeDataString(ChapterName)}/corrected";
        }

        return "/api/audio"; // Falls back to sample audio
    }

    private string? GetPeaksUrl()
    {
        if (string.IsNullOrWhiteSpace(ChapterName))
        {
            return null;
        }

        return $"/api/audio/chapter/{Uri.EscapeDataString(ChapterName)}/corrected/peaks?pxPerSec={PeakPxPerSec}";
    }

    private string GetDisplayTitle()
    {
        return Uri.UnescapeDataString(ChapterName ?? "Audio");
    }

    private async Task HandleTimeUpdate(double time)
    {
        _currentTime = time;

        var isPlaying = _waveformPlayer?.IsPlaying == true;
        if (!isPlaying)
        {
            // Keep manual keyboard selection stable while paused.
            return;
        }

        // Only re-render when the active sentence changes, not on every time tick.
        // This avoids flooding the Blazor render queue (~40 re-renders/sec).
        var activeSentence = _sentences.FirstOrDefault(s => time >= s.StartTime && time < s.EndTime);
        var newId = activeSentence?.Id;
        if (newId != _lastTimeBasedSentenceId)
        {
            _lastTimeBasedSentenceId = newId;
            _selectedSentenceId = null;
            _playbackNavigationIndex = newId.HasValue
                ? _sentences.FindIndex(sentence => sentence.Id == newId.Value)
                : null;

            // Only allow one alert per sentence while audio is actually playing.
            // Manual keyboard seeking should stay silent.
            if (newId.HasValue
                && _lastPlaybackAlertSentenceId.HasValue
                && newId.Value != _lastPlaybackAlertSentenceId.Value)
            {
                _lastPlaybackAlertSentenceId = null;
            }

            if (_currentView == "playback"
                && activeSentence is not null
                && _visibleErrorSentenceIds.Contains(activeSentence.Id)
                && _lastPlaybackAlertSentenceId != activeSentence.Id)
            {
                await TryPlayPlaybackErrorAlertAsync();
                _lastPlaybackAlertSentenceId = activeSentence.Id;
            }

            StateHasChanged();
        }
    }

    private async Task TryPlayPlaybackErrorAlertAsync()
    {
        var alertUrl = GetPlaybackErrorAlertUrl();
        if (string.IsNullOrWhiteSpace(alertUrl))
        {
            return;
        }

        try
        {
            _alertSoundPlayer ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/alert-sound-player.js");
            await _alertSoundPlayer.InvokeVoidAsync("play", alertUrl);
        }
        catch (JSDisconnectedException)
        {
            // Ignore disconnect races during navigation.
        }
        catch (Exception ex)
        {
            // Do not toast here to avoid spamming while playback continues.
            Console.WriteLine($"Failed to play playback error alert sound: {ex.Message}");
        }
    }

    private string? GetPlaybackErrorAlertUrl()
    {
        if (_playbackErrorAlertSoundSetting is null)
        {
            return null;
        }

        return $"/api/audio/alerts/playback-error?v={_playbackErrorAlertSoundSetting.UpdatedAtUtc.Ticks}";
    }

