@page "/proof/{ChapterName}"
@inject Ams.Workstation.Server.Services.BlazorWorkspace Workspace
@inject Ams.Workstation.Server.Services.ChapterDataService ChapterDataService
@inject Ams.Workstation.Server.Services.ProofReportService ProofReportService
@inject Ams.Workstation.Server.Services.ErrorPatternService ErrorPatternService
@inject Ams.Workstation.Server.Services.ReviewedStatusService ReviewedStatusService
@inject Ams.Workstation.Server.Services.AudioExportService AudioExportService
@inject Ams.Workstation.Server.Services.IgnoredPatternsService IgnoredPatternsService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using Ams.Workstation.Server.Models
@implements IAsyncDisposable

<PageTitle>@ChapterName - Proof - AMS Workstation</PageTitle>

<BitStack Horizontal="true" Gap="0.5rem" AutoHeight="true" HorizontalAlign="BitAlignment.Center" Style="margin-bottom: 1rem;">
    <BitButton Variant="@(_currentView == "errors" ? BitVariant.Fill : BitVariant.Outline)"
               OnClick="@(() => SwitchView("errors"))">
        Errors View
    </BitButton>
    <BitButton Variant="@(_currentView == "playback" ? BitVariant.Fill : BitVariant.Outline)"
               OnClick="@(() => SwitchView("playback"))">
        Playback View
    </BitButton>
    <BitButton Variant="@(_isReviewed ? BitVariant.Fill : BitVariant.Outline)"
               Color="@(_isReviewed ? BitColor.Success : BitColor.Primary)"
               OnClick="ToggleReviewed">
        @(_isReviewed ? "Reviewed" : "Mark as Reviewed")
    </BitButton>
</BitStack>

@if (_currentView == "playback")
{
    <BitGrid Columns="12">
        <BitGridItem ColumnSpan="12" style="min-width: 0;">
                <WaveformPlayer
                    @ref="_waveformPlayer"
                    AudioUrl="@GetAudioUrl()"
                    Title="@GetDisplayTitle()"
                    TimeUpdated="HandleTimeUpdate"
                    OnReady="HandleWaveformReady"
                    OnSeek="HandleSeek"
                    OnFinished="HandlePlaybackFinished"/>
        </BitGridItem>
        <BitGridItem ColumnSpan="12">
            <SentenceList
                Sentences="@_sentences"
                CurrentTime="@_currentTime"
                ActiveSentenceId="@_selectedSentenceId"
                OnSentenceSelected="HandleSentenceSelected" />
        </BitGridItem>
    </BitGrid>
}
else
{
    <ErrorsView Report="_report" ChapterPatterns="_chapterPatterns"
                IgnoredKeys="IgnoredPatternsService.GetIgnoredKeys()"
                SelectedIndex="_selectedErrorIndex"
                OnPlaySentence="HandlePlayFromErrors"
                OnExportSentence="HandleExportFromErrors"
                OnCrxSentence="HandleCrxFromErrors"
                OnIgnoreSentence="HandleIgnoreFromErrors"
                OnTogglePatternIgnore="HandleTogglePatternIgnore"
                OnViewSentence="HandleViewFromErrors" />
}

@if (!string.IsNullOrEmpty(_exportMessage))
{
    <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground"
             Style="text-align: center; padding: 0.5rem;">
        @_exportMessage
    </BitText>
}

<CrxModal @ref="_crxModal" OnSubmitted="HandleCrxSubmitted" />


@code {
    private double _currentTime;
    private bool _isWaveformReady;
    private WaveformPlayer? _waveformPlayer;
    private List<SentenceViewModel> _sentences = new();
    private string _currentView = "playback";
    private ChapterReport? _report;
    private IReadOnlyList<ErrorPattern>? _chapterPatterns;
    private bool _isReviewed;
    private CrxModal? _crxModal;
    private string? _exportMessage;
    private IJSObjectReference? _snippetPlayer;
    private string? _lastRenderedChapter;
    private bool _scrollToTopPending;

    // Keyboard navigation state
    private int _selectedErrorIndex;
    private int? _selectedSentenceId;
    private IJSObjectReference? _keyboardModule;
    private DotNetObjectReference<ChapterReview>? _dotNetRef;
    private List<SentenceReport> _errorSentencesList = new();

    [Parameter] public string? ChapterName { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        // Ensure chapter is selected (opens handle if not already)
        if (!string.IsNullOrEmpty(ChapterName))
        {
            var decodedName = Uri.UnescapeDataString(ChapterName);
            if (!string.Equals(_lastRenderedChapter, decodedName, StringComparison.Ordinal))
            {
                _scrollToTopPending = true;
                _lastRenderedChapter = decodedName;
                _selectedErrorIndex = 0;
                _selectedSentenceId = null;
            }
            if (Workspace.CurrentChapterName != decodedName)
            {
                Workspace.SelectChapter(decodedName);
            }

            // Load sentences for this chapter
            await LoadSentencesAsync(decodedName);

            // Load proof report for errors view
            LoadReport(decodedName);

            // Load reviewed status (direct service call)
            _isReviewed = ReviewedStatusService.IsReviewed(decodedName);
        }

        // Reset waveform ready state when chapter changes
        _isWaveformReady = false;
        _currentTime = 0;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            _keyboardModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/keyboard-shortcuts.js");
            await _keyboardModule.InvokeVoidAsync("init", _dotNetRef);
        }

        if (_scrollToTopPending)
        {
            _scrollToTopPending = false;
            await JS.InvokeVoidAsync("eval", "document.querySelector('.workstation-content')?.scrollTo(0, 0)");
        }
    }

    private void LoadReport(string chapterName)
    {
        // Direct service call - NO HttpClient
        var hydrate = Workspace.CurrentChapterHandle?.Chapter.Documents.HydratedTranscript;
        if (hydrate != null)
        {
            _report = ProofReportService.BuildReport(chapterName, hydrate);
            _chapterPatterns = ErrorPatternService.AggregatePatternsForChapter(chapterName, hydrate, IgnoredPatternsService.GetIgnoredKeys()).Patterns;
            MaterializeErrorSentences();
        }
    }

    private void MaterializeErrorSentences()
    {
        if (_report == null)
        {
            _errorSentencesList = new();
            return;
        }

        _errorSentencesList = _report.Sentences
            .Where(HasVisibleError)
            .OrderByDescending(s => ParseWer(s.Wer))
            .ThenBy(s => s.Id)
            .ToList();

        // Clamp index to prevent out-of-range after list shrinks (e.g., ignore pattern)
        if (_errorSentencesList.Count == 0)
            _selectedErrorIndex = 0;
        else if (_selectedErrorIndex >= _errorSentencesList.Count)
            _selectedErrorIndex = _errorSentencesList.Count - 1;
    }

    private void SwitchView(string view)
    {
        // Save position before switching
        if (_currentView == "playback")
        {
            SnapshotPlaybackPosition();
        }

        _currentView = view;
        StateHasChanged();
    }

    private void SnapshotPlaybackPosition()
    {
        // If no explicit selection, find sentence containing current playback time
        if (!_selectedSentenceId.HasValue && _sentences.Count > 0)
        {
            var timeSentence = _sentences.FirstOrDefault(s => _currentTime >= s.StartTime && _currentTime < s.EndTime);
            if (timeSentence != null)
            {
                _selectedSentenceId = timeSentence.Id;
            }
        }
    }

    private async Task LoadSentencesAsync(string chapterName)
    {
        _sentences = await ChapterDataService.GetSentencesAsync(chapterName, IgnoredPatternsService.GetIgnoredKeys());
    }

    private string GetAudioUrl()
    {
        // Use the chapter endpoint to stream from AudioBuffer
        if (!string.IsNullOrEmpty(ChapterName))
        {
            return $"/api/audio/chapter/{Uri.EscapeDataString(ChapterName)}";
        }

        return "/api/audio"; // Falls back to sample audio
    }

    private string GetDisplayTitle()
    {
        return Uri.UnescapeDataString(ChapterName ?? "Audio");
    }

    private void HandleTimeUpdate(double time)
    {
        _currentTime = time;
        _selectedSentenceId = null;
        StateHasChanged();
    }

    private void HandleWaveformReady()
    {
        _isWaveformReady = true;
        StateHasChanged();
    }

    private void HandleSeek(double time)
    {
        _currentTime = time;
    }

    private void HandlePlaybackFinished()
    {
        // Could add logic here for auto-advance to next chapter
    }

    private async Task HandleSentenceSelected(SentenceViewModel sentence)
    {
        _selectedSentenceId = sentence.Id;
        // Seek waveform to the start time of the selected sentence
        if (_waveformPlayer != null)
        {
            await _waveformPlayer.SeekTo(sentence.StartTime);
        }
    }

    private async Task HandlePlayFromErrors(SentenceReport sentence)
    {
        _snippetPlayer ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/snippet-player.js");
        if (string.IsNullOrEmpty(ChapterName))
        {
            return;
        }

        var chapter = Uri.EscapeDataString(ChapterName);
        var start = sentence.StartTime.ToString(System.Globalization.CultureInfo.InvariantCulture);
        var end = sentence.EndTime.ToString(System.Globalization.CultureInfo.InvariantCulture);
        var url = $"/api/audio/chapter/{chapter}?start={start}&end={end}";
        await _snippetPlayer.InvokeVoidAsync("playSegment", url);
    }

    private void ToggleReviewed()
    {
        if (string.IsNullOrEmpty(ChapterName)) return;
        var decoded = Uri.UnescapeDataString(ChapterName);
        _isReviewed = !_isReviewed;
        ReviewedStatusService.SetReviewed(decoded, _isReviewed);
        StateHasChanged();
    }

    private void HandleExportFromErrors(SentenceReport sentence)
    {
        if (string.IsNullOrEmpty(ChapterName)) return;
        try
        {
            var result = AudioExportService.ExportSegment(sentence.StartTime, sentence.EndTime);
            _exportMessage = $"Exported: {result.Filename}";
        }
        catch (Exception ex)
        {
            _exportMessage = $"Export failed: {ex.Message}";
        }
        StateHasChanged();
    }

    private void HandleCrxFromErrors(SentenceReport sentence)
    {
        if (string.IsNullOrEmpty(ChapterName)) return;
        var decoded = Uri.UnescapeDataString(ChapterName);
        _crxModal?.Open(decoded, sentence.StartTime, sentence.EndTime, sentence.Id, sentence.Excerpt, sentence);
    }

    private void HandleCrxSubmitted(CrxSubmitResult result)
    {
        if (result.Success)
        {
            _exportMessage = $"CRX #{result.ErrorNumber} added ({result.AudioFile})";
        }
        else
        {
            _exportMessage = $"CRX failed: {result.Error}";
        }
        StateHasChanged();
    }

    private async Task HandleIgnoreFromErrors(SentenceReport sentence)
    {
        if (sentence.Diff?.Ops is null) return;

        var ops = sentence.Diff.Ops.ToList();
        var count = 0;
        for (int i = 0; i < ops.Count; i++)
        {
            var op = ops[i];
            if (op.Op == "delete")
            {
                var bookText = string.Join(" ", op.Tokens);
                if (i + 1 < ops.Count && ops[i + 1].Op == "insert")
                {
                    var scriptText = string.Join(" ", ops[i + 1].Tokens);
                    IgnoredPatternsService.SetIgnored(Services.ErrorPatternService.BuildKey("sub", bookText, scriptText), true);
                    count++;
                    i++;
                }
                else
                {
                    IgnoredPatternsService.SetIgnored(Services.ErrorPatternService.BuildKey("del", bookText, ""), true);
                    count++;
                }
            }
            else if (op.Op == "insert")
            {
                var scriptText = string.Join(" ", op.Tokens);
                IgnoredPatternsService.SetIgnored(Services.ErrorPatternService.BuildKey("ins", "", scriptText), true);
                count++;
            }
        }

        if (count > 0)
        {
            var decoded = Uri.UnescapeDataString(ChapterName!);
            LoadReport(decoded);
            await LoadSentencesAsync(decoded);
            _exportMessage = $"Ignored {count} error pattern{(count == 1 ? "" : "s")} for entire book.";
        }
        StateHasChanged();
    }

    private void HandleTogglePatternIgnore(ErrorPattern pattern)
    {
        IgnoredPatternsService.ToggleIgnored(pattern.Key);

        // Refresh report + patterns so the UI immediately reflects the change
        if (!string.IsNullOrEmpty(ChapterName))
            LoadReport(Uri.UnescapeDataString(ChapterName));

        StateHasChanged();
    }

    private async Task HandleViewFromErrors(SentenceReport sentence)
    {
        _currentView = "playback";
        var target = _sentences.FirstOrDefault(s => s.Id == sentence.Id);
        if (target != null && _waveformPlayer != null)
            await _waveformPlayer.SeekTo(target.StartTime);
        StateHasChanged();
    }

    // ── Keyboard JSInvokable handlers ──

    [JSInvokable]
    public void OnSwitchView(string direction)
    {
        // Save current position
        if (_currentView == "playback")
        {
            SnapshotPlaybackPosition();
        }

        // Toggle between the two views
        _currentView = _currentView == "errors" ? "playback" : "errors";
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnNavigateItem(string direction)
    {
        if (_currentView == "errors")
        {
            if (_errorSentencesList.Count == 0) return;
            if (direction == "prev")
                _selectedErrorIndex = Math.Max(0, _selectedErrorIndex - 1);
            else
                _selectedErrorIndex = Math.Min(_errorSentencesList.Count - 1, _selectedErrorIndex + 1);
        }
        else
        {
            if (_sentences.Count == 0) return;

            int currentIndex = _sentences.FindIndex(s => _currentTime >= s.StartTime && _currentTime < s.EndTime);
            if (currentIndex < 0) currentIndex = 0;

            if (direction == "prev")
                currentIndex = Math.Max(0, currentIndex - 1);
            else
                currentIndex = Math.Min(_sentences.Count - 1, currentIndex + 1);

            // Seek the waveform — time-sync handles highlighting from here
            if (_waveformPlayer != null)
                await _waveformPlayer.SeekTo(_sentences[currentIndex].StartTime);
        }
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnCrossNav(string direction)
    {
        if (direction == "errors-to-playback")
        {
            if (_errorSentencesList.Count == 0) return;
            var errorSentence = _errorSentencesList[_selectedErrorIndex];
            _currentView = "playback";

            var sentence = _sentences.FirstOrDefault(s => s.Id == errorSentence.Id);
            if (sentence != null && _waveformPlayer != null)
                await _waveformPlayer.SeekTo(sentence.StartTime);
        }
        else // playback-to-errors
        {
            // Get current sentence Id
            int? sentenceId = _selectedSentenceId;
            if (!sentenceId.HasValue && _sentences.Count > 0)
            {
                var timeSentence = _sentences.FirstOrDefault(s => _currentTime >= s.StartTime && _currentTime < s.EndTime);
                sentenceId = timeSentence?.Id;
            }

            _currentView = "errors";

            if (sentenceId.HasValue)
            {
                var errorIndex = _errorSentencesList.FindIndex(s => s.Id == sentenceId.Value);
                if (errorIndex >= 0)
                {
                    _selectedErrorIndex = errorIndex;
                }
                // If not found, keep existing _selectedErrorIndex (saved position fallback)
            }
        }
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnSpacebar()
    {
        if (_currentView == "errors")
        {
            if (_errorSentencesList.Count == 0) return;
            var sentence = _errorSentencesList[_selectedErrorIndex];
            await HandlePlayFromErrors(sentence);
        }
        else
        {
            if (_waveformPlayer != null)
                await _waveformPlayer.PlayPause();
        }
    }

    [JSInvokable]
    public void OnToggleReviewed()
    {
        ToggleReviewed();
    }

    [JSInvokable]
    public void OnOpenCrx()
    {
        if (_currentView != "errors" || _errorSentencesList.Count == 0) return;
        var sentence = _errorSentencesList[_selectedErrorIndex];
        HandleCrxFromErrors(sentence);
    }

    [JSInvokable]
    public void OnModalClose()
    {
        _crxModal?.Close();
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnModalSubmit()
    {
        if (_crxModal != null)
        {
            await _crxModal.SubmitAsync();
        }
    }

    // ── Error visibility logic (copied from ErrorsView for indexing) ──

    private bool HasVisibleError(SentenceReport sentence)
    {
        if (HasVisibleDiffOps(sentence.Diff, IgnoredPatternsService.GetIgnoredKeys()))
        {
            return true;
        }

        if (sentence.Diff?.Ops is null || sentence.Diff.Ops.Count == 0)
        {
            return !string.Equals(sentence.Status, "ok", StringComparison.OrdinalIgnoreCase);
        }

        return false;
    }

    private static bool HasVisibleDiffOps(DiffReport? diff, IReadOnlySet<string>? ignoredKeys)
    {
        if (diff?.Ops is null || diff.Ops.Count == 0)
        {
            return false;
        }

        if (ignoredKeys is null || ignoredKeys.Count == 0)
        {
            return diff.Ops.Any(op => op.Op != "equal");
        }

        var ops = diff.Ops.ToList();
        for (var i = 0; i < ops.Count; i++)
        {
            var op = ops[i];
            if (string.Equals(op.Op, "equal", StringComparison.Ordinal))
            {
                continue;
            }

            if (string.Equals(op.Op, "delete", StringComparison.Ordinal))
            {
                var bookText = string.Join(" ", op.Tokens);
                if (i + 1 < ops.Count && string.Equals(ops[i + 1].Op, "insert", StringComparison.Ordinal))
                {
                    var scriptText = string.Join(" ", ops[i + 1].Tokens);
                    if (!ignoredKeys.Contains(Services.ErrorPatternService.BuildKey("sub", bookText, scriptText)))
                    {
                        return true;
                    }

                    i++;
                }
                else
                {
                    if (!ignoredKeys.Contains(Services.ErrorPatternService.BuildKey("del", bookText, string.Empty)))
                    {
                        return true;
                    }
                }
            }
            else if (string.Equals(op.Op, "insert", StringComparison.Ordinal))
            {
                var scriptText = string.Join(" ", op.Tokens);
                if (!ignoredKeys.Contains(Services.ErrorPatternService.BuildKey("ins", string.Empty, scriptText)))
                {
                    return true;
                }
            }
        }

        return false;
    }

    private static double ParseWer(string wer)
    {
        if (double.TryParse(wer.TrimEnd('%'), out var v)) return v;
        return 0;
    }

    private static string FormatTime(double seconds)
    {
        if (double.IsNaN(seconds) || double.IsInfinity(seconds)) return "0:00.000";
        var mins = (int)(seconds / 60);
        var secs = (int)(seconds % 60);
        var ms = (int)((seconds % 1) * 1000);
        return $"{mins}:{secs:D2}.{ms:D3}";
    }

    public async ValueTask DisposeAsync()
    {
        if (_keyboardModule is not null)
        {
            try
            {
                await _keyboardModule.InvokeVoidAsync("dispose");
                await _keyboardModule.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
        }
        _dotNetRef?.Dispose();

        if (_snippetPlayer is not null)
        {
            try
            {
                await _snippetPlayer.InvokeVoidAsync("dispose");
                await _snippetPlayer.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
        }
    }

}
