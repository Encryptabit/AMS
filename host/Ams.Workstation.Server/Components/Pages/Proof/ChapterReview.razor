@page "/proof/{ChapterName}"
@page "/proof/editing/{ChapterName}"
@inject Ams.Workstation.Server.Services.BlazorWorkspace Workspace
@inject Ams.Workstation.Server.Services.ChapterDataService ChapterDataService
@inject Ams.Workstation.Server.Services.ProofReportService ProofReportService
@inject Ams.Workstation.Server.Services.ErrorPatternService ErrorPatternService
@inject Ams.Workstation.Server.Services.ReviewedStatusService ReviewedStatusService
@inject Ams.Workstation.Server.Services.AudioExportService AudioExportService
@inject Ams.Workstation.Server.Services.IgnoredPatternsService IgnoredPatternsService
@inject Ams.Workstation.Server.Services.ToastService ToastService
@inject Ams.Workstation.Server.Services.CrxService CrxService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using Ams.Workstation.Server.Components.Navigation
@using Ams.Workstation.Server.Models
@using Ams.Core.Runtime.Audio
@using Ams.Workstation.Server.Components.UI
@implements IAsyncDisposable

<PageTitle>@ChapterName - Proof - AMS Workstation</PageTitle>

<div class="proof-review">
    <div class="proof-view-switcher" data-ams-proof="view-switcher">
        <AmsButton Variant="@(_currentView == "errors" ? "primary" : "secondary")"
                   OnClick="@(() => SwitchView("errors"))">
            Errors View
        </AmsButton>
        <AmsButton Variant="@(_currentView == "playback" ? "primary" : "secondary")"
                   OnClick="@(() => SwitchView("playback"))">
            Playback View
        </AmsButton>
        <AmsButton Variant="@(_isReviewed ? "primary" : "secondary")"
                   OnClick="ToggleReviewed">
            @(_isReviewed ? "Reviewed" : "Mark as Reviewed")
        </AmsButton>
        <span data-proof-editing-handoff="pickups">
            <AmsButton Variant="secondary"
                       OnClick="NavigateToPickups">
                Pickups
            </AmsButton>
        </span>
    </div>

    @if (_currentView == "playback")
    {
        <div class="proof-playback-grid">
            <div class="proof-playback-grid-item proof-playback-grid-item--span-12">
                <section class="ams-card playback-alert-settings" data-ams-proof="alert-sound-card">
                    <div class="proof-alert-settings__controls">
                        <input type="text"
                               class="ams-input"
                               value="@_playbackErrorAlertSourcePath"
                               @oninput="@(e => _playbackErrorAlertSourcePath = e.Value?.ToString() ?? string.Empty)"
                               placeholder="Alert sound file path (.wav, .mp3, .ogg, .flac, .m4a)" />
                        <AmsButton Variant="primary"
                                   OnClick="SavePlaybackErrorAlertSound">
                            Save Alert Sound
                        </AmsButton>
                        <AmsButton Variant="secondary"
                                   Disabled="@(_playbackErrorAlertSoundSetting is null)"
                                   OnClick="ClearPlaybackErrorAlertSound">
                            Clear
                        </AmsButton>
                    </div>
                    <span class="playback-alert-status ams-caption ams-caption--muted">
                        @GetPlaybackErrorAlertStatusText()
                    </span>
                </section>
            </div>
            <div class="proof-playback-grid-item proof-playback-grid-item--span-12 proof-playback-grid-item--player">
                <WaveformPlayer
                    @ref="_waveformPlayer"
                    AudioUrl="@GetAudioUrl()"
                    PeaksUrl="@GetPeaksUrl()"
                    Title="@GetDisplayTitle()"
                    TimeUpdated="HandleTimeUpdate"
                    OnReady="HandleWaveformReady"
                    OnSeek="HandleSeek"
                    OnFinished="HandlePlaybackFinished"/>
            </div>
            <div class="proof-playback-grid-item proof-playback-grid-item--span-12">
                <SentenceList
                    Sentences="@_sentences"
                    CurrentTime="@_currentTime"
                    ActiveSentenceId="@_selectedSentenceId"
                    OnSentenceSelected="HandleSentenceSelected" />
            </div>
        </div>
    }
    else
    {
        <ErrorsView Report="_report" ChapterPatterns="_chapterPatterns"
                    IgnoredKeys="IgnoredPatternsService.GetIgnoredKeys()"
                    ExportedSentenceIds="_exportedSentenceIds"
                    SelectedIndex="_selectedErrorIndex"
                    OnPlaySentence="HandlePlayFromErrors"
                    OnExportSentence="HandleExportFromErrors"
                    OnCrxSentence="HandleCrxFromErrors"
                    OnIgnoreSentence="HandleIgnoreFromErrors"
                    OnTogglePatternIgnore="HandleTogglePatternIgnore"
                    OnViewSentence="HandleViewFromErrors" />
    }

    <CrxModal @ref="_crxModal" OnSubmitted="HandleCrxSubmitted" />
    <IgnoreErrorModal @ref="_ignoreModal" OnSubmitted="HandleIgnoreModalSubmitted" />
</div>
@code {
    private const int PeakPxPerSec = 1200;
    private double _currentTime;
    private WaveformPlayer? _waveformPlayer;
    private List<SentenceViewModel> _sentences = new();
    private string _currentView = "playback";
    private ChapterReport? _report;
    private IReadOnlyList<ErrorPattern>? _chapterPatterns;
    private bool _isReviewed;
    private CrxModal? _crxModal;
    private IgnoreErrorModal? _ignoreModal;
    private HashSet<int> _exportedSentenceIds = new();
    private HashSet<int> _visibleErrorSentenceIds = new();
    private IJSObjectReference? _snippetPlayer;
    private IJSObjectReference? _alertSoundPlayer;
    private string _playbackErrorAlertSourcePath = string.Empty;
    private AppPlaybackAlertSoundSettings? _playbackErrorAlertSoundSetting;
    private string? _lastRenderedChapter;
    private bool _scrollToTopPending;

    // Keyboard navigation state
    private int _selectedErrorIndex;
    private int? _selectedSentenceId;
    private int? _lastTimeBasedSentenceId;
    private int? _lastPlaybackAlertSentenceId;
    private int? _playbackNavigationIndex;
    private IJSObjectReference? _keyboardModule;
    private DotNetObjectReference<ChapterReview>? _dotNetRef;
    private List<SentenceReport> _errorSentencesList = new();
    private double? _pendingSeekTime;
    private double? _pendingKeyboardSeekTime;

    [Parameter] public string? ChapterName { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        // Ensure chapter is selected (opens handle if not already)
        if (!string.IsNullOrEmpty(ChapterName))
        {
            var decodedName = Uri.UnescapeDataString(ChapterName);
            if (!string.Equals(_lastRenderedChapter, decodedName, StringComparison.Ordinal))
            {
                _scrollToTopPending = true;
                _lastRenderedChapter = decodedName;
                _selectedErrorIndex = 0;
                _selectedSentenceId = null;
                _lastTimeBasedSentenceId = null;
                _lastPlaybackAlertSentenceId = null;
                _playbackNavigationIndex = null;
                _pendingSeekTime = null;
                _pendingKeyboardSeekTime = null;
            }
            if (Workspace.CurrentChapterName != decodedName)
            {
                Workspace.SelectChapter(decodedName);
            }

            // Load sentences for this chapter
            await LoadSentencesAsync(decodedName);

            // Load proof report for errors view
            LoadReport(decodedName);

            // Load exported sentence IDs from CRX entries
            LoadExportedSentenceIds();

            // Load reviewed status (direct service call)
            _isReviewed = ReviewedStatusService.IsReviewed(decodedName);
            _playbackErrorAlertSoundSetting = Workspace.GetPlaybackErrorAlertSoundSetting();
        }

        _currentTime = 0;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            _keyboardModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/keyboard-shortcuts.js");
            await _keyboardModule.InvokeVoidAsync("init", _dotNetRef);
        }

        if (_scrollToTopPending)
        {
            _scrollToTopPending = false;
            await JS.InvokeVoidAsync("eval", "document.querySelector('.workstation-content')?.scrollTo(0, 0)");
        }

    }

    private void LoadReport(string chapterName)
    {
        // Direct service call - NO HttpClient
        var hydrate = Workspace.CurrentChapterHandle?.Chapter.Documents.HydratedTranscript;
        if (hydrate != null)
        {
            _report = ProofReportService.BuildReport(chapterName, hydrate);
            _chapterPatterns = ErrorPatternService.AggregatePatternsForChapter(chapterName, hydrate, IgnoredPatternsService.GetIgnoredKeys()).Patterns;
            MaterializeErrorSentences();
        }
        else
        {
            _report = null;
            _chapterPatterns = null;
            MaterializeErrorSentences();
        }
    }

    private void LoadExportedSentenceIds()
    {
        try
        {
            var entries = CrxService.GetEntries();
            _exportedSentenceIds = entries
                .Where(e => e.SentenceId > 0)
                .Select(e => e.SentenceId)
                .ToHashSet();
        }
        catch
        {
            _exportedSentenceIds = new();
        }
    }

    private void MaterializeErrorSentences()
    {
        if (_report == null)
        {
            _errorSentencesList = new();
            _visibleErrorSentenceIds = new();
            return;
        }

        _errorSentencesList = _report.Sentences
            .Where(HasVisibleError)
            .OrderBy(s => s.Id)
            .ToList();
        _visibleErrorSentenceIds = _errorSentencesList
            .Select(sentence => sentence.Id)
            .ToHashSet();

        // Clamp index to prevent out-of-range after list shrinks (e.g., ignore pattern)
        if (_errorSentencesList.Count == 0)
            _selectedErrorIndex = 0;
        else if (_selectedErrorIndex >= _errorSentencesList.Count)
            _selectedErrorIndex = _errorSentencesList.Count - 1;
    }

    private void SwitchView(string view)
    {
        // Save position before switching
        if (_currentView == "playback")
        {
            SnapshotPlaybackPosition();
        }

        _currentView = view;
        StateHasChanged();
    }

    private void NavigateToPickups()
    {
        Navigation.NavigateTo(StageRouteCatalog.GetProofPickupsHandoffPath());
    }

    private void SnapshotPlaybackPosition()
    {
        // If no explicit selection, find sentence containing current playback time
        if (!_selectedSentenceId.HasValue && _sentences.Count > 0)
        {
            var timeSentence = _sentences.FirstOrDefault(s => _currentTime >= s.StartTime && _currentTime < s.EndTime);
            if (timeSentence != null)
            {
                _selectedSentenceId = timeSentence.Id;
            }
        }
    }

    private async Task LoadSentencesAsync(string chapterName)
    {
        _sentences = await ChapterDataService.GetSentencesAsync(chapterName, IgnoredPatternsService.GetIgnoredKeys());
    }

    private string GetAudioUrl()
    {
        // Playback view must resolve through corrected-aware endpoint (corrected → treated → current).
        if (!string.IsNullOrWhiteSpace(ChapterName))
        {
            return $"/api/audio/chapter/{Uri.EscapeDataString(ChapterName)}/corrected";
        }

        return "/api/audio"; // Falls back to sample audio
    }

    private string? GetPeaksUrl()
    {
        if (string.IsNullOrWhiteSpace(ChapterName))
        {
            return null;
        }

        return $"/api/audio/chapter/{Uri.EscapeDataString(ChapterName)}/corrected/peaks?pxPerSec={PeakPxPerSec}";
    }

    private string GetDisplayTitle()
    {
        return Uri.UnescapeDataString(ChapterName ?? "Audio");
    }

    private async Task HandleTimeUpdate(double time)
    {
        _currentTime = time;

        var isPlaying = _waveformPlayer?.IsPlaying == true;
        if (!isPlaying)
        {
            // Keep manual keyboard selection stable while paused.
            return;
        }

        // Only re-render when the active sentence changes, not on every time tick.
        // This avoids flooding the Blazor render queue (~40 re-renders/sec).
        var activeSentence = _sentences.FirstOrDefault(s => time >= s.StartTime && time < s.EndTime);
        var newId = activeSentence?.Id;
        if (newId != _lastTimeBasedSentenceId)
        {
            _lastTimeBasedSentenceId = newId;
            _selectedSentenceId = null;
            _playbackNavigationIndex = newId.HasValue
                ? _sentences.FindIndex(sentence => sentence.Id == newId.Value)
                : null;

            // Only allow one alert per sentence while audio is actually playing.
            // Manual keyboard seeking should stay silent.
            if (newId.HasValue
                && _lastPlaybackAlertSentenceId.HasValue
                && newId.Value != _lastPlaybackAlertSentenceId.Value)
            {
                _lastPlaybackAlertSentenceId = null;
            }

            if (_currentView == "playback"
                && activeSentence is not null
                && _visibleErrorSentenceIds.Contains(activeSentence.Id)
                && _lastPlaybackAlertSentenceId != activeSentence.Id)
            {
                await TryPlayPlaybackErrorAlertAsync();
                _lastPlaybackAlertSentenceId = activeSentence.Id;
            }

            StateHasChanged();
        }
    }

    private async Task TryPlayPlaybackErrorAlertAsync()
    {
        var alertUrl = GetPlaybackErrorAlertUrl();
        if (string.IsNullOrWhiteSpace(alertUrl))
        {
            return;
        }

        try
        {
            _alertSoundPlayer ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/alert-sound-player.js");
            await _alertSoundPlayer.InvokeVoidAsync("play", alertUrl);
        }
        catch (JSDisconnectedException)
        {
            // Ignore disconnect races during navigation.
        }
        catch (Exception ex)
        {
            // Do not toast here to avoid spamming while playback continues.
            Console.WriteLine($"Failed to play playback error alert sound: {ex.Message}");
        }
    }

    private string? GetPlaybackErrorAlertUrl()
    {
        if (_playbackErrorAlertSoundSetting is null)
        {
            return null;
        }

        return $"/api/audio/alerts/playback-error?v={_playbackErrorAlertSoundSetting.UpdatedAtUtc.Ticks}";
    }

    private void SavePlaybackErrorAlertSound()
    {
        var sourcePath = _playbackErrorAlertSourcePath?.Trim();
        if (string.IsNullOrWhiteSpace(sourcePath))
        {
            ToastService.Warning("Enter a local sound file path before saving.");
            return;
        }

        try
        {
            _playbackErrorAlertSoundSetting = Workspace.SetPlaybackErrorAlertSound(sourcePath);
            _playbackErrorAlertSourcePath = string.Empty;
            ToastService.Success($"Playback alert sound saved: {_playbackErrorAlertSoundSetting.SourceFileName}");
        }
        catch (Exception ex)
        {
            ToastService.Error($"Failed to save playback alert sound: {ex.Message}");
        }
    }

    private void ClearPlaybackErrorAlertSound()
    {
        try
        {
            Workspace.ClearPlaybackErrorAlertSound();
            _playbackErrorAlertSoundSetting = null;
            ToastService.Info("Playback alert sound cleared.");
        }
        catch (Exception ex)
        {
            ToastService.Error($"Failed to clear playback alert sound: {ex.Message}");
        }
    }

    private string GetPlaybackErrorAlertStatusText()
    {
        if (_playbackErrorAlertSoundSetting is null)
        {
            return "No app-level playback alert sound is configured. Set one to hear a notification when playback reaches an error sentence.";
        }

        return $"Current app-level alert sound: {_playbackErrorAlertSoundSetting.SourceFileName}";
    }

    private async Task HandleWaveformReady()
    {
        if (_pendingSeekTime.HasValue && _waveformPlayer != null)
        {
            var seekTime = _pendingSeekTime.Value;
            _pendingSeekTime = null;
            await _waveformPlayer.SeekTo(seekTime);
        }

        StateHasChanged();
    }

    private void HandleSeek(double time)
    {
        _currentTime = time;

        if (_pendingKeyboardSeekTime.HasValue)
        {
            // wavesurfer may emit an intermediate seeking callback at the pre-seek time.
            // Ignore that transient value and wait until the target seek time is reached.
            if (Math.Abs(time - _pendingKeyboardSeekTime.Value) <= 0.05)
            {
                _pendingKeyboardSeekTime = null;
            }

            StateHasChanged();
            return;
        }

        if (_playbackNavigationIndex.HasValue
            && _playbackNavigationIndex.Value >= 0
            && _playbackNavigationIndex.Value < _sentences.Count)
        {
            var navigationSentence = _sentences[_playbackNavigationIndex.Value];
            var isNearNavigationTarget = Math.Abs(time - navigationSentence.StartTime) <= 0.05;

            if (!isNearNavigationTarget)
            {
                _playbackNavigationIndex = null;
                _selectedSentenceId = null;
            }
        }
        else
        {
            _selectedSentenceId = null;
        }

        StateHasChanged();
    }

    private void HandlePlaybackFinished()
    {
        // Could add logic here for auto-advance to next chapter
    }

    private async Task HandleSentenceSelected(SentenceViewModel sentence)
    {
        var shouldSeek = _waveformPlayer != null && Math.Abs(_currentTime - sentence.StartTime) > 0.005;

        _selectedSentenceId = sentence.Id;
        _playbackNavigationIndex = _sentences.FindIndex(s => s.Id == sentence.Id);
        _currentTime = sentence.StartTime;

        // Seek waveform to the start time of the selected sentence (if needed).
        if (shouldSeek)
        {
            _pendingKeyboardSeekTime = sentence.StartTime;
            await _waveformPlayer!.SeekTo(sentence.StartTime);
        }
        else
        {
            _pendingKeyboardSeekTime = null;
        }
    }

    private async Task HandlePlayFromErrors(SentenceReport sentence)
    {
        _snippetPlayer ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/snippet-player.js");
        if (string.IsNullOrEmpty(ChapterName))
        {
            return;
        }

        var chapter = Uri.EscapeDataString(ChapterName);
        var start = sentence.StartTime.ToString(System.Globalization.CultureInfo.InvariantCulture);
        var end = sentence.EndTime.ToString(System.Globalization.CultureInfo.InvariantCulture);
        var url = $"/api/audio/chapter/{chapter}?start={start}&end={end}";
        await _snippetPlayer.InvokeVoidAsync("playSegment", url);
    }

    private void ToggleReviewed()
    {
        if (string.IsNullOrEmpty(ChapterName)) return;
        var decoded = Uri.UnescapeDataString(ChapterName);
        _isReviewed = !_isReviewed;
        ReviewedStatusService.SetReviewed(decoded, _isReviewed);
        ToastService.Success(_isReviewed ? $"Marked {decoded} as reviewed" : $"Unmarked {decoded} as reviewed");
        StateHasChanged();
    }

    private void HandleExportFromErrors(SentenceReport sentence)
    {
        if (string.IsNullOrEmpty(ChapterName)) return;
        try
        {
            var result = AudioExportService.ExportSegment(sentence.StartTime, sentence.EndTime);
            ToastService.Success($"Exported: {result.Filename}");
        }
        catch (Exception ex)
        {
            ToastService.Error($"Export failed: {ex.Message}");
        }
    }

    private void HandleCrxFromErrors(SentenceReport sentence)
    {
        if (string.IsNullOrEmpty(ChapterName)) return;
        var decoded = Uri.UnescapeDataString(ChapterName);
        _crxModal?.Open(decoded, sentence.StartTime, sentence.EndTime, sentence.Id, sentence.Excerpt, sentence);
    }

    private void HandleCrxSubmitted(CrxSubmitResult result)
    {
        if (result.Success)
        {
            ToastService.Success($"Error #{result.ErrorNumber} exported to CRX");
            LoadExportedSentenceIds();
        }
        else
        {
            ToastService.Error($"CRX failed: {result.Error}");
        }
        StateHasChanged();
    }

    private async Task HandleIgnoreFromErrors(SentenceReport sentence)
    {
        if (sentence.Diff?.Ops is null) return;

        var ops = sentence.Diff.Ops.ToList();
        var count = 0;
        for (int i = 0; i < ops.Count; i++)
        {
            var op = ops[i];
            if (op.Op == "delete")
            {
                var bookText = string.Join(" ", op.Tokens);
                if (i + 1 < ops.Count && ops[i + 1].Op == "insert")
                {
                    var scriptText = string.Join(" ", ops[i + 1].Tokens);
                    IgnoredPatternsService.SetIgnored(Services.ErrorPatternService.BuildKey("sub", bookText, scriptText), true);
                    count++;
                    i++;
                }
                else
                {
                    IgnoredPatternsService.SetIgnored(Services.ErrorPatternService.BuildKey("del", bookText, ""), true);
                    count++;
                }
            }
            else if (op.Op == "insert")
            {
                var scriptText = string.Join(" ", op.Tokens);
                IgnoredPatternsService.SetIgnored(Services.ErrorPatternService.BuildKey("ins", "", scriptText), true);
                count++;
            }
        }

        if (count > 0)
        {
            var decoded = Uri.UnescapeDataString(ChapterName!);
            LoadReport(decoded);
            await LoadSentencesAsync(decoded);
            ToastService.Info($"Ignored {count} error pattern{(count == 1 ? "" : "s")} for entire book");
        }
        StateHasChanged();
    }

    private void HandleTogglePatternIgnore(ErrorPattern pattern)
    {
        IgnoredPatternsService.ToggleIgnored(pattern.Key);

        // Refresh report + patterns so the UI immediately reflects the change
        if (!string.IsNullOrEmpty(ChapterName))
            LoadReport(Uri.UnescapeDataString(ChapterName));

        StateHasChanged();
    }

    private void HandleViewFromErrors(SentenceReport sentence)
    {
        _currentView = "playback";
        var target = _sentences.FirstOrDefault(s => s.Id == sentence.Id);
        if (target != null)
            _pendingSeekTime = target.StartTime;
        StateHasChanged();
    }

    // ── Keyboard JSInvokable handlers ──

    [JSInvokable]
    public void OnChapterNav(string direction)
    {
        var chapters = Workspace.AvailableChapters;
        if (chapters.Count == 0 || string.IsNullOrEmpty(ChapterName)) return;

        var current = Uri.UnescapeDataString(ChapterName);
        var index = chapters.IndexOf(current);
        if (index < 0) return;

        var next = direction == "next" ? index + 1 : index - 1;
        if (next < 0 || next >= chapters.Count) return;

        Navigation.NavigateTo(StageRouteCatalog.BuildProofChapterCompatibilityPath(chapters[next]));
    }

    [JSInvokable]
    public void OnSwitchView(string direction)
    {
        // Save current position
        if (_currentView == "playback")
        {
            SnapshotPlaybackPosition();
        }

        // Toggle between the two views
        _currentView = _currentView == "errors" ? "playback" : "errors";
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnNavigateItem(string direction)
    {
        if (_currentView == "errors")
        {
            if (_errorSentencesList.Count == 0) return;
            if (direction == "prev")
                _selectedErrorIndex = Math.Max(0, _selectedErrorIndex - 1);
            else
                _selectedErrorIndex = Math.Min(_errorSentencesList.Count - 1, _selectedErrorIndex + 1);
        }
        else
        {
            if (_sentences.Count == 0) return;

            var currentIndex = ResolvePlaybackNavigationIndex();

            if (direction == "prev")
                currentIndex = Math.Max(0, currentIndex - 1);
            else
                currentIndex = Math.Min(_sentences.Count - 1, currentIndex + 1);

            var targetSentence = _sentences[currentIndex];
            var shouldSeek = _waveformPlayer != null && Math.Abs(_currentTime - targetSentence.StartTime) > 0.005;

            _playbackNavigationIndex = currentIndex;
            _selectedSentenceId = targetSentence.Id;
            _currentTime = targetSentence.StartTime;

            // Keep keyboard navigation responsive even when adjacent sentences share the same start time.
            if (shouldSeek)
            {
                _pendingKeyboardSeekTime = targetSentence.StartTime;
                await _waveformPlayer!.SeekTo(targetSentence.StartTime);
            }
            else
            {
                _pendingKeyboardSeekTime = null;
            }
        }
        StateHasChanged();
    }

    private int ResolvePlaybackNavigationIndex()
    {
        if (_playbackNavigationIndex.HasValue
            && _playbackNavigationIndex.Value >= 0
            && _playbackNavigationIndex.Value < _sentences.Count)
        {
            return _playbackNavigationIndex.Value;
        }

        if (_selectedSentenceId.HasValue)
        {
            var selectedIndex = _sentences.FindIndex(s => s.Id == _selectedSentenceId.Value);
            if (selectedIndex >= 0)
            {
                return selectedIndex;
            }
        }

        if (_lastTimeBasedSentenceId.HasValue)
        {
            var timeSentenceIndex = _sentences.FindIndex(s => s.Id == _lastTimeBasedSentenceId.Value);
            if (timeSentenceIndex >= 0)
            {
                return timeSentenceIndex;
            }
        }

        var exactIndex = _sentences.FindIndex(s => _currentTime >= s.StartTime && _currentTime < s.EndTime);
        if (exactIndex >= 0)
        {
            return exactIndex;
        }

        var fallbackIndex = _sentences.FindLastIndex(s => s.StartTime <= _currentTime);
        return fallbackIndex >= 0 ? fallbackIndex : 0;
    }

    [JSInvokable]
    public void OnCrossNav(string direction)
    {
        if (direction == "errors-to-playback")
        {
            if (_errorSentencesList.Count == 0) return;
            var errorSentence = _errorSentencesList[_selectedErrorIndex];
            _currentView = "playback";

            var sentence = _sentences.FirstOrDefault(s => s.Id == errorSentence.Id);
            if (sentence != null)
                _pendingSeekTime = sentence.StartTime;
        }
        else // playback-to-errors
        {
            // Get current sentence Id
            int? sentenceId = _selectedSentenceId;
            if (!sentenceId.HasValue && _sentences.Count > 0)
            {
                var timeSentence = _sentences.FirstOrDefault(s => _currentTime >= s.StartTime && _currentTime < s.EndTime);
                sentenceId = timeSentence?.Id;
            }

            _currentView = "errors";

            if (sentenceId.HasValue)
            {
                var errorIndex = _errorSentencesList.FindIndex(s => s.Id == sentenceId.Value);
                if (errorIndex >= 0)
                {
                    _selectedErrorIndex = errorIndex;
                }
                // If not found, keep existing _selectedErrorIndex (saved position fallback)
            }
        }
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnSpacebar()
    {
        if (_currentView == "errors")
        {
            if (_errorSentencesList.Count == 0) return;
            var sentence = _errorSentencesList[_selectedErrorIndex];
            await HandlePlayFromErrors(sentence);
        }
        else
        {
            if (_waveformPlayer != null)
                await _waveformPlayer.PlayPause();
        }
    }

    [JSInvokable]
    public void OnToggleReviewed()
    {
        ToggleReviewed();
    }

    [JSInvokable]
    public void OnOpenCrx()
    {
        var sentence = GetActiveSentenceReport();
        if (sentence == null) return;
        HandleCrxFromErrors(sentence);
    }

    [JSInvokable]
    public async Task OnIgnoreError()
    {
        var sentence = GetActiveSentenceReport();
        if (sentence == null) return;

        // Count non-equal error groups (delete+insert = 1 sub, standalone del/ins = 1 each)
        var errorCount = CountErrors(sentence);

        if (errorCount <= 1)
        {
            // Single error: ignore directly
            await HandleIgnoreFromErrors(sentence);
        }
        else
        {
            // Multiple errors: open selection dialog
            _ignoreModal?.Open(sentence);
        }
    }

    private SentenceReport? GetActiveSentenceReport()
    {
        if (_currentView == "errors")
        {
            if (_errorSentencesList.Count == 0) return null;
            return _errorSentencesList[_selectedErrorIndex];
        }

        // Playback view: resolve from selected sentence or current time
        if (_report == null) return null;

        int? sentenceId = _selectedSentenceId;
        if (!sentenceId.HasValue && _sentences.Count > 0)
        {
            var timeSentence = _sentences.FirstOrDefault(s => _currentTime >= s.StartTime && _currentTime < s.EndTime);
            sentenceId = timeSentence?.Id;
        }

        if (!sentenceId.HasValue) return null;
        return _report.Sentences.FirstOrDefault(s => s.Id == sentenceId.Value);
    }

    private static int CountErrors(SentenceReport sentence)
    {
        if (sentence.Diff?.Ops is null) return 0;
        var ops = sentence.Diff.Ops.ToList();
        var count = 0;
        for (int i = 0; i < ops.Count; i++)
        {
            if (ops[i].Op == "delete")
            {
                count++;
                if (i + 1 < ops.Count && ops[i + 1].Op == "insert")
                    i++; // skip the insert half of a substitution
            }
            else if (ops[i].Op == "insert")
            {
                count++;
            }
        }
        return count;
    }

    private async Task HandleIgnoreModalSubmitted(List<IgnoreErrorModal.IgnoreErrorItem> selectedItems)
    {
        foreach (var item in selectedItems)
            IgnoredPatternsService.SetIgnored(item.Key, true);

        if (selectedItems.Count > 0 && !string.IsNullOrEmpty(ChapterName))
        {
            var decoded = Uri.UnescapeDataString(ChapterName);
            LoadReport(decoded);
            await LoadSentencesAsync(decoded);
            ToastService.Info($"Ignored {selectedItems.Count} error pattern{(selectedItems.Count == 1 ? "" : "s")} for entire book");
        }
        StateHasChanged();
    }

    [JSInvokable]
    public void OnModalClose()
    {
        if (_ignoreModal?.IsVisible == true)
            _ignoreModal.Close();
        else
            _crxModal?.Close();
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnModalSubmit()
    {
        if (_ignoreModal?.IsVisible == true)
            await _ignoreModal.SubmitAsync();
        else if (_crxModal != null)
            await _crxModal.SubmitAsync();
    }

    // ── Error visibility logic (copied from ErrorsView for indexing) ──

    private bool HasVisibleError(SentenceReport sentence)
    {
        if (HasVisibleDiffOps(sentence.Diff, IgnoredPatternsService.GetIgnoredKeys()))
        {
            return true;
        }

        if (sentence.Diff?.Ops is null || sentence.Diff.Ops.Count == 0)
        {
            return !string.Equals(sentence.Status, "ok", StringComparison.OrdinalIgnoreCase);
        }

        return false;
    }

    private static bool HasVisibleDiffOps(DiffReport? diff, IReadOnlySet<string>? ignoredKeys)
    {
        if (diff?.Ops is null || diff.Ops.Count == 0)
        {
            return false;
        }

        if (ignoredKeys is null || ignoredKeys.Count == 0)
        {
            return diff.Ops.Any(op => op.Op != "equal");
        }

        var ops = diff.Ops.ToList();
        for (var i = 0; i < ops.Count; i++)
        {
            var op = ops[i];
            if (string.Equals(op.Op, "equal", StringComparison.Ordinal))
            {
                continue;
            }

            if (string.Equals(op.Op, "delete", StringComparison.Ordinal))
            {
                var bookText = string.Join(" ", op.Tokens);
                if (i + 1 < ops.Count && string.Equals(ops[i + 1].Op, "insert", StringComparison.Ordinal))
                {
                    var scriptText = string.Join(" ", ops[i + 1].Tokens);
                    if (!ignoredKeys.Contains(Services.ErrorPatternService.BuildKey("sub", bookText, scriptText)))
                    {
                        return true;
                    }

                    i++;
                }
                else
                {
                    if (!ignoredKeys.Contains(Services.ErrorPatternService.BuildKey("del", bookText, string.Empty)))
                    {
                        return true;
                    }
                }
            }
            else if (string.Equals(op.Op, "insert", StringComparison.Ordinal))
            {
                var scriptText = string.Join(" ", op.Tokens);
                if (!ignoredKeys.Contains(Services.ErrorPatternService.BuildKey("ins", string.Empty, scriptText)))
                {
                    return true;
                }
            }
        }

        return false;
    }

    private static double ParseWer(string wer)
    {
        if (double.TryParse(wer.TrimEnd('%'), out var v)) return v;
        return 0;
    }

    private static string FormatTime(double seconds)
    {
        if (double.IsNaN(seconds) || double.IsInfinity(seconds)) return "0:00.000";
        var mins = (int)(seconds / 60);
        var secs = (int)(seconds % 60);
        var ms = (int)((seconds % 1) * 1000);
        return $"{mins}:{secs:D2}.{ms:D3}";
    }

    public async ValueTask DisposeAsync()
    {
        if (_keyboardModule is not null)
        {
            try
            {
                await _keyboardModule.InvokeVoidAsync("dispose");
                await _keyboardModule.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
        }
        _dotNetRef?.Dispose();

        if (_alertSoundPlayer is not null)
        {
            try
            {
                await _alertSoundPlayer.InvokeVoidAsync("dispose");
                await _alertSoundPlayer.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
        }

        if (_snippetPlayer is not null)
        {
            try
            {
                await _snippetPlayer.InvokeVoidAsync("dispose");
                await _snippetPlayer.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
        }
    }

