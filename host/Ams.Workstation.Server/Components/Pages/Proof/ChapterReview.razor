    }

    private async Task HandleSentenceSelected(SentenceViewModel sentence)
    {
        if (TryConsumePostLongPressTapSuppression(sentence.Id, "tap"))
        {
            return;
        }

        if (_isSelectionModeActive)
        {
            ToggleSelectionMembership(sentence.Id, "tap");
            return;
        }

        var shouldSeek = _waveformPlayer != null && Math.Abs(_currentTime - sentence.StartTime) > 0.005;

        _selectedSentenceId = sentence.Id;
        _playbackNavigationIndex = _sentences.FindIndex(s => s.Id == sentence.Id);
        _currentTime = sentence.StartTime;

        // Seek waveform to the start time of the selected sentence (if needed).
        if (shouldSeek)
        {
            _pendingKeyboardSeekTime = sentence.StartTime;
            await _waveformPlayer!.SeekTo(sentence.StartTime);
        }
        else
        {
            _pendingKeyboardSeekTime = null;
        }
    }

    private string GetSelectionModeIndicatorText()
    {
        if (!_isSelectionModeActive)
        {
            return "Selection mode inactive.";
        }

        var noun = SelectionCount == 1 ? "sentence" : "sentences";
        var selectionPolicyHint = _lastSelectionGestureEvent is "swipe-left-ignore" or "explicit-ignore"
            ? " Batch ignore keeps current selection."
            : string.Empty;

        return $"Selection mode active: {SelectionCount} {noun} selected. Long-press again to clear and resume playback.{selectionPolicyHint}";
    }

    private void ToggleSelectionMembership(int sentenceId, string trigger)
    {
        if (sentenceId <= 0)
        {
            _lastSelectionGestureEvent = "toggle-invalid";
            LogSelectionModeDiagnostic(_lastSelectionGestureEvent, trigger, sentenceId, "Cannot toggle selection for a non-positive sentence id.");
            return;
        }

        var sentenceIndex = _sentences.FindIndex(sentence => sentence.Id == sentenceId);
        if (sentenceIndex < 0)
        {
            _lastSelectionGestureEvent = "toggle-missing-sentence";
            LogSelectionModeDiagnostic(_lastSelectionGestureEvent, trigger, sentenceId, "Sentence id is not present in the current sentence list.");
            return;
        }

        var added = _selectedSentenceIds.Add(sentenceId);
        if (!added)
        {
            _selectedSentenceIds.Remove(sentenceId);
        }

        _selectedSentenceId = sentenceId;
        _playbackNavigationIndex = sentenceIndex;
        _lastSelectionGestureEvent = added ? "toggle-add" : "toggle-remove";
        LogSelectionModeDiagnostic(_lastSelectionGestureEvent, trigger, sentenceId, $"selectedCount={_selectedSentenceIds.Count}");
        StateHasChanged();
    }

    private async Task EnterSelectionModeAsync(int sentenceId, string trigger)
    {
        if (!TryResolveSelectionSentenceId(sentenceId, out var resolvedSentenceId))
        {
            _lastSelectionGestureEvent = "long-press-enter-missing-sentence";
            LogSelectionModeDiagnostic(_lastSelectionGestureEvent, trigger, sentenceId, "No valid sentence was available to seed selection mode.");
            return;
        }

        _isSelectionModeActive = true;
        _selectedSentenceIds.Clear();
        _selectedSentenceIds.Add(resolvedSentenceId);
        _selectedSentenceId = resolvedSentenceId;
        _playbackNavigationIndex = _sentences.FindIndex(sentence => sentence.Id == resolvedSentenceId);

        var autoPaused = await TryPausePlaybackForSelectionModeAsync();
        _resumePlaybackOnSelectionExit = autoPaused;
        _lastSelectionGestureEvent = "long-press-enter";

        LogSelectionModeDiagnostic(
            _lastSelectionGestureEvent,
            trigger,
            resolvedSentenceId,
            $"selectedCount={_selectedSentenceIds.Count};autoPaused={autoPaused}");

        StateHasChanged();
    }

    private async Task ClearSelectionModeAndResumeAsync(int sentenceId, string trigger)
    {
        var selectedCountBeforeClear = _selectedSentenceIds.Count;
        _selectedSentenceIds.Clear();
        _isSelectionModeActive = false;

        var resumedPlayback = await TryResumePlaybackAfterSelectionModeAsync();
        _resumePlaybackOnSelectionExit = false;
        _lastSelectionGestureEvent = "long-press-exit";

        LogSelectionModeDiagnostic(
            _lastSelectionGestureEvent,
            trigger,
            sentenceId,
            $"clearedCount={selectedCountBeforeClear};resumedPlayback={resumedPlayback}");

        StateHasChanged();
    }

    private bool TryResolveSelectionSentenceId(int sentenceId, out int resolvedSentenceId)
    {
        if (sentenceId > 0 && _sentences.Any(sentence => sentence.Id == sentenceId))
        {
            resolvedSentenceId = sentenceId;
            return true;
        }

        if (_selectedSentenceId.HasValue && _sentences.Any(sentence => sentence.Id == _selectedSentenceId.Value))
        {
            resolvedSentenceId = _selectedSentenceId.Value;
            return true;
        }

        if (_lastTimeBasedSentenceId.HasValue && _sentences.Any(sentence => sentence.Id == _lastTimeBasedSentenceId.Value))
        {
            resolvedSentenceId = _lastTimeBasedSentenceId.Value;
            return true;
        }

        var sentenceAtCurrentTime = _sentences.FirstOrDefault(sentence => _currentTime >= sentence.StartTime && _currentTime < sentence.EndTime);
        if (sentenceAtCurrentTime is not null)
        {
            resolvedSentenceId = sentenceAtCurrentTime.Id;
            return true;
        }

        if (_sentences.Count > 0)
        {
            resolvedSentenceId = _sentences[0].Id;
            return true;
        }

        resolvedSentenceId = 0;
        return false;
    }

    private async Task<bool> TryPausePlaybackForSelectionModeAsync()
    {
        if (_currentView != "playback" || _waveformPlayer is null || !_waveformPlayer.IsPlaying)
        {
            return false;
        }

        try
        {
            await _waveformPlayer.PlayPause();
            return true;
        }
        catch (Exception ex)
        {
            LogSelectionModeDiagnostic("pause-failed", "enter-selection", _selectedSentenceId ?? 0, ex.Message);
            return false;
        }
    }

    private async Task<bool> TryResumePlaybackAfterSelectionModeAsync()
    {
        if (!_resumePlaybackOnSelectionExit
            || _currentView != "playback"
            || _waveformPlayer is null
            || _waveformPlayer.IsPlaying)
        {
            return false;
        }

        try
        {
            await _waveformPlayer.PlayPause();
            return true;
        }
        catch (Exception ex)
        {
            LogSelectionModeDiagnostic("resume-failed", "exit-selection", _selectedSentenceId ?? 0, ex.Message);
            return false;
        }
    }

    private void LogSelectionModeDiagnostic(string eventName, string trigger, int sentenceId, string details)
    {
        Console.WriteLine($"[ProofSelectionMode] event={eventName}; trigger={trigger}; view={_currentView}; sentenceId={sentenceId}; mode={SelectionModeState}; selectedCount={_selectedSentenceIds.Count}; details={details}");
    }

    private bool IsDuplicateLongPressDispatch(int sentenceId)
    {
        var nowUtc = DateTimeOffset.UtcNow;
        var isDuplicate = sentenceId > 0
            && sentenceId == _lastLongPressDispatchSentenceId
            && (nowUtc - _lastLongPressDispatchAtUtc) <= DuplicateLongPressWindow;

        _lastLongPressDispatchSentenceId = sentenceId;
        _lastLongPressDispatchAtUtc = nowUtc;
        return isDuplicate;
    }

    private void RememberPostLongPressTapSuppression(int sentenceId)
    {
        if (sentenceId <= 0)
        {
            return;
        }

        _suppressedSelectionTapSentenceIds[sentenceId] = DateTimeOffset.UtcNow;
    }

    private bool TryConsumePostLongPressTapSuppression(int sentenceId, string trigger)
    {
        if (sentenceId <= 0)
        {
            return false;
        }

        var nowUtc = DateTimeOffset.UtcNow;
        PruneExpiredPostLongPressTapSuppressions(nowUtc);

        if (!_suppressedSelectionTapSentenceIds.TryGetValue(sentenceId, out var suppressedAtUtc))
        {
            return false;
        }

        _suppressedSelectionTapSentenceIds.Remove(sentenceId);

        var age = nowUtc - suppressedAtUtc;
        if (age > PostLongPressTapSuppressionWindow)
        {
            return false;
        }

        _lastSelectionGestureEvent = "selection-tap-consumed-after-long-press";
        LogSelectionModeDiagnostic(_lastSelectionGestureEvent, trigger, sentenceId, $"suppressionAgeMs={age.TotalMilliseconds:F0}");
        return true;
    }

    private void PruneExpiredPostLongPressTapSuppressions(DateTimeOffset nowUtc)
    {
        if (_suppressedSelectionTapSentenceIds.Count == 0)
        {
            return;
        }

        var expiredSentenceIds = _suppressedSelectionTapSentenceIds
            .Where(entry => (nowUtc - entry.Value) > PostLongPressTapSuppressionWindow)
            .Select(entry => entry.Key)
            .ToList();

        foreach (var expiredSentenceId in expiredSentenceIds)
        {
            _suppressedSelectionTapSentenceIds.Remove(expiredSentenceId);
        }
    }

    private static bool IsFallbackActionSurface(string sourceSurface)
        => !string.IsNullOrWhiteSpace(sourceSurface)
           && sourceSurface.StartsWith("mobile-action-bar-", StringComparison.Ordinal);

    private bool TryValidateBatchGestureContext(
        string eventName,
        string trigger,
        int sentenceId,
        string sourceSurface,
        out HashSet<int> selectedSentenceIds)
    {
        selectedSentenceIds = _selectedSentenceIds
            .Where(id => id > 0)
            .ToHashSet();

        if (!IsFallbackActionSurface(sourceSurface)
            && !string.Equals(sourceSurface, CurrentMobileActionSurface, StringComparison.Ordinal))
        {
            _lastSelectionGestureEvent = $"{eventName}-ignored-surface-mismatch";
            LogSelectionModeDiagnostic(
                _lastSelectionGestureEvent,
                trigger,
                sentenceId,
                $"surface={sourceSurface};expectedSurface={CurrentMobileActionSurface};reason=surface-mismatch");
            return false;
        }

        // Single-sentence path: when selection mode is inactive, treat the swiped sentence as a one-element batch.
        // Fallback (mobile-action-bar) surfaces with no swipe origin still require active selection mode.
        if (!_isSelectionModeActive)
        {
            if (sentenceId <= 0)
            {
                _lastSelectionGestureEvent = $"{eventName}-ignored-no-target";
                LogSelectionModeDiagnostic(_lastSelectionGestureEvent, trigger, sentenceId, $"surface={sourceSurface};reason=no-sentence-target");
                return false;
            }

            selectedSentenceIds = new HashSet<int> { sentenceId };
            return true;
        }

        if (selectedSentenceIds.Count == 0)
        {
            _lastSelectionGestureEvent = $"{eventName}-ignored-empty-selection";
            LogSelectionModeDiagnostic(_lastSelectionGestureEvent, trigger, sentenceId, $"surface={sourceSurface};reason=no-selected-sentences");
            return false;
        }

        if (sentenceId > 0 && !selectedSentenceIds.Contains(sentenceId))
        {
            _lastSelectionGestureEvent = $"{eventName}-ignored-unselected-context";
            LogSelectionModeDiagnostic(_lastSelectionGestureEvent, trigger, sentenceId, $"surface={sourceSurface};reason=gesture-origin-not-selected");
            return false;
        }

        return true;
    }

    private Task HandleSelectionSwipeRightAsync(int sentenceId, string sourceSurface)
    {
        var isFallbackAction = sourceSurface.StartsWith("mobile-action-bar-", StringComparison.Ordinal);
        var trigger = isFallbackAction ? "export-button" : "swipe-right";
        var eventName = isFallbackAction ? "explicit-export" : "swipe-right-export";

        if (!TryValidateBatchGestureContext(eventName, trigger, sentenceId, sourceSurface, out var selectedSentenceIds))
        {
            return Task.CompletedTask;
        }

        if (string.IsNullOrEmpty(ChapterName))
        {
            _lastSelectionGestureEvent = $"{eventName}-failed-missing-chapter";
            LogSelectionModeDiagnostic(_lastSelectionGestureEvent, trigger, sentenceId, $"surface={sourceSurface};selectedCount={selectedSentenceIds.Count}");
            return Task.CompletedTask;
        }

        var reportBySentenceId = _report?.Sentences.ToDictionary(sentence => sentence.Id)
            ?? new Dictionary<int, SentenceReport>();

        var exportSeeds = _sentences
            .Where(sentence => selectedSentenceIds.Contains(sentence.Id))
            .Select(sentence =>
            {
                reportBySentenceId.TryGetValue(sentence.Id, out var sentenceReport);
                return new CrxExportSeed(
                    sentence.Id,
                    sentence.StartTime,
                    sentence.EndTime,
                    sentence.Text,
                    sentenceReport);
            })
            .OrderBy(seed => seed.StartTime)
            .ThenBy(seed => seed.SentenceId)
            .ToList();

        if (exportSeeds.Count == 0)
        {
            _lastSelectionGestureEvent = $"{eventName}-failed-missing-sentences";
            LogSelectionModeDiagnostic(_lastSelectionGestureEvent, trigger, sentenceId, $"surface={sourceSurface};selectedCount={selectedSentenceIds.Count}");
            return Task.CompletedTask;
        }

        if (_crxModal is null)
        {
            _lastSelectionGestureEvent = $"{eventName}-failed-modal-unavailable";
            LogSelectionModeDiagnostic(_lastSelectionGestureEvent, trigger, sentenceId, $"surface={sourceSurface};selectedCount={selectedSentenceIds.Count}");
            return Task.CompletedTask;
        }

        var composition = ComposeCrxExportComposition(exportSeeds);
        var decodedChapter = Uri.UnescapeDataString(ChapterName);

        _pendingExportSentenceIds = exportSeeds
            .Select(seed => seed.SentenceId)
            .Where(id => id > 0)
            .ToHashSet();

        if (composition.AllReports.Count > 1)
        {
            _crxModal.OpenMulti(
                decodedChapter,
                composition.StartTime,
                composition.EndTime,
                composition.AnchorSentenceId,
                composition.Excerpt,
                composition.AllReports,
                composition.RequiresRangeConfirmation);
        }
        else
        {
            _crxModal.Open(
                decodedChapter,
                composition.StartTime,
                composition.EndTime,
                composition.AnchorSentenceId,
                composition.Excerpt,
                composition.AnchorReport,
                composition.RequiresRangeConfirmation);
        }

        _lastSelectionGestureEvent = eventName;
        LogSelectionModeDiagnostic(
            _lastSelectionGestureEvent,
            trigger,
            sentenceId,
            $"surface={sourceSurface};selectedCount={composition.Cardinality};range={FormatTime(composition.StartTime)}-{FormatTime(composition.EndTime)};rangeMode={composition.RangeMode};confirmRequired={composition.RequiresRangeConfirmation}");

        LogCrxExportDiagnostic(trigger, sourceSurface, sentenceId, composition);

        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task HandleSelectionSwipeLeftAsync(int sentenceId, string sourceSurface)
    {
        var isFallbackAction = sourceSurface.StartsWith("mobile-action-bar-", StringComparison.Ordinal);
        var trigger = isFallbackAction ? "ignore-button" : "swipe-left";
        var eventName = isFallbackAction ? "explicit-ignore" : "swipe-left-ignore";

        return ExecuteSelectionBatchIgnoreAsync(
            sentenceId: sentenceId,
            trigger: trigger,
            sourceSurface: sourceSurface,
            eventName: eventName);
    }

    private async Task ExecuteSelectionBatchIgnoreAsync(
        int sentenceId,
        string trigger,
        string sourceSurface,
        string eventName)
    {
        const string selectionPolicy = "retain";

        if (!TryValidateBatchGestureContext(eventName, trigger, sentenceId, sourceSurface, out var selectedSentenceIds))
        {
            LogBatchIgnoreDiagnostic(
                result: $"{eventName}-invalid-context",
                trigger: trigger,
                sourceSurface: sourceSurface,
                sentenceId: sentenceId,
                selectedCount: selectedSentenceIds.Count,
                ignoredPatternCount: 0,
                failedSentenceCount: selectedSentenceIds.Count,
                refreshed: false,
                selectionPolicy: selectionPolicy);
            return;
        }

        if (_report is null)
        {
            _lastSelectionGestureEvent = $"{eventName}-failed-missing-report";
            LogSelectionModeDiagnostic(_lastSelectionGestureEvent, trigger, sentenceId, $"surface={sourceSurface};selectedCount={selectedSentenceIds.Count}");

            LogBatchIgnoreDiagnostic(
                result: _lastSelectionGestureEvent,
                trigger: trigger,
                sourceSurface: sourceSurface,
                sentenceId: sentenceId,
                selectedCount: selectedSentenceIds.Count,
                ignoredPatternCount: 0,
                failedSentenceCount: selectedSentenceIds.Count,
                refreshed: false,
                selectionPolicy: selectionPolicy);
            return;
        }

        var selectedReports = _report.Sentences
            .Where(sentence => selectedSentenceIds.Contains(sentence.Id))
            .OrderBy(sentence => sentence.Id)
            .ToList();

        if (selectedReports.Count == 0)
        {
            _lastSelectionGestureEvent = $"{eventName}-failed-missing-sentences";
            LogSelectionModeDiagnostic(_lastSelectionGestureEvent, trigger, sentenceId, $"surface={sourceSurface};selectedCount={selectedSentenceIds.Count}");

            LogBatchIgnoreDiagnostic(
                result: _lastSelectionGestureEvent,
                trigger: trigger,
                sourceSurface: sourceSurface,
                sentenceId: sentenceId,
                selectedCount: selectedSentenceIds.Count,
                ignoredPatternCount: 0,
                failedSentenceCount: selectedSentenceIds.Count,
                refreshed: false,
                selectionPolicy: selectionPolicy);
            return;
        }

        var ignoredPatternCount = 0;
        var failedSentenceCount = 0;

        foreach (var selectedSentence in selectedReports)
        {
            var ignoredCountForSentence = IgnorePatternsForSentence(selectedSentence);
            ignoredPatternCount += ignoredCountForSentence;
            if (ignoredCountForSentence <= 0)
            {
                failedSentenceCount++;
            }
        }

        if (ignoredPatternCount <= 0)
        {
            _lastSelectionGestureEvent = $"{eventName}-noop";
            LogSelectionModeDiagnostic(
                _lastSelectionGestureEvent,
                trigger,
                sentenceId,
                $"surface={sourceSurface};selectedCount={selectedReports.Count};ignoredCount=0;failedCount={selectedReports.Count};selectionPolicy={selectionPolicy}");

            LogBatchIgnoreDiagnostic(
                result: _lastSelectionGestureEvent,
                trigger: trigger,
                sourceSurface: sourceSurface,
                sentenceId: sentenceId,
                selectedCount: selectedReports.Count,
                ignoredPatternCount: 0,
                failedSentenceCount: selectedReports.Count,
                refreshed: false,
                selectionPolicy: selectionPolicy);
            return;
        }

        var refreshed = false;
        if (!string.IsNullOrEmpty(ChapterName))
        {
            var decoded = Uri.UnescapeDataString(ChapterName);
            LoadReport(decoded);
            await LoadSentencesAsync(decoded);
            refreshed = true;
        }

        _lastSelectionGestureEvent = eventName;
        LogSelectionModeDiagnostic(
            _lastSelectionGestureEvent,
            trigger,
            sentenceId,
            $"surface={sourceSurface};selectedCount={selectedReports.Count};ignoredCount={ignoredPatternCount};failedCount={failedSentenceCount};selectionPolicy={selectionPolicy}");

        LogBatchIgnoreDiagnostic(
            result: _lastSelectionGestureEvent,
            trigger: trigger,
            sourceSurface: sourceSurface,
            sentenceId: sentenceId,
            selectedCount: selectedReports.Count,
            ignoredPatternCount: ignoredPatternCount,
            failedSentenceCount: failedSentenceCount,
            refreshed: refreshed,
            selectionPolicy: selectionPolicy);

        var sentenceNoun = selectedReports.Count == 1 ? "sentence" : "sentences";
        var patternNoun = ignoredPatternCount == 1 ? "pattern" : "patterns";
        ToastService.Info($"Ignored {ignoredPatternCount} error {patternNoun} across {selectedReports.Count} selected {sentenceNoun}. Selection retained.");

        StateHasChanged();
    }

    private static CrxExportComposition ComposeCrxExportComposition(IReadOnlyList<CrxExportSeed> exportSeeds)
    {
        if (exportSeeds.Count == 0)
        {
            return new CrxExportComposition(
                StartTime: 0,
                EndTime: CrxFallbackExportDurationSec,
                AnchorSentenceId: 0,
                Excerpt: "Batch export",
                AnchorReport: null,
                AllReports: Array.Empty<SentenceReport>(),
                RequiresRangeConfirmation: true,
                RangeMode: "fallback-empty",
                Cardinality: 0);
        }

        var orderedByStart = exportSeeds
            .OrderBy(seed => seed.StartTime)
            .ThenBy(seed => seed.SentenceId)
            .ToList();

        var anchorSeed = orderedByStart[0];

        var startCandidates = orderedByStart
            .Select(seed => seed.StartTime)
            .Where(IsFiniteNonNegativeTime)
            .ToList();

        var endCandidates = orderedByStart
            .Select(seed => seed.EndTime)
            .Where(IsFiniteNonNegativeTime)
            .ToList();

        var batchStart = startCandidates.Count > 0 ? startCandidates.Min() : double.NaN;
        var batchEnd = endCandidates.Count > 0 ? endCandidates.Max() : double.NaN;

        var requiresRangeConfirmation = !IsValidCrxRange(batchStart, batchEnd);
        var rangeMode = "composed";

        if (requiresRangeConfirmation)
        {
            var fallbackAnchor = startCandidates
                .Concat(endCandidates)
                .DefaultIfEmpty(Math.Max(0, anchorSeed.StartTime))
                .Min();

            batchStart = Math.Max(0, fallbackAnchor - CrxFallbackLeadInSec);
            batchEnd = batchStart + CrxFallbackExportDurationSec;
            rangeMode = "fallback";
        }

        return new CrxExportComposition(
            StartTime: batchStart,
            EndTime: batchEnd,
            AnchorSentenceId: anchorSeed.SentenceId,
            Excerpt: BuildBatchCrxExcerpt(exportSeeds),
            AnchorReport: exportSeeds.Count == 1 ? anchorSeed.Report : null,
            AllReports: orderedByStart
                .Select(seed => seed.Report)
                .Where(r => r is not null)
                .ToList()!,
            RequiresRangeConfirmation: requiresRangeConfirmation,
            RangeMode: rangeMode,
            Cardinality: exportSeeds.Count);
    }

    private static bool IsFiniteNonNegativeTime(double value)
        => !double.IsNaN(value) && !double.IsInfinity(value) && value >= 0;

    private static bool IsValidCrxRange(double start, double end)
        => IsFiniteNonNegativeTime(start)
           && IsFiniteNonNegativeTime(end)
           && (end - start) > CrxMinExportDurationSec;

    private static string BuildBatchCrxExcerpt(IReadOnlyList<CrxExportSeed> exportSeeds)
    {
        if (exportSeeds.Count == 0)
        {
            return "Batch export";
        }

        if (exportSeeds.Count == 1)
        {
            var singleText = exportSeeds[0].Text?.Trim();
            return string.IsNullOrWhiteSpace(singleText)
                ? $"Sentence #{exportSeeds[0].SentenceId}"
                : singleText;
        }

        var orderedById = exportSeeds
            .OrderBy(seed => seed.SentenceId)
            .ToList();

        var contextText = string.Join(
            " ",
            orderedById
                .Select(seed => seed.Text?.Trim())
                .Where(text => !string.IsNullOrWhiteSpace(text)));

        if (contextText.Length > 240)
        {
            contextText = $"{contextText[..237]}...";
        }

        var summary = $"Batch export sentences #{orderedById[0].SentenceId} through #{orderedById[^1].SentenceId} ({orderedById.Count} total).";
        return string.IsNullOrWhiteSpace(contextText)
            ? summary
            : $"{summary} {contextText}";
    }

