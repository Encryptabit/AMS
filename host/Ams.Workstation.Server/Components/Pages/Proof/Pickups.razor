    private bool TryApplyFitRangeField(string field, string? rawValue, string rangeName, ref double startSec, ref double endSec)
    {
        if (!TryParseFitSeconds(rawValue, $"{rangeName} {field}", out var parsed))
        {
            return false;
        }

        switch (field)
        {
            case FitFieldStart:
                startSec = parsed;
                break;
            case FitFieldEnd:
                endSec = parsed;
                break;
            default:
                _fitInputValidationError = $"Unknown Fit range field '{field}'.";
                return false;
        }

        if (endSec <= startSec + 0.000_001d)
        {
            _fitInputValidationError = $"Invalid Fit {rangeName}: end must be greater than start.";
            return false;
        }

        _fitInputValidationError = null;
        return true;
    }

    private bool TryParseFitSeconds(string? rawValue, string fieldName, out double value)
    {
        if (!double.TryParse(rawValue, NumberStyles.Float, CultureInfo.InvariantCulture, out value)
            || double.IsNaN(value)
            || double.IsInfinity(value)
            || value < 0)
        {
            _fitInputValidationError = $"Invalid Fit {fieldName}: enter a non-negative seconds value.";
            return false;
        }

        return true;
    }

    private bool TryParseFitCrossfadeCurve(string? rawValue, out string curve)
    {
        curve = string.IsNullOrWhiteSpace(rawValue) ? string.Empty : rawValue.Trim();
        if (!FitCrossfadeCurves.Contains(curve, StringComparer.Ordinal))
        {
            _fitInputValidationError = $"Unsupported Fit crossfade curve '{curve}'.";
            return false;
        }

        return true;
    }

