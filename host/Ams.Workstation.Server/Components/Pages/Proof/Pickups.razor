@page "/proof/pickups"
@inject Ams.Workstation.Server.Services.BlazorWorkspace Workspace
@inject Ams.Workstation.Server.Services.ProofPickupsSessionService Session
@inject NavigationManager Navigation
@using Ams.Core.Common
@using Ams.Workstation.Server.Components.Navigation
@using Ams.Workstation.Server.Models
@using Ams.Workstation.Server.Services
@using Ams.Workstation.Server.Components.UI
@implements IDisposable

<PageTitle>Pickups - Proof - AMS Workstation</PageTitle>

<div class="proof-pickups-page" data-proof-pickups-page="true">
    <div class="proof-pickups-stack">
        <div class="proof-pickups-header">
            <h1>Proof Pickups</h1>
            <p class="ams-body ams-body--muted">Import stitched pickup source, match CRX targets, stage replacements, and commit/revert lifecycle ops for active chapter.</p>
        </div>

        <span data-proof-pickups-handoff="editing">
            <AmsButton Variant="secondary"
                       OnClick="NavigateToEditing"
                       data-proof-pickups-action="return-editing">
                Return to Editing
            </AmsButton>
        </span>

        @if (!Workspace.IsInitialized || !Workspace.HasBookIndex)
        {
            <div class="ams-message ams-message--info" role="status">
                Workspace with book-index is required before pickup workflow can run.
            </div>
        }
        else
        {
            <section class="ams-card">
                <div class="proof-pickups-controls proof-pickups-action-bar">
                    <div class="proof-pickups-field">
                        <label class="ams-field">
                            <span class="ams-caption ams-caption--muted">Chapter</span>
                            <select class="ams-select"
                                    value="@(_selectedChapter ?? string.Empty)"
                                    @onchange="@(e => HandleChapterChange(e.Value?.ToString()))"
                                    disabled="@_snapshot.IsBusy">
                                <option value="">— Select chapter —</option>
                                @foreach (var item in ChapterOptions)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            </select>
                        </label>
                    </div>

                    <div class="proof-pickups-field proof-pickups-field--source">
                        <label class="ams-field">
                            <span class="ams-caption ams-caption--muted">Stitched pickup WAV</span>
                            <input type="text"
                                   class="ams-input"
                                   value="@(_pickupSourcePath ?? string.Empty)"
                                   @oninput="@(e => _pickupSourcePath = e.Value?.ToString() ?? string.Empty)"
                                   placeholder="C:\path\chapter_pickups.wav"
                                   disabled="@_snapshot.IsBusy" />
                        </label>
                    </div>

                    <AmsButton Variant="primary"
                               OnClick="HandleImportAsync"
                               Disabled="@(!CanImport)"
                               data-proof-pickups-action="import">
                        Import + Match
                    </AmsButton>

                    <AmsButton Variant="danger"
                               OnClick="HandleCancelActiveAction"
                               Disabled="@(!_snapshot.IsBusy)"
                               data-proof-pickups-action="cancel">
                        Cancel
                    </AmsButton>
                </div>

                @if (!_snapshot.HasActiveChapter)
                {
                    <div class="ams-message ams-message--warning" role="status">
                        Active chapter required before import/stage actions.
                    </div>
                }
            </section>

            @if (_snapshot.IsBusy)
            {
                <div class="proof-pickups-progress">
                    <p class="ams-caption ams-caption--muted">@GetProgressLabel()</p>
                    <AmsProgress Value="@(_snapshot.Progress * 100)" State="@GetProgressState()" ShowLabel="true" />
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(_snapshot.LastError))
            {
                <div class="ams-message ams-message--error" role="status" data-proof-pickups-last-error="true">
                    @_snapshot.LastError
                </div>
            }

            <div class="proof-pickups-grid">
                <section class="ams-card proof-queue-card" data-proof-pickups-queue="matched">
                    <div class="proof-queue-card__header">
                        <h2 class="ams-subtitle">Matched</h2>
                        <AmsTag Tone="info">@VisibleMatchedAssets.Count</AmsTag>
                    </div>

                    @if (VisibleMatchedAssets.Count == 0)
                    {
                        <p class="ams-caption ams-caption--muted">No matched pickups ready for staging.</p>
                    }
                    else
                    {
                        @foreach (var asset in VisibleMatchedAssets)
                        {
                            var target = ResolveTarget(asset);
                            <section class="ams-card proof-pickups-item">
                                <div class="proof-pickups-item__stack">
                                    <p class="ams-body">@DescribeMatchedAsset(asset, target)</p>
                                    <p class="ams-caption ams-caption--muted">Pickup range: @FormatRange(asset.TrimStartSec, asset.TrimEndSec)</p>
                                    <AmsButton Variant="secondary"
                                               Size="sm"
                                               OnClick="() => HandleStageAsync(asset.Id)"
                                               Disabled="@_snapshot.IsBusy">
                                        Stage
                                    </AmsButton>
                                </div>
                            </section>
                        }
                    }
                </section>

                <section class="ams-card proof-queue-card" data-proof-pickups-queue="unmatched">
                    <div class="proof-queue-card__header">
                        <h2 class="ams-subtitle">Unmatched</h2>
                        <AmsTag Tone="warning">@_snapshot.Unmatched.Count</AmsTag>
                    </div>

                    @if (_snapshot.Unmatched.Count == 0)
                    {
                        <p class="ams-caption ams-caption--muted">No unmatched pickup segments.</p>
                    }
                    else
                    {
                        @foreach (var asset in _snapshot.Unmatched)
                        {
                            <section class="ams-card proof-pickups-item">
                                <div class="proof-pickups-item__stack">
                                    <p class="ams-body">Asset @asset.Id[..Math.Min(8, asset.Id.Length)]</p>
                                    <p class="ams-caption ams-caption--muted">Pickup range: @FormatRange(asset.TrimStartSec, asset.TrimEndSec)</p>
                                </div>
                            </section>
                        }
                    }
                </section>

                <section class="ams-card proof-queue-card" data-proof-pickups-queue="staged">
                    <div class="proof-queue-card__header">
                        <h2 class="ams-subtitle">Staged</h2>
                        <AmsTag Tone="success">@_snapshot.Staged.Count</AmsTag>
                    </div>

                    @if (_snapshot.Staged.Count == 0)
                    {
                        <p class="ams-caption ams-caption--muted">No staged replacements.</p>
                    }
                    else
                    {
                        @foreach (var staged in _snapshot.Staged)
                        {
                            <section class="ams-card proof-pickups-item">
                                <div class="proof-pickups-item__stack">
                                    <p class="ams-body">Op @staged.Id[..Math.Min(8, staged.Id.Length)] — sentence @staged.SentenceId</p>
                                    <p class="ams-caption ams-caption--muted">Chapter range: @FormatRange(staged.OriginalStartSec, staged.OriginalEndSec)</p>
                                    <div class="proof-pickups-item__actions">
                                        <AmsButton Variant="primary"
                                                   Size="sm"
                                                   OnClick="() => HandleCommitAsync(staged.Id)"
                                                   Disabled="@_snapshot.IsBusy"
                                                   data-proof-pickups-action="commit">
                                            Commit
                                        </AmsButton>
                                        <AmsButton Variant="secondary"
                                                   Size="sm"
                                                   OnClick="() => HandleUnstageAsync(staged.Id)"
                                                   Disabled="@_snapshot.IsBusy"
                                                   data-proof-pickups-action="unstage">
                                            Unstage
                                        </AmsButton>
                                    </div>
                                </div>
                            </section>
                        }
                    }
                </section>
            </div>

            <div class="proof-pickups-grid" data-proof-pickups-lifecycle="true">
                <section class="ams-card proof-queue-card" data-proof-pickups-queue="applied">
                    <div class="proof-queue-card__header">
                        <h2 class="ams-subtitle">Applied</h2>
                        <AmsTag Tone="success">@_snapshot.Applied.Count</AmsTag>
                    </div>

                    @if (_snapshot.Applied.Count == 0)
                    {
                        <p class="ams-caption ams-caption--muted">No applied replacements.</p>
                    }
                    else
                    {
                        @foreach (var applied in _snapshot.Applied)
                        {
                            <section class="ams-card proof-pickups-item">
                                <div class="proof-pickups-item__stack">
                                    <p class="ams-body">Op @applied.Id[..Math.Min(8, applied.Id.Length)] — sentence @applied.SentenceId</p>
                                    <p class="ams-caption ams-caption--muted">Chapter range: @FormatRange(applied.OriginalStartSec, applied.OriginalEndSec)</p>
                                    <AmsButton Variant="secondary"
                                               Size="sm"
                                               OnClick="() => HandleRevertAsync(applied.Id)"
                                               Disabled="@_snapshot.IsBusy"
                                               data-proof-pickups-action="revert">
                                        Revert
                                    </AmsButton>
                                </div>
                            </section>
                        }
                    }
                </section>

                <section class="ams-card proof-queue-card" data-proof-pickups-queue="reverted">
                    <div class="proof-queue-card__header">
                        <h2 class="ams-subtitle">Reverted</h2>
                        <AmsTag Tone="warning">@_snapshot.Reverted.Count</AmsTag>
                    </div>

                    @if (_snapshot.Reverted.Count == 0)
                    {
                        <p class="ams-caption ams-caption--muted">No reverted replacements.</p>
                    }
                    else
                    {
                        @foreach (var reverted in _snapshot.Reverted)
                        {
                            <section class="ams-card proof-pickups-item">
                                <div class="proof-pickups-item__stack">
                                    <p class="ams-body">Op @reverted.Id[..Math.Min(8, reverted.Id.Length)] — sentence @reverted.SentenceId</p>
                                    <p class="ams-caption ams-caption--muted">Chapter range: @FormatRange(reverted.OriginalStartSec, reverted.OriginalEndSec)</p>
                                </div>
                            </section>
                        }
                    }
                </section>

                <section class="ams-card proof-queue-card" data-proof-pickups-queue="failed">
                    <div class="proof-queue-card__header">
                        <h2 class="ams-subtitle">Failed</h2>
                        <AmsTag Tone="danger">@_snapshot.Failed.Count</AmsTag>
                    </div>

                    @if (_snapshot.Failed.Count == 0)
                    {
                        <p class="ams-caption ams-caption--muted">No failed replacements.</p>
                    }
                    else
                    {
                        @foreach (var failed in _snapshot.Failed)
                        {
                            <section class="ams-card proof-pickups-item">
                                <div class="proof-pickups-item__stack">
                                    <p class="ams-body">Op @failed.Id[..Math.Min(8, failed.Id.Length)] — sentence @failed.SentenceId</p>
                                    <p class="ams-caption ams-caption--muted">Chapter range: @FormatRange(failed.OriginalStartSec, failed.OriginalEndSec)</p>
                                </div>
                            </section>
                        }
                    }
                </section>
            </div>

            <section class="ams-card" data-proof-pickups-diagnostics="true">
                <h2 class="ams-subtitle">Diagnostics</h2>

                <dl class="proof-pickups-diagnostics">
                    <div>
                        <dt>Phase</dt>
                        <dd data-proof-pickups-phase="true">@_snapshot.Phase</dd>
                    </div>
                    <div>
                        <dt>Progress</dt>
                        <dd>@($"{_snapshot.Progress * 100:F0}%")</dd>
                    </div>
                    <div>
                        <dt>Active chapter stem</dt>
                        <dd>@(_snapshot.ActiveChapterStem ?? "(none)")</dd>
                    </div>
                    <div>
                        <dt>EDL revision</dt>
                        <dd>@(_snapshot.EdlRevision?.ToString() ?? "(none)")</dd>
                    </div>
                    <div>
                        <dt>Last op id</dt>
                        <dd data-proof-pickups-last-op="true">@(_snapshot.LastOperationId ?? "(none)")</dd>
                    </div>
                    <div>
                        <dt>Last validation error</dt>
                        <dd>@(_snapshot.LastValidationError ?? "(none)")</dd>
                    </div>
                </dl>

                @if (!string.IsNullOrWhiteSpace(_snapshot.DeterministicOrderingDiagnostics))
                {
                    <p class="ams-caption ams-caption--muted">Deterministic ordering</p>
                    <pre class="proof-pickups-diagnostics-text">@_snapshot.DeterministicOrderingDiagnostics</pre>
                }
            </section>

            <section class="ams-card" data-proof-pickups-ledger="true">
                <div class="proof-queue-card__header">
                    <h2 class="ams-subtitle">Artifact ledger</h2>
                    <AmsTag Tone="info">@(_snapshot.ArtifactLedgerRevision?.ToString() ?? "(none)")</AmsTag>
                </div>

                @if (!string.IsNullOrWhiteSpace(_snapshot.ArtifactLedgerReadError))
                {
                    <div class="ams-message ams-message--error" role="status" data-proof-pickups-ledger-read-error="true">
                        @_snapshot.ArtifactLedgerReadError
                    </div>
                }

                @if (_snapshot.ArtifactLedgerEntries.Count == 0)
                {
                    <p class="ams-caption ams-caption--muted" data-proof-pickups-ledger-empty="true">
                        No artifact ledger entries for active chapter.
                    </p>
                }
                else
                {
                    <div class="proof-pickups-ledger proof-pickups-ledger-list">
                        @foreach (var entry in _snapshot.ArtifactLedgerEntries.OrderByDescending(item => item.Sequence).Take(20))
                        {
                            <section class="ams-card proof-pickups-item" data-proof-pickups-ledger-row="true">
                                <div class="proof-pickups-item__stack">
                                    <p class="ams-body">#@entry.Sequence — @entry.Transition — op @entry.OperationId</p>
                                    <p class="ams-caption ams-caption--muted">phase=@entry.Phase, queue=@entry.QueueStatus, edl=@entry.EdlState, rollback=@entry.RollbackVerdict</p>
                                    @if (!string.IsNullOrWhiteSpace(entry.FailureReason))
                                    {
                                        <p class="proof-pickups-item__failure">failure: @entry.FailureReason</p>
                                    }
                                </div>
                            </section>
                        }
                    </div>
                }
            </section>
        }
    </div>
</div>

@code {
    private string? _pickupSourcePath;
    private string? _selectedChapter;
    private ProofPickupsSessionSnapshot _snapshot = ProofPickupsSessionSnapshot.Empty;
    private CancellationTokenSource? _actionCts;

    private IReadOnlyList<ChapterOption> ChapterOptions
        => Workspace.AvailableChapters
            .Select(chapter => new ChapterOption(chapter, chapter))
            .ToList();

    private sealed record ChapterOption(string Value, string Text);

    private IReadOnlyList<PickupAsset> VisibleMatchedAssets
    {
        get
        {
            if (_snapshot.Matched.Count == 0)
            {
                return Array.Empty<PickupAsset>();
            }

            var lifecycleSentenceIds = _snapshot.Staged
                .Concat(_snapshot.Applied)
                .Concat(_snapshot.Reverted)
                .Concat(_snapshot.Failed)
                .Select(item => item.SentenceId)
                .ToHashSet();

            return _snapshot.Matched
                .Where(asset => !asset.MatchedSentenceId.HasValue || !lifecycleSentenceIds.Contains(asset.MatchedSentenceId.Value))
                .ToArray();
        }
    }

    private bool CanImport
        => !_snapshot.IsBusy
           && _snapshot.HasActiveChapter
           && !string.IsNullOrWhiteSpace(_pickupSourcePath);

    protected override void OnInitialized()
    {
        _pickupSourcePath = AmsPathResolver.NormalizeOptionalPath(Workspace.PickupSessionPath);
        _selectedChapter = Workspace.CurrentChapterName;
        _snapshot = Session.SyncToWorkspace();

        if (string.IsNullOrWhiteSpace(_pickupSourcePath))
        {
            _pickupSourcePath = _snapshot.SourcePath;
        }

        if (string.IsNullOrWhiteSpace(_selectedChapter))
        {
            _selectedChapter = _snapshot.ActiveChapterName;
        }
    }

    private void NavigateToEditing()
    {
        var handoffPath = StageRouteCatalog.GetProofEditingHandoffPath(_snapshot.ActiveChapterName);

        if (!string.IsNullOrWhiteSpace(_snapshot.ActiveChapterName))
        {
            var handoffMatch = StageRouteCatalog.Resolve(handoffPath);
            var resolvesToEditing = handoffMatch is not null
                && string.Equals(handoffMatch.Stage.Id, StageRouteCatalog.StageIds.Proof, StringComparison.OrdinalIgnoreCase)
                && string.Equals(handoffMatch.Module.Id, StageRouteCatalog.ModuleIds.ProofEditing, StringComparison.OrdinalIgnoreCase);

            if (!resolvesToEditing)
            {
                handoffPath = StageRouteCatalog.BuildProofChapterCanonicalPath(_snapshot.ActiveChapterName);
            }
        }

        Navigation.NavigateTo(handoffPath);
    }

    private Task HandleChapterChange(string? chapterName)
    {
        if (string.IsNullOrWhiteSpace(chapterName))
        {
            return Task.CompletedTask;
        }

        if (!Workspace.SelectChapter(chapterName))
        {
            return Task.CompletedTask;
        }

        _selectedChapter = chapterName;
        _snapshot = Session.SyncToWorkspace();

        if (string.IsNullOrWhiteSpace(_pickupSourcePath))
        {
            _pickupSourcePath = _snapshot.SourcePath;
        }

        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task HandleImportAsync()
    {
        if (!CanImport)
        {
            return;
        }

        ReplaceActionCts();
        _snapshot = await Session
            .ImportAsync(_pickupSourcePath ?? string.Empty, _actionCts!.Token)
            .ConfigureAwait(false);

        if (!string.IsNullOrWhiteSpace(_snapshot.SourcePath))
        {
            _pickupSourcePath = _snapshot.SourcePath;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleStageAsync(string assetId)
    {
        _snapshot = await Session
            .StageAsync(assetId)
            .ConfigureAwait(false);

        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleUnstageAsync(string replacementId)
    {
        _snapshot = await Session
            .UnstageAsync(replacementId)
            .ConfigureAwait(false);

        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleCommitAsync(string replacementId)
    {
        ReplaceActionCts();
        _snapshot = await Session
            .CommitAsync(replacementId, _actionCts!.Token)
            .ConfigureAwait(false);

        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleRevertAsync(string replacementId)
    {
        ReplaceActionCts();
        _snapshot = await Session
            .RevertAsync(replacementId, _actionCts!.Token)
            .ConfigureAwait(false);

        await InvokeAsync(StateHasChanged);
    }

    private void HandleCancelActiveAction()
    {
        _actionCts?.Cancel();
    }

    private void ReplaceActionCts()
    {
        if (_actionCts is not null)
        {
            try
            {
                _actionCts.Cancel();
            }
            catch
            {
                // best effort
            }

            _actionCts.Dispose();
        }

        _actionCts = new CancellationTokenSource();
    }

    private CrxPickupTarget? ResolveTarget(PickupAsset asset)
    {
        if (asset.MatchedErrorNumber is int errorNumber)
        {
            var byError = _snapshot.Targets.FirstOrDefault(target => target.ErrorNumber == errorNumber);
            if (byError is not null)
            {
                return byError;
            }
        }

        if (asset.MatchedSentenceId is int sentenceId)
        {
            var bySentence = _snapshot.Targets.FirstOrDefault(target => target.SentenceId == sentenceId);
            if (bySentence is not null)
            {
                return bySentence;
            }
        }

        return null;
    }

    private static string DescribeMatchedAsset(PickupAsset asset, CrxPickupTarget? target)
    {
        var error = asset.MatchedErrorNumber?.ToString() ?? target?.ErrorNumber.ToString() ?? "?";
        var sentenceId = asset.MatchedSentenceId?.ToString() ?? target?.SentenceId.ToString() ?? "?";
        return $"Error #{error} — sentence {sentenceId}";
    }

    private static string FormatRange(double startSec, double endSec)
        => $"{startSec:F3}s to {endSec:F3}s";

    private string GetProgressLabel()
        => _snapshot.Phase switch
        {
            ProofPickupsSessionPhase.ResolvingTargets => "Resolving CRX targets",
            ProofPickupsSessionPhase.Importing => "Matching stitched pickups",
            ProofPickupsSessionPhase.Staging => "Staging pickup operation",
            ProofPickupsSessionPhase.Unstaging => "Unstaging pickup operation",
            ProofPickupsSessionPhase.Committing => "Committing staged pickup",
            ProofPickupsSessionPhase.Reverting => "Reverting committed pickup",
            _ => "Processing"
        };

    private string GetProgressState()
        => _snapshot.Phase switch
        {
            ProofPickupsSessionPhase.Staging => "success",
            ProofPickupsSessionPhase.Committing => "success",
            ProofPickupsSessionPhase.Unstaging => "warning",
            ProofPickupsSessionPhase.Reverting => "warning",
            _ => "info"
        };

    public void Dispose()
    {
        if (_actionCts is null)
        {
            return;
        }

        try
        {
            _actionCts.Cancel();
        }
        catch
        {
            // best effort
        }
        finally
        {
            _actionCts.Dispose();
            _actionCts = null;
        }
    }
}
