    private async Task HandleFitPolicyChangedAsync(PickupFitPlanItem item, string field, string? rawValue)
    {
        if (!CanEditFitItem(item) || !TryGetFitRevision(out var expectedRevision))
        {
            return;
        }

        var roomtoneBeforeSec = item.TransitionPolicy.RoomtoneBeforeSec;
        var roomtoneAfterSec = item.TransitionPolicy.RoomtoneAfterSec;
        var crossfadeDurationSec = item.TransitionPolicy.CrossfadeDurationSec;
        var crossfadeCurve = item.TransitionPolicy.CrossfadeCurve;
        var roomtoneAssetId = item.TransitionPolicy.RoomtoneAssetId;

        switch (field)
        {
            case FitFieldRoomtoneBefore:
                if (!TryParseFitSeconds(rawValue, "roomtone before", out roomtoneBeforeSec))
                {
                    await InvokeAsync(StateHasChanged);
                    return;
                }

                break;
            case FitFieldRoomtoneAfter:
                if (!TryParseFitSeconds(rawValue, "roomtone after", out roomtoneAfterSec))
                {
                    await InvokeAsync(StateHasChanged);
                    return;
                }

                break;
            case FitFieldCrossfadeDuration:
                if (!TryParseFitSeconds(rawValue, "crossfade duration", out crossfadeDurationSec))
                {
                    await InvokeAsync(StateHasChanged);
                    return;
                }

                break;
            case FitFieldCrossfadeCurve:
                if (!TryParseFitCrossfadeCurve(rawValue, out crossfadeCurve))
                {
                    await InvokeAsync(StateHasChanged);
                    return;
                }

                break;
            case FitFieldRoomtoneAsset:
                roomtoneAssetId = string.IsNullOrWhiteSpace(rawValue) ? null : rawValue.Trim();
                break;
            default:
                _fitInputValidationError = $"Unknown Fit policy field '{field}'.";
                await InvokeAsync(StateHasChanged);
                return;
        }

        var policy = new PickupFitTransitionPolicy(
            roomtoneBeforeSec,
            roomtoneAfterSec,
            crossfadeDurationSec,
            crossfadeCurve,
            roomtoneAssetId);

        _fitInputValidationError = null;
        _snapshot = await Session
            .SetFitPolicyAsync(item.FitItemId, expectedRevision, policy)
            .ConfigureAwait(false);

        await InvokeAsync(StateHasChanged);
    }

