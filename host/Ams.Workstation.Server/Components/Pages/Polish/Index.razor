@page "/polish"
@page "/polish/scaffold"
@page "/polish/pickups"
@page "/polish/batch"

<PageTitle>Polish - AMS Workstation</PageTitle>

<div class="polish-index">
    <BitStack Horizontal="false" HorizontalAlign="BitAlignment.Center" Gap="1.5rem">
        <div class="polish-header">
            <BitText Typography="BitTypography.H4">Polish Area</BitText>
            <BitText Typography="BitTypography.Body1" Color="BitColor.SecondaryForeground">
                Polish is intentionally scaffold-only in the shared stage shell for M002/S04.
            </BitText>
        </div>

        <BitCard Class="polish-scaffold-card">
            <BitStack Horizontal="false" Gap="0.75rem">
                <BitTag Color="BitColor.Info">Scaffold</BitTag>
                <BitText Typography="BitTypography.Body2">
                    Use this page to confirm stage continuity while the shell contract remains focused on Prep and Proof handoff behavior.
                </BitText>
                <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">
                    Existing pickup and batch tooling remains available through explicit legacy routes.
                </BitText>
            </BitStack>
        </BitCard>

        <BitCard>
            <BitStack Horizontal="false" Gap="0.75rem">
                <BitText Typography="BitTypography.Subtitle2" Style="text-transform: uppercase; letter-spacing: 0.05em;">
                    Legacy workflows
                </BitText>
                <BitText Typography="BitTypography.Body2" Color="BitColor.SecondaryForeground">
                    These routes are preserved for compatibility but are not part of the stage shell module contract.
                </BitText>

                <BitStack Horizontal="true" Gap="0.75rem" Wrap="true">
                    <BitButton Variant="BitVariant.Outline" Color="BitColor.Primary" Href="@LegacyPickupsPath">
                        Open Legacy Pickup Substitution
                    </BitButton>
                    <BitButton Variant="BitVariant.Outline" Color="BitColor.Primary" Href="@LegacyBatchPath">
                        Open Legacy Batch Editor
                    </BitButton>
                </BitStack>
            </BitStack>
        </BitCard>
    </BitStack>
</div>

@code {
    private const string LegacyPickupsPath = "/polish/legacy/pickups";
    private const string LegacyBatchPath = "/polish/legacy/batch";
}

<style>
    .polish-index {
        max-width: 800px;
        margin: 0 auto;
    }

    .polish-header {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .polish-scaffold-card {
        border: 1px dashed var(--bit-clr-brd-sec);
    }
</style>
