@page "/polish"
@page "/polish/scaffold"
@page "/polish/pickups"
@page "/polish/batch"
@using Ams.Workstation.Server.Components.Navigation

<PageTitle>Polish - AMS Workstation</PageTitle>

<div class="polish-index" data-polish-scaffold-page="true">
    <div class="polish-index__stack">
        <header class="polish-header">
            <h1>Polish Area</h1>
            <p class="polish-header__summary">
                Polish remains scaffold-only in shared shell. Pickup workflow now owned by Proof module.
            </p>
        </header>

        <section class="ams-card polish-scaffold-card" aria-labelledby="polish-scaffold-summary">
            <div class="polish-scaffold-card__stack">
                <span class="ams-tag ams-tag--info ams-tag--md">Scaffold</span>
                <p id="polish-scaffold-summary" class="polish-scaffold-card__summary">
                    Use this page to confirm stage continuity while Prep → Proof → Polish transitions remain stable.
                </p>
                <p class="polish-scaffold-card__caption">
                    Legacy pickup pages were removed. Use Proof Pickups for import/match/stage.
                </p>
                <a href="@GetProofPickupsPath()"
                   class="ams-btn ams-btn--secondary ams-btn--md polish-scaffold-card__action"
                   data-polish-scaffold-link="proof-pickups">
                    Open Proof Pickups
                </a>
            </div>
        </section>
    </div>
</div>

@code {
    private static string GetProofPickupsPath()
        => StageRouteCatalog.GetModuleCanonicalPath(
            StageRouteCatalog.StageIds.Proof,
            StageRouteCatalog.ModuleIds.ProofPickups);
}
