@page "/polish/{ChapterName}"
@inject Ams.Workstation.Server.Services.PolishService PolishService
@inject Ams.Workstation.Server.Services.PolishVerificationService VerificationService
@inject Ams.Workstation.Server.Services.StagingQueueService StagingQueueService
@inject Ams.Workstation.Server.Services.BlazorWorkspace Workspace
@inject Ams.Workstation.Server.Services.CrxService CrxService
@inject Ams.Workstation.Server.Services.PreviewBufferService PreviewBufferService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using Ams.Workstation.Server.Models
@using Ams.Workstation.Server.Services
@using Ams.Core.Common
@using Ams.Core.Artifacts.Hydrate
@using System.Text.RegularExpressions
@implements IAsyncDisposable

<PageTitle>@ChapterName - Polish - AMS Workstation</PageTitle>

<BitStack Horizontal="false" Gap="1rem" AutoHeight="true">
    @* Header *@
    <BitStack Horizontal="true" Gap="0.5rem" VerticalAlign="BitAlignment.Center" AutoHeight="true">
        <BitButton Variant="BitVariant.Text" IconName="@BitIconName.Back" OnClick="NavigateBack" Title="Back to Polish" />
        <BitText Typography="BitTypography.H5">@Uri.UnescapeDataString(ChapterName ?? "")</BitText>
        @if (_stagedItems is { Count: > 0 })
        {
            <BitTag Color="BitColor.Info" Style="margin-left: auto;">
                @_stagedItems.Count staged
            </BitTag>
        }
    </BitStack>

    @* Waveform *@
    <WaveformPlayer
        @ref="_waveformPlayer"
        AudioUrl="@GetAudioUrl()"
        Title="@GetDisplayTitle()"
        TimeUpdated="HandleTimeUpdate"
        OnReady="HandleWaveformReady"
        OnSeek="HandleSeek"
        OnRegionUpdated="HandleRegionUpdated" />

    @* Controls row *@
    <BitStack Horizontal="true" Gap="0.5rem" AutoHeight="true">
        <BitButton Variant="BitVariant.Outline"
                   IconName="@BitIconName.Upload"
                   IsEnabled="@(!_isProcessing)"
                   OnClick="ShowImporter">
            Import Pickup
        </BitButton>
        @if (_stagedItems is { Count: > 0 } && _stagedItems.Any(s => s.Status == ReplacementStatus.Staged))
        {
            <BitButton Variant="BitVariant.Fill"
                       Color="BitColor.Success"
                       IconName="@BitIconName.Accept"
                       IsEnabled="@(!_isProcessing)"
                       OnClick="HandleApplyAll">
                Apply All
            </BitButton>
        }
        @if (_isProcessing)
        {
            <BitProgress Circular="true" Style="width: 24px; height: 24px;" />
            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Processing...</BitText>
        }
    </BitStack>

    @if (!string.IsNullOrEmpty(_statusMessage))
    {
        <BitMessage Color="@_statusColor">
            @_statusMessage
        </BitMessage>
    }

    @* Verification section: shown after apply with revalidation results *@
    @if (_verificationResult is not null && _verificationSegmentStart.HasValue && _verificationSegmentEnd.HasValue)
    {
        <BitCard Style="padding: 0.75rem;">
            <BitText Typography="BitTypography.Subtitle2" Style="margin-bottom: 0.5rem;">Post-Replacement Verification</BitText>
            <ContextPlayer
                WaveformRef="_waveformPlayer"
                SegmentStartSec="@_verificationSegmentStart.Value"
                SegmentEndSec="@_verificationSegmentEnd.Value"
                ValidationResult="@_verificationResult"
                OnAccept="HandleVerificationAccept"
                OnReject="HandleVerificationReject" />
        </BitCard>
    }

    @* Two-column layout *@
    <BitGrid Columns="12">
        <BitGridItem ColumnSpan="7" Style="min-width: 0;">
            <PickupImporter
                ChapterStem="@GetChapterStem()"
                FlaggedSentences="@_flaggedSentences"
                OnMatchesReady="HandleMatchesReady"
                OnStageRequested="HandleStageRequested" />
        </BitGridItem>
        <BitGridItem ColumnSpan="5" Style="min-width: 0;">
            <StagingQueue
                ChapterStem="@GetChapterStem()"
                Items="@_stagedItems"
                OnApply="HandleApply"
                OnRevert="HandleRevert"
                OnRemove="HandleRemove"
                OnApplyAll="HandleApplyAll"
                OnPreview="HandlePreview" />
        </BitGridItem>
    </BitGrid>
</BitStack>

@code {
    private WaveformPlayer? _waveformPlayer;
    private double _currentTime;
    private bool _isWaveformReady;
    private bool _isProcessing;
    private string? _statusMessage;
    private BitColor _statusColor = BitColor.Info;

    private IReadOnlyList<StagedReplacement>? _stagedItems;
    private IReadOnlyList<HydratedSentence>? _flaggedSentences;

    // Preview/corrected state
    private bool _isPreviewMode;
    private long _previewVersion;
    private long _correctedVersion;

    // Verification state
    private RevalidationResult? _verificationResult;
    private double? _verificationSegmentStart;
    private double? _verificationSegmentEnd;
    private int? _verificationSentenceId;

    private static readonly Regex ShouldBeRegex = new(
        @"should\s*be\s*:\s*(?<text>.*?)(?=\r?\n\s*read\s*as\s*:|$)",
        RegexOptions.IgnoreCase | RegexOptions.Singleline | RegexOptions.Compiled);

    private static readonly Regex ReadAsRegex = new(
        @"read\s*as\s*:\s*(?<text>.*)$",
        RegexOptions.IgnoreCase | RegexOptions.Singleline | RegexOptions.Compiled);

    private static readonly Regex ComparePunctuationRegex = new(@"[^\w\s]", RegexOptions.Compiled);
    private static readonly Regex CompareWhitespaceRegex = new(@"\s+", RegexOptions.Compiled);
    private static readonly Regex ChapterNumberRegex = new(@"\d+", RegexOptions.Compiled);

    [Parameter] public string? ChapterName { get; set; }

    protected override void OnParametersSet()
    {
        if (string.IsNullOrEmpty(ChapterName)) return;

        var decodedName = Uri.UnescapeDataString(ChapterName);

        // Select chapter in workspace
        if (Workspace.CurrentChapterName != decodedName)
        {
            Workspace.SelectChapter(decodedName);
        }

        // Load staged replacements
        var stem = GetChapterStem();
        if (!string.IsNullOrEmpty(stem))
        {
            _stagedItems = StagingQueueService.GetQueue(stem);
        }

        // Load flagged sentences (those with CRX errors or diff errors)
        LoadFlaggedSentences(decodedName);
    }

    private void LoadFlaggedSentences(string chapterName)
    {
        if (Workspace.TryGetHydratedTranscript(chapterName, out var hydrated) && hydrated != null)
        {
            // Prefer CRX-constrained targets (chapter + timecode + comments) so pickup
            // matching stays narrow and deterministic.
            var chapterEntries = TryGetCrxChapterEntries(chapterName);
            if (chapterEntries.Count > 0)
            {
                _flaggedSentences = ResolveCrxTargets(chapterEntries, hydrated.Sentences);
                return;
            }

            // Fallback: actionable correction targets from hydrate diff/status.
            _flaggedSentences = hydrated.Sentences.Where(IsPickupCandidate).ToList();
        }
    }

    private static bool IsPickupCandidate(HydratedSentence sentence)
    {
        if (!string.Equals(sentence.Status, "ok", StringComparison.OrdinalIgnoreCase))
            return true;

        var stats = sentence.Diff?.Stats;
        return stats is not null && (stats.Insertions > 0 || stats.Deletions > 0);
    }

    private List<CrxEntry> TryGetCrxChapterEntries(string currentChapterName)
    {
        IReadOnlyList<CrxEntry> entries;
        try
        {
            entries = CrxService.GetEntries();
        }
        catch
        {
            return new List<CrxEntry>();
        }

        if (entries.Count == 0)
            return new List<CrxEntry>();

        return entries
            .Where(e => ChapterMatches(e.Chapter, currentChapterName))
            .OrderBy(e => e.ErrorNumber)
            .ToList();
    }

    private static List<HydratedSentence> ResolveCrxTargets(
        IReadOnlyList<CrxEntry> chapterEntries,
        IReadOnlyList<HydratedSentence> sentences)
    {
        var resolved = new List<HydratedSentence>();
        var seenIds = new HashSet<int>();

        foreach (var entry in chapterEntries)
        {
            var sentence = ResolveSentenceFromCrxEntry(entry, sentences);
            if (sentence == null)
                continue;

            if (seenIds.Add(sentence.Id))
                resolved.Add(sentence);
        }

        return resolved;
    }

    private static HydratedSentence? ResolveSentenceFromCrxEntry(CrxEntry entry, IReadOnlyList<HydratedSentence> sentences)
    {
        if (sentences.Count == 0)
            return null;

        if (entry.SentenceId > 0)
        {
            var direct = sentences.FirstOrDefault(s => s.Id == entry.SentenceId);
            if (direct != null)
                return direct;
        }

        var (shouldBe, readAs) = ParseCrxComments(entry.Comments);
        var hasShouldBe = !string.IsNullOrWhiteSpace(shouldBe);
        var hasReadAs = !string.IsNullOrWhiteSpace(readAs);

        var timedSentences = sentences.Where(s => s.Timing is not null).ToList();
        var candidatePool = timedSentences.Count > 0 ? timedSentences : sentences.ToList();

        double? timeSec = entry.StartTime > 0 ? entry.StartTime : TryParseTimecode(entry.Timecode);
        if (timeSec.HasValue && candidatePool.Count > 0)
        {
            // Keep a nearest-neighbor pool so coarse CRX timecodes (HH:MM:SS)
            // that land near sentence boundaries still consider adjacent lines.
            var nearest = candidatePool
                .Where(s => s.Timing is not null)
                .OrderBy(s => DistanceToSentenceCenterSeconds(s, timeSec.Value))
                .Take(8)
                .ToList();

            var containing = candidatePool
                .Where(s => s.Timing != null
                            && timeSec.Value >= s.Timing.StartSec - 1.5
                            && timeSec.Value <= s.Timing.EndSec + 1.5)
                .ToList();

            if (containing.Count >= 2)
            {
                var merged = containing
                    .Concat(nearest)
                    .GroupBy(s => s.Id)
                    .Select(g => g.First())
                    .OrderBy(s => DistanceToSentenceCenterSeconds(s, timeSec.Value))
                    .Take(8)
                    .ToList();
                candidatePool = merged;
            }
            else
            {
                candidatePool = nearest;
            }
        }

        if (candidatePool.Count == 1)
            return candidatePool[0];

        double bestScore = double.MinValue;
        HydratedSentence? best = null;

        foreach (var sentence in candidatePool)
        {
            double bookScore = hasShouldBe
                ? LevenshteinMetrics.Similarity(
                    NormalizeForCompare(sentence.BookText),
                    NormalizeForCompare(shouldBe))
                : 0;

            double scriptScore = hasReadAs
                ? LevenshteinMetrics.Similarity(
                    NormalizeForCompare(sentence.ScriptText),
                    NormalizeForCompare(readAs))
                : 0;

            double textScore = (hasShouldBe, hasReadAs) switch
            {
                (true, true) => (bookScore + scriptScore) / 2.0,
                (true, false) => bookScore,
                (false, true) => scriptScore,
                _ => 0
            };

            double timeScore = timeSec.HasValue
                ? Math.Max(0, 1.0 - (DistanceToSentenceCenterSeconds(sentence, timeSec.Value) / 20.0))
                : 0;

            double combinedScore = (hasShouldBe || hasReadAs)
                ? (textScore * 0.8) + (timeScore * 0.2)
                : timeScore;

            if (combinedScore > bestScore)
            {
                bestScore = combinedScore;
                best = sentence;
            }
        }

        return best;
    }

    private static (string ShouldBe, string ReadAs) ParseCrxComments(string? comments)
    {
        if (string.IsNullOrWhiteSpace(comments))
            return (string.Empty, string.Empty);

        var shouldBe = "";
        var readAs = "";

        var shouldMatch = ShouldBeRegex.Match(comments);
        if (shouldMatch.Success)
            shouldBe = shouldMatch.Groups["text"].Value.Trim();

        var readMatch = ReadAsRegex.Match(comments);
        if (readMatch.Success)
            readAs = readMatch.Groups["text"].Value.Trim();

        return (shouldBe, readAs);
    }

    private static double? TryParseTimecode(string? timecode)
    {
        if (string.IsNullOrWhiteSpace(timecode))
            return null;

        if (TimeSpan.TryParse(timecode, out var ts))
            return ts.TotalSeconds;

        return null;
    }

    private static bool ChapterMatches(string? crxChapter, string? currentChapter)
    {
        if (string.IsNullOrWhiteSpace(crxChapter) || string.IsNullOrWhiteSpace(currentChapter))
            return false;

        var crxNumber = TryExtractChapterNumber(crxChapter);
        var currentNumber = TryExtractChapterNumber(currentChapter);
        if (crxNumber.HasValue && currentNumber.HasValue)
            return crxNumber.Value == currentNumber.Value;

        return string.Equals(
            NormalizeForCompare(crxChapter),
            NormalizeForCompare(currentChapter),
            StringComparison.Ordinal);
    }

    private static int? TryExtractChapterNumber(string chapterLabel)
    {
        var match = ChapterNumberRegex.Match(chapterLabel);
        if (!match.Success)
            return null;

        return int.TryParse(match.Value, out var value) ? value : null;
    }

    private static double DistanceToSentenceCenterSeconds(HydratedSentence sentence, double timeSec)
    {
        if (sentence.Timing is null)
            return double.MaxValue;

        var center = (sentence.Timing.StartSec + sentence.Timing.EndSec) / 2.0;
        return Math.Abs(center - timeSec);
    }

    private static string NormalizeForCompare(string? text)
    {
        if (string.IsNullOrWhiteSpace(text))
            return string.Empty;

        var normalized = text.ToLowerInvariant().Trim();
        normalized = ComparePunctuationRegex.Replace(normalized, " ");
        normalized = CompareWhitespaceRegex.Replace(normalized, " ").Trim();
        return normalized;
    }

    private string GetAudioUrl()
    {
        if (string.IsNullOrEmpty(ChapterName))
            return "/api/audio";

        if (_isPreviewMode)
            return $"/api/audio/preview?v={_previewVersion}";

        return $"/api/audio/chapter/{Uri.EscapeDataString(ChapterName)}/corrected?v={_correctedVersion}";
    }

    private string GetDisplayTitle()
    {
        var title = Uri.UnescapeDataString(ChapterName ?? "Audio");
        if (_isPreviewMode) return $"{title} (Preview)";
        if (_correctedVersion > 0) return $"{title} (Corrected)";
        return title;
    }

    private string GetChapterStem()
    {
        if (string.IsNullOrEmpty(ChapterName)) return "";
        var decodedName = Uri.UnescapeDataString(ChapterName);
        return Workspace.GetStemForChapter(decodedName) ?? decodedName;
    }

    private void NavigateBack()
    {
        Navigation.NavigateTo("/polish");
    }

    private void HandleTimeUpdate(double time)
    {
        _currentTime = time;
        StateHasChanged();
    }

    private void HandleWaveformReady()
    {
        _isWaveformReady = true;
        StateHasChanged();
    }

    private void HandleSeek(double time)
    {
        _currentTime = time;
    }

    private void HandleRegionUpdated((string Id, double Start, double End) region)
    {
        // Region boundary updates from waveform player are handled by PickupImporter
        // via its own WaveformPlayer instance. This handler is for the main chapter waveform.
    }

    private void ShowImporter()
    {
        // PickupImporter is always visible in the left column; this button
        // scrolls to it or could toggle visibility in future.
    }

    private void HandleMatchesReady(List<PickupMatch> matches)
    {
        _statusMessage = $"Found {matches.Count} match{(matches.Count == 1 ? "" : "es")} in pickup file.";
        _statusColor = matches.Count > 0 ? BitColor.Success : BitColor.Warning;
        StateHasChanged();
    }

    private void HandleStageRequested(StagedReplacement replacement)
    {
        // Refresh the staging queue after a new item is staged
        var stem = GetChapterStem();
        if (!string.IsNullOrEmpty(stem))
        {
            _stagedItems = StagingQueueService.GetQueue(stem);
        }
        _statusMessage = $"Staged replacement for sentence {replacement.SentenceId}.";
        _statusColor = BitColor.Info;
        StateHasChanged();
    }

    private async Task HandleApply(string replacementId)
    {
        _isProcessing = true;
        _verificationResult = null;
        _isPreviewMode = false;
        StateHasChanged();

        try
        {
            // Find the staged item to get segment info for re-validation
            var item = _stagedItems?.FirstOrDefault(s => s.Id == replacementId);

            var (resultBuffer, timingDelta) = await PolishService.ApplyReplacementAsync(replacementId, CancellationToken.None);
            _correctedVersion++;
            _statusMessage = $"Applied replacement. Timing delta: {timingDelta:+0.000;-0.000}s. Re-validating...";
            _statusColor = BitColor.Success;
            StateHasChanged();

            // Auto-trigger re-validation on the affected segment (use actual replaced end, not original)
            if (item is not null)
            {
                await RunRevalidationAsync(resultBuffer, item.OriginalStartSec, item.ActualReplacedEndSec(), item.SentenceId);
            }
        }
        catch (Exception ex)
        {
            _statusMessage = $"Apply failed: {ex.Message}";
            _statusColor = BitColor.Error;
        }
        finally
        {
            RefreshQueue();
            _isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task HandleRevert(string replacementId)
    {
        _isProcessing = true;
        _isPreviewMode = false;
        StateHasChanged();

        try
        {
            var (resultBuffer, timingDelta) = await PolishService.RevertReplacementAsync(replacementId, CancellationToken.None);
            _correctedVersion++;
            _statusMessage = $"Reverted replacement. Timing delta: {timingDelta:+0.000;-0.000}s";
            _statusColor = BitColor.Warning;
        }
        catch (Exception ex)
        {
            _statusMessage = $"Revert failed: {ex.Message}";
            _statusColor = BitColor.Error;
        }
        finally
        {
            RefreshQueue();
            _isProcessing = false;
            StateHasChanged();
        }
    }

    private void HandleRemove(string replacementId)
    {
        StagingQueueService.Unstage(replacementId);
        RefreshQueue();
        _statusMessage = "Removed staged replacement.";
        _statusColor = BitColor.Info;
        StateHasChanged();
    }

    private async Task HandleApplyAll()
    {
        if (_stagedItems is null) return;

        _isProcessing = true;
        _isPreviewMode = false;
        StateHasChanged();

        var applied = 0;
        var failed = 0;

        foreach (var item in _stagedItems.Where(s => s.Status == ReplacementStatus.Staged).ToList())
        {
            try
            {
                await PolishService.ApplyReplacementAsync(item.Id, CancellationToken.None);
                applied++;
            }
            catch
            {
                failed++;
            }
        }

        _correctedVersion++;
        RefreshQueue();
        _isProcessing = false;
        _statusMessage = $"Applied {applied} replacement{(applied == 1 ? "" : "s")}{(failed > 0 ? $", {failed} failed" : "")}.";
        _statusColor = failed > 0 ? BitColor.Warning : BitColor.Success;
        StateHasChanged();
    }

    private async Task HandlePreview(string replacementId)
    {
        if (_waveformPlayer is null || !_isWaveformReady) return;

        var item = _stagedItems?.FirstOrDefault(s => s.Id == replacementId);
        if (item is null) return;

        // Applied items are already in the corrected waveform — exit preview mode so
        // the waveform source switches back to the corrected audio URL
        if (item.Status == ReplacementStatus.Applied)
        {
            if (_isPreviewMode)
            {
                _isPreviewMode = false;
                StateHasChanged();
                await _waveformPlayer.WaitForReadyAsync();
            }
            await _waveformPlayer.PlaySegment(item.OriginalStartSec, item.ActualReplacedEndSec());
            return;
        }

        // Staged items: generate an in-memory splice preview
        try
        {
            _isProcessing = true;
            StateHasChanged();

            PolishService.GeneratePreview(replacementId);
            _previewVersion = PreviewBufferService.Version;
            _isPreviewMode = true;
            StateHasChanged();

            await _waveformPlayer.WaitForReadyAsync();
            await _waveformPlayer.PlaySegment(item.OriginalStartSec, item.ActualReplacedEndSec());
        }
        catch (Exception ex)
        {
            _statusMessage = $"Preview failed: {ex.Message}";
            _statusColor = BitColor.Error;
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

    private void RefreshQueue()
    {
        var stem = GetChapterStem();
        if (!string.IsNullOrEmpty(stem))
        {
            _stagedItems = StagingQueueService.GetQueue(stem);
        }
    }

    /// <summary>
    /// Runs ASR re-validation on the replaced segment and shows the ContextPlayer.
    /// </summary>
    private async Task RunRevalidationAsync(
        Ams.Core.Artifacts.AudioBuffer resultBuffer,
        double segmentStartSec,
        double segmentEndSec,
        int sentenceId)
    {
        try
        {
            // Look up the expected book text for this sentence
            var expectedText = GetExpectedTextForSentence(sentenceId);
            if (string.IsNullOrWhiteSpace(expectedText))
            {
                _statusMessage = "Applied successfully but could not find expected text for re-validation.";
                _statusColor = BitColor.Warning;
                return;
            }

            var result = await VerificationService.RevalidateSegmentAsync(
                resultBuffer, segmentStartSec, segmentEndSec, expectedText, CancellationToken.None);

            // Record in history
            var stem = GetChapterStem();
            if (!string.IsNullOrEmpty(stem))
            {
                VerificationService.RecordResult(stem, result);
            }

            // Show ContextPlayer with results
            _verificationResult = result;
            _verificationSegmentStart = segmentStartSec;
            _verificationSegmentEnd = segmentEndSec;
            _verificationSentenceId = sentenceId;

            _statusMessage = result.Passed
                ? $"Re-validation PASSED ({result.Similarity:P1} similarity). Review and accept or reject."
                : $"Re-validation needs work ({result.Similarity:P1} similarity). Listen and decide.";
            _statusColor = result.Passed ? BitColor.Success : BitColor.Warning;
        }
        catch (Exception ex)
        {
            _statusMessage = $"Applied successfully, but re-validation failed: {ex.Message}";
            _statusColor = BitColor.Warning;
        }
    }

    /// <summary>
    /// Gets the expected book text for a sentence by ID from the flagged sentences list.
    /// </summary>
    private string? GetExpectedTextForSentence(int sentenceId)
    {
        return _flaggedSentences?.FirstOrDefault(s => s.Id == sentenceId)?.BookText;
    }

    /// <summary>
    /// Handles the user accepting a verified fix -- syncs to Proof area.
    /// </summary>
    private async Task HandleVerificationAccept()
    {
        if (_verificationSentenceId is null) return;

        var stem = GetChapterStem();
        if (!string.IsNullOrEmpty(stem))
        {
            await VerificationService.SyncToProofAsync(stem, _verificationSentenceId.Value, passed: true);
        }

        _statusMessage = $"Fix accepted and synced to Proof area for sentence {_verificationSentenceId.Value}.";
        _statusColor = BitColor.Success;

        // Clear verification UI
        _verificationResult = null;
        _verificationSegmentStart = null;
        _verificationSegmentEnd = null;
        _verificationSentenceId = null;
        StateHasChanged();
    }

    /// <summary>
    /// Handles the user rejecting a fix -- suggests revert or boundary adjustment.
    /// </summary>
    private void HandleVerificationReject()
    {
        _statusMessage = "Fix rejected. Consider reverting the replacement or adjusting boundaries and re-applying.";
        _statusColor = BitColor.Warning;

        // Clear verification UI
        _verificationResult = null;
        _verificationSegmentStart = null;
        _verificationSegmentEnd = null;
        _verificationSentenceId = null;
        StateHasChanged();
    }

    public ValueTask DisposeAsync()
    {
        return ValueTask.CompletedTask;
    }
}
