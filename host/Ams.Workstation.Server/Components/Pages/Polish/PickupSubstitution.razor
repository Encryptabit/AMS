    // ── Sentence Lookup ───────────────────────────────────────────
    private HydratedSentence? FindSentence(int sentenceId)
    {
        return _flaggedSentences?.FirstOrDefault(s => s.Id == sentenceId);
    }

    /// <summary>
    /// Finds the corresponding <see cref="PickupAsset"/> for a <see cref="PickupMatch"/>
    /// by correlating on error number and sentence ID. Required for the reassignment
    /// callback path which operates on PickupAsset instances.
    /// </summary>
    private PickupAsset? FindAssetForMatch(PickupMatch match)
    {
        return _matchedPickups.FirstOrDefault(a =>
            a.MatchedErrorNumber == match.ErrorNumber &&
            a.MatchedSentenceId == match.SentenceId);
    }

    // ── CRX Chapter Matching ─────────────────────────────────────
    private static bool ChapterMatches(string? crxChapter, string? currentChapter)
    {
        if (string.IsNullOrWhiteSpace(crxChapter) || string.IsNullOrWhiteSpace(currentChapter))
            return false;

        var crxNumber = TryExtractChapterNumber(crxChapter);
        var currentNumber = TryExtractChapterNumber(currentChapter);
        if (crxNumber.HasValue && currentNumber.HasValue)
            return crxNumber.Value == currentNumber.Value;

        return string.Equals(
            NormalizeForCompare(crxChapter),
            NormalizeForCompare(currentChapter),
            StringComparison.Ordinal);
    }

    private static int? TryExtractChapterNumber(string chapterLabel)
    {
        var match = ChapterNumberRegex.Match(chapterLabel);
        if (!match.Success)
            return null;

        return int.TryParse(match.Value, out var value) ? value : null;
    }

    private static string NormalizeForCompare(string? text)
    {
        if (string.IsNullOrWhiteSpace(text))
            return string.Empty;

        return Regex.Replace(
            Regex.Replace(text.ToLowerInvariant().Trim(), @"[^\w\s]", " "),
            @"\s+", " ").Trim();
    }

    // ── CRX Target Resolution ─────────────────────────────────────
    private static List<HydratedSentence> ResolveCrxTargets(
        IReadOnlyList<CrxEntry> chapterEntries,
        IReadOnlyList<HydratedSentence> sentences)
    {
        if (chapterEntries.Count == 0 || sentences.Count == 0)
            return new List<HydratedSentence>();

        var resolved = new List<HydratedSentence>();
        var seenIds = new HashSet<int>();

        foreach (var entry in chapterEntries)
        {
            var sentence = ResolveSentenceFromCrxEntry(entry, sentences);
            if (sentence == null)
                continue;

            if (seenIds.Add(sentence.Id))
                resolved.Add(sentence);
        }

        return resolved;
    }

    private static HydratedSentence? ResolveSentenceFromCrxEntry(
        CrxEntry entry,
        IReadOnlyList<HydratedSentence> sentences)
    {
        if (sentences.Count == 0)
            return null;

        if (entry.SentenceId > 0)
        {
            var direct = sentences.FirstOrDefault(s => s.Id == entry.SentenceId);
            if (direct != null)
                return direct;
        }

        double? timeSec = entry.StartTime > 0 ? entry.StartTime : TryParseTimecode(entry.Timecode);
        if (timeSec.HasValue)
        {
            var nearest = sentences
                .Where(s => s.Timing is not null)
                .OrderBy(s => DistanceToSentenceCenter(s, timeSec.Value))
                .FirstOrDefault();

            if (nearest != null)
                return nearest;
        }

        return sentences.FirstOrDefault();
    }

    private static double? TryParseTimecode(string? timecode)
    {
        if (string.IsNullOrWhiteSpace(timecode))
            return null;

        if (TimeSpan.TryParse(timecode, out var ts))
            return ts.TotalSeconds;

        return null;
    }

    private static double DistanceToSentenceCenter(HydratedSentence sentence, double timeSec)
    {
        if (sentence.Timing is null)
            return double.MaxValue;

        var center = (sentence.Timing.StartSec + sentence.Timing.EndSec) / 2.0;
        return Math.Abs(center - timeSec);
    }

    private static string? NormalizePathInput(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
            return null;

        var normalized = path.Trim().Trim('"', '\'').Trim();
        return string.IsNullOrWhiteSpace(normalized) ? null : normalized;
    }

    // ── Disposal ──────────────────────────────────────────────────
    public async ValueTask DisposeAsync()
    {
        // Cancel any in-progress processing
        try { _cts.Cancel(); } catch { /* already cancelled */ }
        _cts.Dispose();

        if (_snippetPlayer is not null)
        {
            try
            {
                await _snippetPlayer.InvokeVoidAsync("dispose");
                await _snippetPlayer.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
        }

        // Clear collections to release references
        _matchesByChapter.Clear();
        _chaptersWithCrx.Clear();
        _confirmedLowConfidence.Clear();
        _flaggedSentences = null;
        _stagedItems = null;
        _waveformPlayer = null;
        _snippetPlayer = null;
        _draggedMatch = null;
    }
}
