@page "/polish/pickup"
@inject Ams.Workstation.Server.Services.BlazorWorkspace Workspace
@inject Ams.Workstation.Server.Services.CrxService CrxService
@inject Ams.Workstation.Server.Services.StagingQueueService StagingQueueService
@inject Ams.Workstation.Server.Services.PolishService PolishService
@inject Ams.Workstation.Server.Services.PickupMatchingService PickupMatchingService
@inject Ams.Workstation.Server.Services.PolishVerificationService VerificationService
@inject Ams.Workstation.Server.Services.PreviewBufferService PreviewBufferService
@inject Ams.Workstation.Server.Services.UndoService UndoService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using Ams.Workstation.Server.Models
@using Ams.Workstation.Server.Services
@using Ams.Core.Common
@using Ams.Core.Artifacts.Hydrate
@using System.Text.RegularExpressions
@implements IAsyncDisposable

<PageTitle>Pickup Substitution - AMS Workstation</PageTitle>

<BitStack Horizontal="false" Gap="1rem" AutoHeight="true">

    @* Row 0 - Header Bar: pickup session + roomtone file selectors *@
    <BitCard Style="padding: 0.75rem;">
        <BitStack Horizontal="false" Gap="0.5rem" AutoHeight="true">
            <BitStack Horizontal="true" Gap="0.5rem" VerticalAlign="BitAlignment.Center" AutoHeight="true">
                <BitTextField @bind-Value="_pickupSessionPath"
                              Placeholder="Pickup session WAV file path..."
                              Style="flex: 1;"
                              IsEnabled="@(!_isProcessing)" />
                <BitButton Variant="BitVariant.Fill"
                           OnClick="HandleSetPickupSession"
                           IsEnabled="@(!string.IsNullOrWhiteSpace(_pickupSessionPath) && !_isProcessing)">
                    Set
                </BitButton>
                <BitTextField @bind-Value="_roomtoneFilePath"
                              Placeholder="Roomtone WAV file path..."
                              Style="flex: 1;"
                              IsEnabled="@(!_isProcessing)" />
                <BitButton Variant="BitVariant.Fill"
                           OnClick="HandleSetRoomtone"
                           IsEnabled="@(!string.IsNullOrWhiteSpace(_roomtoneFilePath) && !_isProcessing)">
                    Set
                </BitButton>
            </BitStack>
            @if (_isProcessing)
            {
                <BitStack Horizontal="true" Gap="0.5rem" VerticalAlign="BitAlignment.Center" AutoHeight="true">
                    <BitProgress Percent="@(_processingProgress * 100)"
                                 Label="@(_processingStatus ?? "Processing...")"
                                 ShowPercentNumber="true" />
                </BitStack>
            }
        </BitStack>
    </BitCard>

    @if (!Workspace.IsInitialized || !Workspace.HasBookIndex)
    {
        <BitMessage Color="BitColor.Info">
            No working directory set or book-index.json not found. Go to Home to set a working directory.
        </BitMessage>
    }
    else if (_chaptersWithCrx.Count == 0)
    {
        <BitMessage Color="BitColor.Info">
            No chapters with CRX entries found. Import a CRX file or submit errors from the Proof area first.
        </BitMessage>
    }
    else
    {
        @* Row 1 - Breadcrumb *@
        <BitStack Horizontal="true" Gap="0.5rem" VerticalAlign="BitAlignment.Center" AutoHeight="true">
            @if (_currentChapterIndex >= 0 && _currentChapterIndex < _chaptersWithCrx.Count)
            {
                var current = _chaptersWithCrx[_currentChapterIndex];
                var committedCount = GetCommittedCount(current.Stem);
                <BitText Typography="BitTypography.Subtitle1">
                    @current.ChapterName
                </BitText>
                <BitText Typography="BitTypography.Body2" Color="BitColor.SecondaryForeground">
                    (@(_currentChapterIndex + 1)/@_chaptersWithCrx.Count)
                </BitText>
                <BitText Typography="BitTypography.Body2" Color="BitColor.SecondaryForeground">
                    &mdash; @committedCount/@current.CrxCount committed
                </BitText>
                @if (current.AllCommitted || committedCount >= current.CrxCount)
                {
                    <BitTag Color="BitColor.Success">Complete</BitTag>
                }
            }
        </BitStack>

        @* Row 2 - Waveform with Flippers *@
        <BitStack Horizontal="true" Gap="0.5rem" VerticalAlign="BitAlignment.Center" AutoHeight="true">
            <BitButton Variant="BitVariant.Outline"
                       IconName="@BitIconName.ChevronLeft"
                       IsEnabled="@CanGoPrev"
                       OnClick="HandlePrev"
                       Title="Previous chapter" />
            <div style="flex: 1;">
                <WaveformPlayer
                    @ref="_waveformPlayer"
                    AudioUrl="@GetAudioUrl()"
                    Title="@GetCurrentChapterName()"
                    OnReady="HandleWaveformReady"
                    OnRegionUpdated="HandleRegionUpdated" />
            </div>
            <BitButton Variant="BitVariant.Outline"
                       IconName="@BitIconName.ChevronRight"
                       IsEnabled="@CanGoNext"
                       OnClick="HandleNext"
                       Title="Next chapter" />
        </BitStack>

        @* Row 3 - Three-Column Pipeline *@
        <BitGrid Columns="12">
            @* Column 1: Matches *@
            <BitGridItem ColumnSpan="4" Style="min-width: 0;">
                <BitStack Horizontal="false" Gap="0.5rem" AutoHeight="true">
                    <BitStack Horizontal="true" Gap="0.5rem" VerticalAlign="BitAlignment.Center" AutoHeight="true">
                        <BitText Typography="BitTypography.Subtitle2"
                                 Style="text-transform: uppercase; letter-spacing: 0.05em;">
                            Matches
                        </BitText>
                        <BitTag Color="BitColor.Info">@GetMatchedItems().Count</BitTag>
                        @if (GetMatchedItems().Count > 0)
                        {
                            <BitButton Variant="BitVariant.Text"
                                       Color="BitColor.Info"
                                       OnClick="HandleStageAll"
                                       Style="margin-left: auto;"
                                       IsEnabled="@(!_isProcessing)">
                                Stage All
                            </BitButton>
                        }
                    </BitStack>
                    @foreach (var item in GetMatchedItems())
                    {
                        <div draggable="true"
                             @ondragstart="() => HandleDragStart(item)"
                             @ondragend="HandleDragEnd"
                             class="@(_draggedMatch == item ? "pickup-dragging" : "")">
                            <PickupBox Match="@item.Match"
                                       State="PickupBoxState.Matched"
                                       PickupFilePath="@_pickupSessionPath"
                                       Sentence="@FindSentence(item.Match.SentenceId)"
                                       OnStage="HandleStageMatch"
                                       OnAudition="HandleAudition" />
                        </div>
                    }
                </BitStack>
            </BitGridItem>

            @* Column 2: Staged (drop target for drag-and-drop) *@
            <BitGridItem ColumnSpan="4" Style="min-width: 0;">
                <div @ondragover="HandleDragOver"
                     @ondragover:preventDefault="true"
                     @ondrop="HandleDrop"
                     class="staged-drop-zone">
                <BitStack Horizontal="false" Gap="0.5rem" AutoHeight="true">
                    <BitStack Horizontal="true" Gap="0.5rem" VerticalAlign="BitAlignment.Center" AutoHeight="true">
                        <BitText Typography="BitTypography.Subtitle2"
                                 Style="text-transform: uppercase; letter-spacing: 0.05em;">
                            Staged
                        </BitText>
                        <BitTag Color="BitColor.Warning">@GetStagedItems().Count</BitTag>
                        @if (GetStagedItems().Count > 0)
                        {
                            <BitButton Variant="BitVariant.Text"
                                       Color="BitColor.Success"
                                       OnClick="HandleCommitAll"
                                       Style="margin-left: auto;"
                                       IsEnabled="@(!_isProcessing)">
                                Commit All
                            </BitButton>
                        }
                    </BitStack>
                    @foreach (var item in GetStagedItems())
                    {
                        <PickupBox Replacement="@item"
                                   State="PickupBoxState.Staged"
                                   PickupFilePath="@item.PickupSourcePath"
                                   Sentence="@FindSentence(item.SentenceId)"
                                   OnUnstage="HandleUnstage"
                                   OnCommit="HandleCommit"
                                   OnAudition="HandleAudition" />
                    }
                </BitStack>
                </div>
            </BitGridItem>

            @* Column 3: Committed *@
            <BitGridItem ColumnSpan="4" Style="min-width: 0;">
                <BitStack Horizontal="false" Gap="0.5rem" AutoHeight="true">
                    <BitStack Horizontal="true" Gap="0.5rem" VerticalAlign="BitAlignment.Center" AutoHeight="true">
                        <BitText Typography="BitTypography.Subtitle2"
                                 Style="text-transform: uppercase; letter-spacing: 0.05em;">
                            Committed
                        </BitText>
                        <BitTag Color="BitColor.Success">@GetCommittedItems().Count</BitTag>
                    </BitStack>
                    @foreach (var item in GetCommittedItems())
                    {
                        <PickupBox Replacement="@item"
                                   State="PickupBoxState.Committed"
                                   PickupFilePath="@item.PickupSourcePath"
                                   Sentence="@FindSentence(item.SentenceId)"
                                   OnRevert="HandleRevert" />
                    }
                </BitStack>
            </BitGridItem>
        </BitGrid>

        @* Row 4 - Roomtone Operations (visible when roomtone file is set) *@
        @if (!string.IsNullOrWhiteSpace(_roomtoneFilePath))
        {
            <BitCard Style="padding: 0.75rem;">
                <BitText Typography="BitTypography.Subtitle2" Style="margin-bottom: 0.5rem;">
                    Roomtone Operations
                </BitText>
                <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground"
                         Style="margin-bottom: 0.5rem;">
                    Select a region on the waveform (blue), then choose an operation.
                </BitText>
                <BitStack Horizontal="true" Gap="0.5rem" VerticalAlign="BitAlignment.Center" AutoHeight="true">
                    <BitButton Variant="BitVariant.Outline"
                               IconName="@BitIconName.Add"
                               IsEnabled="@(_roomtoneRegionValid && !_isProcessing)"
                               OnClick="@(() => HandleRoomtoneOp(RoomtoneOperation.Insert))">
                        Insert
                    </BitButton>
                    <BitButton Variant="BitVariant.Outline"
                               IconName="@BitIconName.Switch"
                               IsEnabled="@(_roomtoneRegionValid && !_isProcessing)"
                               OnClick="@(() => HandleRoomtoneOp(RoomtoneOperation.Replace))">
                        Replace
                    </BitButton>
                    <BitButton Variant="BitVariant.Outline"
                               Color="BitColor.Error"
                               IconName="@BitIconName.Delete"
                               IsEnabled="@(_roomtoneRegionValid && !_isProcessing)"
                               OnClick="@(() => HandleRoomtoneOp(RoomtoneOperation.Delete))">
                        Delete
                    </BitButton>
                    <div style="margin-left: 1rem; display: flex; align-items: center; gap: 0.5rem;">
                        <BitText Typography="BitTypography.Caption1">Crossfade:</BitText>
                        <input type="range" min="5" max="200" step="5"
                               value="@_crossfadeDurationMs"
                               @oninput="OnCrossfadeInput"
                               style="width: 120px;" />
                        <BitText Typography="BitTypography.Caption1">@(_crossfadeDurationMs)ms</BitText>
                    </div>
                </BitStack>
                @if (!string.IsNullOrEmpty(_processingStatus) && _processingStatus.Contains("Roomtone"))
                {
                    <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground"
                             Style="margin-top: 0.25rem;">
                        @_processingStatus
                    </BitText>
                }
            </BitCard>
        }
    }
</BitStack>

<style>
    .pickup-dragging {
        opacity: 0.5;
    }

    .staged-drop-zone {
        min-height: 100px;
        transition: background-color 0.2s;
    }

    .staged-drop-zone:has(.pickup-dragging) {
        background-color: rgba(255, 193, 7, 0.08);
        border: 2px dashed rgba(255, 193, 7, 0.4);
        border-radius: 4px;
    }
</style>

@code {
    // ── Book-wide state ───────────────────────────────────────────
    private string? _pickupSessionPath;
    private string? _roomtoneFilePath;
    private bool _isProcessing;
    private string? _processingStatus;
    private double _processingProgress; // 0.0-1.0

    // ── Roomtone state ──────────────────────────────────────────
    private double _roomtoneRegionStart;
    private double _roomtoneRegionEnd;
    private bool _roomtoneRegionValid;
    private int _crossfadeDurationMs = 30; // Default 30ms, range 5-200ms

    // ── Cross-chapter pickup data ─────────────────────────────────
    private Dictionary<string, List<CrossChapterPickupMatch>> _matchesByChapter = new();

    // ── Flipper navigation ────────────────────────────────────────
    private List<ChapterCrxInfo> _chaptersWithCrx = new();
    private int _currentChapterIndex = -1;

    // ── Current chapter state ─────────────────────────────────────
    private WaveformPlayer? _waveformPlayer;
    private bool _isWaveformReady;
    private long _correctedVersion;
    private IReadOnlyList<HydratedSentence>? _flaggedSentences;
    private IReadOnlyList<StagedReplacement>? _stagedItems;

    private record ChapterCrxInfo(string ChapterName, string Stem, int CrxCount, bool AllCommitted);

    // ── Regex helpers (same as ChapterPolish) ─────────────────────
    private static readonly Regex ChapterNumberRegex = new(@"\d+", RegexOptions.Compiled);

    // ── Computed properties ───────────────────────────────────────
    private bool CanGoNext => _currentChapterIndex >= 0 && _currentChapterIndex < _chaptersWithCrx.Count - 1;
    private bool CanGoPrev => _currentChapterIndex > 0;

    // ── Lifecycle ─────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        LoadChaptersWithCrx();

        if (_chaptersWithCrx.Count > 0)
        {
            await NavigateToChapter(0);
        }
    }

    // ── Flipper Navigation ────────────────────────────────────────
    private void LoadChaptersWithCrx()
    {
        _chaptersWithCrx.Clear();

        if (!Workspace.IsInitialized || !Workspace.HasBookIndex)
            return;

        IReadOnlyList<CrxEntry> entries;
        try
        {
            entries = CrxService.GetEntries();
        }
        catch
        {
            return;
        }

        if (entries.Count == 0)
            return;

        foreach (var chapterName in Workspace.AvailableChapters)
        {
            var chapterEntries = entries
                .Where(e => ChapterMatches(e.Chapter, chapterName))
                .ToList();

            if (chapterEntries.Count == 0)
                continue;

            var stem = Workspace.GetStemForChapter(chapterName) ?? chapterName;
            var stagedQueue = StagingQueueService.GetQueue(stem);
            var committedCount = stagedQueue.Count(s => s.Status == ReplacementStatus.Applied);

            _chaptersWithCrx.Add(new ChapterCrxInfo(
                chapterName,
                stem,
                chapterEntries.Count,
                committedCount >= chapterEntries.Count));
        }
    }

    private async Task NavigateToChapter(int index)
    {
        if (index < 0 || index >= _chaptersWithCrx.Count)
            return;

        _currentChapterIndex = index;
        _isWaveformReady = false; // Reset; will be set true again in HandleWaveformReady
        var info = _chaptersWithCrx[index];

        Workspace.SelectChapter(info.ChapterName);
        LoadChapterState(info);
        StateHasChanged();
    }

    private void LoadChapterState(ChapterCrxInfo info)
    {
        // Load flagged sentences
        if (Workspace.TryGetHydratedTranscript(info.ChapterName, out var hydrated) && hydrated != null)
        {
            IReadOnlyList<CrxEntry> entries;
            try { entries = CrxService.GetEntries(); }
            catch { entries = Array.Empty<CrxEntry>(); }

            var chapterEntries = entries
                .Where(e => ChapterMatches(e.Chapter, info.ChapterName))
                .OrderBy(e => e.ErrorNumber)
                .ToList();

            if (chapterEntries.Count > 0)
            {
                _flaggedSentences = ResolveCrxTargets(chapterEntries, hydrated.Sentences);
            }
            else
            {
                _flaggedSentences = hydrated.Sentences
                    .Where(IsPickupCandidate)
                    .ToList();
            }
        }
        else
        {
            _flaggedSentences = null;
        }

        // Load staging queue
        _stagedItems = StagingQueueService.GetQueue(info.Stem);

        // Reset corrected version to force waveform reload
        _correctedVersion++;
    }

    private async Task HandlePrev() => await NavigateToChapter(_currentChapterIndex - 1);
    private async Task HandleNext() => await NavigateToChapter(_currentChapterIndex + 1);

    // ── Drag-and-drop state ──────────────────────────────────────
    private CrossChapterPickupMatch? _draggedMatch;

    // ── Header Actions ────────────────────────────────────────────
    private async Task HandleSetPickupSession()
    {
        await HandlePickupFileSet();
    }

    private async Task HandleSetRoomtone()
    {
        // Add a blue roomtone selection region to the waveform at a default position
        if (_waveformPlayer != null && _isWaveformReady && !string.IsNullOrWhiteSpace(_roomtoneFilePath))
        {
            // Default region: 1-second selection near the start
            var defaultStart = 1.0;
            var defaultEnd = 2.0;
            if (_waveformPlayer.Duration > 0)
            {
                defaultEnd = Math.Min(defaultEnd, _waveformPlayer.Duration * 0.1);
                if (defaultEnd <= defaultStart)
                    defaultEnd = Math.Min(defaultStart + 0.5, _waveformPlayer.Duration);
            }

            _roomtoneRegionStart = defaultStart;
            _roomtoneRegionEnd = defaultEnd;
            _roomtoneRegionValid = defaultEnd > defaultStart;

            await _waveformPlayer.AddEditableRegion(
                "roomtone-selection", defaultStart, defaultEnd,
                "rgba(59, 130, 246, 0.3)"); // Blue for roomtone
        }

        StateHasChanged();
    }

    // ── Upfront Cross-Chapter Processing ──────────────────────────
    private async Task HandlePickupFileSet()
    {
        if (string.IsNullOrWhiteSpace(_pickupSessionPath)) return;
        _isProcessing = true;
        _processingStatus = "Preparing chapters...";
        _processingProgress = 0;
        StateHasChanged();

        try
        {
            // 1. Gather flagged sentences from all CRX chapters
            var chapterTargets = new List<(string Stem, string Name, IReadOnlyList<HydratedSentence> Flagged)>();
            foreach (var ch in _chaptersWithCrx)
            {
                Workspace.SelectChapter(ch.ChapterName);
                if (Workspace.TryGetHydratedTranscript(ch.ChapterName, out var hydrated) && hydrated != null)
                {
                    var flagged = LoadFlaggedSentencesForChapter(ch.ChapterName, hydrated);
                    if (flagged.Count > 0)
                        chapterTargets.Add((ch.Stem, ch.ChapterName, flagged));
                }
            }

            // Restore to current chapter
            if (_currentChapterIndex >= 0 && _currentChapterIndex < _chaptersWithCrx.Count)
                Workspace.SelectChapter(_chaptersWithCrx[_currentChapterIndex].ChapterName);

            // 2. Run cross-chapter import with progress
            var progress = new Progress<(string Status, double Progress)>(p =>
            {
                _processingStatus = p.Status;
                _processingProgress = p.Progress;
                InvokeAsync(StateHasChanged);
            });

            _matchesByChapter = await PolishService.ImportPickupsCrossChapterAsync(
                _pickupSessionPath.Trim(), chapterTargets, progress, CancellationToken.None);

            _processingStatus = $"Found {_matchesByChapter.Values.Sum(m => m.Count)} matches across {_matchesByChapter.Count} chapters.";
        }
        catch (Exception ex) { _processingStatus = $"Processing failed: {ex.Message}"; }
        finally
        {
            _isProcessing = false;
            await SyncWaveformRegions();
            StateHasChanged();
        }
    }

    private IReadOnlyList<HydratedSentence> LoadFlaggedSentencesForChapter(
        string chapterName, HydratedTranscript hydrated)
    {
        IReadOnlyList<CrxEntry> entries;
        try { entries = CrxService.GetEntries(); }
        catch { entries = Array.Empty<CrxEntry>(); }

        var chapterEntries = entries
            .Where(e => ChapterMatches(e.Chapter, chapterName))
            .OrderBy(e => e.ErrorNumber)
            .ToList();

        if (chapterEntries.Count > 0)
            return ResolveCrxTargets(chapterEntries, hydrated.Sentences);

        return hydrated.Sentences
            .Where(IsPickupCandidate)
            .ToList();
    }

    // ── Column State Derivation ───────────────────────────────────
    private IReadOnlyList<CrossChapterPickupMatch> GetMatchedItems()
    {
        if (_currentChapterIndex < 0 || _currentChapterIndex >= _chaptersWithCrx.Count)
            return Array.Empty<CrossChapterPickupMatch>();

        var stem = _chaptersWithCrx[_currentChapterIndex].Stem;
        if (!_matchesByChapter.TryGetValue(stem, out var matches))
            return Array.Empty<CrossChapterPickupMatch>();

        // Exclude items that have a StagedReplacement (Staged or Applied status)
        var stagedSentenceIds = (_stagedItems ?? Array.Empty<StagedReplacement>())
            .Where(s => s.Status == ReplacementStatus.Staged || s.Status == ReplacementStatus.Applied)
            .Select(s => s.SentenceId)
            .ToHashSet();

        return matches
            .Where(m => !stagedSentenceIds.Contains(m.Match.SentenceId))
            .ToList();
    }

    private IReadOnlyList<StagedReplacement> GetStagedItems()
    {
        return (_stagedItems ?? Array.Empty<StagedReplacement>())
            .Where(s => s.Status == ReplacementStatus.Staged)
            .ToList();
    }

    private IReadOnlyList<StagedReplacement> GetCommittedItems()
    {
        return (_stagedItems ?? Array.Empty<StagedReplacement>())
            .Where(s => s.Status == ReplacementStatus.Applied)
            .ToList();
    }

    private int GetCommittedCount(string stem)
    {
        var queue = StagingQueueService.GetQueue(stem);
        return queue.Count(s => s.Status == ReplacementStatus.Applied);
    }

    // ── Action Handlers ───────────────────────────────────────────
    private async Task HandleStageMatch(PickupMatch match)
    {
        if (_currentChapterIndex < 0 || _currentChapterIndex >= _chaptersWithCrx.Count)
            return;

        var info = _chaptersWithCrx[_currentChapterIndex];
        var sentence = FindSentence(match.SentenceId);
        if (sentence?.Timing == null || string.IsNullOrWhiteSpace(_pickupSessionPath))
            return;

        try
        {
            PolishService.StageReplacement(
                info.Stem,
                match,
                _pickupSessionPath.Trim(),
                sentence.Timing.StartSec,
                sentence.Timing.EndSec);

            RefreshCurrentChapterState();
            await SyncWaveformRegions();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Stage failed: {ex.Message}");
        }
    }

    private async Task HandleUnstage(string replacementId)
    {
        StagingQueueService.Unstage(replacementId);
        RefreshCurrentChapterState();
        await SyncWaveformRegions();
    }

    private async Task HandleStageAll()
    {
        var matched = GetMatchedItems();
        foreach (var m in matched)
            await HandleStageMatch(m.Match);
    }

    private async Task HandleCommit(string replacementId)
    {
        _isProcessing = true;
        StateHasChanged();

        try
        {
            var (resultBuffer, timingDelta) = await PolishService.ApplyReplacementAsync(
                replacementId, CancellationToken.None);

            _correctedVersion++; // Force waveform URL cache-bust
            RefreshCurrentChapterState();
            await SyncWaveformRegions();

            // Check for chapter completion
            await CheckCompletionAndAdvance();
        }
        catch (Exception ex)
        {
            _processingStatus = $"Commit failed: {ex.Message}";
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task HandleCommitAll()
    {
        var staged = GetStagedItems().ToList();
        _isProcessing = true;
        StateHasChanged();

        var committed = 0;
        foreach (var item in staged)
        {
            try
            {
                await PolishService.ApplyReplacementAsync(item.Id, CancellationToken.None);
                committed++;
            }
            catch { /* continue with next */ }
        }

        _correctedVersion++;
        RefreshCurrentChapterState();
        await SyncWaveformRegions();
        _isProcessing = false;
        _processingStatus = $"Committed {committed}/{staged.Count} replacements.";
        await CheckCompletionAndAdvance();
        StateHasChanged();
    }

    private async Task HandleRevert(string replacementId)
    {
        _isProcessing = true;
        StateHasChanged();

        try
        {
            await PolishService.RevertReplacementAsync(replacementId, CancellationToken.None);
            _correctedVersion++;
            RefreshCurrentChapterState();
            await SyncWaveformRegions();
        }
        catch (Exception ex)
        {
            _processingStatus = $"Revert failed: {ex.Message}";
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task HandleAudition(string id)
    {
        if (_waveformPlayer == null || !_isWaveformReady) return;

        // Try to find a staged item to audition its pickup segment via preview
        var stagedItem = (_stagedItems ?? Array.Empty<StagedReplacement>())
            .FirstOrDefault(s => s.Id == id);
        if (stagedItem != null)
        {
            try
            {
                PolishService.GeneratePreview(stagedItem.Id);
                // Play the replacement region on the chapter waveform
                await _waveformPlayer.PlaySegment(
                    stagedItem.OriginalStartSec,
                    stagedItem.OriginalStartSec + stagedItem.PickupDuration());
            }
            catch { /* Non-critical audition failure */ }
            return;
        }

        // For matched items, find by extracting sentenceId from "match-{id}" format
        if (id.StartsWith("match-") && int.TryParse(id["match-".Length..], out var sentenceId))
        {
            var sentence = _flaggedSentences?.FirstOrDefault(s => s.Id == sentenceId);
            if (sentence?.Timing != null)
            {
                await _waveformPlayer.PlaySegment(sentence.Timing.StartSec, sentence.Timing.EndSec);
            }
        }
    }

    // ── Waveform Region Management ─────────────────────────────────
    private async Task HandleWaveformReady()
    {
        _isWaveformReady = true;
        await SyncWaveformRegions();
        StateHasChanged();
    }

    private async Task HandleRegionUpdated((string Id, double Start, double End) region)
    {
        // Handle roomtone selection region updates
        if (region.Id == "roomtone-selection")
        {
            _roomtoneRegionStart = region.Start;
            _roomtoneRegionEnd = region.End;
            _roomtoneRegionValid = region.End > region.Start + 0.001;
            StateHasChanged();
            return;
        }

        // Extract replacement ID from region ID (format: "staged-{replacementId}")
        if (!region.Id.StartsWith("staged-")) return;
        var replacementId = region.Id["staged-".Length..];

        // Update boundaries in staging queue
        StagingQueueService.UpdateBoundaries(replacementId, region.Start, region.End);
        RefreshCurrentChapterState();
    }

    private async Task SyncWaveformRegions()
    {
        if (_waveformPlayer == null || !_isWaveformReady) return;

        // Clear all existing regions
        await _waveformPlayer.ClearRegions();

        // Add editable regions for staged items (green)
        var staged = GetStagedItems();
        foreach (var item in staged)
        {
            await _waveformPlayer.AddEditableRegion(
                $"staged-{item.Id}",
                item.OriginalStartSec,
                item.OriginalEndSec,
                "rgba(59, 200, 120, 0.3)"); // Green for staged
        }

        // Add non-editable regions for committed items (gray, dimmed)
        var committed = GetCommittedItems();
        foreach (var item in committed)
        {
            await _waveformPlayer.AddRegion(
                $"committed-{item.Id}",
                item.OriginalStartSec,
                item.OriginalStartSec + item.PickupDuration(),
                "rgba(150, 150, 150, 0.25)"); // Gray for committed
        }

        // Add roomtone selection region (blue) if roomtone file is set
        if (!string.IsNullOrWhiteSpace(_roomtoneFilePath) && _roomtoneRegionValid)
        {
            await _waveformPlayer.AddEditableRegion(
                "roomtone-selection",
                _roomtoneRegionStart,
                _roomtoneRegionEnd,
                "rgba(59, 130, 246, 0.3)"); // Blue for roomtone selection
        }
    }

