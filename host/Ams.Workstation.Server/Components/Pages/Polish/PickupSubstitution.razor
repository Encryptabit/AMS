    private async Task HandleRegionUpdated((string Id, double Start, double End) region)
    {
        // Handle roomtone selection region updates
        if (region.Id == "roomtone-selection")
        {
            _roomtoneRegionStart = region.Start;
            _roomtoneRegionEnd = region.End;
            _roomtoneRegionValid = region.End > region.Start + 0.001;
            StateHasChanged();
            return;
        }

        // Handle pickup trim region updates
        if (region.Id == "pickup-trim" && _selectedPickup != null)
        {
            _selectedPickup = _selectedPickup with
            {
                TrimStartSec = Math.Max(0, region.Start),
                TrimEndSec = region.End
            };

            // Update in the matched/unmatched lists
            var matchedIdx = _matchedPickups.FindIndex(p => p.Id == _selectedPickup.Id);
            if (matchedIdx >= 0) _matchedPickups[matchedIdx] = _selectedPickup;
            var unmatchedIdx = _unmatchedPickups.FindIndex(p => p.Id == _selectedPickup.Id);
            if (unmatchedIdx >= 0) _unmatchedPickups[unmatchedIdx] = _selectedPickup;

            // If there's a corresponding staged replacement, update its pickup boundaries
            if (_selectedPickup.MatchedSentenceId.HasValue)
            {
                var replacement = (_stagedItems ?? Array.Empty<StagedReplacement>())
                    .FirstOrDefault(s => s.SentenceId == _selectedPickup.MatchedSentenceId.Value
                                         && s.Status == ReplacementStatus.Staged);
                if (replacement != null)
                {
                    StagingQueueService.TryUpdatePickupBoundaries(
                        replacement.Id, region.Start, region.End, out _);
                    RefreshCurrentChapterState();
                }
            }

            StateHasChanged();
            return;
        }

        // Extract replacement ID from region ID (format: "staged-{replacementId}")
        if (!region.Id.StartsWith("staged-")) return;
        var replacementId = region.Id["staged-".Length..];

        var stem = GetCurrentChapterStem();
        if (stem == null) return;

        // The region boundaries come in current-time space (projected).
        // Convert back to baseline coordinates for storage:
        // newBaseline = oldBaseline + (newCurrent - oldCurrent)
        var replacement2 = (_stagedItems ?? Array.Empty<StagedReplacement>())
            .FirstOrDefault(s => s.Id == replacementId);
        if (replacement2 == null) return;

        var oldCurrentStart = StagingQueueService.GetCurrentTime(stem, replacement2.OriginalStartSec);
        var oldCurrentEnd = StagingQueueService.GetCurrentTime(stem, replacement2.OriginalEndSec);
        var newBaselineStart = replacement2.OriginalStartSec + (region.Start - oldCurrentStart);
        var newBaselineEnd = replacement2.OriginalEndSec + (region.End - oldCurrentEnd);

        // Update boundaries in staging queue with baseline coordinates.
        if (!StagingQueueService.TryUpdateBoundaries(replacementId, newBaselineStart, newBaselineEnd, out var error))
        {
            _processingStatus = $"Boundary update rejected: {error}";
            RefreshCurrentChapterState();
            await SyncWaveformRegions();
            StateHasChanged();
            return;
        }

        RefreshCurrentChapterState();
    }

    private async Task SyncWaveformRegions()
    {
        if (_waveformPlayer == null || !_isWaveformReady) return;

        var stem = GetCurrentChapterStem();

        // Clear all existing regions
        await _waveformPlayer.ClearRegions();

        // Add editable regions for staged items (green) at projection-mapped positions
        var staged = GetStagedItems();
        foreach (var item in staged)
        {
            var currentStart = stem != null
                ? StagingQueueService.GetCurrentTime(stem, item.OriginalStartSec)
                : item.OriginalStartSec;
            var currentEnd = stem != null
                ? StagingQueueService.GetCurrentTime(stem, item.OriginalEndSec)
                : item.OriginalEndSec;

            await _waveformPlayer.AddEditableRegion(
                $"staged-{item.Id}",
                currentStart,
                currentEnd,
                "rgba(59, 200, 120, 0.3)"); // Green for staged
        }

        // Add non-editable regions for committed items (gray, dimmed) at projected positions
        var committed = GetCommittedItems();
        foreach (var item in committed)
        {
            var currentStart = stem != null
                ? StagingQueueService.GetCurrentTime(stem, item.OriginalStartSec)
                : item.OriginalStartSec;

            await _waveformPlayer.AddRegion(
                $"committed-{item.Id}",
                currentStart,
                currentStart + item.PickupDuration(),
                "rgba(150, 150, 150, 0.25)"); // Gray for committed
        }

        // Add roomtone selection region (blue) if roomtone file is set
        if (!string.IsNullOrWhiteSpace(_roomtoneFilePath) && _roomtoneRegionValid)
        {
            await _waveformPlayer.AddEditableRegion(
                "roomtone-selection",
                _roomtoneRegionStart,
                _roomtoneRegionEnd,
                "rgba(59, 130, 246, 0.3)"); // Blue for roomtone selection
        }
    }

