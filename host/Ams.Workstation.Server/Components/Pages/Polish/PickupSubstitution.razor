            _correctedVersion++;
            _processingStatus = $"Roomtone {operation} applied successfully.";
            RefreshCurrentChapterState();
            await SyncWaveformRegions();
        }
        catch (Exception ex) { _processingStatus = $"Roomtone operation failed: {ex.Message}"; }
        finally { _isProcessing = false; StateHasChanged(); }
    }

