    private async Task HandleAudition(string id)
    {
        // Try to find a replacement to audition in the active chapter
        var replacementItem = (_stagedItems ?? Array.Empty<StagedReplacement>())
            .FirstOrDefault(s => s.Id == id);
        if (replacementItem != null)
        {
            try
            {
                if (replacementItem.Status == ReplacementStatus.Staged)
                {
                    // Stage audition uses a sidecar player so the chapter waveform stays loaded.
                    _snippetPlayer ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/snippet-player.js");

                    var (previewVersion, chapterStartSec, chapterEndSec) =
                        PolishService.GenerateAuditionClip(replacementItem.Id);

                    if (_waveformPlayer != null && _isWaveformReady)
                    {
                        await _waveformPlayer.SeekTo(chapterStartSec);
                    }

                    await _snippetPlayer.InvokeVoidAsync(
                        "playSegment",
                        $"/api/audio/preview?v={previewVersion}",
                        new
                        {
                            waveformElementId = _waveformPlayer?.ElementId,
                            chapterStartSec,
                            chapterEndSec
                        });
                    return;
                }

                if (_waveformPlayer != null && _isWaveformReady && replacementItem.Status == ReplacementStatus.Applied)
                {
                    await StopSidecarIfActive();

                    // Committed/applied audition plays directly from corrected chapter audio.
                    await _waveformPlayer.PlaySegment(
                        replacementItem.OriginalStartSec,
                        replacementItem.OriginalStartSec + replacementItem.PickupDuration());
                }
            }
            catch { /* Non-critical audition failure */ }
            return;
        }

        if (_waveformPlayer == null || !_isWaveformReady) return;
        await StopSidecarIfActive();

        // For matched items, find by extracting sentenceId from "match-{id}" format
        if (id.StartsWith("match-") && int.TryParse(id["match-".Length..], out var sentenceId))
        {
            var sentence = _flaggedSentences?.FirstOrDefault(s => s.Id == sentenceId);
            if (sentence?.Timing != null)
            {
                await _waveformPlayer.PlaySegment(sentence.Timing.StartSec, sentence.Timing.EndSec);
            }
        }
    }

    private async Task HandleAuditionContext(string replacementId)
    {
        try
        {
            _snippetPlayer ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/snippet-player.js");

            var (previewVersion, chapterStartSec, chapterEndSec) =
                PolishService.GenerateContextPlaybackPreview(replacementId);

            if (_waveformPlayer != null && _isWaveformReady)
            {
                await _waveformPlayer.SeekTo(chapterStartSec);
            }

            await _snippetPlayer.InvokeVoidAsync(
                "playSegment",
                $"/api/audio/preview?v={previewVersion}",
                new
                {
                    waveformElementId = _waveformPlayer?.ElementId,
                    chapterStartSec,
                    chapterEndSec
                });
        }
        catch { /* Non-critical context audition failure */ }
    }

    private async Task HandleManualAssign((PickupAsset Asset, CrxPickupTarget Target) args)
    {
        // Create a new PickupAsset with updated match fields
        var assigned = args.Asset with
        {
            MatchedErrorNumber = args.Target.ErrorNumber,
            MatchedSentenceId = args.Target.SentenceId,
            MatchedChapterStem = args.Target.ChapterStem
        };

        // Move from unmatched to matched
        _unmatchedPickups.Remove(args.Asset);
        _matchedPickups.Add(assigned);

        // Also add a CrossChapterPickupMatch to _matchesByChapter so staging works
        var match = new PickupMatch(
            SentenceId: args.Target.SentenceId,
            PickupStartSec: assigned.TrimStartSec,
            PickupEndSec: assigned.TrimEndSec,
            Confidence: assigned.Confidence,
            RecognizedText: assigned.TranscribedText,
            ErrorNumber: args.Target.ErrorNumber,
            IsLowConfidence: false);

        var crossMatch = new CrossChapterPickupMatch(args.Target.ChapterStem, match);
        if (!_matchesByChapter.TryGetValue(args.Target.ChapterStem, out var chapterMatches))
        {
            chapterMatches = new List<CrossChapterPickupMatch>();
            _matchesByChapter[args.Target.ChapterStem] = chapterMatches;
        }
        chapterMatches.Add(crossMatch);

        await SyncWaveformRegions();
        StateHasChanged();
    }

    private async Task HandleReassign((PickupAsset Asset, CrxPickupTarget Target) args)
    {
        // Remove old match from _matchesByChapter if it exists
        if (args.Asset.MatchedChapterStem != null &&
            _matchesByChapter.TryGetValue(args.Asset.MatchedChapterStem, out var oldChapterMatches))
        {
            oldChapterMatches.RemoveAll(m =>
                m.Match.ErrorNumber == args.Asset.MatchedErrorNumber);
        }

        // Create updated asset
        var reassigned = args.Asset with
        {
            MatchedErrorNumber = args.Target.ErrorNumber,
            MatchedSentenceId = args.Target.SentenceId,
            MatchedChapterStem = args.Target.ChapterStem
        };

        // Update in matched list
        var idx = _matchedPickups.FindIndex(p => p.Id == args.Asset.Id);
        if (idx >= 0) _matchedPickups[idx] = reassigned;

        // Add new CrossChapterPickupMatch
        var match = new PickupMatch(
            SentenceId: args.Target.SentenceId,
            PickupStartSec: reassigned.TrimStartSec,
            PickupEndSec: reassigned.TrimEndSec,
            Confidence: reassigned.Confidence,
            RecognizedText: reassigned.TranscribedText,
            ErrorNumber: args.Target.ErrorNumber,
            IsLowConfidence: false);

        var crossMatch = new CrossChapterPickupMatch(args.Target.ChapterStem, match);
        if (!_matchesByChapter.TryGetValue(args.Target.ChapterStem, out var newChapterMatches))
        {
            newChapterMatches = new List<CrossChapterPickupMatch>();
            _matchesByChapter[args.Target.ChapterStem] = newChapterMatches;
        }
        newChapterMatches.Add(crossMatch);

        await SyncWaveformRegions();
        StateHasChanged();
    }

    private void HandlePickupBoxSelect(string id)
    {
        // Find the selected pickup asset or staged replacement for the detail panel
        _selectedPickup = _matchedPickups.FirstOrDefault(p => p.Id == id)
                       ?? _unmatchedPickups.FirstOrDefault(p => p.Id == id);

        if (_selectedPickup == null)
        {
            // Check if it's a staged replacement ID
            _selectedReplacement = (_stagedItems ?? Array.Empty<StagedReplacement>())
                .FirstOrDefault(s => s.Id == id);
        }
        else
        {
            _selectedReplacement = null;
        }

        _isPickupWaveformReady = false;
        StateHasChanged();
    }

