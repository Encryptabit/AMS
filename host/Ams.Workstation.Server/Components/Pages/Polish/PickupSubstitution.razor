@page "/polish"
@inject Ams.Workstation.Server.Services.BlazorWorkspace Workspace
@inject Ams.Workstation.Server.Services.CrxService CrxService
@inject Ams.Workstation.Server.Services.StagingQueueService StagingQueueService
@inject Ams.Workstation.Server.Services.PolishService PolishService
@inject Ams.Workstation.Server.Services.PickupMatchingService PickupMatchingService
@inject Ams.Workstation.Server.Services.PickupAssetService PickupAssetService
@inject Ams.Workstation.Server.Services.EditListService EditListService
@inject Ams.Workstation.Server.Services.PolishVerificationService VerificationService
@inject Ams.Workstation.Server.Services.UndoService UndoService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using Ams.Workstation.Server.Models
@using Ams.Workstation.Server.Services
@using Ams.Core.Common
@using Ams.Core.Artifacts.Hydrate
@using Microsoft.JSInterop
@using System.Text.RegularExpressions
@implements IAsyncDisposable

<PageTitle>Pickup Substitution - AMS Workstation</PageTitle>

<SectionContent SectionName="header-extra">
    <div style="display: flex; align-items: center; gap: 0.5rem; flex-shrink: 1; min-width: 0;">
        <BitTextField @bind-Value="_pickupSessionPath"
                      Placeholder="Pickup WAV path..."
                      Style="width: 220px; flex-shrink: 1; min-width: 120px;"
                      IsEnabled="@(!_isProcessing)" />
        <BitButton Variant="BitVariant.Fill"
                   Size="BitSize.Small"
                   OnClick="HandleSetPickupSession"
                   IsEnabled="@(!string.IsNullOrWhiteSpace(_pickupSessionPath) && !_isProcessing)">
            Set
        </BitButton>
        <BitTextField @bind-Value="_roomtoneFilePath"
                      Placeholder="Roomtone WAV path..."
                      Style="width: 220px; flex-shrink: 1; min-width: 120px;"
                      IsEnabled="@(!_isProcessing)" />
        <BitButton Variant="BitVariant.Fill"
                   Size="BitSize.Small"
                   OnClick="HandleSetRoomtone"
                   IsEnabled="@(!string.IsNullOrWhiteSpace(_roomtoneFilePath) && !_isProcessing)">
            Set
        </BitButton>
    </div>
</SectionContent>

<BitStack Horizontal="false" Gap="1rem" AutoHeight="true">

    @if (_isProcessing)
    {
        <BitProgress Percent="@(_processingProgress * 100)"
                     Label="@(_processingStatus ?? "Processing...")"
                     ShowPercentNumber="true" />
    }

    @if (!Workspace.IsInitialized || !Workspace.HasBookIndex)
    {
        <BitMessage Color="BitColor.Info">
            No working directory set or book-index.json not found. Go to Home to set a working directory.
        </BitMessage>
    }
    else if (_chaptersWithCrx.Count == 0)
    {
        <BitMessage Color="BitColor.Info">
            No chapters with CRX entries found. Import a CRX file or submit errors from the Proof area first.
        </BitMessage>
    }
    else
    {
        @* Migration warning banner *@
        @if (_showMigrationWarning)
        {
            <BitMessage Color="BitColor.Warning">
                <BitStack Horizontal="true" Gap="0.5rem" VerticalAlign="BitAlignment.Center" AutoHeight="true">
                    <BitText Typography="BitTypography.Body2">
                        Existing staged items use the old timeline format.
                        Clear and re-import pickups to use the new system with projection-mapped boundaries.
                    </BitText>
                    <BitButton Variant="BitVariant.Outline"
                               Color="BitColor.Warning"
                               Size="BitSize.Small"
                               OnClick="HandleClearAndRestart"
                               IsEnabled="@(!_isProcessing)">
                        Clear &amp; Restart
                    </BitButton>
                    <BitButton Variant="BitVariant.Text"
                               Size="BitSize.Small"
                               OnClick="() => { _showMigrationWarning = false; StateHasChanged(); }">
                        Dismiss
                    </BitButton>
                </BitStack>
            </BitMessage>
        }

        @* Row 1 - Breadcrumb *@
        <BitStack Horizontal="true" Gap="0.5rem" VerticalAlign="BitAlignment.Center" AutoHeight="true">
            @if (_currentChapterIndex >= 0 && _currentChapterIndex < _chaptersWithCrx.Count)
            {
                var current = _chaptersWithCrx[_currentChapterIndex];
                var committedCount = GetCommittedCount(current.Stem);
                <BitText Typography="BitTypography.Subtitle1">
                    @current.ChapterName
                </BitText>
                <BitText Typography="BitTypography.Body2" Color="BitColor.SecondaryForeground">
                    (@(_currentChapterIndex + 1)/@_chaptersWithCrx.Count)
                </BitText>
                <BitText Typography="BitTypography.Body2" Color="BitColor.SecondaryForeground">
                    &mdash; @committedCount/@current.CrxCount committed
                </BitText>
                @if (current.AllCommitted || committedCount >= current.CrxCount)
                {
                    <BitTag Color="BitColor.Success">Complete</BitTag>
                }
            }
        </BitStack>

        @* Row 2 - Waveform with Flippers *@
        <BitStack Horizontal="true" Gap="0.5rem" VerticalAlign="BitAlignment.Center" AutoHeight="true"
                  Style="min-width: 0; overflow: hidden;">
            <BitButton Variant="BitVariant.Outline"
                       IconName="@BitIconName.ChevronLeft"
                       IsEnabled="@(!_isProcessing && CanGoPrev)"
                       OnClick="HandlePrev"
                       Title="Previous chapter" />
            <div style="flex: 1; min-width: 0; overflow: hidden;">
                <WaveformPlayer
                    @ref="_waveformPlayer"
                    AudioUrl="@GetAudioUrl()"
                    PeaksUrl="@GetPeaksUrl()"
                    Title="@GetCurrentChapterName()"
                    OnReady="HandleWaveformReady"
                    OnRegionUpdated="HandleRegionUpdated" />
            </div>
            <BitButton Variant="BitVariant.Outline"
                       IconName="@BitIconName.ChevronRight"
                       IsEnabled="@(!_isProcessing && CanGoNext)"
                       OnClick="HandleNext"
                       Title="Next chapter" />
        </BitStack>

        @* Row 3 - Three-Column Pipeline *@
        <BitGrid Columns="12">
            @* Column 1: Matches *@
            <BitGridItem ColumnSpan="4" Style="min-width: 0;">
                <BitStack Horizontal="false" Gap="0.5rem" AutoHeight="true">
                    <BitStack Horizontal="true" Gap="0.5rem" VerticalAlign="BitAlignment.Center" AutoHeight="true">
                        <BitText Typography="BitTypography.Subtitle2"
                                 Style="text-transform: uppercase; letter-spacing: 0.05em;">
                            Matches
                        </BitText>
                        <BitTag Color="BitColor.Info">@GetMatchedItems().Count</BitTag>
                        @if (GetMatchedItems().Count > 0)
                        {
                            <BitButton Variant="BitVariant.Text"
                                       Color="BitColor.Info"
                                       OnClick="HandleStageAll"
                                       Style="margin-left: auto;"
                                       IsEnabled="@(!_isProcessing && !GetMatchedItems().Any(m => m.Match.IsLowConfidence && !IsLowConfidenceConfirmed(m.Match)))">
                                Stage All
                            </BitButton>
                        }
                    </BitStack>
                    @foreach (var item in GetMatchedItems())
                    {
                        <div draggable="@(!item.Match.IsLowConfidence || IsLowConfidenceConfirmed(item.Match))"
                             @ondragstart="() => HandleDragStart(item)"
                             @ondragend="HandleDragEnd"
                             class="@(_draggedMatch == item ? "pickup-dragging" : "")">
                            @if (item.Match.IsLowConfidence && !IsLowConfidenceConfirmed(item.Match))
                            {
                                <BitCard Style="border: 1px solid var(--bit-clr-wrn-dark); padding: 0.5rem;">
                                    <BitStack Horizontal="false" Gap="0.25rem" AutoHeight="true">
                                        <BitStack Horizontal="true" Gap="0.25rem" VerticalAlign="BitAlignment.Center" AutoHeight="true">
                                            <BitTag Color="BitColor.Warning">Low Confidence</BitTag>
                                            <BitText Typography="BitTypography.Caption1">
                                                @($"{item.Match.Confidence:P0}") match for sentence @item.Match.SentenceId
                                            </BitText>
                                        </BitStack>
                                        <BitText Typography="BitTypography.Caption2" Color="BitColor.SecondaryForeground">
                                            ASR: "@item.Match.RecognizedText"
                                        </BitText>
                                        <BitButton Variant="BitVariant.Outline"
                                                   Color="BitColor.Warning"
                                                   Size="BitSize.Small"
                                                   OnClick="@(() => ConfirmLowConfidenceMatch(item.Match.ErrorNumber))">
                                            Confirm Match
                                        </BitButton>
                                    </BitStack>
                                </BitCard>
                            }
                            else
                            {
                                <PickupBox Match="@item.Match"
                                           Asset="@FindAssetForMatch(item.Match)"
                                           State="PickupBoxState.Matched"
                                           Sentence="@FindSentence(item.Match.SentenceId)"
                                           AvailableTargets="@_availableCrxTargets"
                                           OnStage="HandleStageMatch"
                                           OnReassign="HandleReassign"
                                           OnSelect="HandlePickupBoxSelect"
                                           OnAudition="HandleAudition" />
                            }
                        </div>
                    }

                    @* Unmatched bucket within Matches column *@
                    @if (_unmatchedPickups.Count > 0)
                    {
                        <BitStack Horizontal="true" Gap="0.5rem" VerticalAlign="BitAlignment.Center" AutoHeight="true"
                                  Style="margin-top: 0.5rem; border-top: 1px solid var(--bit-clr-bg-sec); padding-top: 0.5rem;">
                            <BitText Typography="BitTypography.Subtitle2"
                                     Style="text-transform: uppercase; letter-spacing: 0.05em;">
                                Unmatched
                            </BitText>
                            <BitTag Color="BitColor.Warning">@_unmatchedPickups.Count</BitTag>
                        </BitStack>
                        @foreach (var asset in _unmatchedPickups)
                        {
                            <PickupBox Asset="@asset"
                                       State="PickupBoxState.Unmatched"
                                       AvailableTargets="@_availableCrxTargets"
                                       OnAssign="HandleManualAssign"
                                       OnSelect="HandlePickupBoxSelect" />
                        }
                    }
                </BitStack>
            </BitGridItem>

            @* Column 2: Staged (drop target for drag-and-drop) *@
            <BitGridItem ColumnSpan="4" Style="min-width: 0;">
                <div @ondragover="HandleDragOver"
                     @ondragover:preventDefault="true"
                     @ondrop="HandleDrop"
                     class="staged-drop-zone">
                <BitStack Horizontal="false" Gap="0.5rem" AutoHeight="true">
                    <BitStack Horizontal="true" Gap="0.5rem" VerticalAlign="BitAlignment.Center" AutoHeight="true">
                        <BitText Typography="BitTypography.Subtitle2"
                                 Style="text-transform: uppercase; letter-spacing: 0.05em;">
                            Staged
                        </BitText>
                        <BitTag Color="BitColor.Warning">@GetStagedItems().Count</BitTag>
                        @if (GetStagedItems().Count > 0)
                        {
                            <BitButton Variant="BitVariant.Text"
                                       Color="BitColor.Success"
                                       OnClick="HandleCommitAll"
                                       Style="margin-left: auto;"
                                       IsEnabled="@(!_isProcessing)">
                                Commit All
                            </BitButton>
                        }
                    </BitStack>
                    @foreach (var item in GetStagedItems())
                    {
                        <PickupBox Replacement="@item"
                                   State="PickupBoxState.Staged"
                                   Sentence="@FindSentence(item.SentenceId)"
                                   OnUnstage="HandleUnstage"
                                   OnCommit="HandleCommit"
                                   OnAuditionContext="HandleAuditionContext"
                                   OnAudition="HandleAudition"
                                   OnSelect="HandlePickupBoxSelect" />
                    }
                </BitStack>
                </div>
            </BitGridItem>

            @* Column 3: Committed *@
            <BitGridItem ColumnSpan="4" Style="min-width: 0;">
                <BitStack Horizontal="false" Gap="0.5rem" AutoHeight="true">
                    <BitStack Horizontal="true" Gap="0.5rem" VerticalAlign="BitAlignment.Center" AutoHeight="true">
                        <BitText Typography="BitTypography.Subtitle2"
                                 Style="text-transform: uppercase; letter-spacing: 0.05em;">
                            Committed
                        </BitText>
                        <BitTag Color="BitColor.Success">@GetCommittedItems().Count</BitTag>
                    </BitStack>
                    @foreach (var item in GetCommittedItems())
                    {
                        <PickupBox Replacement="@item"
                                   State="PickupBoxState.Committed"
                                   Sentence="@FindSentence(item.SentenceId)"
                                   OnRevert="HandleRevert"
                                   OnAudition="HandleAudition"
                                   OnSelect="HandlePickupBoxSelect" />
                    }
                </BitStack>
            </BitGridItem>
        </BitGrid>

        @* Row 3.5 - Pickup Detail Panel (shown when a pickup is selected) *@
        @if (_selectedPickup != null)
        {
            <BitCard Style="padding: 0.75rem;">
                <BitStack Horizontal="false" Gap="0.5rem" AutoHeight="true">
                    <BitStack Horizontal="true" Gap="0.5rem" VerticalAlign="BitAlignment.Center" AutoHeight="true">
                        <BitText Typography="BitTypography.Subtitle2">
                            Pickup Trim
                        </BitText>
                        <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">
                            @TruncateText(_selectedPickup.TranscribedText, 60)
                        </BitText>
                        <BitButton Variant="BitVariant.Text"
                                   Size="BitSize.Small"
                                   OnClick="() => { _selectedPickup = null; _selectedReplacement = null; StateHasChanged(); }"
                                   Style="margin-left: auto;">
                            Close
                        </BitButton>
                    </BitStack>
                    <WaveformPlayer @ref="_pickupWaveform"
                                    AudioUrl="@GetPickupAudioUrl(_selectedPickup)"
                                    Height="120"
                                    OnReady="HandlePickupWaveformReady"
                                    OnRegionUpdated="HandleRegionUpdated" />
                </BitStack>
            </BitCard>
        }

        @* Row 4 - Roomtone Operations (visible when roomtone file is set) *@
        @if (!string.IsNullOrWhiteSpace(_roomtoneFilePath))
        {
            <BitCard Style="padding: 0.75rem;">
                <BitText Typography="BitTypography.Subtitle2" Style="margin-bottom: 0.5rem;">
                    Roomtone Operations
                </BitText>
                <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground"
                         Style="margin-bottom: 0.5rem;">
                    Select a region on the waveform (blue), then choose an operation.
                </BitText>
                <BitStack Horizontal="true" Gap="0.5rem" VerticalAlign="BitAlignment.Center" AutoHeight="true">
                    <BitButton Variant="BitVariant.Outline"
                               IconName="@BitIconName.Add"
                               IsEnabled="@(_roomtoneRegionValid && !_isProcessing)"
                               OnClick="@(() => HandleRoomtoneOp(RoomtoneOperation.Insert))">
                        Insert
                    </BitButton>
                    <BitButton Variant="BitVariant.Outline"
                               IconName="@BitIconName.Switch"
                               IsEnabled="@(_roomtoneRegionValid && !_isProcessing)"
                               OnClick="@(() => HandleRoomtoneOp(RoomtoneOperation.Replace))">
                        Replace
                    </BitButton>
                    <BitButton Variant="BitVariant.Outline"
                               Color="BitColor.Error"
                               IconName="@BitIconName.Delete"
                               IsEnabled="@(_roomtoneRegionValid && !_isProcessing)"
                               OnClick="@(() => HandleRoomtoneOp(RoomtoneOperation.Delete))">
                        Delete
                    </BitButton>
                    <div style="margin-left: 1rem; display: flex; align-items: center; gap: 0.5rem;">
                        <BitText Typography="BitTypography.Caption1">Crossfade:</BitText>
                        <input type="range" min="5" max="200" step="5"
                               value="@_crossfadeDurationMs"
                               @oninput="OnCrossfadeInput"
                               style="width: 120px;" />
                        <BitText Typography="BitTypography.Caption1">@(_crossfadeDurationMs)ms</BitText>
                    </div>
                </BitStack>
                @if (!string.IsNullOrEmpty(_processingStatus) && _processingStatus.Contains("Roomtone"))
                {
                    <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground"
                             Style="margin-top: 0.25rem;">
                        @_processingStatus
                    </BitText>
                }
            </BitCard>
        }
    }
</BitStack>

<style>
    .pickup-dragging {
        opacity: 0.5;
    }

    .staged-drop-zone {
        min-height: 100px;
        transition: background-color 0.2s;
    }

    .staged-drop-zone:has(.pickup-dragging) {
        background-color: rgba(255, 193, 7, 0.08);
        border: 2px dashed rgba(255, 193, 7, 0.4);
        border-radius: 4px;
    }
</style>

@code {
    // ── Book-wide state ───────────────────────────────────────────
    private string? _pickupSessionPath;
    private string? _roomtoneFilePath;
    private bool _isProcessing;
    private string? _processingStatus;
    private double _processingProgress; // 0.0-1.0
    private CancellationTokenSource _cts = new();

    // ── Roomtone state ──────────────────────────────────────────
    private double _roomtoneRegionStart;
    private double _roomtoneRegionEnd;
    private bool _roomtoneRegionValid;
    private int _crossfadeDurationMs = 70; // Default 70ms, range 5-200ms

    // ── Cross-chapter pickup data ─────────────────────────────────
    private Dictionary<string, List<CrossChapterPickupMatch>> _matchesByChapter = new();
    private HashSet<int> _confirmedLowConfidence = new();

    // ── Unified import state (PickupAssetService) ─────────────────
    private List<PickupAsset> _matchedPickups = new();
    private List<PickupAsset> _unmatchedPickups = new();
    private List<CrxPickupTarget> _availableCrxTargets = new();

    // ── Selected pickup for detail panel ──────────────────────────
    private PickupAsset? _selectedPickup;
    private StagedReplacement? _selectedReplacement;
    private WaveformPlayer? _pickupWaveform;
    private bool _isPickupWaveformReady;

    // ── Migration state ───────────────────────────────────────────
    private bool _showMigrationWarning;

    // ── Flipper navigation ────────────────────────────────────────
    private List<ChapterCrxInfo> _chaptersWithCrx = new();
    private int _currentChapterIndex = -1;

    // ── Current chapter state ─────────────────────────────────────
    private WaveformPlayer? _waveformPlayer;
    private bool _isWaveformReady;
    private long _correctedVersion;
    private IReadOnlyList<HydratedSentence>? _flaggedSentences;
    private IReadOnlyList<StagedReplacement>? _stagedItems;
    private IJSObjectReference? _snippetPlayer;
    private bool _hasAutoLoadedKnownPaths;
    private const int PeakPxPerSec = 1200;

    private record ChapterCrxInfo(string ChapterName, string Stem, int CrxCount, bool AllCommitted);

    // ── Regex helpers ─────────────────────────────────────────────
    private static readonly Regex ChapterNumberRegex = new(@"\d+", RegexOptions.Compiled);

    // ── Computed properties ───────────────────────────────────────
    private bool CanGoNext => _currentChapterIndex >= 0 && _currentChapterIndex < _chaptersWithCrx.Count - 1;
    private bool CanGoPrev => _currentChapterIndex > 0;

    // ── Lifecycle ─────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        _pickupSessionPath = NormalizePathInput(Workspace.PickupSessionPath);
        _roomtoneFilePath = NormalizePathInput(Workspace.RoomtoneFilePath);

        LoadChaptersWithCrx();

        // Migration detection: check if old staging queue has items but new edit list is empty
        DetectMigrationNeeded();

        if (_chaptersWithCrx.Count > 0)
        {
            await NavigateToChapter(0);
        }

        await AutoLoadKnownPaths();
    }

    private void DetectMigrationNeeded()
    {
        foreach (var ch in _chaptersWithCrx)
        {
            var queue = StagingQueueService.GetQueue(ch.Stem);
            var hasOldItems = queue.Any(s =>
                s.Status == ReplacementStatus.Staged || s.Status == ReplacementStatus.Applied);

            if (hasOldItems && !EditListService.HasEdits(ch.Stem))
            {
                _showMigrationWarning = true;
                return;
            }
        }
    }

    private async Task HandleClearAndRestart()
    {
        _isProcessing = true;
        _processingStatus = "Clearing old data...";
        StateHasChanged();

        try
        {
            foreach (var ch in _chaptersWithCrx)
            {
                StagingQueueService.Clear(ch.Stem);
                EditListService.Clear(ch.Stem);
            }

            _showMigrationWarning = false;
            _matchesByChapter.Clear();
            _matchedPickups.Clear();
            _unmatchedPickups.Clear();
            _confirmedLowConfidence.Clear();
            _selectedPickup = null;
            _selectedReplacement = null;

            RefreshCurrentChapterState();
            await SyncWaveformRegions();
            _processingStatus = "Cleared. Re-import pickups to use the new system.";
        }
        catch (Exception ex)
        {
            _processingStatus = $"Clear failed: {ex.Message}";
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

    // ── Flipper Navigation ────────────────────────────────────────
    private void LoadChaptersWithCrx()
    {
        _chaptersWithCrx.Clear();

        if (!Workspace.IsInitialized || !Workspace.HasBookIndex)
            return;

        IReadOnlyList<CrxEntry> entries;
        try
        {
            entries = CrxService.GetEntries();
        }
        catch
        {
            return;
        }

        if (entries.Count == 0)
            return;

        foreach (var chapterName in Workspace.AvailableChapters)
        {
            var chapterEntries = entries
                .Where(e => ChapterMatches(e.Chapter, chapterName))
                .ToList();

            if (chapterEntries.Count == 0)
                continue;

            var stem = Workspace.GetStemForChapter(chapterName) ?? chapterName;
            var stagedQueue = StagingQueueService.GetQueue(stem);
            var committedCount = stagedQueue.Count(s => s.Status == ReplacementStatus.Applied);

            _chaptersWithCrx.Add(new ChapterCrxInfo(
                chapterName,
                stem,
                chapterEntries.Count,
                committedCount >= chapterEntries.Count));
        }
    }

    private async Task NavigateToChapter(int index)
    {
        if (index < 0 || index >= _chaptersWithCrx.Count)
            return;

        // Deallocate previous chapter's corrected audio buffer to prevent memory pressure
        if (_currentChapterIndex >= 0 && _currentChapterIndex < _chaptersWithCrx.Count)
        {
            try
            {
                var prevHandle = Workspace.CurrentChapterHandle;
                prevHandle?.Chapter.Audio.Deallocate("corrected");
            }
            catch { /* Ignore deallocation errors during navigation */ }
        }

        _currentChapterIndex = index;
        _isWaveformReady = false; // Reset; will be set true again in HandleWaveformReady
        var info = _chaptersWithCrx[index];

        Workspace.SelectChapter(info.ChapterName);
        LoadChapterState(info);
        StateHasChanged();
    }

    private void LoadChapterState(ChapterCrxInfo info)
    {
        // Load flagged sentences
        if (Workspace.TryGetHydratedTranscript(info.ChapterName, out var hydrated) && hydrated != null)
        {
            IReadOnlyList<CrxEntry> entries;
            try { entries = CrxService.GetEntries(); }
            catch { entries = Array.Empty<CrxEntry>(); }

            var chapterEntries = entries
                .Where(e => ChapterMatches(e.Chapter, info.ChapterName))
                .OrderBy(e => e.ErrorNumber)
                .ToList();

            if (chapterEntries.Count > 0)
            {
                _flaggedSentences = ResolveCrxTargets(chapterEntries, hydrated.Sentences);
            }
            else
            {
                _flaggedSentences = Array.Empty<HydratedSentence>();
            }
        }
        else
        {
            _flaggedSentences = null;
        }

        // Load staging queue
        _stagedItems = StagingQueueService.GetQueue(info.Stem);

        // Reset corrected version to force waveform reload
        _correctedVersion++;
    }

    private async Task HandlePrev() => await NavigateToChapter(_currentChapterIndex - 1);
    private async Task HandleNext() => await NavigateToChapter(_currentChapterIndex + 1);

    // ── Drag-and-drop state ──────────────────────────────────────
    private CrossChapterPickupMatch? _draggedMatch;

    // ── Header Actions ────────────────────────────────────────────
    private async Task HandleSetPickupSession()
    {
        await HandlePickupFileSet();
    }

    private async Task HandleSetRoomtone()
    {
        _roomtoneFilePath = NormalizePathInput(_roomtoneFilePath);

        // Validate roomtone file path
        if (string.IsNullOrWhiteSpace(_roomtoneFilePath) || !System.IO.File.Exists(_roomtoneFilePath))
        {
            _processingStatus = "Roomtone file not found. Check the file path.";
            StateHasChanged();
            return;
        }

        Workspace.SetPolishPaths(_pickupSessionPath, _roomtoneFilePath);

        // Initialize a default roomtone selection region.
        var defaultStart = 1.0;
        var defaultEnd = 2.0;
        if (_waveformPlayer?.Duration > 0)
        {
            defaultEnd = Math.Min(defaultEnd, _waveformPlayer.Duration * 0.1);
            if (defaultEnd <= defaultStart)
                defaultEnd = Math.Min(defaultStart + 0.5, _waveformPlayer.Duration);
        }

        _roomtoneRegionStart = defaultStart;
        _roomtoneRegionEnd = defaultEnd;
        _roomtoneRegionValid = defaultEnd > defaultStart;

        // Add region immediately if waveform is already ready.
        if (_waveformPlayer != null && _isWaveformReady && _roomtoneRegionValid)
        {
            await _waveformPlayer.AddEditableRegion(
                "roomtone-selection", defaultStart, defaultEnd,
                "rgba(59, 130, 246, 0.3)"); // Blue for roomtone
        }

        StateHasChanged();
    }

    private async Task AutoLoadKnownPaths()
    {
        if (_hasAutoLoadedKnownPaths)
            return;

        _hasAutoLoadedKnownPaths = true;

        var hasPickupPath = !string.IsNullOrWhiteSpace(_pickupSessionPath) &&
            System.IO.File.Exists(_pickupSessionPath);
        var hasRoomtonePath = !string.IsNullOrWhiteSpace(_roomtoneFilePath) &&
            System.IO.File.Exists(_roomtoneFilePath);

        if (hasPickupPath && _chaptersWithCrx.Count > 0)
            await HandlePickupFileSet();

        if (hasRoomtonePath)
            await HandleSetRoomtone();
    }

    // ── Upfront Cross-Chapter Processing ──────────────────────────
    private async Task HandlePickupFileSet()
    {
        _pickupSessionPath = NormalizePathInput(_pickupSessionPath);
        if (string.IsNullOrWhiteSpace(_pickupSessionPath)) return;

        // Validate pickup source path exists (file or directory for individual pickups)
        if (!System.IO.File.Exists(_pickupSessionPath) && !System.IO.Directory.Exists(_pickupSessionPath))
        {
            _processingStatus = "Pickup file or folder not found. Check the path.";
            StateHasChanged();
            return;
        }

        Workspace.SetPolishPaths(_pickupSessionPath, _roomtoneFilePath);

        // Cancel any in-progress processing
        await _cts.CancelAsync();
        _cts.Dispose();
        _cts = new CancellationTokenSource();
        var token = _cts.Token;

        _isProcessing = true;
        _processingStatus = "Building CRX targets...";
        _processingProgress = 0;
        _confirmedLowConfidence.Clear();
        StateHasChanged();

        try
        {
            // 1. Load all CRX entries
            IReadOnlyList<CrxEntry> allEntries;
            try { allEntries = CrxService.GetEntries(); }
            catch { allEntries = Array.Empty<CrxEntry>(); }

            // 2. Build CrxPickupTarget list from CRX entries
            var crxTargets = new List<CrxPickupTarget>();
            foreach (var ch in _chaptersWithCrx)
            {
                token.ThrowIfCancellationRequested();

                var chapterEntries = allEntries
                    .Where(e => ChapterMatches(e.Chapter, ch.ChapterName))
                    .OrderBy(e => e.ErrorNumber)
                    .ToList();

                if (chapterEntries.Count == 0) continue;

                // Need hydrated transcript for sentence resolution
                if (!Workspace.TryGetHydratedTranscript(ch.ChapterName, out var hydrated) || hydrated == null)
                    continue;

                foreach (var entry in chapterEntries)
                {
                    var sentence = ResolveSentenceFromCrxEntry(entry, hydrated.Sentences);
                    if (sentence == null)
                        continue;

                    var shouldBeText = CrxCommentParser.TryParseReadAs(entry.Comments)
                        ?? CrxCommentParser.TryParseShouldBe(entry.Comments);
                    var bookText = sentence.BookText ?? string.Empty;
                    var originalStartSec = sentence.Timing?.StartSec ?? 0;
                    var originalEndSec = sentence.Timing?.EndSec ?? 0;

                    crxTargets.Add(new CrxPickupTarget(
                        ErrorNumber: entry.ErrorNumber,
                        ChapterStem: ch.Stem,
                        ChapterName: ch.ChapterName,
                        SentenceId: sentence.Id,
                        ShouldBeText: shouldBeText ?? bookText,
                        BookText: bookText,
                        OriginalStartSec: originalStartSec,
                        OriginalEndSec: originalEndSec));
                }
            }

            if (crxTargets.Count == 0)
            {
                _processingStatus = "CRX.json is required for pickup import, but no valid CRX targets were resolved. Check CRX entries and sentence mapping.";
                return;
            }

            // 3. Store CRX targets for reassignment UI
            _availableCrxTargets = crxTargets;

            // 4. Run unified import via PickupAssetService (returns matched + unmatched)
            _processingStatus = "Running unified import...";
            _processingProgress = 0.3;
            await InvokeAsync(StateHasChanged);

            var (matched, unmatched) = await PickupAssetService.ImportAsync(
                _pickupSessionPath, crxTargets, token);

            _matchedPickups = matched.ToList();
            _unmatchedPickups = unmatched.ToList();

            _matchesByChapter = BuildMatchesByChapterFromAssets(matched);
            var totalMatches = _matchesByChapter.Values.Sum(m => m.Count);
            _processingProgress = 1.0;
            _processingStatus = System.IO.File.Exists(_pickupSessionPath)
                ? $"Imported {totalMatches} pickups from session file. {unmatched.Count} unmatched."
                : $"Imported {totalMatches} pickups from folder. {unmatched.Count} unmatched.";
        }
        catch (OperationCanceledException) { _processingStatus = "Processing cancelled."; }
        catch (System.IO.FileNotFoundException) { _processingStatus = "Pickup file not found. Check the file path."; }
        catch (Exception ex) { _processingStatus = $"Processing failed: {ex.Message}"; }
        finally
        {
            _isProcessing = false;
            await SyncWaveformRegions();
            StateHasChanged();
        }
    }

    // ── Column State Derivation ───────────────────────────────────
    private IReadOnlyList<CrossChapterPickupMatch> GetMatchedItems()
    {
        if (_currentChapterIndex < 0 || _currentChapterIndex >= _chaptersWithCrx.Count)
            return Array.Empty<CrossChapterPickupMatch>();

        var stem = _chaptersWithCrx[_currentChapterIndex].Stem;
        if (!_matchesByChapter.TryGetValue(stem, out var matches))
            return Array.Empty<CrossChapterPickupMatch>();

        // Exclude items that have a StagedReplacement (Staged or Applied status)
        var stagedSentenceIds = (_stagedItems ?? Array.Empty<StagedReplacement>())
            .Where(s => s.Status == ReplacementStatus.Staged || s.Status == ReplacementStatus.Applied)
            .Select(s => s.SentenceId)
            .ToHashSet();

        return matches
            .Where(m => !stagedSentenceIds.Contains(m.Match.SentenceId))
            .ToList();
    }

    private static Dictionary<string, List<CrossChapterPickupMatch>> BuildMatchesByChapterFromAssets(
        IReadOnlyList<PickupAsset> matchedAssets)
    {
        return matchedAssets
            .Where(a => !string.IsNullOrWhiteSpace(a.MatchedChapterStem) && a.MatchedSentenceId.HasValue)
            .Select(a => new CrossChapterPickupMatch(
                a.MatchedChapterStem!,
                new PickupMatch(
                    SentenceId: a.MatchedSentenceId!.Value,
                    PickupStartSec: a.TrimStartSec,
                    PickupEndSec: a.TrimEndSec,
                    Confidence: a.Confidence,
                    RecognizedText: a.TranscribedText,
                    ErrorNumber: a.MatchedErrorNumber,
                    IsLowConfidence: a.Confidence < 0.5)))
            .GroupBy(m => m.ChapterStem, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(g => g.Key, g => g.ToList(), StringComparer.OrdinalIgnoreCase);
    }

    private IReadOnlyList<StagedReplacement> GetStagedItems()
    {
        return (_stagedItems ?? Array.Empty<StagedReplacement>())
            .Where(s => s.Status == ReplacementStatus.Staged)
            .ToList();
    }

    private IReadOnlyList<StagedReplacement> GetCommittedItems()
    {
        return (_stagedItems ?? Array.Empty<StagedReplacement>())
            .Where(s => s.Status == ReplacementStatus.Applied)
            .ToList();
    }

    private int GetCommittedCount(string stem)
    {
        var queue = StagingQueueService.GetQueue(stem);
        return queue.Count(s => s.Status == ReplacementStatus.Applied);
    }

    // ── Low-confidence match confirmation ─────────────────────────
    private bool IsLowConfidenceConfirmed(PickupMatch match)
        => match.ErrorNumber.HasValue && _confirmedLowConfidence.Contains(match.ErrorNumber.Value);

    private void ConfirmLowConfidenceMatch(int? errorNumber)
    {
        if (errorNumber.HasValue)
            _confirmedLowConfidence.Add(errorNumber.Value);
        StateHasChanged();
    }

    // ── Action Handlers ───────────────────────────────────────────
    private async Task HandleStageMatch(PickupMatch match)
    {
        if (_currentChapterIndex < 0 || _currentChapterIndex >= _chaptersWithCrx.Count)
            return;

        // Block staging of unconfirmed low-confidence matches
        if (match.IsLowConfidence && !IsLowConfidenceConfirmed(match))
            return;

        var info = _chaptersWithCrx[_currentChapterIndex];
        var sentence = FindSentence(match.SentenceId);
        if (sentence?.Timing == null || string.IsNullOrWhiteSpace(_pickupSessionPath))
            return;

        // Resolve the actual pickup file path. For directory sources, the PickupAsset
        // holds the individual WAV file path; for session files, use _pickupSessionPath.
        var pickupFilePath = _pickupSessionPath.Trim();
        var asset = FindAssetForMatch(match);
        if (asset != null && asset.SourceType == PickupSourceType.IndividualFile)
        {
            pickupFilePath = asset.SourceFilePath;
        }

        try
        {
            PolishService.StageReplacement(
                info.Stem,
                match,
                pickupFilePath,
                sentence.Timing.StartSec,
                sentence.Timing.EndSec);

            RefreshCurrentChapterState();
            await SyncWaveformRegions();
        }
        catch (Exception ex)
        {
            _processingStatus = $"Stage failed: {ex.Message}";
            Console.WriteLine($"Stage failed: {ex.Message}");
        }
    }

