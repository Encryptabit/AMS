    private async Task HandleRoomtoneOp(RoomtoneOperation operation)
    {
        if (!_roomtoneRegionValid || string.IsNullOrWhiteSpace(_roomtoneFilePath)) return;

        _isProcessing = true;
        StateHasChanged();
        try
        {
            var request = new RoomtoneRequest(
                operation, _roomtoneRegionStart, _roomtoneRegionEnd,
                _crossfadeDurationMs / 1000.0); // Convert ms to seconds

            await PolishService.ApplyRoomtoneOperationAsync(
