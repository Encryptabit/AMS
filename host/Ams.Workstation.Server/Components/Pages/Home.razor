@page "/"
@using Ams.Workstation.Server.Components.Navigation
@using Ams.Workstation.Server.Components.UI
@inject Ams.Workstation.Server.Services.BlazorWorkspace Workspace
@inject NavigationManager Navigation

<PageTitle>AMS Workstation - Home</PageTitle>

<div class="home-container">
    <div class="home-stack">
        <div class="welcome-header">
            <h1 class="welcome-title">Welcome to AMS Workstation</h1>
            <p class="welcome-subtitle">Audio Management System - Audiobook Mastering Workstation</p>
        </div>

        @if (string.IsNullOrEmpty(Workspace.WorkingDirectory))
        {
            <section class="ams-card getting-started">
                <h2 class="card-subtitle">Getting Started</h2>
                <p class="card-muted">
                    Enter a working directory path in the header bar above and click "Set" to load your workspace.
                </p>
                <ol class="steps-list">
                    <li>Set your working directory (top right)</li>
                    <li>If no book-index.json exists, use Prep to build one</li>
                    <li>Select a chapter from the dropdown to begin review</li>
                </ol>
            </section>
        }
        else
        {
            <section class="ams-card workspace-info">
                <div class="info-block">
                    <div class="info-label">Current Workspace</div>
                    <div class="info-value info-value--mono">@Workspace.WorkingDirectory</div>
                </div>

                @if (Workspace.HasBookIndex)
                {
                    <div class="info-block">
                        <div class="info-label">Available Chapters</div>
                        <div class="info-value">@Workspace.AvailableChapters.Count chapters found</div>
                    </div>

                    <div class="info-block">
                        <div class="info-label">Workspace Status</div>
                        <div class="info-value">@(Workspace.IsInitialized ? "Initialized" : "Not initialized")</div>
                    </div>

                    <div class="ams-message ams-message--success" role="status">
                        <span class="ams-message__icon" aria-hidden="true">✓</span>
                        <span>Workspace ready. Select a chapter from the dropdown above to begin.</span>
                    </div>
                }
                else
                {
                    <div class="ams-message ams-message--warning" role="status">
                        <p>No book-index.json found in this directory.</p>
                        <AmsButton Variant="primary" OnClick="NavigateToPrep">
                            Go to Prep to build index
                        </AmsButton>
                    </div>
                }
            </section>
        }

        <section class="ams-card quick-links">
            <h2 class="card-eyebrow">Quick Links</h2>
            <div class="quick-links-row">
                <a class="ams-btn ams-btn--secondary ams-btn--md" href="@StageRouteCatalog.GetStageEntryPath(StageRouteCatalog.StageIds.Prep)">
                    <span class="ams-btn__icon" aria-hidden="true">⚙</span>
                    <span class="ams-btn__label">Prep Area</span>
                </a>
                <a class="ams-btn ams-btn--secondary ams-btn--md" href="@StageRouteCatalog.GetStageEntryPath(StageRouteCatalog.StageIds.Proof)">
                    <span class="ams-btn__icon" aria-hidden="true">✓</span>
                    <span class="ams-btn__label">Proof Area</span>
                </a>
                <a class="ams-btn ams-btn--secondary ams-btn--md" href="@StageRouteCatalog.GetStageEntryPath(StageRouteCatalog.StageIds.Polish)">
                    <span class="ams-btn__icon" aria-hidden="true">◉</span>
                    <span class="ams-btn__label">Polish Area</span>
                </a>
            </div>
        </section>
    </div>
</div>

@code {
    private void NavigateToPrep()
    {
        Navigation.NavigateTo(StageRouteCatalog.GetStageEntryPath(StageRouteCatalog.StageIds.Prep));
    }
}
