@using System.Globalization
@using Ams.Workstation.Server.Models
@using Ams.Workstation.Server.Services
@inject CrxService CrxService

<div class="crx-modal-overlay @(_isVisible ? "visible" : "")" @onclick="Close">
    <div class="crx-modal" @onclick:stopPropagation>
        <div class="crx-modal-header">
            <BitText Typography="BitTypography.H5">Add to CRX</BitText>
            <BitButton Variant="BitVariant.Text" OnClick="Close" IconName="Cancel" />
        </div>

        <div class="crx-modal-body">
            <div class="crx-grid">
                @* ── Left column: Error Type, Error Checkboxes, Export Range ── *@
                <div class="crx-col-left">
                    <BitDropdown TItem="BitDropdownItem<string>" TValue="string"
                                 @bind-Value="_errorType"
                                 Label="Error Type"
                                 Items="_errorTypeItems" />

                    @if (_errorOps.Count > 0)
                    {
                        <div class="crx-errors-section">
                            <div class="crx-errors-header">
                                <BitText Typography="BitTypography.Body2">Errors to Highlight</BitText>
                                <label class="crx-select-all">
                                    <input type="checkbox" checked="@_allSelected"
                                           @onchange="ToggleSelectAll" />
                                    <BitText Typography="BitTypography.Caption1">Select All</BitText>
                                </label>
                            </div>
                            <div class="crx-errors-list">
                                @for (var i = 0; i < _errorOps.Count; i++)
                                {
                                    var idx = i;
                                    var err = _errorOps[idx];
                                    <label class="crx-error-item">
                                        <input type="checkbox" checked="@err.Selected"
                                               @onchange="@(() => ToggleError(idx))" />
                                        <span class="@(err.Op == "delete" ? "crx-del" : "crx-ins")">
                                            @(err.Op == "delete" ? "DEL" : "INS"): @err.Text
                                        </span>
                                    </label>
                                }
                            </div>
                        </div>
                    }

                    <div class="crx-range-controls" data-ams-crx-range-controls="true">
                        <BitText Typography="BitTypography.Body2">Export Range</BitText>

                        <div class="crx-range-row" data-ams-crx-range-start-control="true">
                            <label class="crx-range-label" for="crx-range-start">Start</label>
                            <div class="crx-range-input-wrap">
                                <input id="crx-range-start"
                                       class="crx-range-input"
                                       data-ams-crx-range-start-input="true"
                                       type="text"
                                       value="@_startInput"
                                       @oninput="OnStartInputTyping"
                                       @onchange="OnStartInputChanged"
                                       @onkeydown="OnStartInputKeyDown"
                                       @onpointerdown="OnStartDragPointerDown"
                                       @onpointermove="OnRangeDragPointerMove"
                                       @onpointermove:preventDefault="true"
                                       @onpointerup="OnRangeDragPointerUp"
                                       @onpointercancel="OnRangeDragPointerCancel" />
                                <span class="crx-range-drag-hint" aria-hidden="true">↕</span>
                            </div>
                        </div>

                        <div class="crx-range-row" data-ams-crx-range-end-control="true">
                            <label class="crx-range-label" for="crx-range-end">End</label>
                            <div class="crx-range-input-wrap">
                                <input id="crx-range-end"
                                       class="crx-range-input"
                                       data-ams-crx-range-end-input="true"
                                       type="text"
                                       value="@_endInput"
                                       @oninput="OnEndInputTyping"
                                       @onchange="OnEndInputChanged"
                                       @onkeydown="OnEndInputKeyDown"
                                       @onpointerdown="OnEndDragPointerDown"
                                       @onpointermove="OnRangeDragPointerMove"
                                       @onpointermove:preventDefault="true"
                                       @onpointerup="OnRangeDragPointerUp"
                                       @onpointercancel="OnRangeDragPointerCancel" />
                                <span class="crx-range-drag-hint" aria-hidden="true">↕</span>
                            </div>
                        </div>

                        <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground" class="crx-range-help">
                            Drag up/down in each time field to nudge that bound.
                        </BitText>

                        @if (!string.IsNullOrWhiteSpace(_rangeValidationMessage))
                        {
                            <BitText Typography="BitTypography.Caption1" Color="BitColor.Error" class="crx-range-validation" data-ams-crx-range-validation="true">
                                @_rangeValidationMessage
                            </BitText>
                        }

                        @if (_requiresRangeConfirmation)
                        {
                            <label class="crx-range-confirm" data-ams-crx-range-confirm-required="true">
                                <input type="checkbox"
                                       checked="@_isRangeConfirmed"
                                       data-ams-crx-range-confirm-checkbox="true"
                                       @onchange="OnRangeConfirmationChanged" />
                                <span>Timing cluster produced a fallback range. Review Start/End and confirm this range before submitting.</span>
                            </label>

                            @if (HasPendingRangeConfirmation)
                            {
                                <BitText Typography="BitTypography.Caption1"
                                         Color="BitColor.SecondaryForeground"
                                         class="crx-range-confirm-status"
                                         data-ams-crx-range-confirm-status="pending">
                                    Confirm current range to enable Add to CRX.
                                </BitText>
                            }
                        }
                    </div>
                </div>

                @* ── Right column: Audio Preview ── *@
                <div class="crx-col-right">
                    <WaveformPlayer @ref="_waveformPlayer"
                                    AudioUrl="@_audioUrl"
                                    PeaksUrl="@_peaksUrl"
                                    Title="Audio Preview"
                                    Height="80"
                                    OnReady="FocusPlayButton" />
                    <BitText Typography="BitTypography.Caption2" Color="BitColor.SecondaryForeground"
                             Style="text-align: center;">
                        @FormatTime(_startTime) → @FormatTime(_endTime)
                    </BitText>
                </div>
            </div>

            @* ── Full-width: Comments ── *@
            <div class="crx-comments">
                <BitText Typography="BitTypography.Body2">Comments</BitText>
                <textarea rows="4" @bind="_comments" class="crx-comments-textarea" />
            </div>
        </div>

        <div class="crx-modal-footer">
            <BitButton Variant="BitVariant.Outline" OnClick="Close">Cancel</BitButton>
            <BitButton Variant="BitVariant.Fill" Color="BitColor.Primary"
                       OnClick="Submit" IsEnabled="@(!_submitting && !HasRangeValidationError && !HasPendingRangeConfirmation)">
                @(_submitting ? "Submitting..." : "Add to CRX")
            </BitButton>
        </div>
    </div>
</div>

@inject IJSRuntime JS

@code {
    private const int PeakPxPerSec = 1200;
    private const double MinRangeDurationSec = 0.001;
    private const double DragSecondsPerPixel = 0.02;

    private bool _isVisible;
    private string _chapterName = "";
    private double _startTime;
    private double _endTime;
    private int _sentenceId;
    private string _excerpt = "";
    private string _errorType = "MR";
    private string _comments = "";
    private string _startInput = "";
    private string _endInput = "";
    private string? _rangeValidationMessage;
    private bool _requiresRangeConfirmation;
    private bool _isRangeConfirmed;
    private bool _submitting;
    private string _audioUrl = "";
    private string? _peaksUrl;
    private SentenceReport? _sentenceReport;
    private WaveformPlayer? _waveformPlayer;
    private RangeDragState? _activeRangeDrag;

    // Error checkboxes built from diff ops
    private List<ErrorOpItem> _errorOps = new();
    private bool _allSelected = true;

    // Pre-built dropdown items
    private readonly List<BitDropdownItem<string>> _errorTypeItems = ErrorTypes.All
        .Select(t => new BitDropdownItem<string> { Value = t, Text = t })
        .ToList();

    [Parameter] public EventCallback<CrxSubmitResult> OnSubmitted { get; set; }

    public void Open(
        string chapterName,
        double start,
        double end,
        int sentenceId,
        string excerpt,
        SentenceReport? sentenceReport = null,
        bool requireRangeConfirmation = false)
    {
        _chapterName = chapterName;
        _startTime = start;
        _endTime = end;
        _sentenceId = sentenceId;
        _excerpt = excerpt;
        _sentenceReport = sentenceReport;
        _errorType = "MR";
        _isVisible = true;
        _requiresRangeConfirmation = requireRangeConfirmation;
        _isRangeConfirmed = !requireRangeConfirmation;

        _startInput = FormatTime(_startTime);
        _endInput = FormatTime(_endTime);
        _rangeValidationMessage = null;
        _activeRangeDrag = null;

        // Build error checkboxes from diff ops
        BuildErrorOps();
        _allSelected = _errorOps.All(e => e.Selected);

        // Generate initial comment
        _comments = GenerateComment();

        // Set audio URL / validation based on initial bounds
        CommitRangeChange();

        StateHasChanged();
        _ = ActivateFocusTrapAsync();
    }

    private async Task ActivateFocusTrapAsync()
    {
        await Task.Yield();
        await JS.InvokeVoidAsync("window.modalFocusTrap.activate");
    }

    private async Task FocusPlayButton()
    {
        // Waveform is ready — focus the play button so spacebar previews the cut
        await JS.InvokeVoidAsync("eval",
            "document.querySelector('.crx-modal-overlay.visible button[title=\"Play\"]')?.focus()");
    }

    public void Close()
    {
        _isVisible = false;
        _audioUrl = "";
        _peaksUrl = null;
        _rangeValidationMessage = null;
        _requiresRangeConfirmation = false;
        _isRangeConfirmed = false;
        _activeRangeDrag = null;
        JS.InvokeVoidAsync("window.modalFocusTrap.deactivate");
        StateHasChanged();
    }

    private void BuildErrorOps()
    {
        _errorOps.Clear();
        if (_sentenceReport?.Diff?.Ops == null) return;

        foreach (var op in _sentenceReport.Diff.Ops)
        {
            if (op.Op == "equal") continue;
            var text = string.Join(" ", op.Tokens);
            _errorOps.Add(new ErrorOpItem(op.Op, text, Selected: true));
        }
    }

    private void ToggleError(int index)
    {
        var item = _errorOps[index];
        _errorOps[index] = item with { Selected = !item.Selected };
        _allSelected = _errorOps.All(e => e.Selected);
        _comments = GenerateComment();
        StateHasChanged();
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        var selectAll = (bool)(e.Value ?? false);
        _allSelected = selectAll;
        for (var i = 0; i < _errorOps.Count; i++)
            _errorOps[i] = _errorOps[i] with { Selected = selectAll };
        _comments = GenerateComment();
        StateHasChanged();
    }

    /// <summary>
    /// Port of generateCrxCommentWithSelection from validation-viewer app.js
    /// </summary>
    private string GenerateComment()
    {
        if (_sentenceReport?.Diff?.Ops == null || _errorOps.Count == 0)
            return _excerpt;

        // Build a set of selected op indices (non-equal ops only)
        var selectedSet = new HashSet<int>();
        var errorIdx = 0;
        for (var i = 0; i < _sentenceReport.Diff.Ops.Count; i++)
        {
            var op = _sentenceReport.Diff.Ops[i];
            if (op.Op == "equal") continue;
            if (_errorOps[errorIdx].Selected)
                selectedSet.Add(i);
            errorIdx++;
        }

        var shouldBeLine = new List<string>();
        var readAsLine = new List<string>();
        var hasDifferences = false;

        for (var i = 0; i < _sentenceReport.Diff.Ops.Count; i++)
        {
            var op = _sentenceReport.Diff.Ops[i];
            var tokens = op.Tokens;
            if (tokens.Count == 0) continue;

            var text = string.Join(" ", tokens);
            var isSelected = selectedSet.Contains(i);

            if (op.Op == "equal")
            {
                shouldBeLine.Add(text);
                readAsLine.Add(text);
            }
            else if (op.Op == "delete")
            {
                if (isSelected)
                {
                    shouldBeLine.Add($"[{text}]");
                    hasDifferences = true;
                }
                else
                {
                    shouldBeLine.Add(text);
                }
            }
            else if (op.Op == "insert")
            {
                if (isSelected)
                {
                    readAsLine.Add($"[{text}]");
                    hasDifferences = true;
                }
                else
                {
                    readAsLine.Add(text);
                }
            }
        }

        if (!hasDifferences)
            return _sentenceReport.BookText;

        var shouldBe = string.Join(" ", shouldBeLine);
        var readAs = string.Join(" ", readAsLine);
        return $"Should be: {shouldBe}{Environment.NewLine}{Environment.NewLine}Read as: {readAs}";
    }

    private bool HasRangeValidationError => !string.IsNullOrWhiteSpace(_rangeValidationMessage);
    private bool HasPendingRangeConfirmation => _requiresRangeConfirmation && !_isRangeConfirmed;

    private void OnRangeConfirmationChanged(ChangeEventArgs e)
    {
        _isRangeConfirmed = e.Value switch
        {
            bool boolValue => boolValue,
            string stringValue when bool.TryParse(stringValue, out var parsed) => parsed,
            _ => false
        };

        StateHasChanged();
    }

    private void OnStartInputTyping(ChangeEventArgs e)
        => _startInput = e.Value?.ToString() ?? string.Empty;

    private void OnEndInputTyping(ChangeEventArgs e)
        => _endInput = e.Value?.ToString() ?? string.Empty;

    private void OnStartInputChanged(ChangeEventArgs e)
        => CommitRangeInput(isStart: true, e.Value?.ToString() ?? _startInput);

    private void OnEndInputChanged(ChangeEventArgs e)
        => CommitRangeInput(isStart: false, e.Value?.ToString() ?? _endInput);

    private void OnStartInputKeyDown(KeyboardEventArgs e)
    {
        if (string.Equals(e.Key, "Enter", StringComparison.Ordinal))
            CommitRangeInput(isStart: true, _startInput);
    }

    private void OnEndInputKeyDown(KeyboardEventArgs e)
    {
        if (string.Equals(e.Key, "Enter", StringComparison.Ordinal))
            CommitRangeInput(isStart: false, _endInput);
    }

    private void OnStartDragPointerDown(PointerEventArgs e)
        => BeginRangeDrag(RangeBound.Start, e);

    private void OnEndDragPointerDown(PointerEventArgs e)
        => BeginRangeDrag(RangeBound.End, e);

    private void OnRangeDragPointerMove(PointerEventArgs e)
    {
        if (_activeRangeDrag is null || _activeRangeDrag.PointerId != e.PointerId)
            return;

        var deltaSeconds = (_activeRangeDrag.StartY - e.ClientY) * DragSecondsPerPixel;
        if (_activeRangeDrag.Bound == RangeBound.Start)
            _startTime = Math.Max(0, _activeRangeDrag.StartValue - deltaSeconds);
        else
            _endTime = Math.Max(0, _activeRangeDrag.StartValue + deltaSeconds);

        if (_requiresRangeConfirmation)
        {
            _isRangeConfirmed = false;
        }

        _startInput = FormatTime(_startTime);
        _endInput = FormatTime(_endTime);
        ValidateRange();
        StateHasChanged();
    }

    private void OnRangeDragPointerUp(PointerEventArgs e)
    {
        if (_activeRangeDrag is null || _activeRangeDrag.PointerId != e.PointerId)
            return;

        _activeRangeDrag = null;
        CommitRangeChange();
    }

    private void OnRangeDragPointerCancel(PointerEventArgs e)
    {
        if (_activeRangeDrag is null || _activeRangeDrag.PointerId != e.PointerId)
            return;

        _activeRangeDrag = null;
        CommitRangeChange();
    }

    private void BeginRangeDrag(RangeBound bound, PointerEventArgs e)
    {
        var currentValue = bound == RangeBound.Start ? _startTime : _endTime;
        _activeRangeDrag = new RangeDragState(bound, e.PointerId, e.ClientY, currentValue);
    }

    private void CommitRangeInput(bool isStart, string raw)
    {
        if (!TryParseTimeInput(raw, out var seconds))
        {
            _rangeValidationMessage = $"{(isStart ? "Start" : "End")} time must use mm:ss.mmm format (example: 1:23.450).";
            StateHasChanged();
            return;
        }

        var normalizedSeconds = Math.Max(0, seconds);
        if (_requiresRangeConfirmation)
        {
            var currentSeconds = isStart ? _startTime : _endTime;
            if (DidRangeBoundChange(currentSeconds, normalizedSeconds))
            {
                _isRangeConfirmed = false;
            }
        }

        if (isStart)
            _startTime = normalizedSeconds;
        else
            _endTime = normalizedSeconds;

        CommitRangeChange();
    }

    private void CommitRangeChange()
    {
        _startInput = FormatTime(_startTime);
        _endInput = FormatTime(_endTime);

        ValidateRange();
        if (HasRangeValidationError)
        {
            _audioUrl = string.Empty;
            _peaksUrl = null;
        }
        else
        {
            _audioUrl = BuildAudioUrl();
            _peaksUrl = BuildPeaksUrl();
        }

        StateHasChanged();
    }

    private bool TryCommitPendingRangeInputs()
    {
        if (!TryParseTimeInput(_startInput, out var parsedStart))
        {
            _rangeValidationMessage = "Start time must use mm:ss.mmm format (example: 1:23.450).";
            StateHasChanged();
            return false;
        }

        if (!TryParseTimeInput(_endInput, out var parsedEnd))
        {
            _rangeValidationMessage = "End time must use mm:ss.mmm format (example: 1:23.450).";
            StateHasChanged();
            return false;
        }

        var normalizedStart = Math.Max(0, parsedStart);
        var normalizedEnd = Math.Max(0, parsedEnd);

        if (_requiresRangeConfirmation
            && (DidRangeBoundChange(_startTime, normalizedStart)
                || DidRangeBoundChange(_endTime, normalizedEnd)))
        {
            _isRangeConfirmed = false;
        }

        _startTime = normalizedStart;
        _endTime = normalizedEnd;
        CommitRangeChange();
        return !HasRangeValidationError && !HasPendingRangeConfirmation;
    }

    private static bool DidRangeBoundChange(double currentSeconds, double nextSeconds)
        => currentSeconds != nextSeconds;

    private void ValidateRange()
    {
        if (_startTime < 0 || _endTime < 0)
        {
            _rangeValidationMessage = "Start and End must be 0 or greater.";
            return;
        }

        var duration = _endTime - _startTime;
        if (duration < 0)
        {
            _rangeValidationMessage = "Start must be before End. Adjust either bound to create a positive export range.";
            return;
        }

        if (duration <= MinRangeDurationSec)
        {
            _rangeValidationMessage = "Range is zero-duration. Adjust Start earlier or End later before submitting this CRX entry.";
            return;
        }

        _rangeValidationMessage = null;
    }

    private static bool TryParseTimeInput(string raw, out double seconds)
    {
        seconds = 0;
        if (string.IsNullOrWhiteSpace(raw))
            return false;

        var value = raw.Trim();

        if (double.TryParse(value, NumberStyles.Float, CultureInfo.InvariantCulture, out var asSeconds) && asSeconds >= 0)
        {
            seconds = asSeconds;
            return true;
        }

        var parts = value.Split(':', StringSplitOptions.TrimEntries);
        if (parts.Length is < 2 or > 3)
            return false;

        if (!double.TryParse(parts[^1], NumberStyles.Float, CultureInfo.InvariantCulture, out var secPart) || secPart < 0 || secPart >= 60)
            return false;

        if (!int.TryParse(parts[^2], NumberStyles.Integer, CultureInfo.InvariantCulture, out var minPart) || minPart < 0)
            return false;

        var hours = 0;
        if (parts.Length == 3)
        {
            if (!int.TryParse(parts[0], NumberStyles.Integer, CultureInfo.InvariantCulture, out hours) || hours < 0)
                return false;
            if (minPart >= 60)
                return false;
        }

        seconds = (hours * 3600) + (minPart * 60) + secPart;
        return true;
    }

    private string BuildAudioUrl()
    {
        var start = _startTime.ToString("0.###", CultureInfo.InvariantCulture);
        var end = _endTime.ToString("0.###", CultureInfo.InvariantCulture);
        return $"/api/audio/chapter/{Uri.EscapeDataString(_chapterName)}?start={start}&end={end}";
    }

    private string BuildPeaksUrl()
    {
        var start = _startTime.ToString("0.###", CultureInfo.InvariantCulture);
        var end = _endTime.ToString("0.###", CultureInfo.InvariantCulture);
        return $"/api/audio/chapter/{Uri.EscapeDataString(_chapterName)}/peaks?start={start}&end={end}&pxPerSec={PeakPxPerSec}";
    }

    private async Task Submit()
    {
        if (!TryCommitPendingRangeInputs())
            return;

        _submitting = true;
        StateHasChanged();
        try
        {
            await Task.Yield();
            var request = new CrxSubmitRequest(
                Start: _startTime,
                End: _endTime,
                SentenceId: _sentenceId,
                ErrorType: _errorType,
                Comments: _comments,
                Excerpt: _excerpt,
                PaddingMs: 0,
                ShouldBe: CrxCommentParser.TryParseShouldBe(_comments),
                ReadAs: CrxCommentParser.TryParseReadAs(_comments)
            );

            var result = CrxService.Submit(_chapterName, request);
            await OnSubmitted.InvokeAsync(result);
            Close();
        }
        finally
        {
            _submitting = false;
        }
    }

    private static string FormatTime(double seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        return $"{(int)ts.TotalMinutes}:{ts.Seconds:D2}.{ts.Milliseconds:D3}";
    }

    public async Task SubmitAsync()
    {
        if (_isVisible && !_submitting)
            await Submit();
    }

    private enum RangeBound
    {
        Start,
        End
    }

    private sealed record RangeDragState(RangeBound Bound, long PointerId, double StartY, double StartValue);

    private record ErrorOpItem(string Op, string Text, bool Selected);
}

<style>
    .crx-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }
    .crx-modal-overlay.visible {
        display: flex;
    }
    .crx-modal {
        background: var(--bit-clr-bg-pri);
        border-radius: 8px;
        width: fit-content;
        min-width: 600px;
        max-width: 95vw;
    }
    .crx-modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem;
        border-bottom: 1px solid var(--bit-clr-brd-sec);
    }
    .crx-modal-body {
        padding: 1rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    .crx-grid {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 1rem;
    }
    .crx-col-left {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        min-width: 140px;
    }
    .crx-col-right {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        max-width: 400px;
    }
    .crx-modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 0.5rem;
        padding: 1rem;
        border-top: 1px solid var(--bit-clr-brd-sec);
    }
    .crx-range-controls {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        padding: 0.45rem;
        border: 1px solid var(--bit-clr-brd-sec);
        border-radius: 6px;
        background: var(--bit-clr-bg-sec);
    }
    .crx-range-row {
        display: grid;
        grid-template-columns: 42px 1fr;
        align-items: center;
        gap: 0.45rem;
    }
    .crx-range-label {
        font-size: 0.8rem;
        color: var(--bit-clr-fg-sec);
    }
    .crx-range-input-wrap {
        position: relative;
        display: flex;
        align-items: center;
    }
    .crx-range-input {
        width: 100%;
        background: var(--bit-clr-bg-pri);
        color: var(--bit-clr-fg-pri);
        border: 1px solid var(--bit-clr-brd-pri);
        border-radius: 4px;
        padding: 0.4rem 1.7rem 0.4rem 0.5rem;
        font-family: inherit;
        font-size: 0.85rem;
        font-variant-numeric: tabular-nums;
        touch-action: none;
        user-select: none;
    }
    .crx-range-drag-hint {
        position: absolute;
        right: 0.45rem;
        color: var(--bit-clr-fg-sec);
        font-size: 0.9rem;
        pointer-events: none;
    }
    .crx-range-help {
        margin-top: 0.15rem;
        line-height: 1.25;
    }
    .crx-range-validation {
        line-height: 1.25;
    }
    .crx-range-confirm {
        display: flex;
        align-items: flex-start;
        gap: 0.45rem;
        font-size: 0.8rem;
        color: var(--bit-clr-fg-pri);
        line-height: 1.25;
        margin-top: 0.25rem;
    }
    .crx-range-confirm input {
        margin-top: 0.15rem;
    }
    .crx-range-confirm-status {
        line-height: 1.2;
    }
    .crx-errors-section {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }
    .crx-errors-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .crx-select-all {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        cursor: pointer;
    }
    .crx-errors-list {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        max-height: 150px;
        overflow-y: auto;
        padding: 0.25rem;
        background: var(--bit-clr-bg-sec);
