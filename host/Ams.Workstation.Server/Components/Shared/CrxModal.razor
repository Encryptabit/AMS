@using Ams.Workstation.Server.Models
@using Ams.Workstation.Server.Services
@using Ams.Workstation.Server.Components.UI
@inject CrxService CrxService
@inject IJSRuntime JS

<AmsDialog @bind-IsOpen="_isVisible"
           Title="Add to CRX"
           OnDismiss="HandleCancel">
    <ChildContent>
        @* Note: AmsDialog owns Escape/backdrop dismissal. E2E drivers must focus .ams-dialog before sending Escape (MEM099). *@
        <div class="crx-modal-body">
        <div class="crx-grid">
            <div class="crx-col-left">
                <label class="ams-field">
                    <span class="ams-caption ams-caption--muted">Error Type</span>
                    <select class="ams-select"
                            value="@_errorType"
                            @onchange="@(e => _errorType = e.Value?.ToString() ?? "MR")">
                        @foreach (var errorType in ErrorTypes.All)
                        {
                            <option value="@errorType">@errorType</option>
                        }
                    </select>
                </label>

                @if (_errorOps.Count > 0)
                {
                    <div class="crx-errors-section">
                        <div class="crx-errors-header">
                            <p class="ams-body">Errors to Highlight</p>
                            <label class="crx-select-all">
                                <input type="checkbox" checked="@_allSelected"
                                       @onchange="ToggleSelectAll" />
                                <span class="ams-caption ams-caption--muted">Select All</span>
                            </label>
                        </div>
                        <div class="crx-errors-list">
                            @for (var i = 0; i < _errorOps.Count; i++)
                            {
                                var idx = i;
                                var err = _errorOps[idx];
                                <label class="crx-error-item">
                                    <input type="checkbox" checked="@err.Selected"
                                           @onchange="@(() => ToggleError(idx))" />
                                    <span class="@(err.Op == "delete" ? "crx-del" : "crx-ins")">
                                        @(err.Op == "delete" ? "DEL" : "INS"): @err.Text
                                    </span>
                                </label>
                            }
                        </div>
                    </div>
                }

                <div class="padding-control">
                    <p class="ams-body">Tail Padding: @_paddingMs ms</p>
                    <input type="range" min="0" max="200" step="10"
                           value="@_paddingMs"
                           @oninput="OnPaddingInput"
                           @onchange="OnPaddingCommit" />
                </div>
            </div>

            <div class="crx-col-right">
                <WaveformPlayer @ref="_waveformPlayer"
                                AudioUrl="@_audioUrl"
                                PeaksUrl="@_peaksUrl"
                                Title="Audio Preview"
                                Height="80"
                                OnReady="FocusPlayButton" />
                <p class="ams-caption ams-caption--muted" style="text-align: center;">
                    @FormatTime(_startTime) → @FormatTime(_endTime + _paddingMs / 1000.0)
                </p>
            </div>
        </div>

        <div class="crx-comments">
            <p class="ams-body">Comments</p>
            <textarea rows="4" @bind="_comments" class="crx-comments-textarea"></textarea>
        </div>
        </div>
    </ChildContent>
    <FooterContent>
        <AmsButton Variant="secondary" OnClick="Close">Cancel</AmsButton>
        <AmsButton Variant="primary"
                   OnClick="Submit"
                   Disabled="@_submitting">
            @(_submitting ? "Submitting..." : "Add to CRX")
        </AmsButton>
    </FooterContent>
</AmsDialog>

@* TODO(T04): scoped SCSS sibling *@
@code {
    private const int PeakPxPerSec = 1200;
    private bool _isVisible;
    private string _chapterName = "";
    private double _startTime;
    private double _endTime;
    private int _sentenceId;
    private string _excerpt = "";
    private string _errorType = "MR";
    private string _comments = "";
    private int _paddingMs = 50;
    private bool _submitting;
    private string _audioUrl = "";
    private string? _peaksUrl;
    private SentenceReport? _sentenceReport;
    private WaveformPlayer? _waveformPlayer;

    // Error checkboxes built from diff ops
    private List<ErrorOpItem> _errorOps = new();
    private bool _allSelected = true;

    [Parameter] public EventCallback<CrxSubmitResult> OnSubmitted { get; set; }

    public void Open(string chapterName, double start, double end, int sentenceId, string excerpt, SentenceReport? sentenceReport = null)
    {
        _chapterName = chapterName;
        _startTime = start;
        _endTime = end;
        _sentenceId = sentenceId;
        _excerpt = excerpt;
        _sentenceReport = sentenceReport;
        _errorType = "MR";
        _paddingMs = 50;
        _isVisible = true;

        // Build error checkboxes from diff ops
        BuildErrorOps();
        _allSelected = _errorOps.All(e => e.Selected);

        // Generate initial comment
        _comments = GenerateComment();

        // Set audio URL
        _audioUrl = BuildAudioUrl();
        _peaksUrl = BuildPeaksUrl();

        StateHasChanged();
    }

    private Task HandleCancel()
    {
        Close();
        return Task.CompletedTask;
    }

    private async Task FocusPlayButton()
    {
        // Waveform is ready — focus the play button so spacebar previews the cut
        await JS.InvokeVoidAsync("eval",
            "document.querySelector('.ams-dialog button[title=\"Play\"]')?.focus()");
    }

    public void Close()
    {
        _isVisible = false;
        _audioUrl = "";
        _peaksUrl = null;
        StateHasChanged();
    }

    private void BuildErrorOps()
    {
        _errorOps.Clear();
        if (_sentenceReport?.Diff?.Ops == null) return;

        foreach (var op in _sentenceReport.Diff.Ops)
        {
            if (op.Op == "equal") continue;
            var text = string.Join(" ", op.Tokens);
            _errorOps.Add(new ErrorOpItem(op.Op, text, Selected: true));
        }
    }

    private void ToggleError(int index)
    {
        var item = _errorOps[index];
        _errorOps[index] = item with { Selected = !item.Selected };
        _allSelected = _errorOps.All(e => e.Selected);
        _comments = GenerateComment();
        StateHasChanged();
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        var selectAll = (bool)(e.Value ?? false);
        _allSelected = selectAll;
        for (var i = 0; i < _errorOps.Count; i++)
            _errorOps[i] = _errorOps[i] with { Selected = selectAll };
        _comments = GenerateComment();
        StateHasChanged();
    }

    /// <summary>
    /// Port of generateCrxCommentWithSelection from validation-viewer app.js
    /// </summary>
    private string GenerateComment()
    {
        if (_sentenceReport?.Diff?.Ops == null || _errorOps.Count == 0)
            return _excerpt;

        // Build a set of selected op indices (non-equal ops only)
        var selectedSet = new HashSet<int>();
        var errorIdx = 0;
        for (var i = 0; i < _sentenceReport.Diff.Ops.Count; i++)
        {
            var op = _sentenceReport.Diff.Ops[i];
            if (op.Op == "equal") continue;
            if (_errorOps[errorIdx].Selected)
                selectedSet.Add(i);
            errorIdx++;
        }

        var shouldBeLine = new List<string>();
        var readAsLine = new List<string>();
        var hasDifferences = false;

        for (var i = 0; i < _sentenceReport.Diff.Ops.Count; i++)
        {
            var op = _sentenceReport.Diff.Ops[i];
            var tokens = op.Tokens;
            if (tokens.Count == 0) continue;

            var text = string.Join(" ", tokens);
            var isSelected = selectedSet.Contains(i);

            if (op.Op == "equal")
            {
                shouldBeLine.Add(text);
                readAsLine.Add(text);
            }
            else if (op.Op == "delete")
            {
                if (isSelected)
                {
                    shouldBeLine.Add($"[{text}]");
                    hasDifferences = true;
                }
                else
                {
                    shouldBeLine.Add(text);
                }
            }
            else if (op.Op == "insert")
            {
                if (isSelected)
                {
                    readAsLine.Add($"[{text}]");
                    hasDifferences = true;
                }
                else
                {
                    readAsLine.Add(text);
                }
            }
        }

        if (!hasDifferences)
            return _sentenceReport.BookText;

        var shouldBe = string.Join(" ", shouldBeLine);
        var readAs = string.Join(" ", readAsLine);
        return $"Should be: {shouldBe}{Environment.NewLine}{Environment.NewLine}Read as: {readAs}";
    }

    private void OnPaddingInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val))
            _paddingMs = val;
    }

    private void OnPaddingCommit(ChangeEventArgs e)
    {
        // Rebuild audio URL only on slider release to avoid excessive reloads
        if (int.TryParse(e.Value?.ToString(), out var val))
        {
            _paddingMs = val;
            _audioUrl = BuildAudioUrl();
            _peaksUrl = BuildPeaksUrl();
            StateHasChanged();
        }
    }

    private string BuildAudioUrl()
    {
        var end = _endTime + (_paddingMs / 1000.0);
        return $"/api/audio/chapter/{Uri.EscapeDataString(_chapterName)}?start={_startTime}&end={end}";
    }

    private string BuildPeaksUrl()
    {
        var end = _endTime + (_paddingMs / 1000.0);
        return $"/api/audio/chapter/{Uri.EscapeDataString(_chapterName)}/peaks?start={_startTime}&end={end}&pxPerSec={PeakPxPerSec}";
    }

    private async Task Submit()
    {
        _submitting = true;
        StateHasChanged();
        try
        {
            await Task.Yield();
            var request = new CrxSubmitRequest(
                Start: _startTime,
                End: _endTime,
                SentenceId: _sentenceId,
                ErrorType: _errorType,
                Comments: _comments,
                Excerpt: _excerpt,
                PaddingMs: _paddingMs,
                ShouldBe: CrxCommentParser.TryParseShouldBe(_comments),
                ReadAs: CrxCommentParser.TryParseReadAs(_comments)
            );

            var result = CrxService.Submit(_chapterName, request);
            await OnSubmitted.InvokeAsync(result);
            Close();
        }
        finally
        {
            _submitting = false;
        }
    }

    private static string FormatTime(double seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        return $"{(int)ts.TotalMinutes}:{ts.Seconds:D2}.{ts.Milliseconds:D3}";
    }

    public async Task SubmitAsync()
    {
        if (_isVisible && !_submitting)
            await Submit();
    }

    private record ErrorOpItem(string Op, string Text, bool Selected);
}
