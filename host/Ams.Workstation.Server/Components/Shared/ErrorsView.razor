@using Ams.Workstation.Server.Models

<BitStack Horizontal="false" Gap="1.5rem" AutoHeight="true">
    @if (Report == null)
    {
        <BitStack HorizontalAlign="BitAlignment.Center" VerticalAlign="BitAlignment.Center" Style="padding: 2rem;">
            <BitProgress Circular="true" />
        </BitStack>
    }
    else
    {
        @* Stats Grid *@
        <BitGrid Columns="4" Spacing="1rem" Style="width: 100%;">
            <BitGridItem ColumnSpan="1" />
            <BitGridItem>
                <StatCard Title="Sentences"
                          Value="@Report.Stats.SentenceCount.ToString()"
                          Detail="@($"Flagged: {Report.Stats.FlaggedCount} | Avg WER: {Report.Stats.AvgWer} | Max: {Report.Stats.MaxWer}")" />
            </BitGridItem>
            <BitGridItem>
                <StatCard Title="Paragraphs"
                          Value="@Report.Stats.ParagraphCount.ToString()"
                          Detail="@($"Avg WER: {Report.Stats.ParagraphAvgWer} | Coverage: {Report.Stats.AvgCoverage}")" />
            </BitGridItem>
            <BitGridItem ColumnSpan="1" />
        </BitGrid>

        @* Chapter Error Patterns *@
        @if (VisiblePatterns.Any())
        {
            <BitStack Horizontal="false" Gap="0.5rem">
                <BitText Typography="BitTypography.Subtitle2">
                    Error Patterns (@VisiblePatterns.Count())
                </BitText>
                <BitGrid Columns="4" ColumnsSm="2" ColumnsMd="3" Spacing="0.75rem">
                    @foreach (var pattern in VisiblePatterns.Take(12))
                    {
                        <BitGridItem>
                            <PatternCard Pattern="pattern"
                                         OnToggleIgnore="() => ToggleIgnore(pattern)" />
                        </BitGridItem>
                    }
                </BitGrid>
            </BitStack>
        }

        @* Detailed Sentences *@
        <BitStack Horizontal="false" Gap="0.75rem">
            <BitText Typography="BitTypography.Subtitle1">
                Sentences with Errors (@ErrorSentences.Count())
            </BitText>
            @foreach (var sentence in ErrorSentences)
            {
                <SentenceErrorCard Sentence="sentence"
                                   OnPlayAudio="() => OnPlaySentence.InvokeAsync(sentence)"
                                   OnExport="() => HandleExport(sentence)"
                                   OnCrx="() => HandleCrx(sentence)"
                                   OnIgnore="() => OnIgnoreSentence.InvokeAsync(sentence)"
                                   IgnoredKeys="IgnoredKeys" />
            }
        </BitStack>
    }
</BitStack>

@code {
    [Parameter] public ChapterReport? Report { get; set; }
    [Parameter] public IReadOnlyList<ErrorPattern>? ChapterPatterns { get; set; }
    [Parameter] public EventCallback<SentenceReport> OnPlaySentence { get; set; }
    [Parameter] public EventCallback<SentenceReport> OnExportSentence { get; set; }
    [Parameter] public EventCallback<SentenceReport> OnCrxSentence { get; set; }
    [Parameter] public EventCallback<SentenceReport> OnIgnoreSentence { get; set; }
    [Parameter] public IReadOnlySet<string>? IgnoredKeys { get; set; }

    private IEnumerable<ErrorPattern> VisiblePatterns =>
        ChapterPatterns?.Where(p => !p.Ignored) ?? Enumerable.Empty<ErrorPattern>();

    private IEnumerable<SentenceReport> ErrorSentences =>
        Report?.Sentences
            .Where(s => s.Status != "ok" || HasNonEqualDiffOps(s.Diff))
            .OrderByDescending(s => ParseWer(s.Wer))
            .ThenBy(s => s.Id)
        ?? Enumerable.Empty<SentenceReport>();

    private static bool HasNonEqualDiffOps(DiffReport? diff) =>
        diff?.Ops.Any(op => op.Op != "equal") == true;

    private double ParseWer(string wer)
    {
        if (double.TryParse(wer.TrimEnd('%'), out var v)) return v;
        return 0;
    }

    private void ToggleIgnore(ErrorPattern pattern)
    {
        // In-memory toggle — persistence deferred to Plan 05
        pattern.Ignored = !pattern.Ignored;
        StateHasChanged();
    }


    private async Task HandleExport(SentenceReport sentence)
    {
        await OnExportSentence.InvokeAsync(sentence);
    }

    private async Task HandleCrx(SentenceReport sentence)
    {
        await OnCrxSentence.InvokeAsync(sentence);
    }
}
