@using Ams.Workstation.Server.Services
@inject ReviewedStatusService ReviewedStatusService

<BitCard Class="@GetCardClass()" @onclick="HandleClick" Style="cursor: pointer;">
    <BitStack Horizontal="false" Gap="0.5rem">
        <BitStack Horizontal="true" Gap="0.5rem" VerticalAlign="BitAlignment.Center" AutoHeight="true">
            <BitText Typography="BitTypography.Subtitle2">@Chapter.Name</BitText>
            @if (IsReviewed)
            {
                <span class="reviewed-badge">reviewed</span>
            }
        </BitStack>
        <div class="chapter-metrics">
            <span class="metric">
                <span class="label">Sentences:</span>
                <span class="value">@Chapter.Metrics.SentenceCount (@Chapter.Metrics.SentenceFlagged flagged)</span>
            </span>
            <span class="metric">
                <span class="label">Avg WER:</span>
                <span class="value @GetWerClass()">@Chapter.Metrics.SentenceAvgWer</span>
            </span>
        </div>
    </BitStack>
</BitCard>

@code {
    [Parameter] public ProofChapterInfo Chapter { get; set; } = default!;
    [Parameter] public EventCallback OnClick { get; set; }

    private bool IsReviewed => ReviewedStatusService.IsReviewed(Chapter.Name);

    private async Task HandleClick() => await OnClick.InvokeAsync();

    private string GetCardClass()
    {
        var statusClass = GetStatusClass();
        return string.IsNullOrEmpty(statusClass) ? "chapter-card" : $"chapter-card {statusClass}";
    }

    private string GetStatusClass()
    {
        return IsReviewed ? "reviewed" : "";
    }

    private string GetWerClass()
    {
        // Parse WER percentage and classify
        if (double.TryParse(Chapter.Metrics.SentenceAvgWer.TrimEnd('%'), out var wer))
        {
            if (wer >= 10) return "wer-high";
            if (wer >= 5) return "wer-medium";
        }
        return "wer-low";
    }
}

<style>
    .chapter-card {
        transition: background-color 0.15s ease;
        padding: 1rem;
    }

    .chapter-card:hover {
        background-color: var(--bit-clr-bg-sec-hover);
    }

    .chapter-metrics {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .metric .label {
        color: var(--bit-clr-fg-sec);
        margin-right: 0.25rem;
    }

    .wer-high {
        color: #f48771;
    }

    .wer-medium {
        color: #dcdcaa;
    }

    .wer-low {
        color: #4ec9b0;
    }

    .chapter-card.reviewed {
        border-left: 3px solid #4ec9b0;
    }

    .reviewed-badge {
        font-size: 0.65rem;
        padding: 0.1rem 0.3rem;
        border-radius: 3px;
        background-color: rgba(78, 201, 176, 0.2);
        color: #4ec9b0;
        text-transform: uppercase;
        font-weight: 600;
    }
</style>
