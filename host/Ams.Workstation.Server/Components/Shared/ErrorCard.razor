@using Ams.Workstation.Server.Models

<BitCard FullSize="true" Style="cursor: pointer;" @onclick="HandleClick">
    <BitStack Horizontal="false" Gap="0.25rem" Style="padding: 0.75rem;">
        <BitStack Horizontal="true" HorizontalAlign="BitAlignment.SpaceBetween" VerticalAlign="BitAlignment.Center">
            <BitText Typography="BitTypography.Body2" Style="font-weight: 600;">#@Sentence.Id</BitText>
            <BitTag Text="@Sentence.Status.ToUpper()"
                    Color="GetStatusColor()"
                    Size="BitSize.Small"
                    Variant="BitVariant.Fill" />
        </BitStack>
        <BitText Typography="BitTypography.Caption1">WER: @Sentence.Wer &nbsp; CER: @Sentence.Cer</BitText>
        @if (!string.IsNullOrEmpty(Sentence.BookText))
        {
            <BitText Typography="BitTypography.Caption2" Color="BitColor.SecondaryForeground"
                     Style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                @Sentence.BookText
            </BitText>
        }
    </BitStack>
</BitCard>

@code {
    [Parameter] public SentenceReport Sentence { get; set; } = default!;
    [Parameter] public EventCallback OnClick { get; set; }

    private async Task HandleClick() => await OnClick.InvokeAsync();

    private BitColor GetStatusColor() => Sentence.Status switch
    {
        "unreliable" => BitColor.Error,
        "attention" => BitColor.Warning,
        "ok" => BitColor.Success,
        _ => BitColor.Secondary
    };
}
