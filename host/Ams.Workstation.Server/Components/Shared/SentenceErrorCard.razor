@using Ams.Workstation.Server.Models

<BitCard Style="@GetBorderStyle()" FullWidth="true">
    <BitStack Horizontal="false" Gap="0.5rem" Style="padding: 1rem;">
        @* Header: ID + WER/CER + Status badge + metadata all horizontal *@
        <BitStack Horizontal="true" Gap="1rem" VerticalAlign="BitAlignment.Center" Wrap="true">
            <BitStack Horizontal="true" Gap="0.35rem" VerticalAlign="BitAlignment.Center">
                <BitText Typography="BitTypography.Body1" Style="font-weight: 600;">#@Sentence.Id</BitText>
                @if (IsExported)
                {
                    <BitIcon IconName="@BitIconName.SkypeCircleCheck"
                             Style="color: #4a9eff; font-size: 1rem;"
                             Title="Exported to CRX" />
                }
            </BitStack>
            <BitText Typography="BitTypography.Caption1">
                WER: <span style="color: var(@GetWerColor());">@Sentence.Wer</span>
                &nbsp;&nbsp;CER: @Sentence.Cer
            </BitText>
            <BitTag Text="@Sentence.Status.ToUpper()"
                    Color="GetStatusColor()"
                    Size="BitSize.Small"
                    Variant="BitVariant.Fill" />
            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Book range: @Sentence.BookRange</BitText>
            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Script range: @Sentence.ScriptRange</BitText>
            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">Timing: @Sentence.Timing</BitText>
        </BitStack>

        @* Manuscript *@
        <BitCard Background="BitColorKind.Primary" NoShadow="true" FullWidth="true">
            <BitStack Horizontal="false" Gap="0.4rem" Style="padding: 0.75rem;">
                <BitText Typography="BitTypography.Overline">MANUSCRIPT</BitText>
                <BitText Typography="BitTypography.Body2" Style="line-height: 1.6;">@Sentence.BookText</BitText>
            </BitStack>
        </BitCard>

        @* Transcript (Diff) *@
        @if (Sentence.Diff != null)
        {
            <BitCard Background="BitColorKind.Primary" NoShadow="true" FullWidth="true">
                <BitStack Horizontal="false" Gap="0.4rem" Style="padding: 0.75rem;">
                    <BitText Typography="BitTypography.Overline">TRANSCRIPT</BitText>
                    <DiffView Diff="Sentence.Diff" IgnoredKeys="IgnoredKeys" />
                </BitStack>
            </BitCard>
        }

        @* Action Buttons *@
        <BitStack Horizontal="true" Gap="0.5rem" Wrap="true" HorizontalAlign="BitAlignment.Center">
            <BitButton Variant="BitVariant.Fill" Size="BitSize.Medium"
                       Color="BitColor.Primary"
                       OnClick="() => OnPlayAudio.InvokeAsync()">
                Play Audio Segment
            </BitButton>
            <BitButton Variant="BitVariant.Outline" Size="BitSize.Medium"
                       Color="BitColor.Tertiary"
                       OnClick="() => OnView.InvokeAsync()">
                View in Playback
            </BitButton>
            <BitButton Variant="BitVariant.Outline" Size="BitSize.Medium"
                       OnClick="() => OnExport.InvokeAsync()">
                Export Audio
            </BitButton>
            <BitButton Variant="BitVariant.Outline" Size="BitSize.Medium"
                       OnClick="() => OnCrx.InvokeAsync()">
                Add to CRX
            </BitButton>
            <BitButton Variant="BitVariant.Text" Size="BitSize.Medium"
                       OnClick="() => OnIgnore.InvokeAsync()">
                Ignore Error...
            </BitButton>
        </BitStack>
    </BitStack>
</BitCard>

@code {
    [Parameter] public SentenceReport Sentence { get; set; } = default!;
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public bool IsExported { get; set; }
    [Parameter] public EventCallback OnPlayAudio { get; set; }
    [Parameter] public EventCallback OnExport { get; set; }
    [Parameter] public EventCallback OnCrx { get; set; }
    [Parameter] public EventCallback OnIgnore { get; set; }
    [Parameter] public EventCallback OnView { get; set; }
    [Parameter] public IReadOnlySet<string>? IgnoredKeys { get; set; }

    private string GetBorderStyle()
    {
        var outline = IsSelected ? "outline: 2px solid var(--bit-clr-pri); " : "";
        return Sentence.Status switch
        {
            "unreliable" => $"{outline}border-left: 3px solid var(--bit-clr-err); margin-bottom: 0.75rem;",
            "attention" => $"{outline}border-left: 3px solid var(--bit-clr-wrn); margin-bottom: 0.75rem;",
            _ => $"{outline}border-left: 3px solid transparent; margin-bottom: 0.75rem;"
        };
    }

    private BitColor GetStatusColor() => Sentence.Status switch
    {
        "unreliable" => BitColor.Error,
        "attention" => BitColor.Warning,
        "ok" => BitColor.Success,
        _ => BitColor.Secondary
    };

    private string GetWerColor()
    {
        if (double.TryParse(Sentence.Wer.TrimEnd('%'), out var wer))
        {
            if (wer >= 50) return "--bit-clr-err";
            if (wer >= 10) return "--bit-clr-wrn";
        }
        return "--bit-clr-suc";
    }
}
