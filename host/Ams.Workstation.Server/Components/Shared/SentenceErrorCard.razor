@using Ams.Workstation.Server.Models

<BitCard Class="@($"sentence-error-card {GetStatusClass()}")">
    <BitStack Horizontal="false" Gap="0.75rem">
        @* Header *@
        <BitStack Horizontal="true" HorizontalAlign="BitAlignment.SpaceBetween">
            <BitStack Horizontal="true" Gap="1rem" VerticalAlign="BitAlignment.Center">
                <BitText Typography="BitTypography.Subtitle2">#@Sentence.Id</BitText>
                <span class="metrics">
                    WER: <span class="@GetWerClass()">@Sentence.Wer</span> |
                    CER: @Sentence.Cer
                </span>
                <span class="status-badge @Sentence.Status">@Sentence.Status</span>
            </BitStack>
            <BitText Typography="BitTypography.Caption2" Color="BitColor.SecondaryForeground">
                @Sentence.Timing
            </BitText>
        </BitStack>

        @* Book Text *@
        <div class="text-section">
            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">
                Manuscript
            </BitText>
            <BitText Typography="BitTypography.Body2">@Sentence.BookText</BitText>
        </div>

        @* Diff View *@
        @if (Sentence.Diff != null)
        {
            <div class="text-section">
                <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">
                    Differences
                </BitText>
                <DiffView Diff="Sentence.Diff" />
            </div>
        }

        @* Action Buttons *@
        <BitStack Horizontal="true" Gap="0.5rem">
            <BitButton Variant="BitVariant.Outline" Size="BitSize.Small"
                       OnClick="() => OnPlayAudio.InvokeAsync()">
                Play
            </BitButton>
            <BitButton Variant="BitVariant.Outline" Size="BitSize.Small"
                       Color="BitColor.Success"
                       OnClick="() => OnExport.InvokeAsync()">
                Export
            </BitButton>
            <BitButton Variant="BitVariant.Outline" Size="BitSize.Small"
                       Color="BitColor.Tertiary"
                       OnClick="() => OnCrx.InvokeAsync()">
                Add to CRX
            </BitButton>
        </BitStack>
    </BitStack>
</BitCard>

@code {
    [Parameter] public SentenceReport Sentence { get; set; } = default!;
    [Parameter] public EventCallback OnPlayAudio { get; set; }
    [Parameter] public EventCallback OnExport { get; set; }
    [Parameter] public EventCallback OnCrx { get; set; }

    private string GetStatusClass() => Sentence.Status switch
    {
        "unreliable" => "unreliable",
        "attention" => "attention",
        _ => ""
    };

    private string GetWerClass()
    {
        if (double.TryParse(Sentence.Wer.TrimEnd('%'), out var wer))
        {
            if (wer >= 50) return "wer-high";
            if (wer >= 10) return "wer-medium";
        }
        return "wer-low";
    }
}

<style>
    .sentence-error-card {
        margin-bottom: 0.75rem;
    }
    .sentence-error-card.unreliable {
        border-left: 4px solid #f48771;
    }
    .sentence-error-card.attention {
        border-left: 4px solid #dcdcaa;
    }
    .text-section {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }
    .metrics {
        font-size: 0.85rem;
    }
    .status-badge {
        font-size: 0.7rem;
        padding: 0.1rem 0.4rem;
        border-radius: 3px;
        text-transform: uppercase;
        font-weight: 600;
    }
    .status-badge.unreliable {
        background-color: rgba(244, 135, 113, 0.2);
        color: #f48771;
    }
    .status-badge.attention {
        background-color: rgba(220, 220, 170, 0.2);
        color: #dcdcaa;
    }
    .status-badge.ok {
        background-color: rgba(78, 201, 176, 0.2);
        color: #4ec9b0;
    }
    .wer-high { color: #f48771; }
    .wer-medium { color: #dcdcaa; }
    .wer-low { color: #4ec9b0; }
</style>
