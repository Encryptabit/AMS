@using Ams.Workstation.Server.Components.UI
@using Ams.Workstation.Server.Models

<section class="@GetCardClass()">
    <header class="sentence-error-card__header">
        <div class="sentence-error-card__meta">
            <span class="sentence-error-card__id">#@Sentence.Id</span>
            <span class="sentence-error-card__wer">
                WER: <span class="@GetWerClass()">@Sentence.Wer</span>
                <span class="sentence-error-card__cer">CER: @Sentence.Cer</span>
            </span>
            <AmsTag Tone="@GetStatusTone()" Size="sm">@GetStatusLabel()</AmsTag>
            <span class="sentence-error-card__range">Book range: @Sentence.BookRange</span>
            <span class="sentence-error-card__range">Script range: @Sentence.ScriptRange</span>
            <span class="sentence-error-card__range">Timing: @Sentence.Timing</span>
        </div>
        @if (IsExported)
        {
            <span aria-hidden="true" class="sentence-error-card__exported" title="Exported to CRX">📤</span>
        }
    </header>

    <div class="sentence-error-card__transcripts">
        <section class="sentence-error-card__transcript-panel">
            <h4 class="sentence-error-card__transcript-title">MANUSCRIPT</h4>
            <p class="sentence-error-card__transcript-text">@Sentence.BookText</p>
        </section>

        @if (Sentence.Diff != null)
        {
            <section class="sentence-error-card__transcript-panel">
                <h4 class="sentence-error-card__transcript-title">TRANSCRIPT</h4>
                <DiffView Diff="Sentence.Diff" IgnoredKeys="IgnoredKeys" />
            </section>
        }
    </div>

    <div class="sentence-error-card__actions">
        <AmsButton Variant="primary" Size="sm"
                   OnClick="() => OnPlayAudio.InvokeAsync()">
            Play Audio Segment
        </AmsButton>
        <AmsButton Variant="secondary" Size="sm"
                   OnClick="() => OnView.InvokeAsync()">
            View in Playback
        </AmsButton>
        <AmsButton Variant="secondary" Size="sm"
                   OnClick="() => OnExport.InvokeAsync()">
            Export Audio
        </AmsButton>
        <AmsButton Variant="secondary" Size="sm"
                   OnClick="() => OnCrx.InvokeAsync()">
            Add to CRX
        </AmsButton>
        <AmsButton Variant="ghost" Size="sm"
                   OnClick="() => OnIgnore.InvokeAsync()">
            Ignore Error...
        </AmsButton>
    </div>
</section>

@code {
    [Parameter] public SentenceReport Sentence { get; set; } = default!;
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public bool IsExported { get; set; }
    [Parameter] public EventCallback OnPlayAudio { get; set; }
    [Parameter] public EventCallback OnExport { get; set; }
    [Parameter] public EventCallback OnCrx { get; set; }
    [Parameter] public EventCallback OnIgnore { get; set; }
    [Parameter] public EventCallback OnView { get; set; }
    [Parameter] public IReadOnlySet<string>? IgnoredKeys { get; set; }

    private string GetCardClass()
    {
        var classes = new List<string>
        {
            "sentence-error-card",
            $"sentence-error-card--status-{GetStatusKey()}"
        };

        if (IsSelected)
        {
            classes.Add("sentence-error-card--selected");
        }

        return string.Join(" ", classes);
    }

    private string GetStatusKey() => Sentence.Status switch
    {
        "unreliable" => "err",
        "attention" => "wrn",
        "ok" => "suc",
        _ => "pri"
    };

    private string GetStatusTone() => Sentence.Status switch
    {
        "unreliable" => "danger",
        "attention" => "warning",
        "ok" => "success",
        _ => "secondary"
    };

    private string GetStatusLabel() => (Sentence.Status ?? string.Empty).ToUpperInvariant();

    private string GetWerClass()
    {
        if (double.TryParse(Sentence.Wer.TrimEnd('%'), out var wer))
        {
            if (wer >= 50) return "sentence-error-card__wer-value sentence-error-card__wer-value--high";
            if (wer >= 10) return "sentence-error-card__wer-value sentence-error-card__wer-value--medium";
        }

        return "sentence-error-card__wer-value sentence-error-card__wer-value--low";
    }
}
