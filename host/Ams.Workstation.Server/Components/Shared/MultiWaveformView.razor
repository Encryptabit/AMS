@inject IJSRuntime JS
@implements IAsyncDisposable

<BitStack Vertical Gap="0.25rem" AutoHeight="true">
    @if (Chapters is not null)
    {
        @foreach (var chapter in Chapters)
        {
            <div class="multi-waveform-track">
                <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground"
                         Style="padding: 0.125rem 0.25rem;">
                    @chapter.ChapterName
                </BitText>
                <WaveformPlayer @ref="@(_waveformRefs[chapter.ChapterName])"
                                AudioUrl="@chapter.AudioUrl"
                                Title="@chapter.ChapterName"
                                Height="@chapter.Height"
                                TimeUpdated="@(time => HandleTimeUpdated(chapter.ChapterName, chapter.RegionStartSec, time))" />
            </div>
        }
    }
</BitStack>

@code {
    private IJSObjectReference? _module;
    private readonly Dictionary<string, WaveformPlayer> _waveformRefs = new();
    private double _lastSyncTime;
    private bool _isSyncing;

    /// <summary>
    /// Configuration for a single chapter track in the multi-waveform stacked view.
    /// </summary>
    public record ChapterWaveformConfig(
        string ChapterName,
        string AudioUrl,
        double RegionStartSec,
        double RegionEndSec,
        int Height = 80);

    /// <summary>
    /// List of chapters to display as stacked waveforms.
    /// </summary>
    [Parameter]
    public IReadOnlyList<ChapterWaveformConfig>? Chapters { get; set; }

    /// <summary>
    /// Callback fired when the synchronized time changes (absolute time in the chapter).
    /// </summary>
    [Parameter]
    public EventCallback<double> OnTimeChanged { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/waveform-interop.js");
        }
    }

    protected override void OnParametersSet()
    {
        // Ensure refs dictionary has entries for all chapters
        if (Chapters is not null)
        {
            foreach (var chapter in Chapters)
            {
                _waveformRefs.TryAdd(chapter.ChapterName, null!);
            }
        }
    }

    private async Task HandleTimeUpdated(string sourceChapter, double regionStart, double relativeTime)
    {
        if (_isSyncing) return;

        // Convert relative time (within region) to absolute time
        var absoluteTime = regionStart + relativeTime;

        // Debounce: only sync if time delta > 0.05s
        if (Math.Abs(absoluteTime - _lastSyncTime) < 0.05) return;
        _lastSyncTime = absoluteTime;

        _isSyncing = true;
        try
        {
            // Collect element IDs of other waveforms and sync via JS interop syncPlayheads
            if (_module is not null && Chapters is not null)
            {
                var otherIds = new List<string>();
                var otherTimes = new Dictionary<string, double>();

                foreach (var chapter in Chapters)
                {
                    if (chapter.ChapterName == sourceChapter) continue;

                    if (_waveformRefs.TryGetValue(chapter.ChapterName, out var waveform) && waveform is not null)
                    {
                        // Convert absolute time back to relative time for this chapter's region
                        var targetRelativeTime = absoluteTime - chapter.RegionStartSec;
                        if (targetRelativeTime >= 0 && targetRelativeTime <= (chapter.RegionEndSec - chapter.RegionStartSec))
                        {
                            otherIds.Add(waveform.ElementId);
                            otherTimes[waveform.ElementId] = targetRelativeTime;
                        }
                    }
                }

                // Use syncPlayheads JS interop for synchronized seeking
                if (otherIds.Count > 0)
                {
                    // syncPlayheads expects a single time -- use relative time for the target region
                    // Since each waveform may have different region offsets, seek individually
                    foreach (var id in otherIds)
                    {
                        await _module.InvokeVoidAsync("syncPlayheads", new[] { id }, otherTimes[id]);
                    }
                }
            }

            await OnTimeChanged.InvokeAsync(absoluteTime);
        }
        finally
        {
            _isSyncing = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Circuit disconnected
            }
        }
    }
}

<style>
    .multi-waveform-track {
        border-bottom: 1px solid var(--bit-clr-brd-sec);
        padding-bottom: 0.25rem;
    }

    .multi-waveform-track:last-child {
        border-bottom: none;
    }
</style>
