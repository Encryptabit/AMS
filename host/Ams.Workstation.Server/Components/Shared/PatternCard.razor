@using Ams.Workstation.Server.Components.UI
@using Ams.Workstation.Server.Models

<section class="@GetCardClass()">
    <header class="pattern-card__header">
        <span class="pattern-card__type pattern-card__type--@GetTypeKey()">
            @Pattern.Type.ToUpperInvariant()
        </span>
        <span class="pattern-card__count">@Pattern.Count occurrences</span>
    </header>

    <span class="pattern-card__diff">
        @if (!string.IsNullOrEmpty(Pattern.Book))
        {
            <span class="pattern-card__from">"@Pattern.Book"</span>
        }
        @if (!string.IsNullOrEmpty(Pattern.Book) && !string.IsNullOrEmpty(Pattern.Script))
        {
            <span class="pattern-card__arrow" aria-hidden="true">→</span>
        }
        @if (!string.IsNullOrEmpty(Pattern.Script))
        {
            <span class="pattern-card__to">"@Pattern.Script"</span>
        }
    </span>

    <div class="pattern-card__actions">
        <AmsButton Variant="secondary"
                   Size="sm"
                   OnClick="() => OnToggleIgnore.InvokeAsync()">
            @(Pattern.Ignored ? "Unignore" : "Ignore")
        </AmsButton>
    </div>
</section>

@code {
    [Parameter] public ErrorPattern Pattern { get; set; } = default!;
    [Parameter] public EventCallback OnToggleIgnore { get; set; }

    private string GetCardClass() => Pattern.Ignored
        ? "pattern-card pattern-card--ignored"
        : "pattern-card";

    private string GetTypeKey() => Pattern.Type?.ToLowerInvariant() switch
    {
        "del" => "del",
        "ins" => "ins",
        "sub" => "sub",
        _ => "other"
    };
}
