@using Ams.Workstation.Server.Models

<BitCard FullSize="true" Style="@GetCardStyle()">
    <BitStack Horizontal="false" Gap="0.25rem" Style="height: 100%;">
        <BitStack Horizontal="true" HorizontalAlign="BitAlignment.SpaceBetween">
            <BitText Typography="BitTypography.Caption1" Style="@GetTypeStyle()">
                @Pattern.Type.ToUpper()
            </BitText>
            <BitText Typography="BitTypography.Caption1" Color="BitColor.SecondaryForeground">
                @Pattern.Count occurrences
            </BitText>
        </BitStack>

        <div style="font-family: monospace; font-size: 0.85rem; line-height: 1.4;">
            @if (!string.IsNullOrEmpty(Pattern.Book))
            {
                <span class="pattern-del">"@Pattern.Book"</span>
            }
            @if (!string.IsNullOrEmpty(Pattern.Book) && !string.IsNullOrEmpty(Pattern.Script))
            {
                <span style="color: var(--bit-clr-fg-sec); margin: 0 0.25rem;">&#8594;</span>
            }
            @if (!string.IsNullOrEmpty(Pattern.Script))
            {
                <span class="pattern-ins">"@Pattern.Script"</span>
            }
        </div>

        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
            @foreach (var ex in Pattern.Examples.Take(3))
            {
                <BitLink OnClick="() => OnExampleClick.InvokeAsync(ex)" Style="font-size: 0.75rem;">
                    @ex.Chapter #@ex.SentenceId
                </BitLink>
            }
        </div>

        <BitStack HorizontalAlign="BitAlignment.Center" Style="margin-top: auto; justify-content: flex-end;">
            <BitButton Variant="BitVariant.Fill"
                       Color="@(Pattern.Ignored ? BitColor.Secondary : BitColor.Primary)"
                       OnClick="() => OnToggleIgnore.InvokeAsync()"
                       Size="BitSize.Small">
                @(Pattern.Ignored ? "Unignore" : "Ignore")
            </BitButton>
        </BitStack>
    </BitStack>
</BitCard>

@code {
    [Parameter] public ErrorPattern Pattern { get; set; } = default!;
    [Parameter] public EventCallback OnToggleIgnore { get; set; }
    [Parameter] public EventCallback<PatternExample> OnExampleClick { get; set; }

    private string GetCardStyle() => Pattern.Ignored
        ? "opacity: 0.4;"
        : "";

    private string GetTypeStyle() => Pattern.Type switch
    {
        "del" => "color: var(--bit-clr-err); font-weight: 600;",
        "ins" => "color: var(--bit-clr-suc); font-weight: 600;",
        "sub" => "color: var(--bit-clr-wrn); font-weight: 600;",
        _ => "font-weight: 600;"
    };
}

<style>
    .pattern-del {
        color: var(--bit-clr-err);
    }
    .pattern-ins {
        color: var(--bit-clr-suc);
    }
</style>
