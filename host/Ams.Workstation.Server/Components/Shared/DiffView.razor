@using Ams.Workstation.Server.Models

<div class="diff-view">
    @foreach (var op in Diff.Ops)
    {
        @if (op.Op == "equal")
        {
            @foreach (var token in op.Tokens)
            {
                <span class="diff-token">@token</span>
            }
        }
        else if (op.Op == "delete")
        {
            @foreach (var token in op.Tokens)
            {
                <span class="diff-token diff-delete">@token</span>
            }
        }
        else if (op.Op == "insert")
        {
            @foreach (var token in op.Tokens)
            {
                <span class="diff-token diff-insert">@token</span>
            }
        }
    }
</div>

@code {
    [Parameter] public DiffReport Diff { get; set; } = default!;
}

<style>
    .diff-view {
        line-height: 1.8;
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem;
    }
    .diff-token {
        padding: 2px 4px;
        border-radius: 3px;
    }
    .diff-delete {
        background-color: var(--bit-clr-err-bg);
        color: var(--bit-clr-err);
        text-decoration: line-through;
    }
    .diff-insert {
        background-color: var(--bit-clr-suc-bg);
        color: var(--bit-clr-suc);
        font-weight: 500;
    }
</style>
