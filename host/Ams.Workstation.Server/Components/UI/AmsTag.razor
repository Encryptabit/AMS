@* Vanilla tag/pill primitive. Tones: primary | secondary | success | warning | danger | info | neutral.
   Sizes: sm | md. Visual rules live in Styles/components/_tag.scss. *@

<span class="@ComposeClasses()" @attributes="AdditionalAttributes">@ChildContent</span>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string Tone { get; set; } = "neutral";
    [Parameter] public string Size { get; set; } = "md";
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string ComposeClasses() => $"ams-tag ams-tag--{Tone} ams-tag--{Size}";
}
