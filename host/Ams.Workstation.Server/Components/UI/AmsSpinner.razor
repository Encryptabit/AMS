@* Vanilla spinner primitive. Tones: primary | secondary | neutral | success | warning | danger | info.
   Sizes: sm | md | lg. Visual rules live in Styles/components/_spinner.scss. *@

<span class="@ComposeClasses()"
      role="status"
      aria-live="polite"
      @attributes="AdditionalAttributes">
    <span class="u-sr-only">@Label</span>
</span>

@code {
    [Parameter] public string Size { get; set; } = "md";
    [Parameter] public string Tone { get; set; } = "primary";
    [Parameter] public string Label { get; set; } = "Loading";
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string ComposeClasses() => $"ams-spinner ams-spinner--{Size} ams-spinner--{Tone}";
}
