<div class="mobile-action-bar"
     data-ams-proof-mobile-action-bar="selection-workflow"
     data-ams-proof-mobile-action-bar-view="@CurrentView"
     data-ams-proof-mobile-action-bar-selection-mode="@(IsSelectionModeActive ? "active" : "inactive")"
     data-ams-proof-mobile-action-bar-selection-count="@SelectedCount"
     data-ams-proof-mobile-action-bar-expanded="@(_isExpanded ? "true" : "false")">
    <button type="button"
            class="mobile-action-bar__handle"
            aria-label="@(_isExpanded ? "Hide quick actions" : "Show quick actions")"
            aria-expanded="@(_isExpanded ? "true" : "false")"
            data-ams-proof-mobile-action-bar-toggle="true"
            @onclick="ToggleExpanded">
        <span class="mobile-action-bar__handle-icon" aria-hidden="true">
            @(_isExpanded ? "▾" : "▴")
        </span>
    </button>

    @if (_isExpanded)
    {
        @if (IsSelectionModeActive)
        {
            <div class="mobile-action-bar__status"
                 data-ams-proof-mobile-selection-summary="@SelectionSummaryState">
                <BitText Typography="BitTypography.Caption1"
                         Color="BitColor.SecondaryForeground">
                    @SelectionSummaryText
                </BitText>
            </div>
        }

        <div class="mobile-action-bar__actions"
             data-ams-proof-mobile-action-grid="true">
            <span class="mobile-action-bar__action-host"
                  data-ams-proof-mobile-action-host="errors"
                  @onpointerdown="@(args => HandleErrorsPointerDown(args))"
                  @onpointerup="HandleErrorsPointerEnd"
                  @onpointercancel="HandleErrorsPointerEnd"
                  @onpointerleave="HandleErrorsPointerEnd">
                <BitButton Variant="@(IsErrorsView ? BitVariant.Fill : BitVariant.Outline)"
                           Color="BitColor.Primary"
                           Size="BitSize.Small"
                           data-ams-proof-mobile-action="errors"
                           OnClick="HandleSwitchToErrorsAsync">
                    Errors
                </BitButton>
            </span>

            <span class="mobile-action-bar__action-host"
                  data-ams-proof-mobile-action-host="playback"
                  @onpointerdown="@(args => HandlePlaybackPointerDown(args))"
                  @onpointerup="HandlePlaybackPointerEnd"
                  @onpointercancel="HandlePlaybackPointerEnd"
                  @onpointerleave="HandlePlaybackPointerEnd">
                <BitButton Variant="@(IsPlaybackView ? BitVariant.Fill : BitVariant.Outline)"
                           Color="BitColor.Primary"
                           Size="BitSize.Small"
                           data-ams-proof-mobile-action="playback"
                           OnClick="HandleSwitchToPlaybackAsync">
                    Playback
                </BitButton>
            </span>

            <BitButton Variant="@(IsReviewed ? BitVariant.Fill : BitVariant.Outline)"
                       Color="@(IsReviewed ? BitColor.Success : BitColor.Primary)"
                       Size="BitSize.Small"
                       data-ams-proof-mobile-action="reviewed"
                       OnClick="HandleToggleReviewedAsync">
                @(IsReviewed ? "Reviewed" : "Review")
            </BitButton>

            <BitButton Variant="BitVariant.Outline"
                       Color="BitColor.Secondary"
                       Size="BitSize.Small"
                       data-ams-proof-mobile-action="pickups"
                       OnClick="HandleNavigateToPickupsAsync">
                Pickups
            </BitButton>

            <BitButton Variant="BitVariant.Outline"
                       Color="BitColor.Secondary"
                       Size="BitSize.Small"
                       data-ams-proof-mobile-action="modules"
                       OnClick="HandleToggleModulesAsync">
                Modules
            </BitButton>
        </div>
    }
</div>

@code {
    private const int LongPressDelayMs = 450;

    [Parameter] public string CurrentView { get; set; } = "playback";
    [Parameter] public bool IsSelectionModeActive { get; set; }
    [Parameter] public int SelectedCount { get; set; }
    [Parameter] public bool IsBatchActionsEnabled { get; set; }
    [Parameter] public bool IsReviewed { get; set; }

    [Parameter] public EventCallback OnSwitchToErrors { get; set; }
    [Parameter] public EventCallback OnSwitchToErrorsLongPress { get; set; }
    [Parameter] public EventCallback OnSwitchToPlayback { get; set; }
    [Parameter] public EventCallback OnSwitchToPlaybackLongPress { get; set; }
    [Parameter] public EventCallback OnExportSelection { get; set; }
    [Parameter] public EventCallback OnIgnoreSelection { get; set; }
    [Parameter] public EventCallback OnToggleReviewed { get; set; }
    [Parameter] public EventCallback OnToggleModules { get; set; }
    [Parameter] public EventCallback OnNavigateToPickups { get; set; }

    private bool _isExpanded;
    private CancellationTokenSource? _errorsLongPressCts;
    private CancellationTokenSource? _playbackLongPressCts;
    private bool _errorsLongPressFired;
    private bool _playbackLongPressFired;

    private string SelectionSummaryState => IsSelectionModeActive ? "active" : "inactive";

    private string SelectionSummaryText
        => IsSelectionModeActive
            ? $"Selected: {SelectedCount} sentence{(SelectedCount == 1 ? string.Empty : "s")}."
            : "Selection mode inactive.";

    private bool IsErrorsView => string.Equals(CurrentView, "errors", StringComparison.Ordinal);

    private bool IsPlaybackView => string.Equals(CurrentView, "playback", StringComparison.Ordinal);

    private void ToggleExpanded() => _isExpanded = !_isExpanded;

    private async Task HandleSwitchToErrorsAsync()
    {
        if (_errorsLongPressFired)
        {
            // The long-press fired during this gesture; the BitButton's
            // synthesised click follows pointerup — swallow it so we don't
            // also run the plain-navigate path.
            _errorsLongPressFired = false;
            return;
        }
        await InvokeCallbackAsync(OnSwitchToErrors);
    }

    private async Task HandleSwitchToPlaybackAsync()
    {
        if (_playbackLongPressFired)
        {
            _playbackLongPressFired = false;
            return;
        }
        await InvokeCallbackAsync(OnSwitchToPlayback);
    }

    private Task HandleToggleReviewedAsync() => InvokeCallbackAsync(OnToggleReviewed);

    private Task HandleToggleModulesAsync() => InvokeCallbackAsync(OnToggleModules);

    private Task HandleNavigateToPickupsAsync() => InvokeCallbackAsync(OnNavigateToPickups);

    private async Task HandleErrorsPointerDown(PointerEventArgs args)
    {
        _errorsLongPressFired = false;
        if (!IsTouchOrPen(args)) return;
        if (!OnSwitchToErrorsLongPress.HasDelegate) return;

        _errorsLongPressCts?.Cancel();
        var cts = new CancellationTokenSource();
        _errorsLongPressCts = cts;
        try
        {
            await Task.Delay(LongPressDelayMs, cts.Token);
            if (cts.IsCancellationRequested) return;
            _errorsLongPressFired = true;
            await OnSwitchToErrorsLongPress.InvokeAsync();
        }
        catch (TaskCanceledException) { }
        finally
        {
            if (ReferenceEquals(_errorsLongPressCts, cts)) _errorsLongPressCts = null;
            cts.Dispose();
        }
    }

    private void HandleErrorsPointerEnd() => _errorsLongPressCts?.Cancel();

    private async Task HandlePlaybackPointerDown(PointerEventArgs args)
    {
        _playbackLongPressFired = false;
        if (!IsTouchOrPen(args)) return;
        if (!OnSwitchToPlaybackLongPress.HasDelegate) return;

        _playbackLongPressCts?.Cancel();
        var cts = new CancellationTokenSource();
        _playbackLongPressCts = cts;
        try
        {
            await Task.Delay(LongPressDelayMs, cts.Token);
            if (cts.IsCancellationRequested) return;
            _playbackLongPressFired = true;
            await OnSwitchToPlaybackLongPress.InvokeAsync();
        }
        catch (TaskCanceledException) { }
        finally
        {
            if (ReferenceEquals(_playbackLongPressCts, cts)) _playbackLongPressCts = null;
            cts.Dispose();
        }
    }

    private void HandlePlaybackPointerEnd() => _playbackLongPressCts?.Cancel();

    private static bool IsTouchOrPen(PointerEventArgs args)
        => string.Equals(args.PointerType, "touch", StringComparison.OrdinalIgnoreCase)
           || string.Equals(args.PointerType, "pen", StringComparison.OrdinalIgnoreCase);

    private static Task InvokeCallbackAsync(EventCallback callback)
        => callback.HasDelegate
            ? callback.InvokeAsync()
            : Task.CompletedTask;
}
