@inherits LayoutComponentBase
@using Ams.Workstation.Server.Components.Shared
@implements IDisposable
@inject NavigationManager NavigationManager

<div class="workstation-layout"
     data-ams-mobile-module-rail-state="@(isMobileModuleRailOpen ? "open" : "closed")">
    <header class="workstation-header">
        <div class="header-title">AMS Workstation</div>

        <div class="workstation-module-rail-toggle"
             data-ams-header-control="module-rail-toggle"
             data-ams-mobile-module-rail-open="@(isMobileModuleRailOpen ? "true" : "false")">
            <BitButton Variant="BitVariant.Outline"
                       Color="BitColor.Secondary"
                       Size="BitSize.Small"
                       id="@MobileModuleRailToggleId"
                       aria-haspopup="dialog"
                       aria-controls="@MobileModuleRailPanelId"
                       aria-expanded="@(isMobileModuleRailOpen ? "true" : "false")"
                       OnClick="ToggleMobileModuleRail">
                @(isMobileModuleRailOpen ? "Close Modules" : "Modules")
            </BitButton>
        </div>

        <div class="workstation-header-controls-host"
             data-ams-shell-region="header-controls"
             data-ams-mobile-overflow-contract="secondary-actions"
             style="flex: 1; min-width: 0;">
            <HeaderControls />
        </div>
    </header>

    <div class="workstation-shell">
        <aside class="workstation-sidebar @SidebarMobileStateClass"
               id="@MobileModuleRailPanelId"
               data-stage-shell-region="left"
               data-ams-mobile-module-rail="@(isMobileModuleRailOpen ? "open" : "closed")">
            <StageModuleRail />
        </aside>

        <div class="workstation-body" data-stage-shell-region="center">
            <main class="workstation-content">
                @Body
            </main>
        </div>

        <aside class="workstation-inspector" data-stage-shell-region="right"><SectionOutlet SectionName="module-inspector" /></aside>
    </div>

    @if (isMobileModuleRailOpen)
    {
        <button type="button"
                class="workstation-module-rail-overlay"
                aria-label="Close module navigation"
                data-ams-mobile-module-rail-overlay="visible"
                @onclick="CloseMobileModuleRail"></button>
    }
</div>

@code {
    private const string MobileModuleRailPanelId = "workstation-mobile-module-rail";
    private const string MobileModuleRailToggleId = "workstation-mobile-module-rail-toggle";

    private bool isMobileModuleRailOpen;

    private string SidebarMobileStateClass
        => isMobileModuleRailOpen
            ? "workstation-sidebar--mobile-open"
            : "workstation-sidebar--mobile-closed";

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += HandleLocationChanged;
    }

    private void ToggleMobileModuleRail()
    {
        isMobileModuleRailOpen = !isMobileModuleRailOpen;
    }

    private void CloseMobileModuleRail()
    {
        isMobileModuleRailOpen = false;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        if (!isMobileModuleRailOpen)
        {
            return;
        }

        isMobileModuleRailOpen = false;
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }
}

<ToastContainer />

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">X</span>
</div>
