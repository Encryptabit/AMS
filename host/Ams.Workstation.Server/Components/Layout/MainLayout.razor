@inherits LayoutComponentBase
@using Ams.Workstation.Server.Components.Shared
@using Microsoft.AspNetCore.Components.Web
@implements IDisposable
@inject NavigationManager NavigationManager

<div class="workstation-layout"
     data-ams-mobile-module-rail-state="@(isMobileModuleRailOpen ? "open" : "closed")">
    <header class="workstation-header">
        <div class="header-title">AMS Workstation</div>

        <div class="workstation-module-rail-toggle"
             data-ams-header-control="module-rail-toggle"
             data-ams-mobile-module-rail-open="@(isMobileModuleRailOpen ? "true" : "false")"
             inert="@(isMobileModuleRailOpen ? "inert" : null)"
             aria-hidden="@(isMobileModuleRailOpen ? "true" : null)">
            <BitButton Variant="BitVariant.Outline"
                       Color="BitColor.Secondary"
                       Size="BitSize.Small"
                       id="@MobileModuleRailToggleId"
                       aria-haspopup="dialog"
                       aria-controls="@MobileModuleRailPanelId"
                       aria-expanded="@(isMobileModuleRailOpen ? "true" : "false")"
                       aria-label="@(isMobileModuleRailOpen ? "Close module navigation" : "Open module navigation")"
                       title="@(isMobileModuleRailOpen ? "Close module navigation" : "Open module navigation")"
                       OnClick="ToggleMobileModuleRail">
                @(isMobileModuleRailOpen ? "Close Modules" : "Modules")
            </BitButton>
        </div>

        <div class="workstation-header-controls-host"
             data-ams-shell-region="header-controls"
             data-ams-mobile-overflow-contract="secondary-actions"
             inert="@(isMobileModuleRailOpen ? "inert" : null)"
             aria-hidden="@(isMobileModuleRailOpen ? "true" : null)"
             style="flex: 1; min-width: 0;">
            <HeaderControls />
        </div>
    </header>

    <div class="workstation-shell">
        <aside class="workstation-sidebar @SidebarMobileStateClass"
               id="@MobileModuleRailPanelId"
               data-stage-shell-region="left"
               data-ams-mobile-module-rail="@(isMobileModuleRailOpen ? "open" : "closed")"
               role="@(isMobileModuleRailOpen ? "dialog" : null)"
               aria-modal="@(isMobileModuleRailOpen ? "true" : null)"
               aria-labelledby="@(isMobileModuleRailOpen ? MobileModuleRailTitleId : null)"
               aria-label="Module navigation"
               tabindex="@(isMobileModuleRailOpen ? "0" : "-1")"
               @ref="mobileModuleRailPanelRef"
               @onkeydown="HandleMobileModuleRailKeyDown">
            @if (isMobileModuleRailOpen)
            {
                <div class="workstation-module-rail-panel-header">
                    <span id="@MobileModuleRailTitleId" class="workstation-module-rail-panel-title">Module navigation</span>
                    <BitButton Variant="BitVariant.Text"
                               Color="BitColor.Secondary"
                               Size="BitSize.Small"
                               aria-label="Close module navigation"
                               title="Close module navigation"
                               OnClick="CloseMobileModuleRail">
                        Close
                    </BitButton>
                </div>
            }

            <StageModuleRail OnModuleInvoked="HandleModuleRailModuleInvoked" />
        </aside>

        <div class="workstation-body"
             data-stage-shell-region="center"
             inert="@(isMobileModuleRailOpen ? "inert" : null)"
             aria-hidden="@(isMobileModuleRailOpen ? "true" : null)">
            <main class="workstation-content">
                @Body
            </main>
        </div>

        <aside class="workstation-inspector"
               data-stage-shell-region="right"
               inert="@(isMobileModuleRailOpen ? "inert" : null)"
               aria-hidden="@(isMobileModuleRailOpen ? "true" : null)"><SectionOutlet SectionName="module-inspector" /></aside>
    </div>

    <div class="workstation-mobile-action-bar-host"
         data-ams-shell-region="mobile-action-bar"
         inert="@(isMobileModuleRailOpen ? "inert" : null)"
         aria-hidden="@(isMobileModuleRailOpen ? "true" : null)">
        <SectionOutlet SectionName="mobile-action-bar" />
    </div>

    @if (isMobileModuleRailOpen)
    {
        <div class="workstation-module-rail-overlay"
             role="presentation"
             aria-hidden="true"
             data-ams-mobile-module-rail-overlay="visible"
             @onclick="CloseMobileModuleRail"></div>
    }
</div>

@code {
    private const string MobileModuleRailPanelId = "workstation-mobile-module-rail";
    private const string MobileModuleRailToggleId = "workstation-mobile-module-rail-toggle";
    private const string MobileModuleRailTitleId = "workstation-mobile-module-rail-title";

    private bool isMobileModuleRailOpen;
    private bool focusMobileModuleRailPanel;
    private ElementReference mobileModuleRailPanelRef;

    private string SidebarMobileStateClass
        => isMobileModuleRailOpen
            ? "workstation-sidebar--mobile-open"
            : "workstation-sidebar--mobile-closed";

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += HandleLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (focusMobileModuleRailPanel && isMobileModuleRailOpen)
        {
            focusMobileModuleRailPanel = false;
            await mobileModuleRailPanelRef.FocusAsync();
        }
    }

    private void ToggleMobileModuleRail()
    {
        var nextState = !isMobileModuleRailOpen;
        isMobileModuleRailOpen = nextState;
        focusMobileModuleRailPanel = nextState;
    }

    private void CloseMobileModuleRail()
    {
        isMobileModuleRailOpen = false;
        focusMobileModuleRailPanel = false;
    }

    private void HandleMobileModuleRailKeyDown(KeyboardEventArgs e)
    {
        if (string.Equals(e.Key, "Escape", StringComparison.OrdinalIgnoreCase))
        {
            CloseMobileModuleRail();
        }
    }

    private void HandleModuleRailModuleInvoked()
    {
        if (isMobileModuleRailOpen)
        {
            CloseMobileModuleRail();
        }
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        if (!isMobileModuleRailOpen)
        {
            return;
        }

        CloseMobileModuleRail();
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }
}

<ToastContainer />

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">X</span>
</div>
