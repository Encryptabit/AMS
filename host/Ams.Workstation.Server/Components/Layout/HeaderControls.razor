@using System.IO
@using Ams.Core.Common
@using Ams.Workstation.Server.Components.Navigation
@implements IDisposable
@inject NavigationManager NavigationManager
@inject Ams.Workstation.Server.Services.BlazorWorkspace Workspace
@inject Ams.Workstation.Server.Services.WorkspaceHistoryService WorkspaceHistory
@inject Ams.Workstation.Server.Services.BookMetadataResetService MetadataReset

<div class="header-controls" data-ams-mobile-overflow-state="@(isMobileOverflowOpen ? "open" : "closed")">
    <div class="header-row header-row--primary">
        <div class="header-nav">
            <BitButton Variant="@(IsActive(StageRouteCatalog.StageIds.Prep) ? BitVariant.Fill : BitVariant.Text)"
                       Color="BitColor.Primary"
                       Size="BitSize.Small"
                       OnClick="@(() => NavigateToStage(StageRouteCatalog.StageIds.Prep))">
                Prep
            </BitButton>
            <BitButton Variant="@(IsActive(StageRouteCatalog.StageIds.Proof) ? BitVariant.Fill : BitVariant.Text)"
                       Color="BitColor.Primary"
                       Size="BitSize.Small"
                       OnClick="@(() => NavigateToStage(StageRouteCatalog.StageIds.Proof))">
                Proof
            </BitButton>
            <BitButton Variant="@(IsActive(StageRouteCatalog.StageIds.Polish) ? BitVariant.Fill : BitVariant.Text)"
                       Color="BitColor.Primary"
                       Size="BitSize.Small"
                       OnClick="@(() => NavigateToStage(StageRouteCatalog.StageIds.Polish))">
                Polish
            </BitButton>
        </div>

        <div class="header-chapter" data-ams-header-control="chapter">
            @if (Workspace.AvailableChapters.Count > 0)
            {
                <BitDropdown TItem="BitDropdownItem<string>"
                             TValue="string"
                             Items="@chapterItems"
                             @bind-Value="selectedChapter"
                             Placeholder="Select chapter"
                             Style="width: 100%; min-width: 0;"
                             OnChange="OnChapterChange" />
            }
        </div>

        <div class="header-extra">
            <SectionOutlet SectionName="header-extra" />
        </div>
    </div>

    <div class="header-row header-row--secondary header-directory">
        <div class="header-field header-field--workspace" data-ams-header-control="workspace">
            <BitDropdown TItem="BitDropdownItem<string>"
                         TValue="string"
                         Items="@savedWorkspaceItems"
                         @bind-Value="selectedSavedWorkspace"
                         Placeholder="Saved workspaces"
                         Style="width: 100%; min-width: 0;"
                         OnChange="OnSavedWorkspaceChange" />
        </div>

        <div class="header-mobile-overflow-trigger"
             data-ams-header-control="mobile-overflow-trigger"
             data-ams-mobile-overflow-open="@(isMobileOverflowOpen ? "true" : "false")">
            <BitButton Variant="BitVariant.Outline"
                       Color="BitColor.Secondary"
                       Size="BitSize.Small"
                       OnClick="ToggleMobileOverflow">
                @(isMobileOverflowOpen ? "Close" : "More")
            </BitButton>
        </div>

        <div class="header-secondary-optional" data-ams-header-optional="mobile-overflow-hidden">
            <div class="header-field header-field--directory" data-ams-header-control="directory">
                <BitTextField @bind-Value="workingDirectory"
                              Immediate="true"
                              Placeholder="Working directory..."
                              Style="width: 100%; min-width: 0;"
                              OnKeyDown="OnDirectoryKeyDown" />
            </div>

            <div class="header-actions" data-ams-header-control="directory-actions">
                <BitButton Variant="BitVariant.Fill"
                           Color="BitColor.Primary"
                           Size="BitSize.Small"
                           OnClick="SetDirectory"
                           IsEnabled="@(!string.IsNullOrWhiteSpace(workingDirectory))">
                    Set
                </BitButton>
                <BitButton Variant="BitVariant.Outline"
                           Color="BitColor.Warning"
                           Size="BitSize.Small"
                           OnClick="ResetMetadataAsync"
                           IsEnabled="@Workspace.IsInitialized">
                    Reset Metadata
                </BitButton>
            </div>

            <div class="header-options" data-ams-header-control="settings">
                <BitCheckbox Label="Precompute Peaks In Background"
                             Value="@Workspace.PrecomputePeaksInBackground"
                             OnChange="HandlePrecomputePeaksToggle" />
            </div>
        </div>
    </div>
</div>

@if (isMobileOverflowOpen)
{
    <div class="header-mobile-overflow-overlay"
         data-ams-header-control="mobile-overflow-overlay"
         @onclick="CloseMobileOverflow">
        <div id="header-mobile-overflow-panel"
             class="header-mobile-overflow-panel"
             role="dialog"
             aria-modal="true"
             aria-label="Header secondary controls"
             data-ams-header-control="mobile-overflow-panel"
             @onkeydown="HandleMobileOverflowKeyDown"
             @onclick:stopPropagation="true"
             tabindex="0">
            <div class="header-mobile-overflow-header">
                <span>Header controls</span>
                <BitButton Variant="BitVariant.Text"
                           Color="BitColor.Secondary"
                           Size="BitSize.Small"
                           OnClick="CloseMobileOverflow">
                    Close
                </BitButton>
            </div>

            <div class="header-mobile-overflow-body">
                <div class="header-field header-field--directory" data-ams-header-control="directory-mobile">
                    <BitTextField @bind-Value="workingDirectory"
                                  Immediate="true"
                                  Placeholder="Working directory..."
                                  Style="width: 100%; min-width: 0;"
                                  OnKeyDown="OnDirectoryKeyDown" />
                </div>

                <div class="header-actions" data-ams-header-control="directory-actions-mobile">
                    <BitButton Variant="BitVariant.Fill"
                               Color="BitColor.Primary"
                               Size="BitSize.Small"
                               OnClick="SetDirectoryFromOverflow"
                               IsEnabled="@(!string.IsNullOrWhiteSpace(workingDirectory))">
                        Set
                    </BitButton>
                    <BitButton Variant="BitVariant.Outline"
                               Color="BitColor.Warning"
                               Size="BitSize.Small"
                               OnClick="ResetMetadataFromOverflow"
                               IsEnabled="@Workspace.IsInitialized">
                        Reset Metadata
                    </BitButton>
                </div>

                <div class="header-options" data-ams-header-control="settings-mobile">
                    <BitCheckbox Label="Precompute Peaks In Background"
                                 Value="@Workspace.PrecomputePeaksInBackground"
                                 OnChange="HandlePrecomputePeaksToggle" />
                </div>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="error-toast">
        <BitMessage Color="@messageColor" OnDismiss="DismissMessage">
            @message
        </BitMessage>
    </div>
}

<BitDialog @bind-IsOpen="isResetDialogOpen"
           Title="Reset Metadata"
           Message="@resetDialogMessage"
           OkText="Reset"
           CancelText="Cancel"
           IsBlocking="true"
           OnOk="ConfirmReset"
           OnCancel="() => isResetDialogOpen = false" />

@code {
    private string workingDirectory = string.Empty;
    private string? selectedChapter;
    private string? selectedSavedWorkspace;
    private string? message;
    private BitColor messageColor = BitColor.Error;
    private StageRouteMatch? currentRoute;
    private List<BitDropdownItem<string>> chapterItems = new();
    private List<BitDropdownItem<string>> savedWorkspaceItems = new();
    private bool isResetDialogOpen;
    private bool isMobileOverflowOpen;
    private string resetDialogMessage = string.Empty;

    protected override void OnInitialized()
    {
        UpdateCurrentPath();
        NavigationManager.LocationChanged += OnLocationChanged;

        // Restore state
        if (!string.IsNullOrEmpty(Workspace.WorkingDirectory))
        {
            workingDirectory = Workspace.WorkingDirectory;
            selectedSavedWorkspace = workingDirectory;
            WorkspaceHistory.RememberWorkspace(workingDirectory);
            RefreshChapterList();
        }

        if (!string.IsNullOrEmpty(Workspace.CurrentChapterName))
        {
            selectedChapter = Workspace.CurrentChapterName;
        }

        RefreshSavedWorkspaceList();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateCurrentPath();
        SyncSelectedChapter();
        isMobileOverflowOpen = false;
        StateHasChanged();
    }

    private void SyncSelectedChapter()
    {
        if (!string.IsNullOrEmpty(Workspace.CurrentChapterName))
            selectedChapter = Workspace.CurrentChapterName;
    }

    private void UpdateCurrentPath()
    {
        var uri = new Uri(NavigationManager.Uri);
        currentRoute = StageRouteCatalog.Resolve(uri.AbsolutePath);
    }

    private bool IsActive(string stageId)
        => currentRoute is not null
           && string.Equals(currentRoute.Stage.Id, stageId, StringComparison.OrdinalIgnoreCase);

    private void NavigateToStage(string stageId)
    {
        if (!StageRouteCatalog.TryGetStage(stageId, out _))
        {
            return;
        }

        isMobileOverflowOpen = false;
        NavigationManager.NavigateTo(StageRouteCatalog.GetStageEntryPath(stageId));
    }

    private void ToggleMobileOverflow()
    {
        isMobileOverflowOpen = !isMobileOverflowOpen;
    }

    private void CloseMobileOverflow()
    {
        isMobileOverflowOpen = false;
    }

    private void HandleMobileOverflowKeyDown(KeyboardEventArgs e)
    {
        if (string.Equals(e.Key, "Escape", StringComparison.OrdinalIgnoreCase))
        {
            CloseMobileOverflow();
        }
    }

    private void SetDirectoryFromOverflow()
    {
        SetDirectory();
    }

    private void ResetMetadataFromOverflow()
    {
        CloseMobileOverflow();
        ResetMetadataAsync();
    }

    private void OnDirectoryKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            SetDirectory();
        }
    }

    private void SetDirectory()
    {
        message = null;

        var normalizedPath = AmsPathResolver.NormalizeOptionalPath(workingDirectory);
        if (string.IsNullOrWhiteSpace(normalizedPath))
        {
            return;
        }

        if (!Directory.Exists(normalizedPath))
        {
            SetMessage($"Directory does not exist: {normalizedPath}", BitColor.Error);
            return;
        }

        if (!Workspace.SetWorkingDirectory(normalizedPath))
        {
            SetMessage($"Failed to initialize workspace: {normalizedPath}", BitColor.Error);
            return;
        }

        workingDirectory = normalizedPath;
        selectedSavedWorkspace = workingDirectory;
        WorkspaceHistory.RememberWorkspace(workingDirectory);

        // Force full page reload at root so stale chapter URLs don't persist
        isMobileOverflowOpen = false;
        NavigationManager.NavigateTo("/", forceLoad: true);
    }

    private void RefreshSavedWorkspaceList()
    {
        var paths = WorkspaceHistory.GetSavedWorkspaces(existingOnly: true).ToList();

        // Build display names from folder name, numbering duplicates
        var nameCounts = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        var displayNames = new List<string>(paths.Count);

        foreach (var path in paths)
        {
            var folderName = Path.GetFileName(path.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar));
            if (string.IsNullOrEmpty(folderName)) folderName = path;

            nameCounts.TryGetValue(folderName, out var count);
            nameCounts[folderName] = count + 1;
            displayNames.Add(folderName);
        }

        // Second pass: append (2), (3), etc. for duplicates
        var emitted = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        savedWorkspaceItems = new List<BitDropdownItem<string>>(paths.Count);
        for (int i = 0; i < paths.Count; i++)
        {
            var name = displayNames[i];
            var text = name;
            if (nameCounts[name] > 1)
            {
                emitted.TryGetValue(name, out var seq);
                seq++;
                emitted[name] = seq;
                if (seq > 1) text = $"{name} ({seq})";
            }
            savedWorkspaceItems.Add(new BitDropdownItem<string> { Text = text, Value = paths[i] });
        }
    }

    private void RefreshChapterList()
    {
        chapterItems.Clear();

        if (Workspace.HasBookIndex && Workspace.AvailableChapters.Count > 0)
        {
            chapterItems = Workspace.AvailableChapters
                .Select(c => new BitDropdownItem<string> { Text = c, Value = c })
                .ToList();
        }
    }

    private void OnSavedWorkspaceChange(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return;
        }

        workingDirectory = path;
        isMobileOverflowOpen = false;
        SetDirectory();
    }

    private void OnChapterChange(string? chapter)
    {
        if (!string.IsNullOrEmpty(chapter) && Workspace.SelectChapter(chapter))
        {
            isMobileOverflowOpen = false;
            NavigationManager.NavigateTo(StageRouteCatalog.BuildProofChapterCompatibilityPath(chapter));
        }
    }

    private void HandlePrecomputePeaksToggle(bool enabled)
    {
        Workspace.SetPrecomputePeaksInBackground(enabled);
    }

    private void ResetMetadataAsync()
    {
        message = null;
        isMobileOverflowOpen = false;

        if (!Workspace.IsInitialized || string.IsNullOrWhiteSpace(Workspace.WorkingDirectory))
        {
            SetMessage("Set a workspace before resetting metadata.", BitColor.Warning);
            return;
        }

        var workspacePath = Workspace.WorkingDirectory;
        var bookId = Path.GetFileName(workspacePath.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar));
        resetDialogMessage = $"Reset metadata for '{bookId}'? This clears ignored patterns, review progress, and polish staging data.";
        isResetDialogOpen = true;
    }

    private void ConfirmReset()
    {
        isResetDialogOpen = false;
        var result = MetadataReset.ResetCurrentBook();
        SetMessage(result.Message, result.Success ? BitColor.Success : BitColor.Error);
    }

    private void SetMessage(string text, BitColor color)
    {
        message = text;
        messageColor = color;
    }

    private void DismissMessage()
    {
        message = null;
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
