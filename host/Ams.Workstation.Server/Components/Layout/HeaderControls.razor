@using System.IO
@using Ams.Core.Common
@using Ams.Workstation.Server.Components.Navigation
@using Ams.Workstation.Server.Components.UI
@using Ams.Workstation.Server.Services
@implements IDisposable
@inject NavigationManager NavigationManager
@inject Ams.Workstation.Server.Services.BlazorWorkspace Workspace
@inject Ams.Workstation.Server.Services.WorkspaceHistoryService WorkspaceHistory
@inject Ams.Workstation.Server.Services.BookMetadataResetService MetadataReset
@inject Ams.Workstation.Server.Services.ThemeService ThemeService

<div class="header-controls">
    <div class="header-nav">
        <AmsButton Variant="@(IsActive(StageRouteCatalog.StageIds.Prep) ? "primary" : "ghost")"
                   Size="sm"
                   OnClick="@(() => NavigateToStage(StageRouteCatalog.StageIds.Prep))">
            Prep
        </AmsButton>
        <AmsButton Variant="@(IsActive(StageRouteCatalog.StageIds.Proof) ? "primary" : "ghost")"
                   Size="sm"
                   OnClick="@(() => NavigateToStage(StageRouteCatalog.StageIds.Proof))">
            Proof
        </AmsButton>
        <AmsButton Variant="@(IsActive(StageRouteCatalog.StageIds.Polish) ? "primary" : "ghost")"
                   Size="sm"
                   OnClick="@(() => NavigateToStage(StageRouteCatalog.StageIds.Polish))">
            Polish
        </AmsButton>
    </div>

    <div class="header-chapter">
        @if (Workspace.AvailableChapters.Count > 0)
        {
            <select class="ams-select"
                    aria-label="Select chapter"
                    data-ams-header-control="chapter"
                    value="@(selectedChapter ?? string.Empty)"
                    @onchange="OnChapterSelectChanged">
                <option value="" disabled selected="@(string.IsNullOrEmpty(selectedChapter))">Select chapter</option>
                @foreach (var chapter in Workspace.AvailableChapters)
                {
                    <option value="@chapter" selected="@(chapter == selectedChapter)">@chapter</option>
                }
            </select>
        }
    </div>

    <SectionOutlet SectionName="header-extra" />

    <div class="header-directory">
        <select class="ams-select ams-select--workspace"
                aria-label="Saved workspaces"
                data-ams-header-control="saved-workspaces"
                value="@(selectedSavedWorkspace ?? string.Empty)"
                @onchange="OnSavedWorkspaceSelectChanged">
            <option value="" disabled selected="@(string.IsNullOrEmpty(selectedSavedWorkspace))">Saved workspaces</option>
            @foreach (var item in savedWorkspaceItems)
            {
                <option value="@item.Value" selected="@(item.Value == selectedSavedWorkspace)">@item.Text</option>
            }
        </select>
        <input type="text"
               class="ams-input ams-input--workspace"
               placeholder="Working directory..."
               aria-label="Working directory"
               data-ams-header-control="working-directory"
               value="@workingDirectory"
               @oninput="OnDirectoryInput"
               @onkeydown="OnDirectoryKeyDown" />
        <AmsButton Variant="primary"
                   Size="sm"
                   Disabled="@string.IsNullOrWhiteSpace(workingDirectory)"
                   OnClick="SetDirectory">
            Set
        </AmsButton>
        <AmsButton Variant="secondary"
                   Size="sm"
                   Disabled="@(!Workspace.IsInitialized)"
                   OnClick="ResetMetadataAsync">
            Reset Metadata
        </AmsButton>
        <label class="ams-checkbox">
            <input type="checkbox"
                   checked="@Workspace.PrecomputePeaksInBackground"
                   @onchange="OnPrecomputePeaksChanged" />
            <span>Precompute Peaks In Background</span>
        </label>
        <AmsButton Variant="ghost"
                   Size="sm"
                   OnClick="ToggleThemeAsync"
                   data-ams-header-control="theme-toggle"
                   aria-label="@ThemeToggleAriaLabel">
            @ThemeToggleLabel
        </AmsButton>
    </div>
</div>

@if (!string.IsNullOrEmpty(message))
{
    <div class="error-toast">
        <div class="ams-message @MessageCssClass" role="status">
            <span class="ams-message__text">@message</span>
            <button type="button" class="ams-message__dismiss" aria-label="Dismiss" @onclick="DismissMessage">×</button>
        </div>
    </div>
}

@if (isResetDialogOpen)
{
    <div class="ams-dialog-backdrop" role="presentation" @onclick="CancelReset"></div>
    <div class="ams-dialog" role="dialog" aria-modal="true" aria-labelledby="reset-dialog-title">
        <h2 class="ams-dialog__title" id="reset-dialog-title">Reset Metadata</h2>
        <p class="ams-dialog__message">@resetDialogMessage</p>
        <div class="ams-dialog__actions">
            <AmsButton Variant="secondary" Size="sm" OnClick="CancelReset">Cancel</AmsButton>
            <AmsButton Variant="danger" Size="sm" OnClick="ConfirmReset">Reset</AmsButton>
        </div>
    </div>
}

@code {
    private enum MessageTone { Error, Warning, Success }

    private sealed record WorkspaceOption(string Text, string Value);

    private string workingDirectory = string.Empty;
    private string? selectedChapter;
    private string? selectedSavedWorkspace;
    private string? message;
    private MessageTone messageTone = MessageTone.Error;
    private StageRouteMatch? currentRoute;
    private List<WorkspaceOption> savedWorkspaceItems = new();
    private bool isResetDialogOpen;
    private string resetDialogMessage = string.Empty;

    private string MessageCssClass => messageTone switch
    {
        MessageTone.Success => "ams-message--success",
        MessageTone.Warning => "ams-message--warning",
        _ => "ams-message--error",
    };

    private string ThemeToggleLabel => ThemeService.Current == AmsTheme.Dark ? "☾ Dark" : "☀ Light";
    private string ThemeToggleAriaLabel
        => ThemeService.Current == AmsTheme.Dark ? "Switch to light theme" : "Switch to dark theme";

    protected override void OnInitialized()
    {
        UpdateCurrentPath();
        NavigationManager.LocationChanged += OnLocationChanged;
        ThemeService.ThemeChanged += OnThemeChanged;

        // Restore state
        if (!string.IsNullOrEmpty(Workspace.WorkingDirectory))
        {
            workingDirectory = Workspace.WorkingDirectory;
            selectedSavedWorkspace = workingDirectory;
            WorkspaceHistory.RememberWorkspace(workingDirectory);
        }

        if (!string.IsNullOrEmpty(Workspace.CurrentChapterName))
        {
            selectedChapter = Workspace.CurrentChapterName;
        }

        RefreshSavedWorkspaceList();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateCurrentPath();
        SyncSelectedChapter();
        StateHasChanged();
    }

    private void OnThemeChanged(AmsTheme _)
    {
        InvokeAsync(StateHasChanged);
    }

    private void SyncSelectedChapter()
    {
        if (!string.IsNullOrEmpty(Workspace.CurrentChapterName))
            selectedChapter = Workspace.CurrentChapterName;
    }

    private void UpdateCurrentPath()
    {
        var uri = new Uri(NavigationManager.Uri);
        currentRoute = StageRouteCatalog.Resolve(uri.AbsolutePath);
    }

    private bool IsActive(string stageId)
        => currentRoute is not null
           && string.Equals(currentRoute.Stage.Id, stageId, StringComparison.OrdinalIgnoreCase);

    private void NavigateToStage(string stageId)
    {
        if (!StageRouteCatalog.TryGetStage(stageId, out _))
        {
            return;
        }

        NavigationManager.NavigateTo(StageRouteCatalog.GetStageEntryPath(stageId));
    }

    private void OnDirectoryInput(ChangeEventArgs e)
    {
        workingDirectory = e.Value?.ToString() ?? string.Empty;
    }

    private void OnDirectoryKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            SetDirectory();
        }
    }

    private void SetDirectory()
    {
        message = null;

        var normalizedPath = AmsPathResolver.NormalizeOptionalPath(workingDirectory);
        if (string.IsNullOrWhiteSpace(normalizedPath))
        {
            return;
        }

        if (!Directory.Exists(normalizedPath))
        {
            SetMessage($"Directory does not exist: {normalizedPath}", MessageTone.Error);
            return;
        }

        if (!Workspace.SetWorkingDirectory(normalizedPath))
        {
            SetMessage($"Failed to initialize workspace: {normalizedPath}", MessageTone.Error);
            return;
        }

        workingDirectory = normalizedPath;
        selectedSavedWorkspace = workingDirectory;
        WorkspaceHistory.RememberWorkspace(workingDirectory);

        // Force full page reload at root so stale chapter URLs don't persist
        NavigationManager.NavigateTo("/", forceLoad: true);
    }

    private void RefreshSavedWorkspaceList()
    {
        var paths = WorkspaceHistory.GetSavedWorkspaces(existingOnly: true).ToList();

        var nameCounts = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        var displayNames = new List<string>(paths.Count);

        foreach (var path in paths)
        {
            var folderName = Path.GetFileName(path.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar));
            if (string.IsNullOrEmpty(folderName)) folderName = path;

            nameCounts.TryGetValue(folderName, out var count);
            nameCounts[folderName] = count + 1;
            displayNames.Add(folderName);
        }

        var emitted = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        savedWorkspaceItems = new List<WorkspaceOption>(paths.Count);
        for (int i = 0; i < paths.Count; i++)
        {
            var name = displayNames[i];
            var text = name;
            if (nameCounts[name] > 1)
            {
                emitted.TryGetValue(name, out var seq);
                seq++;
                emitted[name] = seq;
                if (seq > 1) text = $"{name} ({seq})";
            }
            savedWorkspaceItems.Add(new WorkspaceOption(text, paths[i]));
        }
    }

    private void OnSavedWorkspaceSelectChanged(ChangeEventArgs e)
    {
        var path = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(path))
        {
            return;
        }

        workingDirectory = path;
        selectedSavedWorkspace = path;
        SetDirectory();
    }

    private void OnChapterSelectChanged(ChangeEventArgs e)
    {
        var chapter = e.Value?.ToString();
        if (!string.IsNullOrEmpty(chapter) && Workspace.SelectChapter(chapter))
        {
            selectedChapter = chapter;
            NavigationManager.NavigateTo(StageRouteCatalog.BuildProofChapterCompatibilityPath(chapter));
        }
    }

    private void OnPrecomputePeaksChanged(ChangeEventArgs e)
    {
        var enabled = e.Value is bool b && b;
        Workspace.SetPrecomputePeaksInBackground(enabled);
    }

    private async Task ToggleThemeAsync()
    {
        await ThemeService.ToggleAsync().ConfigureAwait(true);
    }

    private void ResetMetadataAsync()
    {
        message = null;

        if (!Workspace.IsInitialized || string.IsNullOrWhiteSpace(Workspace.WorkingDirectory))
        {
            SetMessage("Set a workspace before resetting metadata.", MessageTone.Warning);
            return;
        }

        var workspacePath = Workspace.WorkingDirectory;
        var bookId = Path.GetFileName(workspacePath.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar));
        resetDialogMessage = $"Reset metadata for '{bookId}'? This clears ignored patterns, review progress, and polish staging data.";
        isResetDialogOpen = true;
    }

    private void ConfirmReset()
    {
        isResetDialogOpen = false;
        var result = MetadataReset.ResetCurrentBook();
        SetMessage(result.Message, result.Success ? MessageTone.Success : MessageTone.Error);
    }

    private void CancelReset()
    {
        isResetDialogOpen = false;
    }

    private void SetMessage(string text, MessageTone tone)
    {
        message = text;
        messageTone = tone;
    }

    private void DismissMessage()
    {
        message = null;
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        ThemeService.ThemeChanged -= OnThemeChanged;
    }
}
