@using System.IO
@implements IDisposable
@inject NavigationManager NavigationManager
@inject Ams.Workstation.Server.Services.BlazorWorkspace Workspace
@inject Ams.Workstation.Server.Services.WorkspaceHistoryService WorkspaceHistory
@inject Ams.Workstation.Server.Services.BookMetadataResetService MetadataReset

<div class="header-controls">
    <div class="header-nav">
        <BitButton Variant="@(IsActive("prep") ? BitVariant.Fill : BitVariant.Text)"
                   Color="BitColor.Primary"
                   OnClick="@(() => Navigate("prep"))">
            Prep
        </BitButton>
        <BitButton Variant="@(IsActive("proof") ? BitVariant.Fill : BitVariant.Text)"
                   Color="BitColor.Primary"
                   OnClick="@(() => Navigate("proof"))">
            Proof
        </BitButton>
        <BitButton Variant="@(IsActive("polish") ? BitVariant.Fill : BitVariant.Text)"
                   Color="BitColor.Primary"
                   OnClick="@(() => Navigate("polish"))">
            Polish
        </BitButton>
    </div>

    <div class="header-chapter">
        @if (Workspace.AvailableChapters.Count > 0)
        {
            <BitDropdown TItem="BitDropdownItem<string>"
                         TValue="string"
                         Items="@chapterItems"
                         @bind-Value="selectedChapter"
                         Placeholder="Select chapter"
                         Style="min-width: 200px;"
                         OnChange="OnChapterChange" />
        }
    </div>

    <SectionOutlet SectionName="header-extra" />

    <div class="header-directory">
        <BitDropdown TItem="BitDropdownItem<string>"
                     TValue="string"
                     Items="@savedWorkspaceItems"
                     @bind-Value="selectedSavedWorkspace"
                     Placeholder="Saved workspaces"
                     Style="width: 220px; flex-shrink: 1; min-width: 120px;"
                     OnChange="OnSavedWorkspaceChange" />
        <BitTextField @bind-Value="workingDirectory"
                      Immediate="true"
                      Placeholder="Working directory..."
                      Style="width: 220px; flex-shrink: 1; min-width: 120px;"
                      OnKeyDown="OnDirectoryKeyDown" />
        <BitButton Variant="BitVariant.Fill"
                   Color="BitColor.Primary"
                   Size="BitSize.Small"
                   OnClick="SetDirectory"
                   IsEnabled="@(!string.IsNullOrWhiteSpace(workingDirectory))">
            Set
        </BitButton>
        <BitButton Variant="BitVariant.Outline"
                   Color="BitColor.Warning"
                   Size="BitSize.Small"
                   OnClick="ResetMetadataAsync"
                   IsEnabled="@Workspace.IsInitialized">
            Reset Metadata
        </BitButton>
        <BitCheckbox Label="Precompute Peaks In Background"
                     Value="@Workspace.PrecomputePeaksInBackground"
                     OnChange="HandlePrecomputePeaksToggle" />
    </div>
</div>

@if (!string.IsNullOrEmpty(message))
{
    <div class="error-toast">
        <BitMessage Color="@messageColor" OnDismiss="DismissMessage">
            @message
        </BitMessage>
    </div>
}

<BitDialog @bind-IsOpen="isResetDialogOpen"
           Title="Reset Metadata"
           Message="@resetDialogMessage"
           OkText="Reset"
           CancelText="Cancel"
           IsBlocking="true"
           OnOk="ConfirmReset"
           OnCancel="() => isResetDialogOpen = false" />

@code {
    private string workingDirectory = string.Empty;
    private string? selectedChapter;
    private string? selectedSavedWorkspace;
    private string? message;
    private BitColor messageColor = BitColor.Error;
    private string? currentPath;
    private List<BitDropdownItem<string>> chapterItems = new();
    private List<BitDropdownItem<string>> savedWorkspaceItems = new();
    private bool isResetDialogOpen;
    private string resetDialogMessage = string.Empty;

    protected override void OnInitialized()
    {
        UpdateCurrentPath();
        NavigationManager.LocationChanged += OnLocationChanged;

        // Restore state
        if (!string.IsNullOrEmpty(Workspace.WorkingDirectory))
        {
            workingDirectory = Workspace.WorkingDirectory;
            selectedSavedWorkspace = workingDirectory;
            WorkspaceHistory.RememberWorkspace(workingDirectory);
            RefreshChapterList();
        }

        if (!string.IsNullOrEmpty(Workspace.CurrentChapterName))
        {
            selectedChapter = Workspace.CurrentChapterName;
        }

        RefreshSavedWorkspaceList();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateCurrentPath();
        SyncSelectedChapter();
        StateHasChanged();
    }

    private void UpdateCurrentPath()
    {
        var uri = new Uri(NavigationManager.Uri);
        currentPath = uri.AbsolutePath.TrimStart('/').ToLowerInvariant();
    }

    private void SyncSelectedChapter()
    {
        if (!string.IsNullOrEmpty(Workspace.CurrentChapterName))
            selectedChapter = Workspace.CurrentChapterName;
    }

    private bool IsActive(string route) => currentPath?.StartsWith(route) == true;

    private void Navigate(string route)
    {
        NavigationManager.NavigateTo($"/{route}");
    }

    private void OnDirectoryKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            SetDirectory();
        }
    }

    private void SetDirectory()
    {
        message = null;

        if (string.IsNullOrWhiteSpace(workingDirectory))
        {
            return;
        }

        var trimmedPath = workingDirectory.Trim();

        if (!Directory.Exists(trimmedPath))
        {
            SetMessage($"Directory does not exist: {trimmedPath}", BitColor.Error);
            return;
        }

        if (!Workspace.SetWorkingDirectory(trimmedPath))
        {
            SetMessage($"Failed to initialize workspace: {trimmedPath}", BitColor.Error);
            return;
        }

        workingDirectory = Path.GetFullPath(trimmedPath);
        selectedSavedWorkspace = workingDirectory;
        WorkspaceHistory.RememberWorkspace(workingDirectory);

        // Force full page reload at root so stale chapter URLs don't persist
        NavigationManager.NavigateTo("/", forceLoad: true);
    }

    private void RefreshSavedWorkspaceList()
    {
        var paths = WorkspaceHistory.GetSavedWorkspaces(existingOnly: true).ToList();

        // Build display names from folder name, numbering duplicates
        var nameCounts = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        var displayNames = new List<string>(paths.Count);

        foreach (var path in paths)
        {
            var folderName = Path.GetFileName(path.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar));
            if (string.IsNullOrEmpty(folderName)) folderName = path;

            nameCounts.TryGetValue(folderName, out var count);
            nameCounts[folderName] = count + 1;
            displayNames.Add(folderName);
        }

        // Second pass: append (2), (3), etc. for duplicates
        var emitted = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        savedWorkspaceItems = new List<BitDropdownItem<string>>(paths.Count);
        for (int i = 0; i < paths.Count; i++)
        {
            var name = displayNames[i];
            var text = name;
            if (nameCounts[name] > 1)
            {
                emitted.TryGetValue(name, out var seq);
                seq++;
                emitted[name] = seq;
                if (seq > 1) text = $"{name} ({seq})";
            }
            savedWorkspaceItems.Add(new BitDropdownItem<string> { Text = text, Value = paths[i] });
        }
    }

    private void RefreshChapterList()
    {
        chapterItems.Clear();

        if (Workspace.HasBookIndex && Workspace.AvailableChapters.Count > 0)
        {
            chapterItems = Workspace.AvailableChapters
                .Select(c => new BitDropdownItem<string> { Text = c, Value = c })
                .ToList();
        }
    }

    private void OnSavedWorkspaceChange(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return;
        }

        workingDirectory = path;
        SetDirectory();
    }

    private void OnChapterChange(string? chapter)
    {
        if (!string.IsNullOrEmpty(chapter) && Workspace.SelectChapter(chapter))
        {
            NavigationManager.NavigateTo($"/proof/{Uri.EscapeDataString(chapter)}");
        }
    }

    private void HandlePrecomputePeaksToggle(bool enabled)
    {
        Workspace.SetPrecomputePeaksInBackground(enabled);
    }

    private void ResetMetadataAsync()
    {
        message = null;

        if (!Workspace.IsInitialized || string.IsNullOrWhiteSpace(Workspace.WorkingDirectory))
        {
            SetMessage("Set a workspace before resetting metadata.", BitColor.Warning);
            return;
        }

        var workspacePath = Workspace.WorkingDirectory;
        var bookId = Path.GetFileName(workspacePath.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar));
        resetDialogMessage = $"Reset metadata for '{bookId}'? This clears ignored patterns, review progress, and polish staging data.";
        isResetDialogOpen = true;
    }

    private void ConfirmReset()
    {
        isResetDialogOpen = false;
        var result = MetadataReset.ResetCurrentBook();
        SetMessage(result.Message, result.Success ? BitColor.Success : BitColor.Error);
    }

    private void SetMessage(string text, BitColor color)
    {
        message = text;
        messageColor = color;
    }

    private void DismissMessage()
    {
        message = null;
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
