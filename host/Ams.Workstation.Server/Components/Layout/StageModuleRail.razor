@using Ams.Workstation.Server.Components.Navigation
@implements IDisposable
@inject NavigationManager NavigationManager

@if (_state.IsVisible)
{
    <nav class="stage-module-rail"
         aria-label="Stage module navigation"
         data-stage-shell="active"
         data-stage-shell-stage="@_state.ActiveStageId"
         data-stage-shell-module="@_state.ActiveModuleId"
         data-stage-shell-path="@_state.NormalizedPath"
         data-stage-shell-marker="@_state.DiagnosticMarker">

        <section class="stage-module-rail__section" data-stage-shell-nav="stages" aria-labelledby="stage-module-rail-stages-label">
            <h2 id="stage-module-rail-stages-label" class="stage-module-rail__section-label">Stages</h2>
            <ul class="stage-module-rail__stage-list" role="list">
                @foreach (var stage in StageRouteCatalog.Stages)
                {
                    var isActiveStage = string.Equals(stage.Id, _state.ActiveStageId, StringComparison.OrdinalIgnoreCase);
                    var stageLinkClass = isActiveStage
                        ? "stage-module-rail__stage-link stage-module-rail__stage-link--active"
                        : "stage-module-rail__stage-link";

                    <li>
                        <a class="@stageLinkClass"
                           href="@stage.EntryPath"
                           data-stage-id="@stage.Id"
                           data-stage-active="@(isActiveStage ? "true" : "false")"
                           aria-current="@(isActiveStage ? "page" : null)">
                            @stage.DisplayName
                        </a>
                    </li>
                }
            </ul>
        </section>

        <section class="stage-module-rail__section" data-stage-shell-nav="modules" aria-labelledby="stage-module-rail-modules-label">
            <h2 id="stage-module-rail-modules-label" class="stage-module-rail__section-label">Modules</h2>
            <ul class="stage-module-rail__module-list" role="list">
                @foreach (var module in _state.Modules)
                {
                    var moduleLinkClass = module.IsActive
                        ? "stage-module-rail__module-link stage-module-rail__module-link--active"
                        : "stage-module-rail__module-link";

                    <li>
                        <a class="@moduleLinkClass"
                           href="@module.Path"
                           data-stage-module-id="@module.Id"
                           data-stage-module-active="@(module.IsActive ? "true" : "false")"
                           aria-current="@(module.IsActive ? "page" : null)">
                            @module.DisplayName
                        </a>
                    </li>
                }
            </ul>
        </section>
    </nav>
}
else
{
    <div class="stage-module-rail stage-module-rail--hidden"
         aria-hidden="true"
         data-stage-shell="inactive"
         data-stage-shell-path="@_state.NormalizedPath"
         data-stage-shell-warning="@_state.WarningMessage">
        <span class="stage-module-rail__fallback-text">@_state.WarningMessage</span>
    </div>
}

@code {
    private StageModuleRailState _state = StageModuleRailState.Hidden(StageRouteCatalog.RootPath, "Stage module rail unavailable.");

    protected override void OnInitialized()
    {
        UpdateState(NavigationManager.Uri);
        NavigationManager.LocationChanged += HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        UpdateState(args.Location);
        _ = InvokeAsync(StateHasChanged);
    }

    private void UpdateState(string location)
    {
        _state = ResolveStateFromLocation(location);
    }

    private static StageModuleRailState ResolveStateFromLocation(string location)
    {
        if (Uri.TryCreate(location, UriKind.Absolute, out var absoluteUri))
        {
            return ResolveStateForPath(absoluteUri.AbsolutePath);
        }

        return ResolveStateForPath(location);
    }

    public static StageModuleRailState ResolveStateForPath(string? path)
    {
        try
        {
            var requestedPath = string.IsNullOrWhiteSpace(path) ? StageRouteCatalog.RootPath : path;
            var match = StageRouteCatalog.Resolve(path);

            if (match is null)
            {
                return StageModuleRailState.Hidden(
                    requestedPath,
                    $"No stage-module rail mapping for path '{requestedPath}'.");
            }

            var modules = match.Stage.Modules
                .Select(module => new StageModuleRailItem(
                    Id: module.Id,
                    DisplayName: module.DisplayName,
                    Path: module.CanonicalPath,
                    SupportsBatching: module.SupportsBatching,
                    IsActive: string.Equals(module.Id, match.Module.Id, StringComparison.OrdinalIgnoreCase)))
                .ToArray();

            var activeModule = modules.FirstOrDefault(module => module.IsActive);
            if (activeModule is null)
            {
                return StageModuleRailState.Hidden(
                    match.NormalizedPath,
                    $"Route resolved without active module for {match.DiagnosticContext}.");
            }

            return new StageModuleRailState(
                IsVisible: true,
                NormalizedPath: match.NormalizedPath,
                ActiveStageId: match.Stage.Id,
                ActiveStageName: match.Stage.DisplayName,
                ActiveModuleId: activeModule.Id,
                ActiveModuleName: activeModule.DisplayName,
                Modules: modules,
                WarningMessage: string.Empty,
                DiagnosticMarker: $"{match.Stage.Id}:{activeModule.Id}");
        }
        catch (Exception ex)
        {
            var requestedPath = string.IsNullOrWhiteSpace(path) ? StageRouteCatalog.RootPath : path;
            return StageModuleRailState.Hidden(
                requestedPath,
                $"Stage-module rail fallback for path '{requestedPath}': {ex.Message}");
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }

    public sealed record StageModuleRailItem(
        string Id,
        string DisplayName,
        string Path,
        bool SupportsBatching,
        bool IsActive);

    public sealed record StageModuleRailState(
        bool IsVisible,
        string NormalizedPath,
        string ActiveStageId,
        string ActiveStageName,
        string ActiveModuleId,
        string ActiveModuleName,
        IReadOnlyList<StageModuleRailItem> Modules,
        string WarningMessage,
        string DiagnosticMarker)
    {
        public static StageModuleRailState Hidden(string path, string warning)
            => new(
                IsVisible: false,
                NormalizedPath: path,
                ActiveStageId: string.Empty,
                ActiveStageName: string.Empty,
                ActiveModuleId: string.Empty,
                ActiveModuleName: string.Empty,
                Modules: Array.Empty<StageModuleRailItem>(),
                WarningMessage: warning,
                DiagnosticMarker: "none");
    }
}
